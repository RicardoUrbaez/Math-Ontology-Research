    <!-- https://mardi4nfdi.de/mathmoddb#NumberOfSusceptibleIndividualsFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NumberOfSusceptibleIndividualsFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PDESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CoefficientScalingInfectiousToExposed"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RemovedIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{\mathcal{S}}^{(l)} = \hat{\mathcal{N}}^{(l)} - (1 + \Sigma_{\mathcal{E}}) \hat{\mathcal{I}}^{(l)} - \hat{\mathcal{R}}^{(l)}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Sigma_{\mathcal{E}}$, Coefficient Scaling Infectious to Exposed</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{\mathcal{I}}^{(l)}$, Number of Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{\mathcal{N}}^{(l)}$, Total Population Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{\mathcal{R}}^{(l)}$, Number of Removed Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{\mathcal{S}}^{(l)}$, Number of Susceptible Individuals</inDefiningFormulation>
        <terms1:description xml:lang="en">equation for the number of susceptible individuals</terms1:description>
        <rdfs:label xml:lang="en">Number of Susceptible Individuals Formulation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674529"/>
    </owl:NamedIndividual>
    


