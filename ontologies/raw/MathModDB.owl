    <!-- https://mardi4nfdi.de/mathmoddb#SpreadingRateTimeDependentConstraint -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SpreadingRateTimeDependentConstraint">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SpreadingRateTimeDependent"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\forall \, t \ge 0,\, 0 \le \alpha (t) &lt; \infty$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha$, Spreading Rate (Time-dependent)</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <terms1:description xml:lang="en">constraints applying to time-dependent spreading rate</terms1:description>
