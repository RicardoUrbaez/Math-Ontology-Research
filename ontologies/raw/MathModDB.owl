    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#HillTypeTwoMuscleOneTendonODESystem -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#HillTypeTwoMuscleOneTendonODESystem">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#HillTypeTwoMuscleOneTendonModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ActiveContractileForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DisplacementMuscleTendon"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EffectiveMassSpringMassSystem"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PassiveMuscleForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PassiveTendonForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$ \begin{align} 
        m_{1} \ddot{x}_{1} &amp;= F_\text{PTE}(t) -F_{\text{ACE}1}(t) - F_{\text{PME}1}(t) \\ 
        m_{2} \ddot{x}_{2} &amp;= -F_\text{PTE}(t) + F_{\text{ACE}2}(t) - F_{\text{PME}2}(t) \end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F_{\text{ACE}}$, Active contractile force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F_{\text{PME}}$, Passive Muscle Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F_{\text{PTE}}$, Passive Tendon Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$m$, Effective Mass (Spring-Mass System)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Displacement Muscle Tendon</inDefiningFormulation>
        <terms1:description xml:lang="en">system of ordinary differential equations describing passive and active muscle forces</terms1:description>
        <rdfs:comment xml:lang="en">System of Ordinary Differential Equations describing passive and active muscle forces during movement on a macroscopic scale, derived by balancing the forces on the muscle ends.</rdfs:comment>
        <rdfs:label xml:lang="en">Hill-Type Two-Muscle-One-Tendon ODE System</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Hill%27s_muscle_model"/>
        <doiID rdf:resource="https://doi.org/10.1002/gamm.202370009"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674387"/>
    </owl:NamedIndividual>
    


