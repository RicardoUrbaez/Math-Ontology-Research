    <!-- https://mardi4nfdi.de/mathmoddb#SolarSystemEquationsOfMotion -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SolarSystemEquationsOfMotion">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#SolarSystemModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalAcceleration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalPosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GravitationalConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Mass"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\vec{a}_j = \sum_{i \neq j}^n G \frac{M_i}{|\vec{r}_i - \vec{r}_j|^3} (\vec{r}_i - \vec{r}_j)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$G$, Gravitational Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$a$, Classical Acceleration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$m$, Mass</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r$, Classical Position</inDefiningFormulation>
        <terms1:description xml:lang="en">mathematical formulation describing the motion of the planets around the sun</terms1:description>
        <rdfs:comment xml:lang="en">The acceleration of a celestial body can be calculated from Newton&apos;s Law of Gravitation. Each body attracts each other body, the total acceleration being the sum of all these attractions.</rdfs:comment>
        <rdfs:label xml:lang="en">Solar System Equations of Motion</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674575"/>
    </owl:NamedIndividual>
    


