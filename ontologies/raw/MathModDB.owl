    <!-- https://mardi4nfdi.de/mathmoddb#MaxwellEquationsModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MaxwellEquationsModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <assumes rdf:resource="https://mardi4nfdi.de/mathmoddb#NonrelativisticApproximation"/>
        <terms1:description xml:lang="en">set of four coupled partial differential equations describing how electric and magnetic fields are generated and altered by each other and by charges and currents</terms1:description>
        <rdfs:comment xml:lang="en">Given the charge density ρ(r, t) and the current density j(r, t), Maxwell&apos;s equations yield the electric and magnetic fields, E(r, t) and B(r, t). These equations are the simplest representative of a more general class of models, also referred as Maxwell&apos;s equations, where ρ(r, t) and j(r, t) should be found from certain additional relations, e.g., from the Ohm&apos;s law.</rdfs:comment>
        <rdfs:comment xml:lang="en">Together with the Lorentz force law, Maxwell&apos;s equations form the foundation of classical electromagnetism and optics. The equations provide a mathematical model for electric, optical, and radio technologies.</rdfs:comment>
        <rdfs:label xml:lang="en">Maxwell Equations Model</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Maxwell%27s_equations"/>
        <doiID rdf:resource="https://doi.org/10.1098/rstl.1865.0008"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675320"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q51501"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MeanFieldEhrenfestModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MeanFieldEhrenfestModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <usedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticlePropagation"/>
        <usedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticlePropagation"/>
        <terms1:description xml:lang="en">mean-field or Ehrenfest approach to quantum-classical dynamics</terms1:description>
        <rdfs:comment xml:lang="en">The trajectories for the heavy particle(s) are propagated on a weighted average of potential energy surfaces of the light particle(s). The weights are determined by the amount of nonadiabatic mixing.</rdfs:comment>
        <rdfs:label xml:lang="en">Mean Field Ehrenfest</rdfs:label>
        <rdfs:label xml:lang="en">Mean-Field Ehrenfest Model</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.1063/1.471952"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MeanFieldPDEModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MeanFieldPDEModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <terms1:description xml:lang="en">for large population sizes particle-based dynamics may be approximated by a mean-field PDE model</terms1:description>
        <rdfs:comment xml:lang="en">These equations describe the spatiotemporal evolution of the concentration of particles, depending on position and time, and approximate the empirical measure of the particle-based dynamics in the case of large N.</rdfs:comment>
        <rdfs:label xml:lang="en">Mean-Field PDE Model</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.48550/arXiv.2407.18952"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MeanFieldSPDEModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MeanFieldSPDEModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <terms1:description xml:lang="en">Mean Field mofel for clustering dynamics comprising of SPDEs</terms1:description>
        <rdfs:comment xml:lang="en">Stochastic effects crucial for systems of finite size N, especially in the case of clustering behavior.</rdfs:comment>
        <rdfs:label xml:lang="en">Mean-Field SPDE Model</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.48550/arXiv.2407.18952"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MeanFieldTheory -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MeanFieldTheory">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#MeanFieldEhrenfestModel"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#MeanFieldPDEModel"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#MeanFieldSPDEModel"/>
        <terms1:description xml:lang="en">studying the behavior of high-dimensional models by studying simpler models that approximate the original by averaging over degrees of freedom</terms1:description>
        <rdfs:label xml:lang="en">Mean-Field Theory</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Mean-field_theory"/>
        <skos:altLabel xml:lang="en">Mean-Field Model</skos:altLabel>
        <skos:altLabel xml:lang="en">Self-consistent Field Theory</skos:altLabel>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q626011"/>
    </owl:NamedIndividual>
    


