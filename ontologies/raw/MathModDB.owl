        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CompetitiveInhibitionConstantUniUniReactionReversibleInhibition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UncompetitiveInhibitionConstantUniUniReactionReversibleInhibition"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{ic} \neq K_{iu}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{ic}$,Competitive Inhibition Constant (Uni Uni Reaction Reversible Inhibition)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iu}$,Uncompetitive Inhibition Constant (Uni Uni Reaction Reversible Inhibition)</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isLinear>
        <terms1:description xml:lang="en">coupling condition for a mixed enzyme inhibition in an uni uni reaction</terms1:description>
        <rdfs:label xml:lang="en">Mixed Enzyme Inhibition Coupling Condition (Uni Uni Reaction)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674511"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MobilityOfElectrons -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MobilityOfElectrons">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">magnitude of the drift velocity of electrons per unit electric field</terms1:description>
        <rdfs:comment xml:lang="en">For use in semiconductor physics.</rdfs:comment>
        <rdfs:label xml:lang="en">Mobility of Electrons</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673948"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MobilityOfHoles -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MobilityOfHoles">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">measure of how easily holes can move through the material under the influence of an electric field</terms1:description>
        <rdfs:comment xml:lang="en">For use in semiconductor physics.</rdfs:comment>
        <rdfs:label xml:lang="en">Mobility of Holes</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673949"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ModelOrderReduction -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ModelOrderReduction">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ComputationalTask"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#BalancedTruncation"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#H2OptimalApproximation"/>
        <terms1:description xml:lang="en">technique in mathematical modeling to effectively reduce the dimensionality of a model</terms1:description>
        <rdfs:comment xml:lang="en">After spatial discretization of PDEa, solving the resulting large-scale systems of ODEs can therefore become incredibly time-consuming. Developed from well established mathematical theory and robust numerical algorithms, Model Order Reduction (MOR) has been recognized as very efficient for reducing the simulation time of large-scale systems.</rdfs:comment>
        <rdfs:label xml:lang="en">Model Order Reduction</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Model_order_reduction"/>
        <rdfs:seeAlso rdf:resource="https://morwiki.mpi-magdeburg.mpg.de/morwiki/index.php/Main_Page"/>
        <doiID rdf:resource="https://doi.org/10.1007/978-1-4471-5102-9_142-1"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6684608"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q12202921"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MolecularAlignment -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MolecularAlignment">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PolarAngle"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumStateVector"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A = \langle \psi | \cos^2 \theta | \psi \rangle$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi$, Quantum State Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\theta$, Polar Angle</inDefiningFormulation>
        <terms1:description xml:lang="en">expectation value indicating in how far molecular axes are parallel to space fxed axes</terms1:description>
        <rdfs:comment xml:lang="en">Typically achieved by the interaction of induced dipole moments with external laser fields.</rdfs:comment>
        <rdfs:label xml:lang="en">Molecular Alignment</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674474"/>
    </owl:NamedIndividual>
    


