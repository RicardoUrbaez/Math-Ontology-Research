        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{S_1} = \frac{k_{4} (k_{-1} + k_{2})}{k_{1} (k_{2} + k_{4})}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{S_1}$, Michaelis Constant</inDefiningFormulation>
