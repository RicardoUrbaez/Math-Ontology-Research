        <doiID rdf:resource="https://doi.org/10.1016/0025-5564(94)90025-6"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#AmpereLaw -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#AmpereLaw">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#MaxwellEquationsModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricCurrentDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricField"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MagneticField"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PermeabilityVacuum"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PermittivityVacuum"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\nabla \times \mathbf{B} = \mu_0\left(\mathbf{J} + \epsilon_0 \frac{\partial \mathbf{E}} {\partial t} \right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B$, Magnetic Field</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$E$, Electric Field</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$J$, Electric Current Density</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\epsilon_0$, Permittivity (Vacuum)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu_0$, Permeability (Vacuum)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">Ampère&apos;s circuital law (with Maxwell&apos;s addition) relates the integrated magnetic field around a closed loop to the electric current passing through the loop.</terms1:description>
        <rdfs:label xml:lang="en">Ampere Law</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Amp%C3%A8re%27s_circuital_law"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674127"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q51500"/>
    </owl:NamedIndividual>
    


