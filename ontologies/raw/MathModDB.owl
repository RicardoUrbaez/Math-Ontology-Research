        <rdfs:comment xml:lang="en">For use in semiconductor physics.</rdfs:comment>
        <rdfs:label xml:lang="en">Density of Holes</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673830"/>
    </owl:NamedIndividual>
    


