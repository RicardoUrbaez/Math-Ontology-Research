    <!-- https://mardi4nfdi.de/mathmoddb#QuantumClassicalHamiltonian -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumClassicalHamiltonian">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticleKineticOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleHamiltonian"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleKineticOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumClassicalHamiltonian"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumClassicalPotential"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{H} = \hat{T} + \underbrace{ \hat{t} + \hat{V}}_{\equiv h} $</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$H$, Quantum-Classical Hamiltonian</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$T$, Heavy Particle Kinetic Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V$, Quantum-Classical Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$h$, Light Particle Hamiltonian</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Light Particle Kinetic Operator</inDefiningFormulation>
        <terms1:description xml:lang="en">Hamiltonian for a system with fast and slow degrees of freedom</terms1:description>
        <rdfs:comment xml:lang="en">Hamiltonian for a system comprising of light/fast and heavy/slow particles, e.g. a molecular system with electrons and nuclei.</rdfs:comment>
        <rdfs:label xml:lang="en">Quantum-Classical Hamiltonian</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Mixed_quantum-classical_dynamics"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q65091550"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumClassicalMassSeparation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumClassicalMassSeparation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <assumedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumClassicalModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticleMass"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleMass"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{m}{M}\ll 1$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$M$, Heavy Particle Mass</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$m$, Light Particle Mass</inDefiningFormulation>
        <terms1:description xml:lang="en">assuming separation of mass scales is the basis of all quantum-classical dynamics models</terms1:description>
        <rdfs:comment xml:lang="en">Often the square root (or sometimes the fourth root) of the light-to-heavy mass ratio are used as smallness parameters in defining an asymptotic limit for quantum-classical dynamics</rdfs:comment>
        <rdfs:label xml:lang="en">Quantum-Classical Mass Separation</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumClassicalModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumClassicalModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalDynamicsModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumClassicalHamiltonian"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumModelClosedSystem"/>
        <containsInitialCondition rdf:resource="https://mardi4nfdi.de/mathmoddb#InitialClassicalMomentum"/>
        <containsInitialCondition rdf:resource="https://mardi4nfdi.de/mathmoddb#InitialClassicalPosition"/>
        <containsInitialCondition rdf:resource="https://mardi4nfdi.de/mathmoddb#InitialQuantumState"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#FewestSwitchesSurfaceHopping1"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#FewestSwitchesSurfaceHopping2"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#MeanFieldEhrenfestModel"/>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isTimeContinuous>
        <terms1:description xml:lang="en">hybrid quantum-classical model for a system with fast and slow degrees of freedom</terms1:description>
        <rdfs:comment xml:lang="en">Used to describe the dynamics of a system comprising of light/fast and heavy/slow particles where the classical approximation can be only justified for the latter ones, as is usually the case in molecular dynamics. There, non-adiabatic transitions of the quantum subsystem (usually electrons) can be triggered by dynamics of the classical subsystem (usually nuclei) and vice versa. Note that the many different approaches to quantum-classical dynamics, most notably surface hopping trajectories simulations, differ in the way how the nonadiabatic transition probabilities are calculated.</rdfs:comment>
        <rdfs:label xml:lang="en">Quantum-Classical Model</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://qcmd.info"/>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Mixed_quantum-classical_dynamics"/>
        <skos:altLabel xml:lang="en">Hybrid Quantum-Classical Dynamics</skos:altLabel>
        <skos:altLabel xml:lang="en">Mixed Quantum-Classical Dynamics</skos:altLabel>
        <skos:altLabel xml:lang="en">Quantum-Classical Molecular Dynamics</skos:altLabel>
        <doiID rdf:resource="https://doi.org/10.1021/acs.chemrev.7b00577"/>
        <doiID rdf:resource="https://doi.org/10.1039/A801824C"/>
        <doiID rdf:resource="https://doi.org/10.3390/e16010062"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675431"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q65091550"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumClassicalPotential -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumClassicalPotential">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumClassicalHamiltonian"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticlePosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticlePosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumClassicalPotential"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumPotentialOperator"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V \equiv V(r,R)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R$, Heavy Particle Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V$, Quantum-Classical Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r$, Light Particle Position</inDefiningFormulation>
        <terms1:description xml:lang="en">total interaction potential of light and heavy particles in quantum-classical models</terms1:description>
        <rdfs:comment xml:lang="en">In quantum-classical molecular dynamics, this potential would contain all the (repulsive and attractive) Coulombic interactions between electrons and nuclei</rdfs:comment>
        <rdfs:label xml:lang="en">Quantum-Classical Potential</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Mixed_quantum-classical_dynamics"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q65091550"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumConditionalQuasiSolvability -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumConditionalQuasiSolvability">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ComputationalTask"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianElectricDipole"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianElectricPolarizability"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianLinearRotor"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SchrödingerEquationTimeIndependent"/>
        <containsInput rdf:resource="https://mardi4nfdi.de/mathmoddb#RotationalConstant"/>
        <containsOutput rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricField"/>
        <containsOutput rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumEigenEnergy"/>
        <containsOutput rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumStateVectorStationary"/>
        <terms1:description xml:lang="en">exact solutions of the time-independent Schrödinger equation for a certain number of low-lying states if certain relations of the parameters hold</terms1:description>
        <rdfs:comment xml:lang="en">For certain Hamiltonians, the concept of Conditional Quasi-Solvability holds: There are exact solutions of the time-independent Schrödinger equation for a certain number of low-lying quantum states (quasi-exact solvability), if and only if certain relations of the parameters of the Hamiltonian hold (conditionally exact solvability). For examples with trigonometric and hyperbolic potentials, see the annotating DOIs.</rdfs:comment>
        <rdfs:label xml:lang="en">Quantum Conditional Quasi-Solvability</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.1063/1.4864465"/>
        <doiID rdf:resource="https://doi.org/10.1103/PhysRevA.91.022111"/>
        <doiID rdf:resource="https://doi.org/10.1103/PhysRevA.97.053417"/>
        <doiID rdf:resource="https://doi.org/10.1140/epjd/e2017-80134-6"/>
        <doiID rdf:resource="https://doi.org/10.3389/fphy.2014.00037"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6684604"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumDampingRate -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumDampingRate">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#RateConstant"/>
        <terms1:description xml:lang="en">rate at which quantum coherence is lost in a system due to interactions with its environment</terms1:description>
        <rdfs:comment xml:lang="en">Quantum damping rates can be used - together with quantum jump operators - to describe the dissipation and/or decoherence of the quantum dynamics in a Lindblad equation (for open quantum systems).</rdfs:comment>
        <rdfs:label xml:lang="en">Quantum Damping Rate</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Lindbladian"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q4476520"/>
        <skos:altLabel xml:lang="en">Dissipative Transition Rate</skos:altLabel>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6534313"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumDensityOperator -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumDensityOperator">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumStateVector"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumMechanicalOperator"/>
        <terms1:description xml:lang="en">matrix that describes an ensemble of physical systems as quantum states</terms1:description>
        <rdfs:label xml:lang="en">Quantum Density Operator</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6534315"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumEigenEnergy -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumEigenEnergy">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#SchrödingerEquationTimeIndependent"/>
        <terms1:description xml:lang="en">specific, quantized energy levels that a quantum system can possess</terms1:description>
        <rdfs:comment xml:lang="en">Eigenenergy are obtained as eigenvalues of the Quantum Hamiltonian Operator by solving the time-independent Schrödinger equation.</rdfs:comment>
        <rdfs:label xml:lang="en">Quantum Eigen Energy</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Eigenvalues_and_eigenvectors"/>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Quantum_state"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6534306"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumEigenEnergyAnharmonic -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumEigenEnergyAnharmonic">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AnharmonicityConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AnharmonicityConstantPerturbationTheory"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfParticles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumEigenEnergy"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumNumber"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#VibrationFrequencyHarmonic"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$E_n=\sum_{r=1}^{3N-6}\omega_r \left( n_r + \frac{1}{2} \right) +\sum_{r \ge s} \chi_{rs} \left( n_r + \frac{1}{2} \right) \left( n_s + \frac{1}{2} \right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$E$, Quantum Eigen Energy</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Number of Particles</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\chi$, Anharmonicity Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\omega$, Vibration Frequency (Harmonic)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Quantum Number</inDefiningFormulation>
        <terms1:description xml:lang="en">eigenenergies of anharmonic oscillator systems</terms1:description>
        <rdfs:comment xml:lang="en">Eigenenergies of anharmonic oscillator systems, e.g. molecular vibrations, beyond the harmonic approximation.</rdfs:comment>
        <rdfs:label xml:lang="en">Quantum Eigen Energy (Anharmonic)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Anharmonicity"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q545228"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674597"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumEigenEnergyHarmonic -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumEigenEnergyHarmonic">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfParticles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PlanckConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumEigenEnergy"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumNumber"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#VibrationFrequencyHarmonic"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumEigenEnergyAnharmonic"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$E_n=\sum_{r=1}^{3N-6}\left( n_r + \frac{1}{2} \right) \hbar \omega_r$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$E$, Quantum Eigen Energy</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Number of Particles</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hbar$, Planck Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\omega$, Vibration Frequency (Harmonic)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Quantum Number</inDefiningFormulation>
        <terms1:description xml:lang="en">eigenenergies of (single or coupled, for N particles) harmonic oscillators</terms1:description>
        <rdfs:comment xml:lang="en">Eigenenergies of (single or coupled, for N particles) harmonic oscillators, e.g. molecular vibrations, within the harmonic approximation.</rdfs:comment>
        <rdfs:label xml:lang="en">Quantum Eigen Energy (Harmonic)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Quantum_harmonic_oscillator"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q677864"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674523"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumEigenEnergyIntermolecular -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumEigenEnergyIntermolecular">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#VibrationalFrequencyShift1stOrder"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#VibrationalFrequencyShift2ndOrder"/>
        <terms1:description xml:lang="en">eigenenergies of molecular vibrations, including the effects of intermolecular vibrations</terms1:description>
        <rdfs:comment xml:lang="en">For simplicity, here only for a chromophore interacting with solvent molecules of a different species. Hence, only non-degenerate perturbation theory (up to 2nd order) is used here. First and second order results for the 0-&gt;1 vibrational frequency|energy shifts are given as two separate formulations.</rdfs:comment>
        <rdfs:label xml:lang="en">Quantum Eigen Energy (Intermolecular)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674525"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumEigenEnergyLinearNonRigidRotor -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumEigenEnergyLinearNonRigidRotor">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#LinearRotorNonRigid"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CentrifugalDistortionConstant"/>
