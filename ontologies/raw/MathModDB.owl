    <!-- https://mardi4nfdi.de/mathmoddb#HookLawSpring -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#HookLawSpring">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ChangeInLength"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Force"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SpringConstant"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#HookeLawLinearElasticity"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F = k \Delta l$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F$, Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta l$, Change In Length</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k$, Spring Constant</inDefiningFormulation>
        <terms1:description xml:lang="en">force to extend or compress a spring by distance scales linearly with  distance</terms1:description>
        <rdfs:comment xml:lang="en">An empirical law which states that the force (F) needed to extend or compress a spring by some distance (x) scales linearly with respect to that distance—that is, F = kx, where k is a constant factor characteristic of the spring (i.e., its stiffness), and x is small compared to the total possible deformation of the spring. The law is named after 17th-century British physicist Robert Hooke.</rdfs:comment>
        <rdfs:label xml:lang="en">Hooke Law (Spring)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674389"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q170282"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#HookeLawLinearElasticity -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#HookeLawLinearElasticity">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DisplacementOfAtoms"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElasticStiffnessTensor"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MechanicalStrain"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MechanicalStress"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma=C:\epsilon$ where $\epsilon(u)=\frac{1}{2}(\nabla u+(\nabla u)^T)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C$, Elastic Stiffness Tensor</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\epsilon$, Mechanical Strain</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Mechanical Stress</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$u$, Displacement of Atoms</inDefiningFormulation>
        <terms1:description xml:lang="en">force to extend or compress a spring by distance scales linearly with distance</terms1:description>
        <rdfs:comment xml:lang="en">An empirical law which states that the force (F) needed to extend or compress a spring by some distance (x) scales linearly with respect to that distance—that is, F = kx. Also the stresses and strains of  material inside a continuous elastic material are connected by a linear relationship that is mathematically similar to Hooke&apos;s spring law, and is often referred to by that name.</rdfs:comment>
        <rdfs:label xml:lang="en">Hooke Law (Linear Elasticity)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Linear_elasticity"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674324"/>
    </owl:NamedIndividual>
    


