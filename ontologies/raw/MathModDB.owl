    <!-- https://mardi4nfdi.de/mathmoddb#RemovedAtTimeStepInTheMultiPopulationSIRModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#RemovedAtTimeStepInTheMultiPopulationSIRModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#MultiPopulationSusceptibleInfectiousRemovedModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RelativeRemovalRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RemovedIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R_{n+1}^i = R_n^i + \gamma_i \Delta t I_n^i$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_n^i$, Number of Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R_n^i$, Number of Removed Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, Relative Removal Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">equation for removed individuals in the discrete multi-population SIR Model</terms1:description>
        <rdfs:label xml:lang="en">Removed at Time Step n+1 in the Multi-Population Discrete SIR Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674559"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#RemovedAtTimeStepInTheSIRModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#RemovedAtTimeStepInTheSIRModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#DiscreteSusceptibleInfectiousRemovedModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RelativeRemovalRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RemovedIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <discretizes rdf:resource="https://mardi4nfdi.de/mathmoddb#ContinuousRateOfChangeOfRemovedInTheSIRModel"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R_{n+1} = R_n + \gamma \Delta t I_n$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_n$, Number of Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R_n$, Number of Removed Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, Relative Removal Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">equation for removed individuals in the SIR Model</terms1:description>
        <rdfs:label xml:lang="en">Removed at Time Step n+1 in the Discrete SIR Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674560"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#RemovedAtTimeStepInTheSIRModelWithBirthsAndDeaths -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#RemovedAtTimeStepInTheSIRModelWithBirthsAndDeaths">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleInfectiousRemovedModelWithBirthsAndDeaths"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BirthRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RelativeRemovalRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RemovedIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R_{n+1} = R_n(1 - \beta \Delta t) + \gamma \Delta t I_n$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_n$, Number of Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R_n$, Number of Removed Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\beta$, Birth Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, Relative Removal Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">equation for removed individuals in the discrete SIR Model with births and deaths</terms1:description>
        <rdfs:label xml:lang="en">Removed at Time Step n+1 in the Discrete SIR Model with Births and Deaths</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674561"/>
    </owl:NamedIndividual>
    


