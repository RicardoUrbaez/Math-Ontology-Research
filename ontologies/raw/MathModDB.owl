        <terms1:description xml:lang="en">matrix giving insight into the coherence of object clusters</terms1:description>
        <rdfs:label xml:lang="en">Object Cluster Matrix</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674088"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ObjectCommittorFunctionFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ObjectCommittorFunctionFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ObjectCommittorFunctions"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SecondEigenvalueofOrthogonalMatrix"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\chi = [u*_2, 1 - u*_2]$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\chi$, Object Committor Functions</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$u*_2$, Second Eigenvalue of Orthogonal Matrix</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isLinear>
        <terms1:description xml:lang="en">formulation determining the object commitor functions</terms1:description>
        <rdfs:label xml:lang="en">Object Committor Function Formulation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674531"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ObjectCommittorFunctions -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ObjectCommittorFunctions">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <terms1:description xml:lang="en">non-negative vectors whose values correspond to the probability to end up in some property when starting the process in some object</terms1:description>
        <rdfs:label xml:lang="en">Object Committor Functions</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674089"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ObjectCommonalityFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ObjectCommonalityFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfObjects"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Object"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ObjectCommonalityMatrix"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ObjectProperty"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$M_{i,j} = f(o_i) \odot f(o_j) for i,j in N$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Number of Objects</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathbf{M}$,Object Commonality Matrix</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$f(o)$, Object Property</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$o$, Object</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isLinear>
        <terms1:description xml:lang="en">function defining the entries in the object commonality matrix</terms1:description>
        <rdfs:label xml:lang="en">Object Commonality Formulation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674532"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ObjectCommonalityMatrix -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ObjectCommonalityMatrix">
