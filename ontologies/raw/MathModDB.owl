        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PoissonDistribution"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ParticleMovementLine"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$g(y) = \int_{L} f(x) dx$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$g$, Poisson Distribution</inDefiningFormulation>
        <terms1:description xml:lang="en">particle movement equation on a line neglecting attenuation</terms1:description>
        <rdfs:label xml:lang="en">Particle Movement on a Line (No Attenuation)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Radon_transform"/>
