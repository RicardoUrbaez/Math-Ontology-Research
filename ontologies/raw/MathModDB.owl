    <!-- https://mardi4nfdi.de/mathmoddb#PoroViscoElasticDiffusionBoundaryCondition -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PoroViscoElasticDiffusionBoundaryCondition">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ExternalChemicalPotential"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidIntrinsicPermeabilityPorousMedium"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HydraulicConductivity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MechanicalDeformation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$M(\nabla\chi,c)\nabla\partial_c\Phi(x,\nabla\chi,c)\cdot \nu = \kappa(x)(\mu_e(t,x)-\partial_c\Phi(x,\nabla\chi,c))$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$M$, Hydraulic Conductivity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\chi$, Mechanical Deformation</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\kappa$, Fluid Intrinsic Permeability (Porous Medium)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu$, External Chemical Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Concentration</inDefiningFormulation>
        <terms1:description xml:lang="en">boundary condition for diffusion equation</terms1:description>
        <rdfs:label xml:lang="en">Poro-Visco-Elastic Diffusion Boundary Condition</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674245"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PoroViscoElasticDiffusionEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PoroViscoElasticDiffusionEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeEnergyDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HydraulicConductivity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MechanicalDeformation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#FickEquation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\dot c(t,x) = - \nabla\cdot(M(x,\nabla\chi(t,x),c(t,x))\nabla\partial_c\Phi(x,\nabla \chi(t,x),c(t,x)))$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$M$, Hydraulic Conductivity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Phi$, Free Energy Density</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\chi$, Mechanical Deformation</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">mathematical formulation for diffusion in poro-visco-elastic models</terms1:description>
        <rdfs:label xml:lang="en">Poro-Visco-Elastic Diffusion Equation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674246"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PoroViscoElasticDirichletBoundary -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PoroViscoElasticDirichletBoundary">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsBoundaryConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PoroViscoElasticModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MechanicalDeformation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MechanicalDeformationBoundaryValue"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SpatialVariable"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#DirichletBoundaryCondition"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\chi(t,x) = \chi_D(t,x)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\chi$, Mechanical Deformation</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\chi_D$, Mechanical Deformation (Boundary Value)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Spatial Variable</inDefiningFormulation>
        <terms1:description xml:lang="en">Dirichlet boundary condition for mechanical deformation</terms1:description>
        <rdfs:label xml:lang="en">Poro-Visco-Elastic (Dirichlet Boundary)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674247"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PoroViscoElasticEvolution -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PoroViscoElasticEvolution">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ResearchProblem"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#ContinuumMechanics"/>
        <terms1:description xml:lang="en">simulation of coupled mechanical deformation of solids to other physical processes such as heat conduction or diffusion of chemical species</terms1:description>
        <rdfs:comment xml:lang="en">This is relevant in many applications in thermo-mechanics, solid-state batteries, poroelasticity in biological tissue, hydrogen storage, and elastomeric materials.</rdfs:comment>
        <rdfs:label xml:lang="en">Poro-Visco-Elastic Evolution</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.1002/zamm.202300486"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6684680"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PoroViscoElasticModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PoroViscoElasticModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <models rdf:resource="https://mardi4nfdi.de/mathmoddb#PoroViscoElasticEvolution"/>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isTimeContinuous>
        <terms1:description xml:lang="en">mathematical model describing the coupled evolution of the mechanical deformation and the concentration of a species</terms1:description>
        <rdfs:comment xml:lang="en">The elastic stresses are given via the derivative of a free energy density function, the viscous stresses are of Kelvin-Voigt type and formulated in terms of a dissipation potental. The evolution of the concentration is given via a diffusion equation that is pulled-back to the reference configuration. The mobility law depends nonlinearly on the deformation gradient and the concentration itself.</rdfs:comment>
        <rdfs:comment xml:lang="en">The finite mechanical deformation is quasistatic and is formulated in the Lagrangian frame. The total stress consists of elastic and viscous stresses. Moreover, a second-order hyper-stress regularization is taken into account.</rdfs:comment>
        <rdfs:label xml:lang="en">Poro-Visco-Elastic Model</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.1002/zamm.202300486"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675379"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PoroViscoElasticNeumannBoundary -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PoroViscoElasticNeumannBoundary">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsBoundaryConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PoroViscoElasticModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeEnergyDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MechanicalDeformation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SpatialVariable"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SurfaceForceDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnitNormalVector"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ViscousDissipationPotential"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#NeumannBoundaryCondition"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$(\partial_{\nabla \chi} \Phi(x,\nabla\chi(t,x),c(t,x)) + \partial_{\nabla\dot\chi}\zeta(x,\nabla\dot\chi(t,x),\nabla\chi(t,x),c(t,x)))\nu - \nabla_s\cdot (\partial_{D^2\chi} H(x,D^2\chi(t,x))\nu) = g(t,x)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Phi$, Free Energy Density</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\chi$, Mechanical Deformation</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\nu$, Unit Normal Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\zeta$, Viscous Dissipation Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$g$, Surface Force Density</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Spatial Variable</inDefiningFormulation>
        <terms1:description xml:lang="en">Neumann boundary condition for mechanical deformation</terms1:description>
        <rdfs:label xml:lang="en">Poro-Visco-Elastic (Neumann Boundary)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674248"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PoroViscoElasticQuasistaticEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PoroViscoElasticQuasistaticEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PoroViscoElasticModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ExternalForceDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeEnergyDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HyperstressPotential"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MechanicalDeformation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SpatialVariable"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ViscousDissipationPotential"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$-\nabla\cdot(\partial_{\nabla \chi} \Phi(x,\nabla\chi(t,x),c(t,x)) + \partial_{\nabla\dot\chi}\zeta(x,\nabla\dot\chi(t,x),\nabla\chi(t,x),c(t,x)) - \nabla\cdot \partial_{D^2\chi} H(x,D^2\chi(t,x)))=f(t,x)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$H$, Hyperstress Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Phi$, Free Energy Density</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\chi$, Mechanical Deformation</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\zeta$, Viscous Dissipation Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$f$, External Force Density</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Spatial Variable</inDefiningFormulation>
        <terms1:description xml:lang="en">equation using linear momentum without inertia for mechanical
deformation</terms1:description>
        <rdfs:label xml:lang="en">Poro-Visco-Elastic Quasistatic Equation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674249"/>
    </owl:NamedIndividual>
    


