    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#StokesEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#StokesEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <assumes rdf:resource="https://mardi4nfdi.de/mathmoddb#CreepingFlowAssumption"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#NavierStokesModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidKinematicViscosityFreeFlow"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidPressureFreeFlow"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidVelocityFreeFlow"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#IdentityFunction"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}
     \frac{\partial v}{\partial t} + \nabla \cdot ( - \nu \left(\nabla v^{ff} + \nabla v^{\mathrm{ff,T}} \right)+ \rho^{-1} p^{ff} I ) &amp;= 0 \\
 \nabla \cdot v^{ff} &amp;= 0
\end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I$, Identity Function</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\nu$, Fluid Kinematic Viscosity (Free Flow)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho$, Fluid Density</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p^{ff}$, Fluid Pressure (Free Flow)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v^{ff}$, Fluid Velocity (Free Flow)</inDefiningFormulation>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isTimeContinuous>
        <terms1:description xml:lang="en">describes a fluid flow with small advective inertial forces compared to viscous forces</terms1:description>
        <rdfs:comment xml:lang="en">Stokes equation describes a fluid flow with small advective inertial forces compared to viscous forces, with a low Reynolds number. It occurs in situations with very slow fluid velocities, high viscosities, or small flow length scales.</rdfs:comment>
        <rdfs:label xml:lang="en">Stokes Equation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Stokes_flow"/>
        <skos:altLabel xml:lang="en">Creeping Flow</skos:altLabel>
        <skos:altLabel xml:lang="en">Creeping Motion</skos:altLabel>
        <skos:altLabel xml:lang="en">Stokes Flow</skos:altLabel>
        <skos:altLabel xml:lang="en">Stokes Law</skos:altLabel>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674516"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q7618547"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#StokesEquationEulerBackward -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#StokesEquationEulerBackward">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <discretizes rdf:resource="https://mardi4nfdi.de/mathmoddb#StokesEquation"/>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">discretizing the Stokes equation by a first-oder backward Euler scheme in time</terms1:description>
        <rdfs:label xml:lang="en">Stokes Equation (Euler Backward)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674350"/>
    </owl:NamedIndividual>
    


