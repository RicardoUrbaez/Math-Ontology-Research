    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#NeumannBoundaryConditionForSEIRModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NeumannBoundaryConditionForSEIRModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsBoundaryConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#HybridPDEODESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposed"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfInfectious"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfRemoved"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfSusceptibles"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#NeumannBoundaryCondition"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s + e + i + r = 1$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$e$, Fraction of Population Density of Exposed</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$i$, Fraction of Population Density of Infectious</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r$, Fraction of Population Density of Removed</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s$, Fraction of Population Density of Susceptibles</inDefiningFormulation>
        <terms1:description xml:lang="en">Neumann boundary condition for SEIR model</terms1:description>
        <rdfs:comment xml:lang="en">Homogeneous Boundary Condition for the Full-PDe SEIR Model ensure that all the fractions of the population densities of susceptibles, exposed, infectious and removed add up to 1 at all times.</rdfs:comment>
        <rdfs:label xml:lang="en">Neumann Boundary Condition for SEIR Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674518"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#NeumannBoundaryConditionStressFreeRelaxation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NeumannBoundaryConditionStressFreeRelaxation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EigenStressOfCrystal"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StressOfCrystal"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnitNormalVector"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#NeumannBoundaryCondition"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$(\sigma-\sigma^\ast)\cdot n=0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Stress of Crystal</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma^\ast$, Eigenstress of Crystal</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Normal Unit Vector</inDefiningFormulation>
        <terms1:description xml:lang="en">Neumann boundary condition in theory of elasticity (stress-free relaxation)</terms1:description>
        <rdfs:label xml:lang="en">Neumann Boundary Condition (Stress-Free Relaxation)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674326"/>
    </owl:NamedIndividual>
    


