    <!-- https://mardi4nfdi.de/mathmoddb#HillTypeTwoMuscleOneTendonModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#HillTypeTwoMuscleOneTendonModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <describedAsStudiedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#Homs-Pons_2024_Coupled_simulations_and_parameter_inversion_for_neural_system_and_electrophysiological_muscle_models"/>
        <models rdf:resource="https://mardi4nfdi.de/mathmoddb#MuscleMovement"/>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDynamic>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isLinear>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isTimeContinuous>
        <terms1:description xml:lang="en">mathematical model derived from the balancing forces at the muscle ends</terms1:description>
        <rdfs:comment xml:lang="en">Mathematical model to predict lumped passive and active muscle forces during movement on a macroscopic scale.</rdfs:comment>
        <rdfs:label xml:lang="en">Hill-Type Two-Muscle-One-Tendon Model</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Hill%27s_muscle_model"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675415"/>
