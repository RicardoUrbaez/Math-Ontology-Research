    <!-- https://mardi4nfdi.de/mathmoddb#GravitationalAccelerationEarthSurface -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GravitationalAccelerationEarthSurface">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EarthMass"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EarthRadius"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GravitationalAccelerationEarthSurface"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GravitationalConstant"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#Acceleration"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\vec{g} \equiv -\frac{GM}{r^2}\vec{r}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$G$, Gravitational Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$M$, Earth Mass</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$g$, Gravitational Acceleration (Earth Surface)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r$, Earth Radius</inDefiningFormulation>
        <terms1:description xml:lang="en">acceleration of an object in free fall within a vacuum, thus without experiencing air drag</terms1:description>
        <rdfs:comment xml:lang="en">At a fixed point on the surface of Earth, the gravity results from the combined effect of gravitation and the centrifugal force from Earth&apos;s rotation. At different points on Earth&apos;s surface, the free fall acceleration ranges from 9.764 to 9.834 m/s2.</rdfs:comment>
        <rdfs:label xml:lang="en">Gravitational Acceleration (Earth Surface)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Gravitational_acceleration"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673989"/>
        <qudtID rdf:resource="https://qudt.org/vocab/quantitykind/AccelerationOfGravity"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q30006"/>
    </owl:NamedIndividual>
    


