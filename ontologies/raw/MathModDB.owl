    <!-- https://mardi4nfdi.de/mathmoddb#MichaelisConstantProduct1BiBiReactionOrderedSteadyStateAssumption -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MichaelisConstantProduct1BiBiReactionOrderedSteadyStateAssumption">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisConstantProduct1BiBiReactionOrderedSteadyStateAssumption"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateConstant"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisConstant"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{P_1} \equiv \frac{k_{-1} k_{-2} k_{-3}}{k_{-5} (k_{-1} k_{-2} + k_{-1} k_3 + k_{-1} k_{-3} + k_{-2} k_{-3})}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{P_1}$, Michaelis Constant Product 1 (Bi Bi Reaction Ordered - Steady State Assumption)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-1}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-2}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-3}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-5}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{3}$, Reaction Rate Constant</inDefiningFormulation>
        <isChemicalConstant rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isChemicalConstant>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <terms1:description xml:lang="en">Michaelis constant for the product 1 of a Bi Bi Reaction with Ordered Mechanism under the Steady State Assumption</terms1:description>
        <rdfs:label xml:lang="en">Michaelis Constant Product 1 (Bi Bi Reaction Ordered - Steady State Assumption)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674062"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MichaelisConstantProduct2BiBiReactionOrderedSteadyStateAssumption -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MichaelisConstantProduct2BiBiReactionOrderedSteadyStateAssumption">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisConstantProduct2BiBiReactionOrderedSteadyStateAssumption"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateConstant"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisConstant"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{P_2} \equiv \frac{k_{-1} (k_{-2} k_{4} + k_{-2} k_{-3} + k_3 k_4)}{k_{-5} (k_{-1} k_{-2} + k_{-1} k_3 + k_{-1} k_{-3} + k_{-2} k_{-3})}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{P_2}$, Michaelis Constant Product 2 (Bi Bi Reaction Ordered - Steady State Assumption)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-1}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-2}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-3}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-4}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{3}$, Reaction Rate Constant</inDefiningFormulation>
