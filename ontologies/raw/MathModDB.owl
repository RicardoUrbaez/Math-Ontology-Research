    <!-- https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationUniUniReactionwithoutProductandMixedPartialInhibitionSteadyStateAssumption -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationUniUniReactionwithoutProductandMixedPartialInhibitionSteadyStateAssumption">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
