        <rdfs:label xml:lang="en">Michaelis Menten Equation (Bi Bi Reaction Theorell-Chance with Product 2 - Michaelis Menten Model - Steady State Assumption)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674507"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationforBiBiReactionTheorellChanceMechanismwithProducts1and2SS -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationforBiBiReactionTheorellChanceMechanismwithProducts1and2SS">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#BiBiReactionTheorellChanceMechanismMichaelisMentenModelwithProducts1and2SS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EquilibriumConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EquilibriumConstantBiBiReactionTheorellChanceSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstantProduct2BiBiReactionTheorellChanceSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstantSubstrate1BiBiReactionTheorellChanceSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LimitingReactionRateBackwardBiBiReactionTheorellChance"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LimitingReactionRateForwardBiBiReactionTheorellChance"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisMentenConstantProduct1BiBiReactionTheorellChanceSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisMentenConstantProduct2BiBiReactionTheorellChanceSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisMentenConstantSubstrate1BiBiReactionTheorellChanceSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisMentenConstantSubstrate2BiBiReactionTheorellChanceSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRate"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_{0} = \frac{V_{1} V_{2} (c_{S_1} c_{S_2} - \frac{c_{P_1} c_{P_2}}{K_{eq}})}{V_2 K_{iS_1} K_{S_2} + V_2 K_{S_2} c_{S_1} + V_2 K_{S_1} c_{S_2} + \frac{V_1 K_{P_2}}{K_{eq}} c_{P_1} + \frac{V_1 K_{P_1}}{K_{eq}} c_{P_2} + V_2 c_{S_1} c_{S_2} + \frac{V_1 K_{P_2}}{K_{iS_1} K_{eq}} c_{S_1} c_{P_1} + \frac{V_2 K_{S_1}}{K_{iP_2}} c_{S_2} c_{P_2} + \frac{V_1}{K_{eq}} c_{P_1} c_{P_2}}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{P_1}$, Michaelis Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{P_2}$, Michaelis Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{S_1}$, Michaelis Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{S_2}$, Michaelis Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{eq}$, Equilibrium Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iP_2}$, Inhibition Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iS_1}$, Inhibition Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V_{1}$, Reaction Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V_{2}$, Reaction Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{P_1}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{P_2}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S_1}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S_2}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0$, Reaction Rate</inDefiningFormulation>
        <terms1:description xml:lang="en">equation for bi bi reaction with Theorell-Chance mechanism with products 1 and 2 following steady state assumption</terms1:description>
        <rdfs:label xml:lang="en">Michaelis Menten Equation (Bi Bi Reaction Theorell-Chance with Products 1 And 2 - Michaelis Menten Model - Steady State Assumption)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674508"/>
    </owl:NamedIndividual>
    


