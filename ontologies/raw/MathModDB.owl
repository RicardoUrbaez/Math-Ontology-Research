        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674032"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#TotalPopulationDensityFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#TotalPopulationDensityFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PDESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DensityFractionCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#IsotropicGaussianFunction"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationDensity"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n(x) \equiv \sum_{\tilde{l}=1}^{\tilde{L}} w_n^{(\tilde{l})} G^{(\tilde{l})}(x)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$G^{(\tilde{l})}(x)$, Isotropic Gaussian Function</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n(x)$, Total Population Density</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$w_n^{(\tilde{l})} $, Density Fraction Coefficient</inDefiningFormulation>
        <terms1:description xml:lang="en">represented as a sum of Isotropic Gaussian functions of all provinces</terms1:description>
        <rdfs:label xml:lang="en">Total Population Density Formulation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674593"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#TotalPopulationSize -->

