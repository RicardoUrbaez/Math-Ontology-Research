    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#InitialNumberOfSEIRCondition -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#InitialNumberOfSEIRCondition">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsInitialConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#ODESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposedInTheODERegionMean"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfInfectiousInTheODERegionMean"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfRemovedInTheODERegionMean"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfSusceptiblesInTheODERegionMean"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfExposedIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RemovedIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{aligned}
&amp;s_2(0)=\frac{S_2(0)}{N_2} \\
&amp;e_2(0)=\frac{E_2(0)}{N_2} \\
&amp;i_2(0)=\frac{I_2(0)}{N_2} \\
&amp;r_2(0)=\frac{R_2(0)}{N_2} \\
\end{aligned}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$E_2$, Number Of Exposed Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_2$, Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N_2$, Total Population Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R_2$, Removed Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S_2$, Susceptible Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\bar{e}_2$, Fraction Of Population Density Of Exposed In The ODE Region (Mean)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\bar{i}_2$, Fraction Of Population Density Of Infectious In The ODE Region (Mean)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\bar{r}_2$, Fraction Of Population Density Of Removed In The ODE Region (Mean)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\bar{s}_2$, Fraction Of Population Density Of Susceptibles In The ODE Region (Mean)</inDefiningFormulation>
        <terms1:description xml:lang="en">initial number of individuals in all four categories is given</terms1:description>
        <rdfs:comment xml:lang="en">Total number of susceptibles S2(0), exposed E2(0), infectious I2(0) and
removed R2(0) of the ODE model at time t= 0 are given</rdfs:comment>
        <rdfs:label xml:lang="en">Initial Number Of SEIR Condition</rdfs:label>
    </owl:NamedIndividual>
    


