    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#TimeIndependenceOfHamiltonian -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#TimeIndependenceOfHamiltonian">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{\partial}{\partial t}\hat{H}=0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$H$, Quantum Hamiltonian Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">assuming that the Hamiltonian of a quantum system does not dependend on time explicitly</terms1:description>
        <rdfs:label xml:lang="en">Time Independence of Hamiltonian</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Schr%C3%B6dinger_equation#Time-independent_equation"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6534352"/>
    </owl:NamedIndividual>
    


