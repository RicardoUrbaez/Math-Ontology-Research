        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S_0^i + I_0^i = N^i$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_0^i$, Number of Infectious Individuals</inDefiningFormulation>
