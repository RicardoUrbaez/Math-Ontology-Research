    <!-- https://mardi4nfdi.de/mathmoddb#NonrelativisticApproximation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NonrelativisticApproximation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalMomentum"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RelativisticMomentum"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p_{rel} \approx p_{cl}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p_{cl}$, Classical Momentum</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p_{rel}$, Relativistic Momentum</inDefiningFormulation>
        <terms1:description xml:lang="en">Newtonian dynamics as an approximation to special relativity</terms1:description>
        <rdfs:label xml:lang="en">Nonrelativistic Approximation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Classical_mechanics#Newtonian_approximation_to_special_relativity"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674480"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#NormalInteractionForceOfTwoParticles -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NormalInteractionForceOfTwoParticles">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#LinearDiscreteElementMethod"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DampingCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InteractionForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalStiffness"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ParticleMass"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ParticlePosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ParticleRadius"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ParticleVelocity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnitNormalVector"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#YoungModulus"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}
\boldsymbol F^N_{ij}&amp;=\left(k_{ij}^N\delta_{ij}+d_{ij}^N\dot{\delta}_{ij}\right)\boldsymbol n_{ij}\\
\delta_{ij}&amp;=\langle \boldsymbol x_i - \boldsymbol x_j, \boldsymbol n_{ij}\rangle\\
\dot{\delta}_{ij}&amp;=\langle \boldsymbol v_i - \boldsymbol v_j, \boldsymbol n_{ij}\rangle\\
r_{ij}&amp;=(r_i+r_j)/2\\
k^N_{ij}&amp;=E_N \pi r_{ij} / 2\\
d_{ij}^N&amp;=D_N 2 \sqrt{k^N_{ij}m_{ij}}\\
m_{ij}&amp;=\frac{m_im_j}{m_i + m_j}\\
\boldsymbol n_{ij} &amp;= \frac{\boldsymbol x_i - \boldsymbol x_j}{\lVert \boldsymbol x_i - \boldsymbol x_j \rVert}
\end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$D_N$, Damping Coefficient</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$E_N$, Young Modulus</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\boldsymbol F^N_{ij}$, Interaction Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\boldsymbol n_{ij}\in \mathbb R^3$, Unit Normal Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\boldsymbol v_i\in \mathbb R^3$, Particle Velocity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\boldsymbol x_i\in \mathbb R^3$, Particle Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{ij}^N$, Normal Stiffness</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$m_i$, Particle Mass</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r_{ij}$, Particle Radius</inDefiningFormulation>
        <terms1:description xml:lang="en">force component acting normally at the contact interface between two particles</terms1:description>
        <rdfs:label xml:lang="en">Normal Interaction Force of Two Particles</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674527"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#NormalModeCoordinate -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NormalModeCoordinate">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">pattern of motion in which all parts of the system move sinusoidally with the same frequency and with a fixed phase relation</terms1:description>
        <rdfs:comment xml:lang="en">Normal coordinates refer to the positions of atoms away from their equilibrium positions, wrt a normal mode of vibration. Formally, normal modes are determined by solving a secular determinant, and then the normal coordinates can be expressed as a summation over the cartesian coordinates (over the atom positions). The normal modes diagonalize the matrix governing the molecular vibrations.</rdfs:comment>
        <rdfs:label xml:lang="en">Normal Mode Coordinate</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Normal_mode"/>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Molecular_vibration#Normal_coordinates"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674076"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q112730947"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#NormalModeCoordinateDimensionless -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NormalModeCoordinateDimensionless">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalModeCoordinate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalModeCoordinateDimensionless"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PlanckConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SpeedOfLight"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#VibrationFrequencyHarmonic"/>
        <nondimensionalizes rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalModeCoordinate"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}
q&amp;\equiv&amp;\sqrt{\gamma}Q \\
\gamma&amp;\equiv&amp;\frac{2 \pi c \omega}{\hbar}
\end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$Q$, Normal Mode Coordinate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hbar$, Planck Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\omega$, Vibration Frequency (Harmonic)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Speed of Light</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q$, Normal Mode Coordinate (Dimensionless)</inDefiningFormulation>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <terms1:description xml:lang="en">nondimensionalized positions of atoms away from their equilibrium positions, wrt a normal mode of vibration</terms1:description>
        <rdfs:label xml:lang="en">Normal Mode Coordinate (Dimensionless)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674077"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#NormalModeMomentum -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NormalModeMomentum">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">canonical momenta, corresponding to the normal mode coordinates used for the description of vibrations of many-body systems, e.g. molecules</terms1:description>
        <rdfs:label xml:lang="en">Normal Mode Momentum</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Normal_mode"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674078"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#NormalModeMomentumDimensionless -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NormalModeMomentumDimensionless">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalModeMomentum"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalModeMomentumDimensionless"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PlanckConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SpeedOfLight"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#VibrationFrequencyHarmonic"/>
        <nondimensionalizes rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalModeMomentum"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}
p&amp;\equiv&amp;\frac{1}{\sqrt{\gamma}\hbar}P \\
\gamma&amp;\equiv&amp;\frac{2 \pi c \omega}{\hbar}
\end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$P$, Normal Mode Momentum</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hbar$, Planck Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\omega$, Vibration Frequency (Harmonic)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Speed of Light</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p$, Normal Mode Momentum (Dimensionless)</inDefiningFormulation>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <terms1:description xml:lang="en">dimensionless canonical momenta, corresponding to the normal mode coordinates used for the description of vibrations of many-body systems, e.g. molecules</terms1:description>
        <rdfs:label xml:lang="en">Normal Mode Momentum (Dimensionless)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674079"/>
    </owl:NamedIndividual>
    


