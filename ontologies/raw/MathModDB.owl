    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#DixonEquationUniUniReactionwithoutProductandMixedCompleteInhibitionSteadyStateAssumption">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
