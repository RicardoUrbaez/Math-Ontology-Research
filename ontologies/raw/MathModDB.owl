    <!-- https://mardi4nfdi.de/mathmoddb#NumberOfExposedIndividualsFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NumberOfExposedIndividualsFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PDESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CoefficientScalingInfectiousToExposed"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfExposedIndividuals"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{\mathcal{E}}^{(l)} = \Sigma_{\mathcal{E}} \hat{\mathcal{I}}^{(l)}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Sigma_{\mathcal{E}}$, Coefficient Scaling Infectious to Exposed</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{\mathcal{E}}^{(l)}$, Number of Exposed Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{\mathcal{I}}^{(l)}$, Number of Infectious Individuals</inDefiningFormulation>
        <terms1:description xml:lang="en">equation for the number of exposed individuals</terms1:description>
        <rdfs:label xml:lang="en">Number of Exposed Individuals Formulation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674528"/>
    </owl:NamedIndividual>
    


