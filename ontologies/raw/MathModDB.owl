    <!-- https://mardi4nfdi.de/mathmoddb#FrictionCoefficient -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#FrictionCoefficient">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">measure that quantifies the amount of friction existing between two surfaces</terms1:description>
        <rdfs:comment xml:lang="en">Coefficient of friction, aka damping constant. Units of inverse time.</rdfs:comment>
        <rdfs:label xml:lang="en">Friction Coefficient</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Friction"/>
        <skos:altLabel xml:lang="en">Damping Constant</skos:altLabel>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673872"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q82580"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GammaGompertzMakehamLaw -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GammaGompertzMakehamLaw">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#GammaGompertzMakehamModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AgeOfAnIndividual"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ExtrinsicMortality"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HeterogeneityOfDeathRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LevelOfMortality"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateOfAging"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RiskOfDeath"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#GompertzMakehamLaw"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu(x) = \frac{a\exp(bx)}{1+\frac{a\gamma}{b}(\exp(bx)-1)}+c$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, Heterogeneity of Death Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu$, Risk of Death</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$a$, Level of Mortality</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$b$, Rate of Aging</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Extrinsic Mortality</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Age of an Individual</inDefiningFormulation>
        <terms1:description xml:lang="en">mathematical formulation for the mortality based on a Gamma-Gompertz-Makeham law</terms1:description>
        <rdfs:label xml:lang="en">Gamma-Gompertz–Makeham Law</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.1371/journal.pone.0198485"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674370"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GammaGompertzMakehamModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GammaGompertzMakehamModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <terms1:description xml:lang="en">mathematical model for the mortality based on a Gamma-Gompertz-Makeham law</terms1:description>
        <rdfs:comment xml:lang="en">We assume that death counts at age x are Poisson-distributed and the underlying population level hazard function follows a Gamma-Gompertz-Makeham model.</rdfs:comment>
        <rdfs:label xml:lang="en">Gamma-Gompertz-Makeham Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675410"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#Gattermann_2017_Line_pool_generation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#Gattermann_2017_Line_pool_generation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Publication"/>
        <terms1:description xml:lang="en">publication</terms1:description>
        <rdfs:label xml:lang="en">Gattermann (2017) Line pool generation</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.1007/s12469-016-0127-x"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GaussLawElectricField -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GaussLawElectricField">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#MaxwellEquationsModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricChargeDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricField"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PermittivityVacuum"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#LaplaceEquationForTheElectricPotential"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#PoissonEquationForTheElectricPotential"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\nabla\cdot E=\frac{\rho}{\epsilon_0}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$E$, Electric Field</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\epsilon_0$, Permittivity (Vacuum)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho$, Electric Charge Density</inDefiningFormulation>
        <terms1:description xml:lang="en">foundational law of electromagnetism stating that electric charges are the &quot;sources&quot; (divergence) of electric fields</terms1:description>
        <rdfs:label xml:lang="en">Gauss Law (Electric Field)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Gauss%27s_law"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674372"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q173356"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GaussLawMagneticField -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GaussLawMagneticField">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#MaxwellEquationsModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MagneticField"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\nabla\cdot B=0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B$, Magnetic Field</inDefiningFormulation>
        <terms1:description xml:lang="en">foundational law of electromagnetism stating that the magnetic field B has divergence equal to zero</terms1:description>
        <rdfs:comment xml:lang="en">Equivalently, magnetic monopoles do not exist.</rdfs:comment>
        <rdfs:label xml:lang="en">Gauss Law (Magnetic Field)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Gauss%27s_law_for_magnetism"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674373"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q1195250"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GaussianDistribution -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GaussianDistribution">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EulerNumber"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ExpectationValue"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GaussianDistribution"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PiNumber"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Variance"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ProbabilityDistribution"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\varphi(z) \equiv \frac 1 {\sigma\sqrt{2\pi}} e^{ -(z-\mu)^2/(2\sigma^2) }$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu$, Expectation Value</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\pi$, Pi Number</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Variance</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\varphi$, Gaussian Distribution</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$e$, Euler Number</inDefiningFormulation>
        <terms1:description xml:lang="en">continuous probability distribution that is symmetric and bell-shaped</terms1:description>
        <rdfs:label xml:lang="en">Gaussian Distribution</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Normal_distribution"/>
        <skos:altLabel xml:lang="en">Normal Distribution</skos:altLabel>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674002"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q133871"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GaussianNoiseModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GaussianNoiseModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GaussianDistribution"/>
        <terms1:description xml:lang="en">signal noise that has a probability density function equal to that of the normal distribution</terms1:description>
        <rdfs:comment xml:lang="en">A typical model of image noise is Gaussian, additive, independent at each pixel, and independent of the signal intensity, caused primarily by Johnson–Nyquist noise (thermal noise), including that which comes from the reset noise of capacitors (&quot;kTC noise&quot;).</rdfs:comment>
        <rdfs:label xml:lang="en">Gaussian Noise Model</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Gaussian_noise"/>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Image_noise"/>
        <skos:altLabel xml:lang="en">Electronic Noise Model</skos:altLabel>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675393"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q2725903"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GaussianProcess -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GaussianProcess">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#StochasticProcess"/>
        <terms1:description xml:lang="en">stochastic process such that every finite collection of random variables has a multivariate normal distribution</terms1:description>
        <rdfs:label xml:lang="en">Gaussian Process</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Gaussian_process"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q1496376"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GeneralizedCompartmentBasedMorphogenGradientModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GeneralizedCompartmentBasedMorphogenGradientModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <assumes rdf:resource="https://mardi4nfdi.de/mathmoddb#AProducedInFirstCompartment"/>
        <assumes rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionDiffusionSystem"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StationaryReactionDiffusionMasterEquation"/>
        <terms1:description xml:lang="en">generalized compartment-based model for morphogen gradient modelling</terms1:description>
        <rdfs:comment xml:lang="en">Assuming that molecules of species A diffuse significantly faster than those of
species B, a larger compartment size for A is chosen.</rdfs:comment>
        <rdfs:label xml:lang="en">Generalized Compartment Based Morphogen Gradient Model</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GeneralizedDiffusionOperator -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GeneralizedDiffusionOperator">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Operators_O_i_Minus"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Operators_O_i_Plus"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionOperator"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{aligned} \tilde{\mathcal{D}} f(\mathbf{n}, \mathbf{m}):\equiv &amp; \frac{D_A}{h^2} \sum_{i=1}^{K_{A}-1}\left\{\left(n_i+1\right) f\left(\mathcal{O}_i^{+} \mathcal{O}_{i+1}^{-} \mathbf{n}, \mathbf{m}\right)-n_i f(\mathbf{n}, \mathbf{m})\right\} \\ &amp; +\frac{D_A}{h^2} \sum_{i=2}^{K_{A}} \left\{\left(n_i+1\right) f\left(\mathcal{O}_i^{+} \mathcal{O}_{i-1}^{-} \mathbf{n}, \mathbf{m}\right)-n_i f(\mathbf{n}, \mathbf{m})\right\} \\ &amp; +\frac{D_B}{h^2} \sum_{i=1}^{K_{B}-1}\left\{\left(m_i+1\right) f\left(\mathbf{n}, \mathcal{O}_i^{+} \mathcal{O}_{i+1}^{-} \mathbf{m}\right)-m_i f(\mathbf{n}, \mathbf{m})\right\} \\ &amp; +\frac{D_B}{h^2} \sum_{i=2}^{K_B}\left\{\left(m_i+1\right) f\left(\mathbf{n}, \mathcal{O}_i^{+} \mathcal{O}_{i-1}^{-} \mathbf{m}\right)-m_i f(\mathbf{n}, \mathbf{m})\right\}\end{aligned}$</definingFormulation>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{O}_i^{+}$, Operators Oi Plus</definingFormulation>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{O}_i^{-}$, Operators Oi Minus</definingFormulation>
        <terms1:description xml:lang="en">generalized version of the diffusion operator</terms1:description>
        <rdfs:label xml:lang="en">Generalized Diffusion Operator</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GeneralizedPoissonDistribution -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GeneralizedPoissonDistribution">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#GeneralizedCompartmentBasedMorphogenGradientModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CompartmentSizeForA"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CompartmentSizeForB"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StationaryDistribution"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi(\mathbf{n}, \mathbf{m})=\exp \left[-\sum_{j=1}^{K_A} \bar{A}_j-\sum_{i=1}^{K_B} \bar{B}_i\right] \prod_{j=1}^{K_A} \frac{\bar{A}_j^{n_j}}{n_{j}!} \prod_{i=1}^{K_B} \frac{\bar{B}_i^{m_i}}{m_{i}!}$,</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi$, Stationary Distribution</inDefiningFormulation>
        <terms1:description xml:lang="en">obtained by solving the stationary mgRDME for the generalized compartment based model</terms1:description>
        <rdfs:label xml:lang="en">Generalized Poisson Distribution</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GeneralizedPoissonDistributionFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GeneralizedPoissonDistributionFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GeneralizedPoissonDistribution"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi(\mathbf{n}, \mathbf{m})=\exp \left[-\sum_{j=1}^{K_A} \bar{A}_j-\sum_{i=1}^{K_B} \bar{B}_i\right] \prod_{j=1}^{K_A} \frac{\bar{A}_j^{n_j}}{n_{j}!} \prod_{i=1}^{K_B} \frac{\bar{B}_i^{m_i}}{m_{i}!}$,</definingFormulation>
        <terms1:description xml:lang="en">generalized poisson distribution formulation</terms1:description>
        <rdfs:label xml:lang="en">Generalized Poisson Distribution Formulation</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GeneralizedReactionDiffusionSystem -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GeneralizedReactionDiffusionSystem">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#GeneralizedCompartmentBasedMorphogenGradientModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CompartmentLengthRatio"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Morphogen"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Signal"/>
        <definingFormulation>$A_j \xrightarrow{k_2 / \gamma} B_i, \quad j=1,2, \ldots, K_A$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Signal</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B$, Morphogen</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, &apos;Compartment Length Ratio&apos;</inDefiningFormulation>
        <terms1:description xml:lang="en">generalized reactions for each compartment of the compartment-based morphogen gradient models</terms1:description>
        <rdfs:comment xml:lang="en">i denotes the compartment index.</rdfs:comment>
        <rdfs:label xml:lang="en">Generalized Compartment Reaction</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GeneralizedReactionOperator -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GeneralizedReactionOperator">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#JointProbability"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Operators_O_i_Minus"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Operators_O_i_Plus"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionOperator"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{aligned} \tilde{\mathcal{R}} f(\mathbf{n}, \mathbf{m}):\equiv &amp; k_1\left\{f\left(\mathcal{O}_1^{-} \mathbf{n}, \mathbf{m}\right)-f(\mathbf{n}, \mathbf{m})\right\} \\ &amp; +\frac{k_2}{\gamma} \sum_{j=1}^{K_A} \sum_{i \in \mathcal{I}(j)}\left\{\left(n_j+1\right) f\left(\mathcal{O}_j^{+} \mathbf{n}, \mathcal{O}_i^{-} \mathbf{m}\right)-n_j f(\mathbf{n}, \mathbf{m})\right\} \\ &amp; +k_3 \sum_{i=1}^{K_B}\left\{\left(m_i+1\right) f\left(\mathbf{n}, \mathcal{O}_i^{+} \mathbf{m}\right)-m_i f(\mathbf{n}, \mathbf{m})\right\} .\end{aligned}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{O}_i^{+}$, Operators Oi Plus</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{O}_i^{-}$, Operators Oi Minus</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p(\mathbb(n), \mathbb(m), t)$, Joint Probability</inDefiningFormulation>
        <terms1:description xml:lang="en">generalized version of the reaction operator</terms1:description>
        <rdfs:label xml:lang="en">Generalized Reaction Operator</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GeneralizedSteadyStateEquations -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GeneralizedSteadyStateEquations">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#GeneralizedCompartmentBasedMorphogenGradientModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AverageNumberOfMoleculesOfMorphogen"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AverageNumberOfMoleculesOfSignal"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionCoefficientA"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionCoefficientB"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MatrixM"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MatrixS"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$M$, Matrix M</definingFormulation>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">\begin{align*}
\left(\frac{D_A}{h_A^2} S_A-k_2 I_A\right) \overline{\mathbf{A}}=-k_1 \mathbf{e}_1 \\
\quad\left(\frac{D_B}{h_B^2} S_B-k_3 I_B\right) \overline{\mathbf{B}}=-\frac{k_2}{\gamma} M \overline{\mathbf{A}}
\end{align*}</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$D_{A}$, Diffusion Coefficient A</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$D_{B}$, Diffusion Coefficient B</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S$, Matrix S</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\overline{A}_i$,  Average Number Of Molecules Of Signal</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\overline{B}_i$,  Average Number Of Molecules Of Morphogen</inDefiningFormulation>
        <terms1:description xml:lang="en">steady state equations satisfied by average number of molecules of A and B in the Generalized Morphogen Gradient Model</terms1:description>
        <rdfs:label xml:lang="en">Generalized Steady State Equations</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GompertzLaw -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GompertzLaw">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <terms1:description xml:lang="en">in probability and statistics, the Gompertz distribution is a continuous probability distribution</terms1:description>
        <rdfs:comment xml:lang="en">Often applied to describe the distribution of adult lifespans by demographers.</rdfs:comment>
        <rdfs:label xml:lang="en">Gompertz Law</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Gompertz_distribution"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674374"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q1011784"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GompertzMakehamLaw -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GompertzMakehamLaw">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#GompertzLaw"/>
        <terms1:description xml:lang="en">mathematical equation describing the human death rate as a sum of an age-dependent component, and an age-independent component</terms1:description>
        <rdfs:comment xml:lang="en">Note that the age-dependent component increases exponentially with age,</rdfs:comment>
        <rdfs:label xml:lang="en">Gompertz–Makeham Law</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Gompertz%E2%80%93Makeham_law_of_mortality"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674371"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q2734378"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GramianGeneralizedControllability -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GramianGeneralizedControllability">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixA"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixB"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixN"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GramianGeneralizedControllability"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#GramianMatrixObservability"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}
W_c &amp;\equiv&amp; \sum_{j=1}^{\infty} \int_0^\infty\ldots\int_0^\infty P_{j}(t_{1},\ldots t_{j}) P^{*}_{j}(t_{1}, \ldots t_{j}) \mathrm{d} t_{1} \ldots \mathrm{d} t_{j} \\
P_{1}(t_{1}) &amp;\equiv&amp;  e^{A t_{1}}iB \\
P_{j}(t_{1},\ldots,t_{j}) &amp;\equiv&amp; e^{At_{j}}iN P_{j-1}
\end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Control System Matrix A</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B$, Control System Matrix B</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Control System Matrix N</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$W_c$, Gramian Generalized Controllability</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">generalized Gramian of controllability, for use in bi-linear control problems</terms1:description>
        <rdfs:label xml:lang="en">Gramian Generalized Controllability</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674004"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GramianGeneralizedObservability -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GramianGeneralizedObservability">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixA"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixC"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixN"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GramianGeneralizedObservability"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#GramianMatrixObservability"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}
W_c &amp;\equiv&amp; \sum_{j=1}^{\infty} \int_0^\infty\ldots\int_0^\infty  Q^{*}_{j}(t_{1},\ldots t_{j})Q_{j}(t_{1},\ldots t_{j})\mathrm{d} t_{1}\ldots\mathrm{d} t_{j} \\
Q_{1}(t_{1}) &amp;\equiv&amp; C e^{A^{*} t_{1}} \\
Q_{j}(t_{1},\ldots,t_{j}) X&amp;\equiv&amp; Q_{j-1}iN e^{A^{*}t_{j}}
\end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Control System Matrix A</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C$, Control System Matrix C</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Control System Matrix N</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$W_o$, Gramian Generalized Observability</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">generalized Gramian of observability, for use in bi-linear control problems</terms1:description>
        <rdfs:label xml:lang="en">Gramian Generalized Observability</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674005"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GramianMatrix -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GramianMatrix">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#GramianMatrixControllability"/>
