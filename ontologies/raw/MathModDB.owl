        <describedAsInventedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#Cundall_1979_Discrete_model_granular_assemblies"/>
        <terms1:description xml:lang="en">family of numerical methods for modeling the behavior of assemblies of discrete particles in contact</terms1:description>
        <rdfs:comment xml:lang="en">Describes any family of numerical functions for computing the motion and the effects of a large number of small particles. DEM is an effective method of addressing engineering problems in granular and discontinuous materials, especially in granular flows, powder mechanics, ice and rock mechanics.</rdfs:comment>
        <rdfs:label xml:lang="en">Discrete Element Method</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/DiscreteElementMethod"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675395"/>
