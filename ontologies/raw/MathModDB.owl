    <!-- https://mardi4nfdi.de/mathmoddb#MaximizingPoissonLogLikelihood -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MaximizingPoissonLogLikelihood">
