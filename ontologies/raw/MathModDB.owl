    <!-- https://mardi4nfdi.de/mathmoddb#MathematicalAnalysisOfDHWEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MathematicalAnalysisOfDHWEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ComputationalTask"/>
        <uses rdf:resource="https://mardi4nfdi.de/mathmoddb#DynamicalElectronScatteringModel"/>
        <terms1:description xml:lang="en">mathematical analysis of Darwin Howie Whelan equation for the scattering of fast electrons described by the Schrödinger equation.</terms1:description>
        <rdfs:label xml:lang="en">Mathematical Analysis of DHW Equation</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.1137/21M139164X"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6684605"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MatrixM -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MatrixM">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">\begin{align*}
M &amp; \equiv \begin{pmatrix} 
M_1 \\ 
\vdots \\ 
M_{K_A} 
\end{pmatrix}\\
\\
M_j &amp; \equiv \begin{pmatrix}
0 &amp; \cdots &amp; 0 &amp; 1 &amp; 0 &amp; \cdots &amp; 0 \\
\vdots &amp; \ddots &amp; \vdots &amp; \vdots &amp; \vdots &amp; \ddots &amp; \vdots \\
0 &amp; \cdots &amp; 0 &amp; 1 &amp; 0 &amp; \cdots &amp; 0
\end{pmatrix}
\end{align*}</definingFormulation>
        <terms1:description xml:lang="en">block Matrix M</terms1:description>
        <rdfs:label xml:lang="en">Matrix M</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MatrixS -->

