        <containsParameter rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactNetwork"/>
        <containsParameter rdf:resource="https://mardi4nfdi.de/mathmoddb#SpreadingRateTimeDependent"/>
        <uses rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleInfectiousEpidemicSpreadingModel"/>
        <terms1:description xml:lang="en">given a set of initially infected cities, a contact network, and a time-dependent spreading rate, the spreading curve for the romanization is calculated</terms1:description>
        <rdfs:label xml:lang="en">Romanization Time Evolution</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6684616"/>
    </owl:NamedIndividual>
    


