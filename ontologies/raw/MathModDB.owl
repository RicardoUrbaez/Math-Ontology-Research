    <!-- https://mardi4nfdi.de/mathmoddb#StressOfCrystal -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#StressOfCrystal">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">stress of a crystal used in theory of elasticity</terms1:description>
        <rdfs:label xml:lang="en">Stress of Crystal</rdfs:label>
