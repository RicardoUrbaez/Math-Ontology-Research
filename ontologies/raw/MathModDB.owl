    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#InfectiousAtTimeStepInTheMultiPopulationSIModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#InfectiousAtTimeStepInTheMultiPopulationSIModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#MultiPopulationSusceptibleInfectiousModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactRateBetweenTwoGroups"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_{n+1}^i = I_n^i + S_n^i \sum_{k=1}^K\frac{\alpha_{ik} \Delta t}{N^i} I_n^k$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_n^i$, Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N^i$, Total Population Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S_n^i$, Susceptible Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha_{ik}$, Contact Rate Between Two Groups</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">equation to define the number of infectious individuals in the multi-population SI Model</terms1:description>
        <rdfs:label xml:lang="en">Infectious at Time Step n+1 in the Multi-Population SI Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674390"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#InfectiousAtTimeStepInTheMultiPopulationSIRModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#InfectiousAtTimeStepInTheMultiPopulationSIRModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#MultiPopulationSusceptibleInfectiousRemovedModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactRateBetweenTwoGroups"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RelativeRemovalRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_{n+1}^i = I_n^i \left(1 - \gamma_i \Delta t \right) +S_n^i \sum_{k=1}^K\frac{\alpha_{ik} \Delta t}{N^i} I_n^k$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_n^i$, Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Total Population Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S_n^i$, Susceptible Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha_{ik}$, Contact Rate Between Two Groups</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, Relative Removal Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">equation to define the number of infectious individuals in the multi-population SIR Model</terms1:description>
        <rdfs:label xml:lang="en">Infectious at Time Step n+1 in the Multi-Population SIR Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674391"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#InfectiousAtTimeStepInTheMultiPopulationSISModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#InfectiousAtTimeStepInTheMultiPopulationSISModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#MultiPopulationSusceptibleInfectiousSusceptibleModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactRateBetweenTwoGroups"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RelativeRemovalRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S_{n+1}^i = S_n^i \left(1- \sum_{k=1}^K \frac{\alpha_{ik} \Delta t}{N^i} I_n^k\right) + \gamma_i \Delta t I_n^i$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_n^i$, Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N^i$, Total Population Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S_n^i$, Susceptible Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha_{ik}$, Contact Rate Between Two Groups</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma_i$, Relative Removal Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">equation to define the number of infectious individuals in the multi-population SIS Model</terms1:description>
        <rdfs:label xml:lang="en">Infectious at Time Step n+1 in the Multi-Population SIS Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674392"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#InfectiousAtTimeStepInTheSIModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#InfectiousAtTimeStepInTheSIModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#DiscreteSusceptibleInfectiousModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_{n+1}=I_n\left(1+\frac{\alpha \Delta t}{N} S_n\right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_n$, Number of Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Total Population Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S_n$, Number of Susceptible Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha$, Contact Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">equation to define the number of infectious individuals in the SI Model</terms1:description>
        <rdfs:label xml:lang="en">Infectious at Time Step n+1 in the SI Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674296"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#InfectiousAtTimeStepInTheSIRModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#InfectiousAtTimeStepInTheSIRModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#DiscreteSusceptibleInfectiousRemovedModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RelativeRemovalRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <discretizes rdf:resource="https://mardi4nfdi.de/mathmoddb#ContinuousRateOfChangeOfInfectiousInTheSIRModel"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_{n+1}=I_n\left(1 - \gamma \Delta t +\frac{\alpha \Delta t}{N} S_n\right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_n$, Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Total Population Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S_n$, Susceptible Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha$, Contact Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, Relative Removal Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">equation to define the number of infectious individuals in the SIR Model</terms1:description>
        <rdfs:label xml:lang="en">Infectious at Time Step n+1 in the SIR Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674393"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#InfectiousAtTimeStepInTheSIRModelWithBirthsAndDeaths -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#InfectiousAtTimeStepInTheSIRModelWithBirthsAndDeaths">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleInfectiousRemovedModelWithBirthsAndDeaths"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BirthRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RelativeRemovalRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_{n+1}=I_n\left(1 - \gamma \Delta t - \beta \Delta t +\frac{\alpha \Delta t}{N} S_n\right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_n$, Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Total Population Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S_n$, Susceptible Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha$, Contact Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\beta$, Birth Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, Relative Removal Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">equation to define the number of infectious individuals in the SIR Model with births and deaths</terms1:description>
        <rdfs:label xml:lang="en">Infectious at Time Step n+1 in the SIR Model with Births and Deaths</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674394"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#InfectiousAtTimeStepInTheSISModelWithBirthsAndDEaths -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#InfectiousAtTimeStepInTheSISModelWithBirthsAndDEaths">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleInfectiousSusceptibleModelWithBirthsAndDeaths"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BirthRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RelativeRemovalRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S_{n+1}=S_n\left(1-\frac{\alpha \Delta t}{N} I_n\right) + \gamma \Delta t I_n + \beta \Delta t (N - S_n)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_n$, Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Total Population Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S_n$, Susceptible Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha$, Contact Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\beta$, Birth Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, Relative Removal Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">equation to define the number of infectious individuals in the SIS Model with births and deaths</terms1:description>
        <rdfs:label xml:lang="en">Infectious at Time Step n+1 in the SIS Model with Births and Deaths</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674395"/>
    </owl:NamedIndividual>
    


