    <!-- https://mardi4nfdi.de/mathmoddb#StokesDarcyModelDiscretized -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#StokesDarcyModelDiscretized">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DarcyModelDiscretized"/>
