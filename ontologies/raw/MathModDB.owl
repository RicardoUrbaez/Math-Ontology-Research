    <!-- https://mardi4nfdi.de/mathmoddb#SchrödingerEquationLieTrotter -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SchrödingerEquationLieTrotter">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ImaginaryUnit"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PlanckConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumKineticOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumPotentialOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumStateVectorDynamic"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <discretizes rdf:resource="https://mardi4nfdi.de/mathmoddb#SchroedingerEquationTimeDependent"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#SchrödingerEquationSplitOperator"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$|\psi(t+\Delta t)\rangle=\exp(-i\Delta t\hat{T}/ \hbar)\exp(-i\Delta t\hat{V}/ \hbar)|\psi(t)\rangle + \mathcal{O}(\Delta t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$T$, Quantum Kinetic Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V$, Quantum Potential Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hbar$, Planck constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathrm{i}$, Imaginary Unit</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi$, Quantum State Vector (Dynamic)</inDefiningFormulation>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">first order (Lie-Trotter) split operator scheme for numerical integration of the time-dependent Schrödinger equation</terms1:description>
        <rdfs:label xml:lang="en">Schrödinger Equation (Lie-Trotter)</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.1016/0021-9991(82)90091-2"/>
        <doiID rdf:resource="https://doi.org/10.1016/0021-9991(91)90137-A"/>
        <doiID rdf:resource="https://doi.org/10.1063/1.444501"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674568"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SchrödingerEquationSecondOrderDifferencing -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SchrödingerEquationSecondOrderDifferencing">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EulerBackwardMethod"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EulerForwardMethod"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ImaginaryUnit"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PlanckConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumStateVectorDynamic"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <discretizes rdf:resource="https://mardi4nfdi.de/mathmoddb#SchroedingerEquationTimeDependent"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$|\psi(t+\Delta t)\rangle = |\psi(t-\Delta t)\rangle -2i\Delta t \hat{H}/\hbar |\psi(t)\rangle + \mathcal{O}(\Delta t)^3$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$H$, Quantum Hamiltonian Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hbar$, Planck constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathrm{i}$, Imaginary Unit</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi$, Quantum State Vector (Dynamic)</inDefiningFormulation>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">second order differencing scheme for numerical integration of the time-dependent Schrödinger equation</terms1:description>
        <rdfs:comment xml:lang="en">Essentially a symmetric (and symplectic!) combination of Euler forward and backward methods.</rdfs:comment>
        <rdfs:label xml:lang="en">Schrödinger Equation (Second Order Differencing)</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.1016/0021-9991(91)90137-A"/>
        <doiID rdf:resource="https://doi.org/10.1063/1.436072"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674270"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SchrödingerEquationSplitOperator -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SchrödingerEquationSplitOperator">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <discretizes rdf:resource="https://mardi4nfdi.de/mathmoddb#SchroedingerEquationTimeDependent"/>
