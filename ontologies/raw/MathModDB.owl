        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, Quantum Damping Rate</inDefiningFormulation>
        <terms1:description xml:lang="en">assuming that a quantum system does not interact with its environment</terms1:description>
        <rdfs:comment xml:lang="en">Note that dissipation as well as dephasing  (or more formally: the corresponding rates in the Lindblad equation) are neglected.</rdfs:comment>
        <rdfs:label xml:lang="en">Closed System Approximation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Lindbladian"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q4476520"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6534354"/>
    </owl:NamedIndividual>
    


