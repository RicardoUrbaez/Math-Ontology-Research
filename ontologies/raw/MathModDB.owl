    <!-- https://mardi4nfdi.de/mathmoddb#StokesDarcyEquationDiscretizedPV -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#StokesDarcyEquationDiscretizedPV">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#StokesDarcyModelDiscretized"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidPressureFreeFlow"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidPressurePorousMedium"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidVelocityFreeFlow"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{pmatrix} \begin{bmatrix} V &amp; B \\ C &amp; 0 \end{bmatrix} &amp; \begin{bmatrix} B&apos;_1 \\ 0 \end{bmatrix} \\ \begin{bmatrix} C&apos;_1 &amp; 0\end{bmatrix} &amp; D&apos; \end{pmatrix} \begin{pmatrix} \begin{bmatrix} v^{ff} \\ p^{ff} \end{bmatrix} \\ p^{pm} \end{pmatrix} = \begin{pmatrix} \begin{bmatrix} g \\ 0 \end{bmatrix} \\ 0 \end{pmatrix}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p^{ff}$, Fluid Pressure (Free Flow)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p^{pm}$, Fluid Pressure (Porous Medium)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v^{ff}$, Fluid Velocity (Free Flow)</inDefiningFormulation>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isSpaceContinuous>
        <terms1:description xml:lang="en">discrete model of Stokes-Darcy as a pressure-velocity (pv) formulation</terms1:description>
        <rdfs:comment xml:lang="en">Equation (9) from the referenced 2021 arXiv manuscript by Schmalfuss et al.: Discrete model of Stokes-Darcy as a pressure-velocity (pv) formulation, to be solved for every time step.</rdfs:comment>
        <rdfs:label xml:lang="en">Stokes Darcy Equation (Discretized, pv)</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.48550/arXiv.2108.13229"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674578"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#StokesDarcyEquationDiscretizedTD -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#StokesDarcyEquationDiscretizedTD">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#StokesDarcyModelDiscretized"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidPressurePorousMedium"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{pmatrix} A&apos; &amp; B&apos; \\ C&apos; &amp; D&apos;\end{pmatrix} \begin{pmatrix} x^{ff} \\ p^{pm} \end{pmatrix} = \begin{pmatrix} b^{ff}  \\ 0 \end{pmatrix}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p^{pm}$, Fluid Pressure (Porous Medium)</inDefiningFormulation>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isSpaceContinuous>
        <terms1:description xml:lang="en">discrete model of Stokes-Darcy as a two-domain (td) formulation</terms1:description>
        <rdfs:comment xml:lang="en">Equation (8) from the referenced 2021 arXiv manuscript by Schmalfuss et al.: Discrete model of Stokes-Darcy as a two-domain (td) formulation, to be solved for every time step.</rdfs:comment>
        <rdfs:label xml:lang="en">Stokes Darcy Equation (Discretized, td)</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.48550/arXiv.2108.13229"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674579"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#StokesDarcyModel -->

