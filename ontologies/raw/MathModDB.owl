    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SusceptibleInfectiousSusceptibleModelWithBirthsAndDeaths">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <models rdf:resource="https://mardi4nfdi.de/mathmoddb#SpreadingOfInfectiousDiseases"/>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">discrete-time SIS model with births and deaths</terms1:description>
        <rdfs:label xml:lang="en">Susceptible Infectious Susceptible Model with Births and Deaths</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675319"/>
