    <!-- https://mardi4nfdi.de/mathmoddb#GramianMatrixControllability -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GramianMatrixControllability">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#LyapunovEquationControllability"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixA"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixB"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GramianMatrixControllability"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$W_c \equiv \int_0^\infty e^{At}iB(-i)B^* e^{A^*t}\mathrm{d} t$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Control System Matrix A</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B$, Control System Matrix B</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$W_c$, Gramian Matrix Controllability</inDefiningFormulation>
        <terms1:description xml:lang="en">matrix used in linear control problems to determine whether a system is controllable</terms1:description>
        <rdfs:label xml:lang="en">Gramian Matrix Controllability</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Controllability_Gramian"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673780"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#GramianMatrixObservability -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#GramianMatrixObservability">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
