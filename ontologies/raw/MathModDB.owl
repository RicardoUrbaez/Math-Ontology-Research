    <!-- https://mardi4nfdi.de/mathmoddb#TendonStrain -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#TendonStrain">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StressFreeTendonLength"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TendonLength"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TendonStrain"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\epsilon_\text{T}(t) \equiv \frac{\mathcal{l}_\text{T}(t)-\mathcal{l}^{\text{slack}}_\text{T} }{\mathcal{l}^{\text{slack}}_\text{T}}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\epsilon_{\text{T}}$, Tendon Strain</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{l}^{\text{slack}}_\text{T}$, Stress Free Tendon Length</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$l_{\text{T}}$, Tendon Length</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">stretching or partially tearing a tendon</terms1:description>
        <rdfs:comment xml:lang="en">Definition of the tendon strain by length of tendon under stress and stress-free length of tendon.</rdfs:comment>
        <rdfs:label xml:lang="en">Tendon Strain</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674102"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#Time -->

