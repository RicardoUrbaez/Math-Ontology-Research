        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfInfectedCities"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#IntegerDimensionless"/>
