    <!-- https://mardi4nfdi.de/mathmoddb#AProducedInFirstCompartment -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#AProducedInFirstCompartment">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <assumedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#StandardCompartmentBasedMorphogenGradientModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CompartmentSize"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Signal"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\emptyset \xrightarrow{k_1 / h} A_1$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Signal</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$h$, Compartment Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_1$, Reaction Rate Constant</inDefiningFormulation>
        <terms1:description xml:lang="en">signal A is produced in the first compartment on the left</terms1:description>
        <rdfs:comment xml:lang="en">Particles of A are produced at a rate of 𝑘₁.</rdfs:comment>
        <rdfs:label xml:lang="en">A Produced In First Compartment</rdfs:label>
    </owl:NamedIndividual>
    


