    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ClassicalNewtonEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ClassicalNewtonEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalDynamicsModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalPosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Mass"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalHamiltonEquations"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{\mathrm{d^2}}{\mathrm{d}t^2} \vec{q} = \vec{F} / m$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F$, Classical Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$m$, Mass</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q$, Classical Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isTimeContinuous>
        <terms1:description xml:lang="en">fundamental equation in classical mechanics that describe the motion of objects under the influence of forces</terms1:description>
        <rdfs:comment xml:lang="en">When a body is acted upon by a force, the time rate of change of its momentum equals the force.</rdfs:comment>
        <rdfs:label xml:lang="en">Classical Newton Equation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674260"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q2397319"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ClassicalNewtonEquationStoermerVerlet -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ClassicalNewtonEquationStoermerVerlet">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalPosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EulerBackwardMethod"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EulerForwardMethod"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Mass"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <discretizes rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalNewtonEquation"/>
        <similarTo rdf:resource="https://mardi4nfdi.de/mathmoddb#SchrödingerEquationSecondOrderDifferencing"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q(t+\tau)=2q(t)-q(t-\tau)+\tau^2F(q(t))/M$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F$, Classical Forces</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tau$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$m$, Mass</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q$, Classical Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">sympletic, reversible time-discretization of Newton&apos;s equations of motion</terms1:description>
        <rdfs:comment xml:lang="en">Originally discovered already by Newton: Essentially a symmetric (and symplectic!) combination of Euler forward and backward methods.</rdfs:comment>
        <rdfs:label xml:lang="en">Classical Newton Equation (Stoermer Verlet)</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.1103/PhysRev.159.98"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674268"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q5475314"/>
    </owl:NamedIndividual>
    


