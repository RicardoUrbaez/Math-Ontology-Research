    <!-- https://mardi4nfdi.de/mathmoddb#RomanizationParameterEstimation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#RomanizationParameterEstimation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ComputationalTask"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LossFunctionMinimization"/>
        <containsConstraintCondition rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactNetworkConstraint"/>
        <containsConstraintCondition rdf:resource="https://mardi4nfdi.de/mathmoddb#SpreadingRateTimeDependentConstraint"/>
        <containsInput rdf:resource="https://mardi4nfdi.de/mathmoddb#ApproximateSpreadingCurve"/>
        <containsInput rdf:resource="https://mardi4nfdi.de/mathmoddb#RomanizedCitiesVector"/>
        <containsOutput rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeDependentContactNetwork"/>
        <uses rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleInfectiousEpidemicSpreadingModel"/>
        <terms1:description xml:lang="en">given a set of data points the contact network and time-dependent spreading rate are determined</terms1:description>
        <rdfs:label xml:lang="en">Romanization Parameter Estimation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6684615"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#RomanizationSpreadingInNorthernTunesia -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#RomanizationSpreadingInNorthernTunesia">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ResearchProblem"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#RomanArchaeology"/>
        <terms1:description xml:lang="en">understanding the mechanisms and dynamics of Romanization spreading in Northern Tunisia</terms1:description>
        <rdfs:comment xml:lang="en">Understanding the mechanisms and dynamics of Romanization spreading in Northern Tunisia from 146 BC to 350 AD based on sparse and fragmented archaeological data.</rdfs:comment>
        <rdfs:label xml:lang="en">Romanization Spreading in Northern Tunesia</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6684672"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#RomanizationTimeEvolution -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#RomanizationTimeEvolution">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ComputationalTask"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleInfectiousEpidemicSpreadingODESystem"/>
        <containsInput rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfSusceptibleCities"/>
        <containsOutput rdf:resource="https://mardi4nfdi.de/mathmoddb#ApproximateSpreadingCurve"/>
