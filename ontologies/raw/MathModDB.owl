    <!-- https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianLinearRotor -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianLinearRotor">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumAngularMomentumOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RotationalConstant"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianNonRigidRotor"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{H}=B\hat{J}^2$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B$, Rotational Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$J$, Quantum Angular Momentum Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{H}$, Quantum Hamiltonian Operator</inDefiningFormulation>
        <terms1:description xml:lang="en">quantum-mechanical represention of a molecule as a linear rotor</terms1:description>
        <rdfs:label xml:lang="en">Quantum Hamiltonian (Linear Rotor)</rdfs:label>
