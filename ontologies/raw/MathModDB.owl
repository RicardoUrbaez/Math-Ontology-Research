        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$ \quad S \equiv \left(\begin{array}{ccccccc}-1 &amp; 1 &amp; 0 &amp; 0 &amp; \ldots &amp; 0 &amp; 0 \\ 1 &amp; -2 &amp; 1 &amp; 0 &amp; \ldots &amp; 0 &amp; 0 \\ 0 &amp; 1 &amp; -2 &amp; 1 &amp; \ldots &amp; 0 &amp; 0 \\ \vdots &amp; \vdots &amp; \vdots &amp; \vdots &amp; \ddots &amp; \vdots &amp; \vdots \\ 0 &amp; 0 &amp; 0 &amp; 0 &amp; \ldots &amp; -2 &amp; 1 \\ 0 &amp; 0 &amp; 0 &amp; 0 &amp; \ldots &amp; 1 &amp; -1\end{array}\right)$</inDefiningFormulation>
        <terms1:description xml:lang="en">Matrix S</terms1:description>
