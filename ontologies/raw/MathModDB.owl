        <terms1:description xml:lang="en">in the limit of vanishing drag coefficient, physical bodies will move like in vacuum, e.g. free fall models</terms1:description>
        <rdfs:label xml:lang="en">Vanishing Drag Coefficient</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674367"/>
    </owl:NamedIndividual>
    


