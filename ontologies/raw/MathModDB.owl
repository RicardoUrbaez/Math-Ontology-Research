    <!-- https://mardi4nfdi.de/mathmoddb#FewestSwitchesSurfaceHopping1 -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#FewestSwitchesSurfaceHopping1">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <usedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticlePropagation"/>
        <usedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticleVelocityAdjustment"/>
        <usedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticTransitions"/>
        <usedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticlePropagation"/>
        <terms1:description xml:lang="en">original fewest switches surface hopping trajectories for quantum-classical dynamics</terms1:description>
        <rdfs:comment xml:lang="en">The trajectories for the heavy particle(s) are propagated on a single potential energy surface (PES) of the light particle(s), but they are allowed to change surface, especially near regions of large nonadiabatic couplings.</rdfs:comment>
        <rdfs:label xml:lang="en">Fewest Switches Surface Hopping 1</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Surface_hopping"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q17155550"/>
        <skos:altLabel xml:lang="en">Molecular Dynamics with Quantum Transitions</skos:altLabel>
        <skos:altLabel xml:lang="en">Trajectory Surface Hopping</skos:altLabel>
        <doiID rdf:resource="https://doi.org/10.1063/1.459170"/>
    </owl:NamedIndividual>
    


