    <!-- https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianOperator -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianOperator">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#SchroedingerEquationTimeDependent"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#SchrödingerEquationTimeIndependent"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumKineticOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumPotentialOperator"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalHamiltonFunction"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{H}=\hat{T}+\hat{V}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$H$, Quantum Hamiltonian Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$T$, Quantum Kinetic Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V$, Quantum Potential Operator</inDefiningFormulation>
        <terms1:description xml:lang="en">operator representing the total energy of a quantum system</terms1:description>
        <rdfs:comment xml:lang="en">In quantum mechanics, this is the operator representing the total energy of a quantum system, thus giving the possible outcomes of energy measurements as well as its time evolution.</rdfs:comment>
        <rdfs:comment xml:lang="de">Operator in der Quantenmechanik, der (mögliche) Energiemesswerte und die Zeitentwicklung angibt.</rdfs:comment>
        <rdfs:label xml:lang="en">Quantum Hamiltonian Operator</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Hamiltonian_(quantum_mechanics)"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6534301"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q660488"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianSymmetricTop -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianSymmetricTop">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumConditionalQuasiSolvability"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumAngularMomentumOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RotationalConstant"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianLinearRotor"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{H}=A\hat{J_A}^2 + B\hat{J_B}^2 + C\hat{J_C}^2$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Rotational Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B$, Rotational Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C$, Rotational Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$J_A$, Quantum Angular Momentum Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$J_B$, Quantum Angular Momentum Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$J_C$, Quantum Angular Momentum Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{H}$, Quantum Hamiltonian Operator</inDefiningFormulation>
        <terms1:description xml:lang="en">quantum-mechanical represention of a molecule as a symmetric top</terms1:description>
        <rdfs:comment xml:lang="en">A symmetric top is a molecule in which two moments of inertia are the same. By definition a symmetric top must have a 3-fold or higher order rotation axis. In practice, spectroscopists divide molecules into two classes of symmetric tops: Oblate symmetric tops (saucer or disc shaped), e.g., C6H6, and Prolate symmetric tops (rugby football, or cigar shaped), e.g. CH3Cl.</rdfs:comment>
        <rdfs:label xml:lang="en">Quantum Hamiltonian (Symmetric Top)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674552"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumJumpOperator -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumJumpOperator">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumDampingRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumJumpOperator"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumMechanicalOperator"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{C_{j,k}} \equiv \sqrt{\Gamma_{k\rightarrow k}}|j\rangle\langle k|$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Gamma$, Quantum Damping Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{C}$, Quantum Jump Operator</inDefiningFormulation>
        <terms1:description xml:lang="en">operator describing the dissipation and/or decoherence of open system quantum dynamics in a Lindblad equation</terms1:description>
        <rdfs:comment xml:lang="en">Quantum jump operators can be used - together with quantum damping rates -  to describe the dissipation and/or decoherence of the quantum dynamics in a Lindblad equation (for open quantum systems).</rdfs:comment>
        <rdfs:label xml:lang="en">Quantum Jump Operator</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Lindbladian#Definition"/>
        <skos:altLabel xml:lang="en">Lindblad Operator</skos:altLabel>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6534312"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumKineticOperator -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumKineticOperator">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Mass"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PlanckConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Position"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumKineticOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumMomentumOperator"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{T} \equiv \frac{\hat{P}^2}{2M} = - \frac{\hbar^2}{2M} \nabla_R^2$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$M$, Mass</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R$, Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{P}$, Quantum Momentum Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{T}$, Quantum Kinetic Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hbar$, Planck Constant</inDefiningFormulation>
        <terms1:description xml:lang="en">operator representing the kinetic energy of a quantum system</terms1:description>
        <rdfs:comment xml:lang="en">In quantum mechanics, this is the (position representation of the) kinetic energy operator a quantum system in Cartesian coordinates. Obviouslyly, a derivative operator acting on a (position representation) wave function.</rdfs:comment>
        <rdfs:label xml:lang="en">Quantum Kinetic Operator</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Hamiltonian_(quantum_mechanics)"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q660488"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674108"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumLindbladEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumLindbladEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumModelOpenSystem"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ImaginaryUnit"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PlanckConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumDampingRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumDensityOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumJumpOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <containsInitialCondition rdf:resource="https://mardi4nfdi.de/mathmoddb#InitialQuantumDensity"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{\mathrm d}{\mathrm{d}t}\rho=-\frac{\mathrm i}\hbar[H,\rho]+\sum _{k=1}^{N^2-1}\gamma_k\left(L_k\rho L_k^\dagger-\frac12[L_k^\dagger L_k,\rho]_+\right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$H$, Quantum Hamiltonian Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$L$, Quantum Jump Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$[\cdot,\cdot]_+$, anti-commutator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma &gt; 0$, Quantum Damping Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hbar$, Planck Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathrm{i}$, Imaginary Unit</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho$, Quantum Density Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isTimeContinuous>
        <terms1:description xml:lang="en">describes open system quantum dynamics including dissipation and/or decoherence</terms1:description>
        <rdfs:comment xml:lang="en">Markovian quantum master equation for the evolution of quantum mechanical density matrices (pure or mixed states).  It generalizes the Schrödinger equation to open quantum systems; that is, systems in contacts with their surroundings. The resulting dynamics is no longer unitary, but still satisfies the property of being trace-preserving and completely positive for any initial condition.</rdfs:comment>
        <rdfs:label xml:lang="en">Quantum Lindblad Equation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Lindbladian"/>
        <skos:altLabel xml:lang="en">Gorini–Kossakowski–Sudarshan–Lindblad Equation</skos:altLabel>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6534317"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q4476520"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumMechanicalOperator -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumMechanicalOperator">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumDensityOperator"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianOperator"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumKineticOperator"/>
