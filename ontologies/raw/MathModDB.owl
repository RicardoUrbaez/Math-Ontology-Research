        <terms1:description xml:lang="en">coefficient of diffusion for the for the chain reaction of chemical species A</terms1:description>
        <rdfs:label xml:lang="en">Diffusion Coefficient A</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#DiffusionCoefficientB -->

