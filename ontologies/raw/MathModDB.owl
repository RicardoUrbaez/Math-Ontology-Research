    <!-- https://mardi4nfdi.de/mathmoddb#SubcellularDAESystem -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SubcellularDAESystem">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#SubcellularModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#IonCurrent"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StateVector"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TransmembranePotential"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}
\frac{\partial\mathbf{y}}{\partial t} &amp;= G \left(\mathbf{y}, V^{\text{f}}_{\text{m}} \right) \\ 
I_{\text{ion}} &amp;= I_{\text{ion}} \left(V^{\text{f}}_{\text{m}}, \mathbf{y}\right) 
\end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_{\text{ion}}$, Ion current</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V^{\text{f}}_{\text{m}}$, Transmembrane potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathbf{y}$, State Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">differential-algebraic equation systems that describes the muscle stress generation</terms1:description>
        <rdfs:comment xml:lang="en">A differential-algebraic equation systems that describes the muscle stress generation an a microscopic scale by means of internal state variables and describes the activation of the ion channels.</rdfs:comment>
        <rdfs:label xml:lang="en">Subcellular DAE System</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674580"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SubcellularModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SubcellularModel">
