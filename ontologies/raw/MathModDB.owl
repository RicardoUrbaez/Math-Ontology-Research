    <!-- https://mardi4nfdi.de/mathmoddb#FluctuatingPartsOfPopulationDensityFractionsApproximatelyZero -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#FluctuatingPartsOfPopulationDensityFractionsApproximatelyZero">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <assumedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#DecompositionOfPopulationDensityFractionsInTheODERegionIntoSpatiallyConstantAndFluctuatingPart"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposedInTheODERegionFluctuatingPart"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfInfectiousInTheODERegionFluctuatingPart"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfRemovedInTheODERegionFluctuatingPart"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfSusceptiblesInTheODERegionFluctuatingPart"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{aligned}
&amp; \tilde{s}_2 \approx 0\\
&amp; \tilde{e}_2 \approx 0\\
&amp; \tilde{i}_2 \approx 0\\
&amp; \tilde{r}_2 \approx 0
\end{aligned}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{e}_2$, Fraction Of Population Density Of Exposed In The ODE Region (Fluctuating Part)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{i}_2$, Fraction Of Population Density Of Infectious In The ODE Region (Fluctuating Part)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{r}_2$, Fraction Of Population Density Of Removed In The ODE Region (Fluctuating Part)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{s}_2$, Fraction Of Population Density Of Susceptibles In The ODE Region (Fluctuating Part)</inDefiningFormulation>
        <terms1:description xml:lang="en">fluctuating parts of population density fractions are approximately zero</terms1:description>
        <rdfs:comment xml:lang="en">s̃₂, ẽ₂, ĩ₂, r̃₂ are assumed to to be approximately zero, since they become vanishingly small as D (Diffusion Coefficient) becomes large.</rdfs:comment>
        <rdfs:label xml:lang="en">Fluctuating Parts Of Population Density Fractions Approximately Zero</rdfs:label>
    </owl:NamedIndividual>
    


