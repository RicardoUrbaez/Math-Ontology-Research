        <uses rdf:resource="https://mardi4nfdi.de/mathmoddb#GammaGompertzMakehamModel"/>
        <terms1:description xml:lang="en">maximizing Poisson log-likelihood of mortality models</terms1:description>
        <rdfs:label xml:lang="en">Maximizing Poisson log-Likelihood</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6684606"/>
    </owl:NamedIndividual>
    


