    <!-- https://mardi4nfdi.de/mathmoddb#RateOfChangeOfPopulationDensityFractionOfSusceptiblesMeanODE -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#RateOfChangeOfPopulationDensityFractionOfSusceptiblesMeanODE">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#ODESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AlleeThreshold"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AsymptomaticInfectionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposedInTheODERegionMean"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfInfectiousInTheODERegionMean"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfSusceptiblesInTheODERegionMean"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfSusceptiblesInThePDERegion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PopulationDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SymptomaticInfectionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnitNormalVector"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$ \dot{\bar{s}}_2 \approx-\left(1-\frac{A}{\bar{n}_2+n_0}\right) \bar{s}_2\left(\beta_e \bar{e}_2+\beta_i \bar{i}_2\right)-\frac{1}{\left|\Omega_2\right|} \int_{\Gamma} \nu_1^T D \nabla s_1 do $</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Allee Threshold</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$D$, Diffusion Coefficient for SEIR Model</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\bar{e}_2$, Fraction Of Population Density Of Exposed In The ODE Region (Mean)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\bar{i}_2$, Fraction Of Population Density Of Infectious In The ODE Region (Mean)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\bar{s}_2$, Fraction Of Population Density Of Susceptibles In The ODE Region (Mean)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\beta_e$, Asymptomatic Infection Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\beta_i$, Symptomatic Infection Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\nu_1^T$, Unit Normal Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Population Density</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s_1$, Fraction Of Population Density Of Susceptibles In The PDE Region</inDefiningFormulation>
        <terms1:description xml:lang="en">rate of change of the mean population density of susceptible individuals described by an ODE</terms1:description>
        <rdfs:comment xml:lang="en">Ordinary Differential Equation describing the rate of change of the population density of susceptibles with a right-hand side contribution from the flux of the PDE solution 𝑠₁ across the interface Γ.</rdfs:comment>
        <rdfs:label xml:lang="en">Rate Of Change Of Population Density Fraction Of Susceptibles Mean ODE</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#RateOfChangeOfPopulationDensityFractionOfSusceptiblesPDE -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#RateOfChangeOfPopulationDensityFractionOfSusceptiblesPDE">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PDESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AlleeThreshold"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AsymptomaticInfectionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposed"/>
