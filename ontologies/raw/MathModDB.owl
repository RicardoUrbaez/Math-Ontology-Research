    <!-- https://mardi4nfdi.de/mathmoddb#StokesModelDiscretized -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#StokesModelDiscretized">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StokesEquationEulerBackward"/>
