        <terms1:description xml:lang="en">in the limit of vanishing air density, physical bodies will move like in vacuum, e.g. free fall models</terms1:description>
        <rdfs:label xml:lang="en">Vanishing Air Density</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674366"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#VanishingDragCoefficient -->

