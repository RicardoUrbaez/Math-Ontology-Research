    <!-- https://mardi4nfdi.de/mathmoddb#AverageOpinionOfFollowersOfInfluencersFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#AverageOpinionOfFollowersOfInfluencersFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#OpinionModelWithInfluencersAndMedia"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AverageOpinionOfInfluencerFollowers"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfluencerIndividualMatrix"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#OpinionVectorOfIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{x}_l(t)=\frac{1}{\sum_k C_{k l}(t)} \sum_{i=1}^N C_{i l}(t) x_i(t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C_l(t)$, Influencer Individual Matrix</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{x}_l(t)$, Average Opinion of Followers of Influencers</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x_i(t)$, Opinion Vector of Individuals</inDefiningFormulation>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <terms1:description xml:lang="en">equation describing the average opinon of the followers of a specific Influencer</terms1:description>
        <rdfs:label xml:lang="en">Average Opinion of Followers of Infuencers Formulation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674136"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#AverageOpinionOfFollowersOfInfluencersInThePartialFieldModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#AverageOpinionOfFollowersOfInfluencersInThePartialFieldModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">opinion of the influencers is drawn towards the average opinion of the followers</terms1:description>
        <rdfs:label xml:lang="en">Average Opinion of Followers of Influencers in the Partial Mean Field Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673765"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#AverageOpinionOfFollowersOfInfluencersInThePartialFieldModelFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#AverageOpinionOfFollowersOfInfluencersInThePartialFieldModelFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PartialMeanFieldOpinionModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AverageOpinionOfFollowersOfInfluencersInThePartialFieldModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LimitingDistributionOfIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MediumInfluencerFractionLimit"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Opinion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{x}_l(t)=\frac{\sum_{m=1}^M \int_D x \rho_{m, l}(x, t) d x}{\sum_{m=1}^M n_{m, l}(t)}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{x}_l(t)$, Average Opinion of Followers of Influencers in the Partial Field Model</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho_{m,l}$, Limiting Distribution of Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n_{m,l}$, Medium Influencer Fraction Limit</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Opinion</inDefiningFormulation>
        <terms1:description xml:lang="en">equation describing the average opinon of the followers of a specific influencer in the partial mean field opinion model</terms1:description>
        <rdfs:label xml:lang="en">Average Opinion of Followers of Infuencers in the Partial Mean Field Model Formulation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674137"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#AverageOpinionOfFollowersOfMediaFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#AverageOpinionOfFollowersOfMediaFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#OpinionModelWithInfluencersAndMedia"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AverageOpinionOfMediaFollowers"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MediumFollowerMatrix"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#OpinionVectorOfIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{x}_m(t)=\frac{1}{\sum_k B_{k m}(t)} \sum_{i=1}^N B_{i m}(t) x_i(t) $</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B_m(t)$, Medium Follower Matrix</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{x}_m(t)$, Average Opinion of Followers of Media</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x_i(t)$, Opinion Vector of Individuals</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <terms1:description xml:lang="en">equation describing the average opinon of the followers of a specific medium</terms1:description>
        <rdfs:label xml:lang="en">Average Opinion of Followers of Media Formulation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674138"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#AverageOpinionOfFollowersOfMediaInThePartialFieldModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#AverageOpinionOfFollowersOfMediaInThePartialFieldModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">opinion of the media is drawn towards the average opinion of the followers of that medium</terms1:description>
        <rdfs:label xml:lang="en">Average Opinion of Followers of Media in the Partial Mean Field Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673770"/>
