    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#InitialConditionForTheMultiPopulationSIRModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#InitialConditionForTheMultiPopulationSIRModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsInitialConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#MultiPopulationSusceptibleInfectiousRemovedModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RemovedIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S_0^i + I_0^i + R_0^i = N^i$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_n$, Number of Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Total Population Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R_n$, Number of Removed Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S_n$, Number of Susceptible Individuals</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">initial number of susceptible, infectious and removed individuals is equal to the total population of each subdomain</terms1:description>
        <rdfs:label xml:lang="en">Initial Condition for the Multi-Population SIR Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674415"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#InitialConditionForTheMultiPopulationSISModel -->

