        <usedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#H2OptimalApproximationBilinear"/>
        <usedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#OptimalControl"/>
        <terms1:description xml:lang="en">dynamics of a probability density of the velocity of a particle under the influence of drag forces and random forces</terms1:description>
        <rdfs:label xml:lang="en">Classical Fokker Planck Model</rdfs:label>
