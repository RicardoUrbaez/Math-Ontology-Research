    <!-- https://mardi4nfdi.de/mathmoddb#LaplaceEquationForTheElectricPotential -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LaplaceEquationForTheElectricPotential">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricPotential"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PermittivityDielectric"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#PoissonEquationForTheElectricPotential"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$-\nabla\left(\epsilon_s\nabla\phi\right)=0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\epsilon_s$, Permittivity (Dielectric)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi$, Electric Potential</inDefiningFormulation>
        <terms1:description xml:lang="en">in electrostatics, the Laplace equation characterizes the electrostatic potential in the absence of charges</terms1:description>
        <rdfs:label xml:lang="en">Laplace Equation for the Electric Potential</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6534320"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q339444"/>
    </owl:NamedIndividual>
    


