    <!-- https://mardi4nfdi.de/mathmoddb#TorqueOfParticle -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#TorqueOfParticle">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#LinearDiscreteElementMethod"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ParticlePosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ParticleRadius"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TangentialInteractionForceOfTwoParticles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Torque"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#Torque"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">\begin{align}
\boldsymbol T_i &amp;= (\boldsymbol x_{a_{ij}} - \boldsymbol x_i)\times \boldsymbol F^T_{ij}\\
\boldsymbol x_{a_{ij}} &amp;= \boldsymbol x_i + \frac{r_i}{r_i + r_j}(\boldsymbol x_i - \boldsymbol x_j)
\end{align}</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$T$, Torque</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\boldsymbol x_i\in\mathbbf R^3$, Particle Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathbf F^T_{ij}$, Tangential Interaction Force of Two Particles</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r_i$, Particle Radius</inDefiningFormulation>
        <terms1:description xml:lang="en">equation expressing the torque on a particle</terms1:description>
        <rdfs:comment xml:lang="en">Angular velocity needs to be taken into account when transforming the contact point between two particles from local to global coordinates.</rdfs:comment>
        <rdfs:label xml:lang="en">Torque of Particle</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674592"/>
    </owl:NamedIndividual>
    


