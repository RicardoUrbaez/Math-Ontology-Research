    <!-- https://mardi4nfdi.de/mathmoddb#ExpectationValueQuantumDensity -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ExpectationValueQuantumDensity">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ExpectationValueQuantumDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumDensityOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumMechanicalOperator"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#ExpectationValueQuantumState"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\langle \hat{O} \rangle \equiv \mathrm{tr}(\hat{O}\hat{\rho})$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{O}$, Quantum Mechanical Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\langle \hat{O} \rangle$, Expectation Value (Quantum Density)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho$, Quantum Density Operator</inDefiningFormulation>
        <terms1:description xml:lang="en">expected (mean) value of a quantum-mechanical observable, calculated from a density</terms1:description>
        <rdfs:label xml:lang="en">Expectation Value (Quantum Density)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Expectation_value_(quantum_mechanics)"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673965"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q2918589"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ExpectationValueQuantumState -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ExpectationValueQuantumState">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ExpectationValueQuantumState"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumMechanicalOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumStateVector"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\langle \hat{O} \rangle \equiv \langle \psi |\hat{O}| \psi \rangle$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{O}$, Quantum Mechanical Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\langle \hat{O} \rangle$, Expectation Value (Quantum State)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi$, Quantum State Vector</inDefiningFormulation>
        <terms1:description xml:lang="en">expected (mean) value of a quantum-mechanical observable, calculated from a state vector</terms1:description>
        <rdfs:label xml:lang="en">Expectation Value (Quantum State)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Expectation_value_(quantum_mechanics)"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673967"/>
    </owl:NamedIndividual>
    


