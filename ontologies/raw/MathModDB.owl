    <!-- https://mardi4nfdi.de/mathmoddb#HanesWoolfEquationUniUniReactionwithoutProductandCompetitiveCompleteInhibitionSteadyStateAssumption -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#HanesWoolfEquationUniUniReactionwithoutProductandCompetitiveCompleteInhibitionSteadyStateAssumption">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CompetitiveInhibitionConstantUniUniReactionReversibleInhibition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitorConcentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InitialReactionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LimitingReactionRateUniUniReactionForward"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisConstantSubstrateUniUniReactionSteadyStateAssumption"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SubstrateConcentration"/>
        <linearizes rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationUniUniReactionwithoutProductandCompetitiveCompleteInhibitionSteadyStateAssumption"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{c_S}{v_0} = \frac{c_S}{V_{max,f}} + \frac{K_S (1 + \frac{c_I}{K_{ic}})}{V_{max,f}}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_S$,Michaelis Constant Substrate (Uni Uni Reaction - Steady State Assumption)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{ic}$,Competitive Inhibition Constant (Uni Uni Reaction Reversible Inhibition)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V_{max,f}$,Limiting Reaction Rate (Uni Uni Reaction - Forward)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_I$,Inhibitor Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_S$,Substrate Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0$,Initial Reaction Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isLinear>
        <terms1:description xml:lang="en">equation for uni uni reaction without product and competitive complete inhibition following steady state assumption</terms1:description>
        <rdfs:label xml:lang="en">Hanes Woolf Equation (Uni Uni Reaction without Product and Competitive Complete Inhibition - Steady State Assumption)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674380"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#HanesWoolfEquationUniUniReactionwithoutProductandMixedCompleteInhibitionSteadyStateAssumption -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#HanesWoolfEquationUniUniReactionwithoutProductandMixedCompleteInhibitionSteadyStateAssumption">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CompetitiveInhibitionConstantUniUniReactionReversibleInhibition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitorConcentration"/>
