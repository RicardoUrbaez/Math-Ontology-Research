    <!-- https://mardi4nfdi.de/mathmoddb#FiniteVolumeMethod -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#FiniteVolumeMethod">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#ContinuityEquationForElectronsFiniteVolume"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#ContinuityEquationForHolesFiniteVolume"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#DarcyEquationFiniteVolume"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#PoissonEquationForTheElectricPotentialFiniteVolume"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#StokesEquationFiniteVolume"/>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isSpaceContinuous>
        <terms1:description xml:lang="en">method for representing and evaluating partial differential equations in the form of algebraic equations</terms1:description>
        <rdfs:comment xml:lang="en">Finite volume methods can be compared and contrasted with the finite difference methods, which approximate derivatives using nodal values, or finite element methods, which create local approximations of a solution using local data, and construct a global approximation by stitching them together.</rdfs:comment>
        <rdfs:comment xml:lang="en">In the finite volume method, volume integrals in a partial differential equation that contain a divergence term are converted to surface integrals, using the divergence theorem. These terms are then evaluated as fluxes at the surfaces of each finite volume.</rdfs:comment>
        <rdfs:label xml:lang="en">Finite Volume Method</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Finite_volume_method"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674355"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q1401936"/>
    </owl:NamedIndividual>
    


