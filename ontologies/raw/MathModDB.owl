    <!-- https://mardi4nfdi.de/mathmoddb#RateOfChangeOfPopulationDensityFractionOfRemovedMeanODE -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#RateOfChangeOfPopulationDensityFractionOfRemovedMeanODE">
