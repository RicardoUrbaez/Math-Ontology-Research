    <!-- https://mardi4nfdi.de/mathmoddb#OverallDistributionOfIndividualsFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#OverallDistributionOfIndividualsFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PartialMeanFieldOpinionModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LimitingDistributionOfIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#OverallDistributionOfIndividuals"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho = \Sigma_{m,l} \rho_{m,l}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho$, Overall Distribution of Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$rho_{m,l}$, Limiting Distribution of Individuals</inDefiningFormulation>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <terms1:description xml:lang="en">equation for the overall distribution of individuals</terms1:description>
        <rdfs:label xml:lang="en">Overall Distribution of Individuals Formulation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674542"/>
    </owl:NamedIndividual>
    


