    <!-- https://mardi4nfdi.de/mathmoddb#LinkRecommendationFunction -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LinkRecommendationFunction">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <terms1:description xml:lang="en">function representing link recommendation</terms1:description>
        <rdfs:comment xml:lang="en">Link recommendation algorithms are often used to suggest new connections to users that have the greatest potential to be established. In modelling Opinion Dynamics, link recommendation can be incorporated via this function by assuming that individuals have a higher chance of switching to an influencer with a structurally similar followership. Strictly increasing on [0,1].</rdfs:comment>
        <rdfs:label xml:lang="en">Link Recommendation Function</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674047"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LiouvilleVonNeumannEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LiouvilleVonNeumannEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ImaginaryUnit"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PlanckConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumDensityOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#SchroedingerEquationTimeDependent"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{\partial\hat\rho}{\partial t} = -\frac{\mathrm{i}}{\hbar}\left[\hat H, \hat\rho\right]$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{H}$, Quantum Hamiltonian Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{\rho}$, Quantum Density Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hbar$, Planck Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathrm{i}$, Imaginary Unit</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">describes how a density operator (for pure or for mixed states) evolves in time</terms1:description>
        <rdfs:comment xml:lang="en">Just as the Schrödinger equation describes how pure states evolve in time, the Liouville-von Neumann equation describes how a density operator evolves in time. Note that there can be different density operators for pure or for mixed states.</rdfs:comment>
        <rdfs:comment xml:lang="en">Note the similarity with the classical Liouville equation where the commutator brackets [.,.] are replaced by Poisson brackets {.,.}</rdfs:comment>
        <rdfs:label xml:lang="en">Liouville-von Neumann Equation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Density_matrix#Von_Neumann_equation_for_time_evolution"/>
        <skos:altLabel xml:lang="en">Quantum Liouville Equation</skos:altLabel>
        <skos:altLabel xml:lang="en">von Neumann equation</skos:altLabel>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6534349"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q2533076"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LogicalRuleExtractionFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LogicalRuleExtractionFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BooleanRing"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GroebnerBasis"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Ideal"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$G = G(\langle\mathcal{B}\rangle)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$G$, Gröbner Basis</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\langle\mathcal{B}\rangle$, Ideal</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{B}$, Boolean Ring</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isLinear>
        <terms1:description xml:lang="en">equation that extracts logical rules by determining the Gröbner basis of an ideal</terms1:description>
        <rdfs:label xml:lang="en">Logical Rule Extraction Formulation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674352"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LorentzForceEquationNonRelativistic -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LorentzForceEquationNonRelativistic">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <assumes rdf:resource="https://mardi4nfdi.de/mathmoddb#NonrelativisticApproximation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalVelocity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricCharge"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricField"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MagneticField"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\boldsymbol{F} = q (\boldsymbol{E} + \boldsymbol{v} \times \boldsymbol{B})$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B$, Magnetic Field</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$E$, Electric Field</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F$, Classical Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q$, Electric Charge</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v$, Classical Velocity</inDefiningFormulation>
        <terms1:description xml:lang="en">force exerted on a moving electric (point) charge in electromagnetic field (non-relativistic approach)</terms1:description>
        <rdfs:label xml:lang="en">Lorentz Force Equation (Non-Relativistic)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674479"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LorentzForceEquationRelativistic -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LorentzForceEquationRelativistic">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalVelocity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricCharge"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricField"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MagneticField"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Mass"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SpeedOfLight"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#LorentzForceEquationNonRelativistic"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{\mathrm{d} }{\mathrm{d}t} {m\mathbf{v} \over \sqrt{1-\left(\frac{\mathbf{v} }{c}\right)^2} } = q\left ( \mathbf{E} + \mathbf{v} \times \mathbf{B} \right ) $</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B$, Magnetic Field</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$E$, Electric Field</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Speed of Light</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$m$, Mass</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q$, Electric Charge</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v$, Classical Velocity</inDefiningFormulation>
        <terms1:description xml:lang="en">force exerted on a moving electric (point) charge in electromagnetic field (relativistic approach)</terms1:description>
        <rdfs:label xml:lang="en">Lorentz Force Equation (Relativistic)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Lorentz_force"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674481"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q172137"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LorentzForceModelNonRelativistic -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LorentzForceModelNonRelativistic">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <assumes rdf:resource="https://mardi4nfdi.de/mathmoddb#NonrelativisticApproximation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LorentzForceEquationNonRelativistic"/>
