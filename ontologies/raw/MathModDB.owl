    <!-- https://mardi4nfdi.de/mathmoddb#NonLocalMeans -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NonLocalMeans">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AreaOfImage"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FilteredValueOfImage"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalizationImageProcessing"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnfilteredValueOfImage"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#WeightingFunction"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$u(p) = {1 \over C(p)}\int_\Omega v(q) f(p,q)dq$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C(p)$, Normalization Image Processing</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Omega$, Area of Image</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$f(p,q)$, Weighting Function</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$u(p)$, Filtered Value of Image</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v(q)$, Unfiltered Value of Image</inDefiningFormulation>
        <terms1:description xml:lang="en">algorithm in image processing for image denoising</terms1:description>
        <rdfs:label xml:lang="en">Non-Local Means</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Non-local_means"/>
        <doiID rdf:resource="https://doi.org/10.1109/CVPR.2005.38"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674307"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q7048948"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#NoncompetitiveEnzymeInhibitionCouplingConditionUniUniReaction -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NoncompetitiveEnzymeInhibitionCouplingConditionUniUniReaction">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CompetitiveInhibitionConstantUniUniReactionReversibleInhibition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UncompetitiveInhibitionConstantUniUniReactionReversibleInhibition"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}  
k_{1} &amp;= k_{5} \\ 
k_{-1} &amp;= k_{-5} \\
k_{-3} &amp;= k_{-4}\\ 
k_{3} &amp;= k_{4} \\ 
K_{ic} &amp;= K_{iu}\\ 
\end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{ic}$,Competitive Inhibition Constant (Uni Uni Reaction Reversible Inhibition)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iu}$,Uncompetitive Inhibition Constant (Uni Uni Reaction Reversible Inhibition)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_1$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_3$,Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_4$,Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_5$,Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-1}$,Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-3}$,Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-4}$,Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-5}$,Reaction Rate Constant</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isLinear>
        <terms1:description xml:lang="en">coupling condition for a non-competitive enzyme inhibition in an uni uni reaction</terms1:description>
        <rdfs:label xml:lang="en">Non-Competitive Enzyme Inhibition Coupling Condition (Uni Uni Reaction)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674519"/>
    </owl:NamedIndividual>
    


