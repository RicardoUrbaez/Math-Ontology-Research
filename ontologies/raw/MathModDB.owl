        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#BiBiReactionTheorellChanceMechanismMichaelisMentenModelwithProduct2SS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstantProduct2BiBiReactionTheorellChanceSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstantSubstrate1BiBiReactionTheorellChanceSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LimitingReactionRateBackwardBiBiReactionTheorellChance"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LimitingReactionRateForwardBiBiReactionTheorellChance"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisMentenConstantProduct1BiBiReactionTheorellChanceSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisMentenConstantProduct2BiBiReactionTheorellChanceSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisMentenConstantSubstrate1BiBiReactionTheorellChanceSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisMentenConstantSubstrate2BiBiReactionTheorellChanceSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRate"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_{0} = \frac{V_1 c_{S_1} c_{S_2}}{K_{iS_1} K_{S_2} + K_{S_2} c_{S_1} + K_{S_1} c_{S_2} + c_{S_1} c_{S_2} + \frac{K_{iS_1} K_{S_2}}{K_{iP_2}} c_{P_2} + \frac{K_{S_1}}{K_{iP_2}} c_{S_2} c_{P_2}}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{S_1}$, Michaelis Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{S_2}$, Michaelis Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iP_2}$, Inhibition Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iS_1}$, Inhibition Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V_{1}$, Reaction Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{P_2}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S_1}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S_2}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0$, Reaction Rate</inDefiningFormulation>
