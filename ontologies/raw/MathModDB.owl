    <!-- https://mardi4nfdi.de/mathmoddb#AttractionDominatesRepulsionAssumption -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#AttractionDominatesRepulsionAssumption">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <assumedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#StochasticParticleBasedModelForClusteringDynamics"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LengthScaleOfAttractiveForces"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LengthScaleOfRepulsiveForces"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StrengthOfAttractiveForces"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StrengthOfRepulsiveForces"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">\begin{align*}
\frac{l_r}{l_a} &lt; 1 \\
\frac{C_r}{C_a} &lt; 1
\end{align*}</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C_a$, Strength Of Attractive Forces</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C_r$, Strength Of Repulsive Forces</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$l_a$, Length Scale Of Attractive Forces</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$l_r$, Length Scale Of Repulsive Forces</inDefiningFormulation>
        <terms1:description xml:lang="en">attractive forces always dominate repulsive forces</terms1:description>
        <rdfs:comment xml:lang="en">At close distances the attractive force diminishes due to the presence of the
repulsive force.</rdfs:comment>
        <rdfs:label xml:lang="en">Attraction Dominates Repulsion Assumption</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#AttractionForceAtOpinion -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#AttractionForceAtOpinion">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">attraction force at an individuals opinion by influencers and media</terms1:description>
        <rdfs:label xml:lang="en">Attraction Force at Opinion</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673755"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#AttractionForceAtOpinionFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#AttractionForceAtOpinionFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PartialMeanFieldOpinionModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AttractionForceAtOpinion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Opinion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#OverallDistributionOfIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PairFunction"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ParameterToScaleAttractiveForceFromInfluencers"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ParameterToScaleAttractiveForceFromMedia"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ParameterToScaleAttractiveForceFromOtherIndividuals"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{F}(x, y_m, z_l, \rho) = a \frac{\int_D \rho(x&apos;, t) \varphi(\|x&apos; - x\|)(x&apos; - x) \, dx&apos;}{\int_D \rho(x&apos;, t) \varphi(\|x&apos; - x\|) \, dx&apos;} + b (y_m(t) - x) + c (z_l(t) - x)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{F}$, Attraction Force At Opinion</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi$, Pair Function</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho$, Overall Distribution of Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$a$, Parameter to Scale Attractive Force from Other Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$b$, Parameter to Scale Attractive Force from Media</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Parameter to Scale Attractive Force from Influencers</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Opinion</inDefiningFormulation>
        <terms1:description xml:lang="en">attraction force at a specific opinion x</terms1:description>
        <rdfs:label xml:lang="en">Attraction Force at Opinion Formulation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674135"/>
    </owl:NamedIndividual>
    


