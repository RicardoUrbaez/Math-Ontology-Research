    <!-- https://mardi4nfdi.de/mathmoddb#MassActionLaw -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MassActionLaw">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Molecularity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRate"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v = k \prod_{i=1}^{n} c_{i}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_i$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Molecularity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v$, Reaction Rate</inDefiningFormulation>
        <terms1:description xml:lang="en">rate of chemical reaction is directly proportional to the product of the activities or concentrations of the reactants</terms1:description>
        <rdfs:label xml:lang="en">Mass Action Law</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674155"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q899494"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MassBalanceLaw -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MassBalanceLaw">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ConservationLaw"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\delta_t + \nabla F = 0$</definingFormulation>
        <terms1:description xml:lang="en">mass that enters a system must, by conservation of mass, either leave the system or accumulate within the system</terms1:description>
        <rdfs:label xml:lang="en">Mass Balance Law</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674156"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q3276889"/>
    </owl:NamedIndividual>
    


