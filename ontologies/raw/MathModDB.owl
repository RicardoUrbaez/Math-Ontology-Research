    <!-- https://mardi4nfdi.de/mathmoddb#LossFunctionMinimization -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LossFunctionMinimization">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactNetwork"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LossFunctionRomanization"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeDependentContactNetwork"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\min _{\sigma =(G, \alpha )} \ell (\sigma )$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$G$, Contact Network</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\ell$, Loss Function Romanization</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Contact Network (Time-dependent)</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <terms1:description xml:lang="en">minimization of loss function over regions and data points</terms1:description>
        <rdfs:label xml:lang="en">Loss Function Minimization</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674482"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LossFunctionModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LossFunctionModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <terms1:description xml:lang="en">in mathematical optimization, a function (to be minimized) representing the cost of each outcome</terms1:description>
        <rdfs:label xml:lang="en">Loss Function Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675430"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q1036748"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LossFunctionRomanization -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LossFunctionRomanization">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ApproximateSpreadingCurve"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LossFunctionRomanization"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfRegions"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfTimepoints"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RomanizedCitiesVector"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeDependentContactNetwork"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimePoint"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#WeightFactor"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\ell (\sigma ) \equiv \sum _{i=1}^{N_T} \sum _{m=1}^{N_R} \frac{(\omega _{m,t_i} - \phi (t_i| \sigma , \omega _{\bullet , 0}))^2 }{C_{m,t_i}^2}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C$, Weight Factor</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N_R$, Number of Regions</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N_T$, Number of Time Points</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\ell$, Loss Function Romanization</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\omega$, Romanized Cities Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi$, Spreading Curve (Approximate)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Contact Network (Time-dependent)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t_i$, Time Point</inDefiningFormulation>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <terms1:description xml:lang="en">loss function summing over regions and data points</terms1:description>
        <rdfs:label xml:lang="en">Loss Function (Romanization)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674049"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LumpedActivationParameter -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LumpedActivationParameter">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FibreContractionVelocity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FibreStretch"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StateVector"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma \equiv H \left( \mathbf{y}, \lambda_\text{f}, \dot{\lambda}_{\text{f}}\right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\dot{\lambda}_{\text{f}}$, Fibre Contraction Velocity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\lambda_{\text{f}}$, Fibre stretch</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathbf{y}$, State Vector</inDefiningFormulation>
        <terms1:description xml:lang="en">lumped activation parameter</terms1:description>
        <rdfs:label xml:lang="en">Lumped Activation Parameter</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673952"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LyapunovEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LyapunovEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnknownMatrix"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#LyapunovEquationControllability"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#LyapunovEquationObservability"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$AX+XA^H+Q=0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$X$, Unknown Matrix</inDefiningFormulation>
        <terms1:description xml:lang="en">matrix equation used in the stability analysis of linear dynamical systems</terms1:description>
        <rdfs:comment xml:lang="en">Numerical solution of a Lyapunov equation $AX+XA^T+B=0$ via Zhou and Sorensen 2-solve method, implemented as part of the Matrix Equation Sparse Solver (M.E.S.S.) project. Copyright  2009-2022 Jens Saak, Martin Koehler, Peter Benner and others.</rdfs:comment>
        <rdfs:label xml:lang="en">Lyapunov Equation</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.mpi-magdeburg.mpg.de/projects/mess"/>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Lyapunov_equation"/>
        <doiID rdf:resource="https://doi.org/10.1155/S1110757X03212055"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674141"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q1028945"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LyapunovEquationControllability -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LyapunovEquationControllability">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixA"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixB"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GramianMatrixControllability"/>
        <similarTo rdf:resource="https://mardi4nfdi.de/mathmoddb#LyapunovEquationObservability"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$AW_c + W_cA^{*} + BB^{*} = 0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Control System Matrix A</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B$, Control System Matrix B</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$W_c$, Gramian Matrix Controllability</inDefiningFormulation>
        <terms1:description xml:lang="en">Lyapunov equation used in the stability analysis of linear dynamical systems to determine the controllability</terms1:description>
        <rdfs:comment xml:lang="en">For the solvability of ordinary Lyapunov equations, the stability condition for A  is the only requirement.</rdfs:comment>
        <rdfs:label xml:lang="en">Lyapunov Equation Controllability</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674151"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LyapunovEquationObservability -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LyapunovEquationObservability">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixA"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixC"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GramianMatrixObservability"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A^{*}W_o + W_oA  + C^*C = 0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Control System Matrix A</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C$, Control System Matrix C</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$W_o$, Gramian Matrix Observability</inDefiningFormulation>
        <terms1:description xml:lang="en">Lyapunov equation used in the stability analysis of linear dynamical systems to determine the observability</terms1:description>
        <rdfs:comment xml:lang="en">For the solvability of ordinary Lyapunov equations, the stability condition for A  is the only requirement.</rdfs:comment>
        <rdfs:label xml:lang="en">Lyapunov Equation Observability</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674152"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LyapunovGeneralizedControllability -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LyapunovGeneralizedControllability">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixA"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixB"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixN"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GramianGeneralizedControllability"/>
        <similarTo rdf:resource="https://mardi4nfdi.de/mathmoddb#LyapunovGeneralizedObservability"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#LyapunovEquationControllability"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#LyapunovEquation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$AW_c + W_cA^{*} + \sum_kN_kW_{c}N_k^{*} + BB^{*} = 0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Control System Matrix A</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B$, Control System Matrix B</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Control System Matrix N</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$W_c$, Gramian Generalized Controllability</inDefiningFormulation>
        <terms1:description xml:lang="en">generalized Lyapunov equation used in the stability analysis of linear dynamical systems to determine the controllability</terms1:description>
        <rdfs:comment xml:lang="en">For a numerical solution, one can resort to iterative schemes, which requires the solution of a standard Lyapunov equation in each step. As an alternative, one may use the biconjugate gradient method (with preconditioner) as suggested by Tobias Breiten from TU Graz, Austria, now TU Berlin.</rdfs:comment>
        <rdfs:comment xml:lang="en">For the solvability of generalized Lyapunov equations, there are two requirements: (1) stability condition for A and (2) suitable upper bound for the norm of N.</rdfs:comment>
        <rdfs:label xml:lang="en">Lyapunov Generalized Controllability</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674145"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LyapunovGeneralizedObservability -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LyapunovGeneralizedObservability">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixA"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixC"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixN"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GramianGeneralizedObservability"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#LyapunovEquationObservability"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#LyapunovEquation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A^{*}W_o + W_oA  + \sum_k N_k^{*}W_{o}N_k + C^*C = 0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Control System Matrix A</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C$, Control System Matrix C</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Control System Matrix N</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$W_c$, Gramian Generalized Observability</inDefiningFormulation>
        <terms1:description xml:lang="en">generalized Lyapunov equation used in the stability analysis of linear dynamical systems to determine the observability</terms1:description>
        <rdfs:comment xml:lang="en">For a numerical solution, one can resort to iterative schemes, which requires the solution of a standard Lyapunov equation in each step. As an alternative, one may use the biconjugate gradient method (with preconditioner) as suggested by Tobias Breiten from TU Graz, Austria, now TU Berlin.</rdfs:comment>
        <rdfs:comment xml:lang="en">For the solvability of generalized Lyapunov equations, there are two requirements: (1) stability condition for A and (2) suitable upper bound for the norm of N.</rdfs:comment>
        <rdfs:label xml:lang="en">Lyapunov Generalized Observability</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674146"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MOR_TransformationMatrix -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MOR_TransformationMatrix">
