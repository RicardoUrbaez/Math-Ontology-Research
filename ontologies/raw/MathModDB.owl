    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#DirichletBoundaryConditionForElectricPotential -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#DirichletBoundaryConditionForElectricPotential">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricPotential"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#DirichletBoundaryCondition"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi(r,t)|_{\Gamma_k}=\psi_{0}+U_k(t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$U_k$, Applied External Voltage</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Gamma_k$, Electrode Interfaces</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi$, Electric Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">Dirichlet boundary condition for the electric potential at an interface</terms1:description>
        <rdfs:label xml:lang="en">Dirichlet Boundary Condition for Electric Potential</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6534329"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#DirichletBoundaryConditionForElectronFermiPotential -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#DirichletBoundaryConditionForElectronFermiPotential">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AppliedExternalVoltage"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectrodeInterfaces"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FermiPotentialForElectrons"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#DirichletBoundaryCondition"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi_n |_{\Gamma_k} = U_k$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$U_k$, Applied External Voltage</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Gamma_k$, Electrode Interfaces</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi_n$, Fermi Potential for Electrons</inDefiningFormulation>
        <terms1:description xml:lang="en">Fermi potential is given by applied external voltages at the Ohmic contacts, e.g. semiconductor-metal interfaces</terms1:description>
        <rdfs:label xml:lang="en">Dirichlet Boundary Condition for Electron Fermi Potential</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674312"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#DirichletBoundaryConditionForHoleFermiPotential -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#DirichletBoundaryConditionForHoleFermiPotential">
