    <!-- https://mardi4nfdi.de/mathmoddb#ObjectRatingMatrixDecompositionSchur -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ObjectRatingMatrixDecompositionSchur">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ObjectRatingMatrix"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#OrthogonalMatrix"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UpperTriangularMatrix"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathbf{R} = \mathbf{U}\mathbf{V}\mathbf{U^T}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathbf{R}$, Object Rating Matrix</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathbf{U}$, Orthogonal Matrix</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathbf{V}$, Upper-Triangular Matrix</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <terms1:description xml:lang="en">Schur decomposition of the object rating matrix</terms1:description>
        <rdfs:label xml:lang="en">Object Rating Matrix Decomposition (Schur)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674535"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q1064218"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#OhmEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#OhmEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricConductivity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricCurrentDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricField"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$J=\sigma E$</definingFormulation>
