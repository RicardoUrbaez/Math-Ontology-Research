    <!-- https://mardi4nfdi.de/mathmoddb#HankelSingularValue -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#HankelSingularValue">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">In control theory, a measure of energy for each state in a system</terms1:description>
        <rdfs:comment xml:lang="en">In control theory, Hankel singular values, named after Hermann Hankel, are the basis for balanced model reduction, in which controllable and observable states are retained while the remaining states are discarded. The reduced model retains the important features of the original model.</rdfs:comment>
        <rdfs:label xml:lang="en">Hankel Singular Value</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Hankel_singular_value"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673782"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q5648530"/>
    </owl:NamedIndividual>
    


