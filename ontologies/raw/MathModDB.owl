    <!-- https://mardi4nfdi.de/mathmoddb#MichaelisMentenConstantSubstrate1BiBiReactionPingPongSS -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MichaelisMentenConstantSubstrate1BiBiReactionPingPongSS">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
