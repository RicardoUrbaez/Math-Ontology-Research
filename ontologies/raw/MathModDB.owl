    <!-- https://mardi4nfdi.de/mathmoddb#OptimalControl -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#OptimalControl">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ComputationalTask"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#OptimalControlBackward"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#OptimalControlForward"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#OptimalControlUpdate"/>
        <containsFinalCondition rdf:resource="https://mardi4nfdi.de/mathmoddb#OptimalControlFinal"/>
        <containsInitialCondition rdf:resource="https://mardi4nfdi.de/mathmoddb#OptimalControlInitial"/>
        <containsObjective rdf:resource="https://mardi4nfdi.de/mathmoddb#OptimalControlCost"/>
        <containsObjective rdf:resource="https://mardi4nfdi.de/mathmoddb#OptimalControlTarget"/>
        <containsOutput rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemInput"/>
        <uses rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemModelBilinear"/>
        <uses rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectronShuttlingModel"/>
        <uses rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumModelClosedSystem"/>
        <uses rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumModelOpenSystem"/>
        <terms1:description xml:lang="en">branch of control theory that deals with finding a control for a dynamical system over a period of time such that an objective function is optimized</terms1:description>
        <rdfs:comment xml:lang="en">Finding controls, e.g. external forces|fields, such that they drive a given control system from a given initial state to a specific final state (target), typically with constraints such as using not too high fields (cost).</rdfs:comment>
        <rdfs:label xml:lang="en">Optimal Control</rdfs:label>
        <arxivID rdf:resource="https://arxiv.org/abs/0707.1883"/>
        <doiID rdf:resource="https://doi.org/10.1016/j.cpc.2018.02.022"/>
        <doiID rdf:resource="https://doi.org/10.1088/0953-4075/40/18/R01"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6534338"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q1971426"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#OptimalControlBackward -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#OptimalControlBackward">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemInput"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemLagrangeMultiplier"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixA"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixB"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixN"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\dot{z}(t)=-(A^{\dagger}+ \sum_ku_k(t)N^{\dagger}_k)z(t)-B^{\dagger}u(t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Control System Matrix A</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B$, Control System Matrix B</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Control System Matrix N</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$u$, Control System Input</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$z$, Control System Lagrange Multiplier</inDefiningFormulation>
        <terms1:description xml:lang="en">Lagrange multipliers of control systems are propagated backward via the adjoint of the input equation</terms1:description>
        <rdfs:label xml:lang="en">Optimal Control Backward</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674536"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#OptimalControlConstraint -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#OptimalControlConstraint">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsConstraintConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#OptimalControl"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemDuration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemInput"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemLagrangeMultiplier"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixA"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixN"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemState"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$J[u,x,z]=2\Re\int_0^Tdtz^{\dagger}(t)\left(\partial_t-A-\sum_ku_k(t)N_k\right)x(t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Control System Matrix A</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Control System Matrix N</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$T$, Control System Duration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$u$, Control System Input</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Control System State</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$z$, Control System Lagrange Multiplier</inDefiningFormulation>
        <terms1:description xml:lang="en">Constraint functional in optimal control systems requiring that the system&apos;s state vector follows the respective equation of motion</terms1:description>
        <rdfs:label xml:lang="en">Optimal Control Constraint</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674541"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#OptimalControlCost -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#OptimalControlCost">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemDuration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemInput"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#OptimalControlCost"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#OptimalControlPenaltyFactor"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$J[u] \equiv \sum_k\alpha_k\int_0^Tdtu_k^2(t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$J$, Optimal Control Cost</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$T$, Control System Duration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha$, Optimal Control Penalty Factor</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$u$, Control System Input</inDefiningFormulation>
        <terms1:description xml:lang="en">cost functional in optimal control</terms1:description>
        <rdfs:comment xml:lang="en">Minimizes the cost of the control of a system, e.g. minimize the fluence of a laser field.</rdfs:comment>
        <rdfs:label xml:lang="en">Optimal Control Cost</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674096"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#OptimalControlFinal -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#OptimalControlFinal">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemDuration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemLagrangeMultiplier"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixD"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemState"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$z(t=T)=Dx(t=T)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$D$, Control System Matrix D</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$T$, Control System Duration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Control System State</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$z$, Control System Lagrange Multiplier</inDefiningFormulation>
        <terms1:description xml:lang="en">final condition for the (backward) propagation of the Lagrange multiplier of a control system</terms1:description>
        <rdfs:label xml:lang="en">Optimal Control Final</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674539"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#OptimalControlForward -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#OptimalControlForward">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemInput"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixA"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixB"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixN"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemState"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\dot{x}(t)=(A+ \sum_ku_k(t)N_k)x(t)+Bu(t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Control System Matrix A</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B$, Control System Matrix B</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Control System Matrix N</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$u$, Control System Input</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Control System State</inDefiningFormulation>
        <terms1:description xml:lang="en">state vectors of control systems are propagated forward via the input equation</terms1:description>
        <rdfs:label xml:lang="en">Optimal Control Forward</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674537"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#OptimalControlInitial -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#OptimalControlInitial">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemState"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InitialControlState"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x(t=0)=x_0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Control System State</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x_0$, Initial Control State</inDefiningFormulation>
        <terms1:description xml:lang="en">initial condition for the (forward) propagation of the state vector of a control system</terms1:description>
        <rdfs:label xml:lang="en">Optimal Control Initial</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674540"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#OptimalControlPenaltyFactor -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#OptimalControlPenaltyFactor">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">used to balance between the two objectives: maximizing the target function[al] versus minimizing the cost function[al]</terms1:description>
        <rdfs:comment xml:lang="en">In optrimal control theory, a penalty factor can be used to balance between the two objectives: maximizing the target function[al] versus minimizing the cost function[al].</rdfs:comment>
        <rdfs:label xml:lang="en">Optimal Control Penalty Factor</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674098"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#OptimalControlTarget -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#OptimalControlTarget">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemDuration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemInput"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixD"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemState"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#OptimalControlTarget"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$J[u,x] \equiv x^{\dagger}(T)Dx(T)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$D$, Control System Matrix D</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$J$, Optimal Control Target</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$T$, Control System Duration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$u$, Control System Input</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Control System State</inDefiningFormulation>
        <terms1:description xml:lang="en">target functional in optimal control</terms1:description>
        <rdfs:comment xml:lang="en">Maximize the quadratic output of a given control system.</rdfs:comment>
        <rdfs:label xml:lang="en">Optimal Control Target</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674097"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#OptimalControlUpdate -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#OptimalControlUpdate">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemInput"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemLagrangeMultiplier"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixN"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemState"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#OptimalControlPenaltyFactor"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$u_k(t)=-\frac{1}{\alpha_k}\Im\left(z^{\dagger}(t)N_kx(t) \right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Control System Matrix N</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha$, Optimal Control Penalty Factor</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$u$, Control System Input</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Control System State</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$z$, Control System Lagrange Multiplier</inDefiningFormulation>
        <terms1:description xml:lang="en">updated control is calculated from state vector and Lagrange multiplier of a control system</terms1:description>
        <rdfs:label xml:lang="en">Optimal Control Update</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674538"/>
    </owl:NamedIndividual>
    


