    <!-- https://mardi4nfdi.de/mathmoddb#BiBiReactionTheorellChanceMechansimODESystem -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#BiBiReactionTheorellChanceMechansimODESystem">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Enzyme-Product2ComplexConcentrationODEBiBiTheorellChance"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Enzyme-Substrate1ComplexConcentrationODEBiBiTheorellChance"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EnzymeConcentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EnzymeConcentrationODEBiBiTheorellChance"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EnzymeProduct2ComplexConcentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EnzymeSubstrate1ComplexConcentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Product1Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Product1ConcentrationODEBiBiTheorellChance"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Product2Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Product2ConcentrationODEBiBiTheorellChance"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRateOfEnzyme"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRateOfEnzymeProduct2Complex"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRateOfEnzymeSubstrate1Complex"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRateOfProduct1"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRateOfProduct2"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRateOfSubstrate1"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRateOfSubstrate2"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Substrate1Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Substrate1ConcentrationODEBiBiTheorellChance"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Substrate2Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Substrate2ConcentrationODEBiBiTheorellChance"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}
\frac{dc_{S_1}}{dt} &amp;= k_{-1} c_{ES_1} - k_{1} c_{E} c_{S_1} \\
\frac{dc_{S_2}}{dt} &amp;= k_{-2} c_{EP_2} c_{P_1} - k_{2} c_{ES_1} c_{S_2} \\
\frac{dc_{P_1}}{dt} &amp;= k_{2} c_{ES_1} c_{S_2} - k_{-2} c_{EP_2} c_{P_1} \\
\frac{dc_{P_2}}{dt} &amp;= k_{3} c_{EP_2} - k_{-3} c_{E} c_{P_2} \\
\frac{dc_{ES_1}}{dt} &amp;= k_{1} c_{E} c_{S_1} + k_{-2} c_{EP_{2}} c_{P_1} - k_{-1} c_{ES_1} - k_2 c_{ES_1} c_{S_2} \\
\frac{dc_{EP_2}}{dt} &amp;= k_{2} c_{ES_1} c_{S_2} + k_{-3} c_{E} c_{P_2} - k_{-2} c_{EP_2} c_{P_1} - k_3 c_{EP_2} \\
\frac{dc_{E}}{dt} &amp;= k_{-1} c_{ES_1} + k_3 c_{EP_2} - k_{1} c_{E} c_{S_1} - k_{-3} c_{E} c_{P_2} 
\end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{EP_2}}{dt}$, Reaction Rate of Enzyme - Product 2 Complex</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{ES_1}}{dt}$, Reaction Rate of Enzyme - Substrate 1 Complex</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{E}}{dt}$, Reaction Rate of Enzyme</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{P_1}}{dt}$, Reaction Rate of Product 1</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{P_2}}{dt}$, Reaction Rate of Product 2</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{S_1}}{dt}$, Reaction Rate of Substrate 1</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{S_2}}{dt}$, Reaction Rate of Substrate 2</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{EP_2}$, Enzyme - Product 2 Complex Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{ES_1}$, Enzyme - Substrate 1 Complex Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{E}$, Enzyme Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{P_1}$, Product 1 Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{P_2}$, Product 2 Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S_1}$, Substrate 1 Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S_2}$, Substrate 2 Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-1}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-2}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-3}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{1}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{2}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{3}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">system of ordinary differential equations describing a bi bi reaction with a Theorell-Chance mechanism</terms1:description>
        <rdfs:label xml:lang="en">Bi Bi Reaction Theorell-Chance Mechanism ODE System</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674226"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#BinaryDecisionVariable -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#BinaryDecisionVariable">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BinaryDecisionVariable"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x_l \equiv \left\{
\begin{array}{ll}
1 &amp; l \textrm{is chosen}\\
o &amp; \textrm{otherwise} \\
\end{array}
\right. $</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x_l$, Binary Decision Variable</inDefiningFormulation>
        <terms1:description xml:lang="en">binary variable deciding if an object is chosen or not</terms1:description>
        <rdfs:comment xml:lang="en">In case of line pool generation, it decides if a line is included or not.</rdfs:comment>
        <rdfs:label xml:lang="en">Binary Decision Variable</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://de.wikipedia.org/wiki/Optimierungsproblem#Mathematische_Definition_und_Begriffe"/>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Integer_programming"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674018"/>
    </owl:NamedIndividual>
    


