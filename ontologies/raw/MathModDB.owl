        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{S_2}}{dt}$, Reaction Rate of Substrate 2</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{EP_1P_2}$, Enzyme - Product 1 - Product 2 Complex Concentration</inDefiningFormulation>
