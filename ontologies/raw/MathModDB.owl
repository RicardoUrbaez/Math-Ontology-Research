    <!-- https://mardi4nfdi.de/mathmoddb#DiffusionConstant -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#DiffusionConstant">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#FickEquation"/>
        <terms1:description xml:lang="en">proportionality constant between the molar flux  and the negative value of the gradient in the concentration of the species</terms1:description>
        <rdfs:comment xml:lang="en">Diffusion coefficient is usually written as the proportionality constant between the molar flux due to molecular diffusion and the negative value of the gradient in the concentration of the species.</rdfs:comment>
        <rdfs:label xml:lang="en">Diffusion Coefficient</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Mass_diffusivity"/>
        <skos:altLabel xml:lang="en">Diffusivity</skos:altLabel>
        <skos:altLabel xml:lang="en">Mass Diffusivity</skos:altLabel>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673864"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q604008"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#DiffusionFlux -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#DiffusionFlux">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#FickEquation"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ParticleFluxDensity"/>
        <terms1:description xml:lang="en">solute mass removal rate resulting from diffusion</terms1:description>
        <rdfs:label xml:lang="en">Diffusion Flux</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673918"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#DiffusionOperator -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#DiffusionOperator">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Operators_O_i_Minus"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Operators_O_i_Plus"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">\begin{aligned} 
\mathcal{D} f(\mathbf{n}, \mathbf{m}): \equiv &amp; \frac{D_A}{h^2} \sum_{i=1}^{K-1}\left\{\left(n_i+1\right) f\left(\mathcal{O}_i^{+} \mathcal{O}_{i+1}^{-} \mathbf{n}, \mathbf{m}\right)-n_i f(\mathbf{n}, \mathbf{m})\right\} \\ &amp; +\frac{D_A}{h^2} \sum_{i=2}^K\left\{\left(n_i+1\right) f\left(\mathcal{O}_i^{+} \mathcal{O}_{i-1}^{-} \mathbf{n}, \mathbf{m}\right)-n_i f(\mathbf{n}, \mathbf{m})\right\} \\ &amp; +\frac{D_B}{h^2} \sum_{i=1}^{K-1}\left\{\left(m_i+1\right) f\left(\mathbf{n}, \mathcal{O}_i^{+} \mathcal{O}_{i+1}^{-} \mathbf{m}\right)-m_i f(\mathbf{n}, \mathbf{m})\right\} \\ &amp; +\frac{D_B}{h^2} \sum_{i=2}^K\left\{\left(m_i+1\right) f\left(\mathbf{n}, \mathcal{O}_i^{+} \mathcal{O}_{i-1}^{-} \mathbf{m}\right)-m_i f(\mathbf{n}, \mathbf{m})\right\}\\

$\mathcal{D}: L^1\left(\mathbb{N}^K \times \mathbb{N}^K\right) \rightarrow L^1\left(\mathbb{N}^K \times \mathbb{N}^K\right)$, where
$L^1\left(\mathbb{N}^K \times \mathbb{N}^K\right):=\left\{f: \mathbb{N}^K \times \mathbb{N}^K \rightarrow \mathbb{R} \mid \sum_{\mathbf{n}, \mathbf{m}} f(\mathbf{n}, \mathbf{m})&lt;\infty\right\}$
\end{aligned}</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{O}_i^{+}$, Operators Oi Plus</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{O}_i^{-}$, Operators Oi Minus</inDefiningFormulation>
        <terms1:description xml:lang="en">diffusion operator used in the reaction diffusion master equation</terms1:description>
        <rdfs:label xml:lang="en">Diffusion Operator</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#DiffusionsModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#DiffusionsModel">
