    <!-- https://mardi4nfdi.de/mathmoddb#DecompositionOfPopulationDensityFractionsInTheODERegionIntoSpatiallyConstantAndFluctuatingPart -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#DecompositionOfPopulationDensityFractionsInTheODERegionIntoSpatiallyConstantAndFluctuatingPart">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#ODESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposedInTheODERegion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposedInTheODERegionFluctuatingPart"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposedInTheODERegionMean"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfInfectiousInTheODERegion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfInfectiousInTheODERegionFluctuatingPart"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfInfectiousInTheODERegionMean"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfRemovedInTheODERegion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfRemovedInTheODERegionFluctuatingPart"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfRemovedInTheODERegionMean"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfSusceptiblesInTheODERegion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfSusceptiblesInTheODERegionFluctuatingPart"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfSusceptiblesInTheODERegionMean"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{aligned}
&amp; s_2 = \bar{s_2} + \Tilde{s_2} \\
&amp; e_2 = \bar{e_2} + \Tilde{e_2} \\
&amp; i_2 = \bar{i_2} + \Tilde{i_2} \\
&amp; r_2 = \bar{r_2} + \Tilde{r_2}
\end{aligned}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Tilde{e_2}$, Fraction Of Population Density Of Exposed In The ODE Region (Fluctuating Part)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Tilde{i_2}$, Fraction Of Population Density Of Infectious In The ODE Region (Fluctuating Part)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Tilde{r_2}$, Fraction Of Population Density Of Removed In The ODE Region (Fluctuating Part)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Tilde{s_2}$, Fraction Of Population Density Of Susceptibles In The ODE Region (Fluctuating Part)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\bar{e_2}$, Fraction Of Population Density Of Exposed In The ODE Region (Mean)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\bar{i_2}$, Fraction Of Population Density Of Infectious In The ODE Region (Mean)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\bar{r_2}$, Fraction Of Population Density Of Removed In The ODE Region (Mean)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\bar{s_2}$, Fraction Of Population Density Of Susceptibles In The ODE Region (Mean)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$e_2$, Fraction Of Population Density Of Exposed In The ODE Region</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$i_2$, Fraction Of Population Density Of Infectious In The ODE Region</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r_2$, Fraction Of Population Density Of Removed In The ODE Region</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s_2$, Fraction Of Population Density Of Susceptibles In The ODE Region</inDefiningFormulation>
        <terms1:description xml:lang="en">decomposition into spatially constant mean and fluctuating part</terms1:description>
        <rdfs:comment xml:lang="en">Decomposition Of Population Density Fractions In The ODE Region Into Spatially Constant And Fluctuating Part with mean zero.</rdfs:comment>
        <rdfs:label xml:lang="en">Decomposition Of Population Density Fractions In The ODE Region Into Spatially Constant And Fluctuating Part</rdfs:label>
    </owl:NamedIndividual>
    


