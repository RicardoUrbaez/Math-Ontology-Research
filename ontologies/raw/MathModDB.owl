    <!-- https://mardi4nfdi.de/mathmoddb#ProductOfPoissonDistributions -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ProductOfPoissonDistributions">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#StandardCompartmentBasedMorphogenGradientModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AverageNumberOfMoleculesOfMorphogen"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AverageNumberOfMoleculesOfSignal"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StationaryDistribution"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi(\mathbf{n}, \mathbf{m})=\exp \left[-\sum_{i=1}^K\left(\bar{A}_i+\bar{B}_i\right)\right] \prod_{i=1}^K \frac{\bar{A}_i^{n_i} \bar{B}_i^{m_i}}{n_{i}!m_{i}!}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\overline{A}$, Average Number Of Molecules Of Signal</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\overline{B}$, Average Number Of Molecules Of Morphogen</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi(\mathbb{n}, \mathbb{m})$, Stationary Distribution</inDefiningFormulation>
        <terms1:description xml:lang="en">product of poisson distributions obtained by solving the stationary reaction-diffusion master equation</terms1:description>
        <rdfs:label xml:lang="en">Product Of Poisson Distributions</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ProductOfPoissonDistributionsFromThemgRDME -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ProductOfPoissonDistributionsFromThemgRDME">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#GeneralizedCompartmentBasedMorphogenGradientModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AverageNumberOfMoleculesOfMorphogen"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AverageNumberOfMoleculesOfSignal"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StationaryDistribution"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi(\mathbf{n}, \mathbf{m})=\exp \left[-\sum_{j=1}^{K_A} \bar{A}_j-\sum_{i=1}^{K_B} \bar{B}_i\right] \prod_{j=1}^{K_A} \frac{\bar{A}_j^{n_j}}{n_{j}!} \prod_{i=1}^{K_B} \frac{\bar{B}_i^{m_i}}{m_{i}!}$,</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\overline{A}$, Average Number Of Molecules Of Signal</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\overline{B}$, Average Number Of Molecules Of Morphogen</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi(\mathbb{n}, \mathbb{m})$, Stationary Distribution</inDefiningFormulation>
        <terms1:description xml:lang="en">Product Of Poisson Distributions obtained by solving the stationary mgRDME</terms1:description>
        <rdfs:label xml:lang="en">Product Of Poisson Distributions From the mgRDME</rdfs:label>
    </owl:NamedIndividual>
    


