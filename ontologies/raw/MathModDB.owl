    <!-- https://mardi4nfdi.de/mathmoddb#BeaversJosephSaffmanCondition -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#BeaversJosephSaffmanCondition">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BeaversJosephCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidDynamicViscosityFreeFlow"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidIntrinsicPermeabilityPorousMedium"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidVelocityFreeFlow"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidViscousStress"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnitNormalVector"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnitTangentVector"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$[(v + \sqrt{K}(\alpha_{\mathrm{BJ}}\mu)^{-1} \tau n)\cdot t_{\mathrm{ff,pm}}]^{ff} = 0 \quad \mathrm {on} \quad \Gamma$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K$, Fluid Intrinsic Permeability (Porous Medium)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha_{BJ}$, Beavers-Joseph Coefficient</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu$, Fluid Dynamic Viscosity (Free Flow)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tau$, Fluid Viscous Stress</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Normal Unit Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t_{\mathrm{ff,pm}}$, Tangent Unit Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v^{ff}$, Fluid Velocity (Free Flow)</inDefiningFormulation>
        <terms1:description xml:lang="en">boundary condition between an unconfined incompressible viscous fluid (Stokes model) and fluid inside a porous medium (Darcy model)</terms1:description>
        <rdfs:label xml:lang="en">Beavers–Joseph-Saffman Condition</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.1007/s11242-009-9344-y"/>
        <doiID rdf:resource="https://doi.org/10.1017/S0022112067001375"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674153"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#BetweenPopulationContactRate -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#BetweenPopulationContactRate">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BetweenPopulationContactRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#Rate"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$a_i \equiv  \sum_{k\neq i}\alpha_{ik} \Delta t N^k/N^i$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N^i$, Total Population Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha_{ik}$, Contact Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$a_i$, Between Population Contact Rate</inDefiningFormulation>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <terms1:description xml:lang="en">contact rate of one sub-population with all other sub-populations</terms1:description>
        <rdfs:comment xml:lang="en">Used in multi-population models.</rdfs:comment>
        <rdfs:label xml:lang="en">Between Population Contact Rate</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673792"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#BiBiReaction -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#BiBiReaction">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ResearchProblem"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#EnzymeKinetics"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#BiBiReactionFollowingPingPongMechanism"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#InitialReactionRateOfBiBiReactionFollowingPingPongMechanismWithProduct1"/>
