    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ConditionToKeepSusceptiblesPositive -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ConditionToKeepSusceptiblesPositive">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsConstraintConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#DiscreteSusceptibleInfectiousModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha \Delta t \leq 1$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$,  Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha$, Contact Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">positive solution constraint</terms1:description>
        <rdfs:comment xml:lang="en">Necessary and sufficient condition to ensure that 𝑆ₙ, is positive for all initial conditions (and I_n &lt; N). Implies that the time step At must be less than the average time required for a successful contact.</rdfs:comment>
        <rdfs:label xml:lang="en">Condition to Keep Susceptibles Positive</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674278"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ConservationLaw -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ConservationLaw">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <terms1:description xml:lang="en">scientific law regarding conservation of a physical property</terms1:description>
        <rdfs:label xml:lang="en">Conservation Law</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Conservation_law"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674279"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q205805"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ConservationOfCityNumbers -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ConservationOfCityNumbers">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfCities"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfInfectedCities"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfSusceptibleCities"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ConservationLaw"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$i_m(t) = P_m - s_m(t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$P_m$, Number of Cities</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$i_m(t)$, Number of Infected Cities</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s_m(t)$, Number of Susceptible Cities</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDynamic>
        <terms1:description xml:lang="en">conservation of city numbers in every region m</terms1:description>
        <rdfs:label xml:lang="en">Conservation of City Numbers</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674280"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ConstantPopulationSize -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ConstantPopulationSize">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsConstraintConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#DiscreteSusceptibleInfectiousModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ConservationLaw"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S_n + I_n \approx N, n = 1,2,...$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_n$, Number of Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Total Population Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S_n$, Number of Susceptible Individuals</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">total population size remains constant</terms1:description>
        <rdfs:label xml:lang="en">Constant Population Size</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674281"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ContactNetwork -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ContactNetwork">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactNetwork"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfCities"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Region"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RegionConnectivity"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$G_{m,n} \equiv \begin{cases} \frac{W_{m,n}}{P_m} + \frac{W_{n,m}}{P_n} \quad &amp;\text{for} \quad m \neq n \\ \frac{W_{m,m}}{P_m} \quad &amp;\text{for} \quad m = n \end{cases}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$G$, Contact Network</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$P$, Number of Cities</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$W$, Region Connectivity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$m$, Region</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Region</inDefiningFormulation>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <terms1:description xml:lang="en">contact network for regions</terms1:description>
        <rdfs:label xml:lang="en">Contact Network</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673883"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ContactNetworkConstraint -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ContactNetworkConstraint">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactNetwork"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Region"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\forall \, m\ne n,\, 0\le G_{m,n} \le 2, \text { and } 0\le G_{m,m} \le 1$</definingFormulation>
        <inDefiningFormulation>$G$, Contact Network</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$m$, Region</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Region</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <terms1:description xml:lang="en">constraints applying to contact network</terms1:description>
        <rdfs:label xml:lang="en">Contact Network Constraint</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674282"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ContactPointOfParticles -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ContactPointOfParticles">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#Position"/>
        <terms1:description xml:lang="en">global position of the contact point of two particles</terms1:description>
        <rdfs:label xml:lang="en">Contact Point Of Particles</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ContactRate -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ContactRate">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#Rate"/>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <terms1:description xml:lang="en">average number of individuals with whom an infectious individual makes sufficient contact (to pass infection) during a unit time</terms1:description>
        <rdfs:label xml:lang="en">Contact Rate</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673793"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ContactRateBetweenTwoGroups -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ContactRateBetweenTwoGroups">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">average number of contacts per unit time of an infective in a group with individuals in another group</terms1:description>
        <rdfs:label xml:lang="en">Contact Rate Between Two Groups</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673877"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ContinuityEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ContinuityEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ParticleFluxDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ParticleNumberDensity"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#ContinuityEquationForElectrons"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#ContinuityEquationForHoles"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ConservationLaw"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$ {\delta \rho / \delta t} + \nabla \cdot j = 0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho$, Particle Number Density</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$j$, Particle Flux Density</inDefiningFormulation>
        <terms1:description xml:lang="en">equation constraining a quantity to flow only via adjacent locations; can express a locality principle</terms1:description>
        <rdfs:label xml:lang="en">Continuity Equation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Continuity_equation"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674283"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q217219"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ContinuityEquationForElectrons -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ContinuityEquationForElectrons">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricCurrentDensityOfElectrons"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricPotential"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElementaryCharge"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FermiPotentialForElectrons"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FermiPotentialForHoles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RecombinationOfElectronHolePairs"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ContinuityEquation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\nabla \cdot j_n=qR(\psi,\phi_n,\phi_p)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R$, Recombination of Electron Hole Pairs</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi_n$, Fermi Potential for Electrons</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi_p$, Fermi Potential for Holes</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi$, Electric Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$j_n$, Electric Current Density of Electrons</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q$, Elementary Charge</inDefiningFormulation>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <terms1:description xml:lang="en">continuity equation for electrons; for use in semiconductor physics</terms1:description>
        <rdfs:label xml:lang="en">Continuity Equation for Electrons</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674284"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ContinuityEquationForElectronsFiniteVolume -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ContinuityEquationForElectronsFiniteVolume">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#ScharfetterGummelScheme"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlVolume"/>
        <discretizes rdf:resource="https://mardi4nfdi.de/mathmoddb#ContinuityEquationForElectrons"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$j_{n;k,k+1}-j_{n;k-1,k}=qR(\psi_k,\phi_{n;k},\phi_{p;k})|\omega_k|$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\omega_k$, Control Volume</inDefiningFormulation>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isSpaceContinuous>
        <terms1:description xml:lang="en">used within the Scharfetter-Gummel finite volume disretization scheme</terms1:description>
        <rdfs:comment xml:lang="en">Used within the Scharfetter-Gummel finite volume disretization scheme which is the standard numerical method for solving the van Roosbroeck system.</rdfs:comment>
        <rdfs:label xml:lang="en">Continuity Equation for Electrons (Finite Volume)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674286"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ContinuityEquationForHoles -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ContinuityEquationForHoles">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricCurrentDensityOfHoles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricPotential"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElementaryCharge"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FermiPotentialForElectrons"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FermiPotentialForHoles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RecombinationOfElectronHolePairs"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ContinuityEquation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\nabla \cdot j_p=-qR(\psi,\phi_n,\phi_p)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R$, Recombination of Electron Hole Pairs</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi_n$, Fermi Potential for Electrons</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi_p$, Fermi Potential for Holes</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi$, Electric Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$j_p$, Electric Current Density of Holes</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q$, Elementary Charge</inDefiningFormulation>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <terms1:description xml:lang="en">continuity equation for holes; for use in semiconductor physics</terms1:description>
        <rdfs:label xml:lang="en">Continuity Equation for Holes</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674285"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ContinuityEquationForHolesFiniteVolume -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ContinuityEquationForHolesFiniteVolume">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#ScharfetterGummelScheme"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlVolume"/>
        <discretizes rdf:resource="https://mardi4nfdi.de/mathmoddb#ContinuityEquationForHoles"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$j_{p;k,k+1}-j_{p;k-1,k}=-qR(\psi_k,\phi_{n;k},\phi_{p;k})|\omega_k|$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\omega_k$, Control Volume</inDefiningFormulation>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isSpaceContinuous>
        <terms1:description xml:lang="en">used within the Scharfetter-Gummel finite volume disretization scheme</terms1:description>
        <rdfs:comment xml:lang="en">Used within the Scharfetter-Gummel finite volume disretization scheme which is the standard numerical method for solving the van Roosbroeck system.</rdfs:comment>
        <rdfs:label xml:lang="en">Continuity Equation for Holes (Finite Volume)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674287"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ContinuityOfDensitiesCondition -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ContinuityOfDensitiesCondition">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsInitialConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#HybridPDEODESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposedInTheODERegion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposedInThePDERegion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfInfectiousInTheODERegion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfInfectiousInThePDERegion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfRemovedInTheODERegion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfRemovedInThePDERegion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfSusceptiblesInTheODERegion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfSusceptiblesInThePDERegion"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{aligned}
&amp;s_1=s_2 \\
&amp;e_1=e_2 \\
&amp;i_1=i_2 \\
&amp;r_1=r_2 \\
\end{aligned}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$e_1$, Fraction Of Population Density Of Exposed In The PDE Region</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$e_2$, Fraction Of Population Density Of Exposed In The ODE Region</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$i_1$, Fraction Of Population Density Of Infectious In The PDE Region</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$i_2$, Fraction Of Population Density Of Infectious In The ODE Region</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r_1$, Fraction Of Population Density Of Removed In The PDE Region</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r_2$, Fraction Of Population Density Of Removed In The ODE Region</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s_1$, Fraction Of Population Density Of Susceptibles In The PDE Region</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s_2$, Fraction Of Population Density Of Susceptibles In The ODE Region</inDefiningFormulation>
        <terms1:description xml:lang="en">continuity of densities across the interface $\Gamma$ in the Hybrid ODE-PDE Model</terms1:description>
        <rdfs:label xml:lang="en">Continuity Of Densities Condition</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ContinuityOfFluxesCondition -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ContinuityOfFluxesCondition">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsInitialConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#HybridPDEODESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposedInThePDERegion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfInfectiousInThePDERegion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfRemovedInThePDERegion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfSusceptiblesInThePDERegion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnitNormalVector"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\nu_1^T D \nabla s_1=\nu_1^T D \nabla e_1=\nu_1^T D \nabla i_1=\nu_1^T D \nabla r_1=0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$D$, Diffusion Coefficient</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\nu_1$, Unit Normal Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$e_1$, Fraction Of Population Density Of Exposed In The PDE Region</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$i_1$, Fraction Of Population Density Of Infectious In The PDE Region</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r_1$, Fraction Of Population Density Of Removed In The PDE Region</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s_1$, Fraction Of Population Density Of Susceptibles In The PDE Region</inDefiningFormulation>
        <terms1:description xml:lang="en">continuity of fluxes across the interface $\Gamma$ in the hybrid ODE-PDE model</terms1:description>
        <rdfs:label xml:lang="en">Continuity Of Fluxes Condition</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ContinuityOfTheNormalMassFlux -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ContinuityOfTheNormalMassFlux">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidVelocityFreeFlow"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidVelocityPorousMedium"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnitNormalVector"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$[v \cdot n]^{pm} = -[v \cdot n]^{ff}  \quad \mathrm{on} \quad \Gamma$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Normal Unit Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v^{ff}$, Fluid Velocity (Free Flow)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v^{pm}$, Fluid Velocity (Porous Medium)</inDefiningFormulation>
        <terms1:description xml:lang="en">continuity condition to be used as boundary condition within Stokes Darcy hybrid models</terms1:description>
        <rdfs:label xml:lang="en">Continuity of the Normal Mass Flux</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674288"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ContinuityOfTheNormalStresses -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ContinuityOfTheNormalStresses">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidPressureFreeFlow"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidPressurePorousMedium"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidViscousStress"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnitNormalVector"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n \cdot [(p I-\tau)n]^{ff} = [p]^{pm} \quad \mathrm{on} \quad \Gamma$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tau$, Fluid Viscous Stress</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Unit Normal Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p^{ff}$, Fluid Pressure (Free Flow)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p^{pm}$, Fluid Pressure (Porous Medium)</inDefiningFormulation>
        <terms1:description xml:lang="en">continuity condition to be used as boundary condition within Stokes Darcy hybrid models</terms1:description>
        <rdfs:label xml:lang="en">Continuity of the Normal Stresses</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674289"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ContinuousRateOfChangeOfInfectiousInTheSIModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ContinuousRateOfChangeOfInfectiousInTheSIModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#ContinuousSusceptibleInfectiousModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <discretizedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptiblesAtTimeStepInTheSIModel"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{d I}{d t}=\frac{\alpha}{N} S I$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I$, Number of Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Total Population SIze</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S$, Number of Susceptible Individuals</inDefiningFormulation>
