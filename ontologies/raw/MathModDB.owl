        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V_{max,f}$,Limiting Reaction Rate (Uni Uni Reaction - Forward)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_I$,Inhibitor Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_S$,Substrate Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0$,Initial Reaction Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isLinear>
        <terms1:description xml:lang="en">equation for uni uni reaction without product and uncompetitive complete inhibition following steady state assumption</terms1:description>
        <rdfs:label xml:lang="en">Lineweaver Burk Equation (Uni Uni Reaction without Product and Uncompetitive Complete Inhibition - Steady State Assumption)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674472"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LineweaverBurkEquationforUniUniReactionwithoutProductIrreversibilityAssumption -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LineweaverBurkEquationforUniUniReactionwithoutProductIrreversibilityAssumption">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InitialReactionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LimitingReactionRateUniUniReactionForward"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisConstantSubstrateUniUniReactionIrreversibilityAssumption"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SubstrateConcentration"/>
        <linearizes rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationforUniUniReactionwithoutProductIrreversibilityAssumption"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{1}{v_0} = \frac{1}{V_{max,f}} + \frac{K_S}{V_{max,f}} \frac{1}{c_S}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_S$, Michaelis Constant Substrate (Uni Uni Reaction - Irreversibility Assumption)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V_{max,f}$, Limiting Reaction Rate (Uni Uni Reaction - Forward)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_S$, Substrate Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0$, Initial Reaction Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isLinear>
        <terms1:description xml:lang="en">equation for uni uni reaction without product following irreversibility assumption</terms1:description>
        <rdfs:label xml:lang="en">Lineweaver Burk Equation (Uni Uni Reaction without Product - Irreversibility Assumption)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674466"/>
    </owl:NamedIndividual>
    


