        <uses rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalFokkerPlanckModel"/>
        <uses rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalLangevinModel"/>
        <terms1:description xml:lang="en">given initial positions and momenta of the particles in a classical mechanics system, the task is to predict these positions and momenta at later time</terms1:description>
