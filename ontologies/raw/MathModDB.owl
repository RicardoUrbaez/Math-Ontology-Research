    <!-- https://mardi4nfdi.de/mathmoddb#SchrödingerEquationStrangMarchuk -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SchrödingerEquationStrangMarchuk">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PlanckConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumKineticOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumPotentialOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumStateVectorDynamic"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <discretizes rdf:resource="https://mardi4nfdi.de/mathmoddb#SchroedingerEquationTimeDependent"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#SchrödingerEquationSplitOperator"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$|\psi(t+\Delta t)\rangle=\exp(-i\Delta t\hat{T}/ (2\hbar))\exp(-i\Delta t\hat{V}/ \hbar)\exp(-i\Delta t\hat{T}/ (2\hbar))|\psi(t)\rangle + \mathcal{O}(\Delta t)^2$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{T}$, Quantum Kinetic Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{V}$, Quantum Potential Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hbar$, Planck constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathrm{i}$, Imaginary Unit</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi(t)$, Quantum State Vector (Dynamic)</inDefiningFormulation>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">second order (Strang-Marchuk) split operator scheme for numerical integration of the time-dependent Schrödinger equation</terms1:description>
        <rdfs:label xml:lang="en">Schrödinger Equation (Strang-Marchuk)</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.1016/0021-9991(82)90091-2"/>
        <doiID rdf:resource="https://doi.org/10.1016/0021-9991(91)90137-A"/>
        <doiID rdf:resource="https://doi.org/10.1063/1.444501"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674266"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q25303744"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SchrödingerEquationTimeIndependent -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SchrödingerEquationTimeIndependent">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <assumes rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeIndependenceOfHamiltonian"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumEigenEnergy"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumNumber"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumStateVectorStationary"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#DarwinHowieWhelanEquationStrained"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#SchroedingerEquationTimeDependent"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat H | \psi_n \rangle = E_n | \psi_n \rangle$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$E_n$, Quantum Eigen Energy</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$H$, Quantum Hamiltonian Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi_n$, Quantum State Vector (Stationary)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Quantum Number</inDefiningFormulation>
        <terms1:description xml:lang="en">eigenvalue equation for the quantum-mechanical Hamiltonian operator, yielding stationary states (wave functions), along with their corresponding energies</terms1:description>
        <rdfs:label xml:lang="en">Schrödinger Equation (Time Independent)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6534310"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q25829357"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SecondConditionForPositiveSolutionsInTheMultiPopulationSIS_Model -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SecondConditionForPositiveSolutionsInTheMultiPopulationSIS_Model">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsConstraintConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#MultiPopulationSusceptibleInfectiousSusceptibleModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BetweenPopulationContactRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RelativeRemovalRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha_{ii} \Delta t \leq (\sqrt{1 - a_i}  + \sqrt{ \gamma_i \Delta t})^2$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma_i$, Relative Removal Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$a_i$, Between Population Contact Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">positive solution condition</terms1:description>
        <rdfs:label xml:lang="en">Second Condition for Positive Solutions in the Multi Population SIS Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674570"/>
    </owl:NamedIndividual>
    


