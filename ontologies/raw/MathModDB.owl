        <modeledBy rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumClassicalModel"/>
        <modeledBy rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumModelClosedSystem"/>
        <modeledBy rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumModelOpenSystem"/>
        <terms1:description xml:lang="en">studying molecular energy levels by stationary, i.e. time-independent molecular spectrosopy</terms1:description>
        <rdfs:comment xml:lang="en">For example, molecular vibrational states can be detected by infrared or Raman spectroscopy.</rdfs:comment>
        <rdfs:label xml:lang="en">Molecular Spectrosopy (Stationary)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6684677"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MolecularVibration -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MolecularVibration">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ResearchProblem"/>
        <modeledBy rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalModes"/>
        <modeledBy rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalModesAnharmonic"/>
        <modeledBy rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalModesHarmonic"/>
        <modeledBy rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalModesIntermolecular"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#MolecularSpectroscopy"/>
        <terms1:description xml:lang="en">periodic motion of the atoms of a molecule around their equilibrium positions</terms1:description>
