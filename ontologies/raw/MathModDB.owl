    <!-- https://mardi4nfdi.de/mathmoddb#infectiousAtTimeStepInTheSISModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#infectiousAtTimeStepInTheSISModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#DiscreteSusceptibleInfectiousSusceptibleModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RelativeRemovalRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_{n+1}=I_n\left(1 - \gamma \Delta t +\frac{\alpha \Delta t}{N} S_n\right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_n$, Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Total Population Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S_n$, Susceptible Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha$, Contact Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, Relative Removal Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">equation to define the number of infectious individuals in the SIS Model</terms1:description>
        <rdfs:label xml:lang="en">Infectious at Time Step n+1 in the SIS Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674595"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#BoltzmannEquationMovingParticlesTimeContinuous) -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#BoltzmannEquationMovingParticlesTimeContinuous)">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AttenuationCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Density"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalVector"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ScatterCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ScatteringCrossSection"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#BoltzmannEquationMovingParticles"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$ \theta \cdot \nabla u (x, \theta) = - \mu (x) \, u (x,\theta) + s(x) \, \int_{S^{n-1}} u (x, \theta&apos;) \, \sigma(\theta,\theta&apos;) \, d\theta&apos;$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu$, Attenuation Coefficient</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Scattering Cross Section</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\theta$, Normal Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s$, Scattering Coefficient</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$u$, Density</inDefiningFormulation>
        <terms1:description xml:lang="en">special version of the Boltzmann equation for moving particles, time continuous</terms1:description>
        <rdfs:label xml:lang="en">Boltzmann Equation for Moving Particles (time continuous)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Boltzmann_equation"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q891653"/>
    </owl:NamedIndividual>
    


