        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isTimeContinuous>
        <terms1:description xml:lang="en">determines the lumped activation parameter and models the activation of ion channels</terms1:description>
        <rdfs:comment xml:lang="en">Determines the lumped activation parameter and models the activation of ion channels in response to changes in the muscle fibers transmembrane.</rdfs:comment>
        <rdfs:label xml:lang="en">Subcellular Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675443"/>
    </owl:NamedIndividual>
    


