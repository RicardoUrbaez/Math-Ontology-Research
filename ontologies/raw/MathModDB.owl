    <!-- https://mardi4nfdi.de/mathmoddb#SpeedOfLight -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SpeedOfLight">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PermeabilityVacuum"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PermittivityVacuum"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SpeedOfLight"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#Velocity"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c \equiv \frac{1}{\sqrt{\epsilon_0 \mu_0}}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\epsilon_0$, Permittivity (Vacuum)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu_0$, Permeability (Vacuum)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Speed of Light</inDefiningFormulation>
        <isPhysicalConstant rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isPhysicalConstant>
        <terms1:description xml:lang="en">speed of electromagnetic waves in vacuum</terms1:description>
        <rdfs:label xml:lang="en">Speed of Light</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Speed_of_light"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674048"/>
        <qudtID rdf:resource="http://qudt.org/vocab/constant/SpeedOfLight_Vacuum"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q2111"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SphericalHarmonicsExpansion3D -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SphericalHarmonicsExpansion3D">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AzimuthalAngle"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PolarAngle"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Radius"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V(r,\theta,\varphi) = \sum_{\ell=0}^\infty\, \sum_{m=-\ell}^\ell C^m_\ell(r)\, Y^m_\ell(\theta,\varphi)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\theta$, Polar Angle</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\varphi$, Azimuthal Angle</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r$, Radius</inDefiningFormulation>
        <terms1:description xml:lang="en">representing a function in 3D in terms of spherical harmonics with distance(radius)-dependent coefficients</terms1:description>
        <rdfs:label xml:lang="en">Spherical Harmonics Expansion (3D)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674514"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SpinQbitShuttling -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SpinQbitShuttling">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ResearchProblem"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#Electromagnetism"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#SemiconductorPhysics"/>
        <terms1:description xml:lang="en">novel functional elements in modular architectures of semiconductor quantum processors</terms1:description>
        <rdfs:comment xml:lang="en">Spin-qubit shuttles are novel functional elements in modular architectures of semiconductor quantum processors, that have the capability of solving the scalability problem. Such coherent quantum links serve to interconnect different processor units and enable the transfer of quantum information over longer distances across the chip by physical transport of electrons.</rdfs:comment>
        <rdfs:label xml:lang="en">Spin Qbit Shuttling</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.20347/WIAS.PREPRINT.3082"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6534343"/>
    </owl:NamedIndividual>
    


