    <!-- https://mardi4nfdi.de/mathmoddb#WhiteNoiseDistributionAssumption -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#WhiteNoiseDistributionAssumption">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <assumedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#MeanFieldSPDEModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiracDeltaDistribution"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#WhiteNoise"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathbb{E}(\xi(x, t))=0, \quad \mathbb{E}\left(\xi(x, t) \xi\left(x^{\prime}, t^{\prime}\right)\right)=\delta\left(x-x^{\prime}\right) \delta\left(t-t^{\prime}\right), \quad \forall t, t^{\prime} \geq 0, \forall x, x^{\prime} \in \mathbb{T}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\delta$, Dirac Delta Distribution</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\xi$, White Noise</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">assumption regarding the distribution and expected value of the white noise</terms1:description>
        <rdfs:label xml:lang="en">White Noise Distribution Assumption</rdfs:label>
    </owl:NamedIndividual>
    


