        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$J$, Electric Current Density</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Electric Conductivity</inDefiningFormulation>
        <terms1:description xml:lang="en">Ohm&apos;s law for transport of electric charge</terms1:description>
        <rdfs:comment xml:lang="en">Note that the formulation used here is a generalization of the well-known R=U/I.</rdfs:comment>
        <rdfs:label xml:lang="en">Ohm Equation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674255"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q41591"/>
