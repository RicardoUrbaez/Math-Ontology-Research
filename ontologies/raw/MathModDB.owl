    <!-- https://mardi4nfdi.de/mathmoddb#ConditionForPositiveSolutionsInTheMultiPopulationSIModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ConditionForPositiveSolutionsInTheMultiPopulationSIModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsConstraintConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#MultiPopulationSusceptibleInfectiousModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactRateBetweenTwoGroups"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$max_i\{\textstyle\sum_{k=1}^K\alpha_{ik}\Delta t N^k/N^i \} \leq 1$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N^i$, Total Population Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha_{ik}$, Contact Rate Between Two Groups</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">positive solution constraint</terms1:description>
        <rdfs:label xml:lang="en">Condition for Positive Solutions in the Multi-Population SI Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674271"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ConditionForPositiveSolutionsInTheMultiPopulationSIRModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ConditionForPositiveSolutionsInTheMultiPopulationSIRModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsConstraintConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#MultiPopulationSusceptibleInfectiousRemovedModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactRateBetweenTwoGroups"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RelativeRemovalRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$max_i\{\textstyle\sum_{k=1}^K\alpha_{ik}\Delta t N^k/N^i, \gamma_i \Delta t \} \leq 1$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N^i$, Total Population Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha_{ik}$, Contact Rate Between Two Groups</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma_i$, Relative Removal Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">positive solution constraint</terms1:description>
        <rdfs:label xml:lang="en">Condition for Positive Solutions in the Multi-Population SIR Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674272"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ConditionForPositiveSolutionsInTheMultiPopulationSISModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ConditionForPositiveSolutionsInTheMultiPopulationSISModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsConstraintConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#MultiPopulationSusceptibleInfectiousSusceptibleModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BetweenPopulationContactRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RelativeRemovalRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\max_{i} \{a_i, \gamma_i \Delta t\} \leq 1$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma_i$, Relative Removal rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$a_i$, Between Population Contact Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">positive solution constraint</terms1:description>
        <rdfs:label xml:lang="en">Condition for Positive Solutions in the Multi-Population SIS Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674273"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ConditionForPositiveSolutionsInTheSIRModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ConditionForPositiveSolutionsInTheSIRModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsConstraintConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#DiscreteSusceptibleInfectiousRemovedModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RelativeRemovalRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$max\{\gamma \Delta t, \alpha \Delta t \} \leq 1$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha$, Contact Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, Relative Removal Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">positive solution constraint</terms1:description>
        <rdfs:comment xml:lang="en">The time step must be less than the average time required for a successful contact and less than the average infectious period.</rdfs:comment>
        <rdfs:label xml:lang="en">Condition for Positive Solutions in the SIR Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674274"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ConditionForPositiveSolutionsInTheSIRModelWithBirthsAndDeaths -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ConditionForPositiveSolutionsInTheSIRModelWithBirthsAndDeaths">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsConstraintConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleInfectiousRemovedModelWithBirthsAndDeaths"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BirthRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RelativeRemovalRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$(\gamma +\beta) \Delta t \leq 1$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\beta$, Birth Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, Relative Removal Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">positive solution constraint</terms1:description>
        <rdfs:label xml:lang="en">Condition for Positive Solutions in the SIR Model with Births and Deaths</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674275"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ConditionForPositiveSolutionsInTheSISModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ConditionForPositiveSolutionsInTheSISModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
