        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRateOfSubstrate2"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRateofEnzymeSubstrate1Substrate2EnzymeProduct1Product2Complex"/>
