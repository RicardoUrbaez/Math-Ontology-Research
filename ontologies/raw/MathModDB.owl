    <!-- https://mardi4nfdi.de/mathmoddb#TimeDependentContactNetwork -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#TimeDependentContactNetwork">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactNetwork"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SpreadingRateTimeDependent"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeDependentContactNetwork"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma \equiv (G,\alpha)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$G$, Contact Network</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha$, Spreading Rate (Time-dependent)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Contact Network (Time-dependent)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <terms1:description xml:lang="en">tuple of spreading rate and contact network interpreted as time-evolving contact network</terms1:description>
        <rdfs:label xml:lang="en">Contact Network (Time-dependent)</rdfs:label>
