    <!-- https://mardi4nfdi.de/mathmoddb#EulerBackwardMethod -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#EulerBackwardMethod">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RightHandSideOfDifferentialEquation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnknownFunction"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#DarcyEquationEulerBackward"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#StokesEquationEulerBackward"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$y_{n+1}=y_{n}+h f\left(t_{n+1}, y_{n+1}\right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$f$, Right Hand Side Of Differential Equation</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$h$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$y$, Unknown Function</inDefiningFormulation>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">one of the most basic numerical methods in numerical analysis and scientific computing for the solution of ordinary differential equations</terms1:description>
        <rdfs:comment xml:lang="en">Similar to the (standard, forward, explicit) Euler method, but differs in that it is an implicit method. The backward Euler method has error of order one in time.</rdfs:comment>
        <rdfs:label xml:lang="en">Euler Backward Method</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Backward_Euler_method"/>
        <skos:altLabel>Implicit Euler Method</skos:altLabel>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674269"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q2736820"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#EulerForwardMethod -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#EulerForwardMethod">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RightHandSideOfDifferentialEquation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnknownFunction"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$y_{n+1}=y_{n}+h f(t_n, y_n)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$f$, Right Hand Side Of Differential Equation</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$h$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$y$, Unknown Function</inDefiningFormulation>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">in mathematics and computational science, this method is a first-order numerical procedure for solving ODEs with a given initial value</terms1:description>
        <rdfs:comment xml:lang="en">It is the most basic explicit method for numerical integration of ordinary differential equations and is the simplest Runge–Kutta method.</rdfs:comment>
        <rdfs:label xml:lang="en">Euler Forward Method</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Euler_method"/>
        <skos:altLabel xml:lang="en">Explicit Euler Method</skos:altLabel>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674265"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q868454"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#EulerMethod -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#EulerMethod">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#EulerBackwardMethod"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#EulerForwardMethod"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#RungeKuttaMethod"/>
        <terms1:description xml:lang="en">first-order numerical procedure for solving ordinary differential equations with a given initial value</terms1:description>
        <rdfs:label xml:lang="en">Euler Method</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Euler_method"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674351"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#EulerNumber -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#EulerNumber">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EulerNumber"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#RealDimensionless"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}\mathrm{e} &amp;\equiv&amp; \lim_{n \to \infty} \left(1 + \frac{1}{n}\right)^n\\\mathrm{e} &amp;\equiv&amp;  \sum\limits_{n = 0}^{\infty} \frac{1}{n!} \end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathrm{e}$, Euler Number</inDefiningFormulation>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <isMathematicalConstant rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isMathematicalConstant>
        <terms1:description xml:lang="en">transcendental number approximately equal 2.718281828....</terms1:description>
        <rdfs:label xml:lang="en">Euler Number</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/E_(mathematical_constant)"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673963"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q82435"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#EvaluationPosteriorPredictiveDistribution -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#EvaluationPosteriorPredictiveDistribution">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">evaluation points: X = (xᵢ)ᵢ₌₁ⁿ and evaluations Y = (yᵢ)ᵢ₌₁ⁿ = (f(xᵢ))ᵢ₌₁ⁿ for the posterior predictive distribution</terms1:description>
        <rdfs:label xml:lang="en">Evaluations Posterior Predictive Distribution</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#EvolutionOfTheConcentrationOfParticlesPDE -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#EvolutionOfTheConcentrationOfParticlesPDE">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#MeanFieldPDEModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ConcentrationOfParticles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ConvolutionBetweenInteractionForceAndDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InteractionForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\partial_t c(x, t)=\partial_x\left(c(x, t)\left(F^{\prime} * c(\cdot, t)\right)(x)\right)+\frac{\sigma^2}{2} \partial_{x x} c(x, t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$(F^{\prime} * c(\cdot, t))$, Convolution Between Interaction Force And Density</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F&apos;$, Interaction Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Diffusion Coefficient</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Concentration Of Particles</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">spatiotemporal evolution of the concentration of particles depending on the position and time</terms1:description>
        <rdfs:comment xml:lang="en">This is a nonlinear, nonlocal Fokker-Planck equation that is also called McKean-Vlasov
PDE or aggregation-diffusion equation.</rdfs:comment>
        <rdfs:label xml:lang="en">Evolution Of The Concentration Of Particles PDE</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#EvolutionOfTheConcentrationOfParticlesSPDE -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#EvolutionOfTheConcentrationOfParticlesSPDE">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#MeanFieldSPDEModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ConcentrationOfParticles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ConvolutionBetweenInteractionForceAndDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfParticles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#WhiteNoise"/>
        <definingFormulation xml:lang="en">$\partial_t c(x, t)=\partial_x\left(c(x, t)\left(F^{\prime} * c(\cdot, t)\right)(x)\right)+\frac{\sigma^2}{2} \partial_{x x} c(x, t)+\frac{\sigma}{\sqrt{N}} \partial_x \cdot(\sqrt{c(x, t)} \xi(x, t))$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$(F^{\prime} * c(\cdot, t))$, Convolution Between Interaction Force And Density</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Number of Particles</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Diffusion Coefficient</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\xi$, White Noise</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Concentration Of Particles</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">randomness is maintained by this stochastic equation also known as Dean-Kawasaki equation</terms1:description>
        <rdfs:label xml:lang="en">Evolution Of The Concentration Of Particles SPDE</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#EvolutionOfThePositionOfAParticleSDE -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#EvolutionOfThePositionOfAParticleSDE">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#StochasticParticleBasedModelForClusteringDynamics"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InteractionPotential"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfParticles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PositionOfParticle"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#WienerProcess"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$d X_i(t)=-\frac{1}{N} \sum_{j=1}^N F^{\prime}\left(X_i(t)-X_j(t)\right) d t+\sigma d W_i(t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F(x)$, Interaction Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Number of Particles</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$W_i$, Wiener Process</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$X_i$, Position Of A Particle</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Diffusion Coefficient</inDefiningFormulation>
        <terms1:description xml:lang="en">positions of particles evolve according to this set of coupled SDEs</terms1:description>
        <rdfs:comment xml:lang="en">𝑋(𝑡) = (𝑋₁(𝑡), …, 𝑋ₙ(𝑡)) denote the (random) system state at time 𝑡</rdfs:comment>
        <rdfs:label xml:lang="en">Evolution Of The Position Of A Particle SDE</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ExcessSubstrateAssumption -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ExcessSubstrateAssumption">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EnzymeConcentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SubstrateConcentration"/>
        <containsInitialCondition rdf:resource="https://mardi4nfdi.de/mathmoddb#InitialSubstrateConcentrationUniUni"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_S &gt;&gt; c_E \rightarrow c_S \approx c_{S_{0}}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{E}$, Enzyme Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S_{0}}$, Substrate Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S}$, Substrate Concentration</inDefiningFormulation>
        <terms1:description xml:lang="en">substrate concentration much higher than enzyme concentration</terms1:description>
        <rdfs:label xml:lang="en">Excess Substrate Assumption</rdfs:label>
    </owl:NamedIndividual>
    


