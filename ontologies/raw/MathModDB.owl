    <!-- https://mardi4nfdi.de/mathmoddb#InhibitionConstantSubstrate2BiBiReactionOrderedSteadyStateAssumption -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#InhibitionConstantSubstrate2BiBiReactionOrderedSteadyStateAssumption">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstantSubstrate2BiBiReactionOrderedSteadyStateAssumption"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateConstant"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstant"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iS_2} \equiv \frac{k_{-1} k_{-2} + k_{-1} k_3 + k_{-1} k_{-3} + k_{-2} k_{-3}}{k_2 (k_3 + k_{-3})}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iS_2}$, Inhibition Constant Substrate 2 (Bi Bi Reaction Ordered - Steady State Assumption)</inDefiningFormulation>
