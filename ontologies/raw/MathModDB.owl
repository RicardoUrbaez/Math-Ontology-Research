    <!-- https://mardi4nfdi.de/mathmoddb#IntegralOfThePopulationDensityFractionOfExposedInitialCondition -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#IntegralOfThePopulationDensityFractionOfExposedInitialCondition">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsInitialConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PDESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CoefficientScalingInfectiousToExposed"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposed"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationDensity"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\int_{\Omega^{(l)}} e(x, 0) n(x) d x=\Sigma_{\mathcal{E}} \hat{\mathcal{I}}^{(l)}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Sigma_{\mathcal{E}}$, Coefficient Scaling Infectious to Exposed</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{\mathcal{I}}^{(l)}$, Number of Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$e(x, 0)$, Fraction of Population Density of Exposed</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n(x)$, Total Population Density</inDefiningFormulation>
        <terms1:description xml:lang="en">integral of the population density fraction of exposed initial condition</terms1:description>
        <rdfs:label xml:lang="en">Integral of the Population Density Fraction of Exposed (Initial Condition)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674430"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#IntegralOfThePopulationDensityFractionOfInfectiousInitialCondition -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#IntegralOfThePopulationDensityFractionOfInfectiousInitialCondition">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsInitialConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PDESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfInfectious"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationDensity"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\int_{\Omega^{(l)}} i(x, 0) n(x) d x=\hat{\mathcal{I}}^{(l)}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{\mathcal{I}}^{(l)}$, Number of Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$i(x, 0)$, Fraction of Population Density of Infectious</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n(x)$, Total Population Density</inDefiningFormulation>
        <terms1:description xml:lang="en">integral of the population density fraction of infectious initial condition</terms1:description>
        <rdfs:label xml:lang="en">Integral of the Population Density Fraction of Infectious (Initial Condition)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674431"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#IntegralOfThePopulationDensityFractionOfSusceptiblesInitialCondition -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#IntegralOfThePopulationDensityFractionOfSusceptiblesInitialCondition">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsInitialConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PDESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CoefficientScalingInfectiousToExposed"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfSusceptibles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectiousIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RemovedIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$ \int_{\Omega^{(l)}} s(x, 0) n(x) dx = \hat{\mathcal{N}}_l-\left(1+\Sigma_{\mathcal{E}}\right) \hat{\mathcal{I}}^{(l)}-\hat{\mathcal{R}}^{(l)} $</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Sigma_{\mathcal{E}}$, Coefficient Scaling Infectious to Exposed</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{\mathcal{I}}^{(l)}$, Number of Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{\mathcal{N}}_l$, Total Population Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{\mathcal{R}}^{(l)}$, Number of Removed Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n(x)$, Total Population Density</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s(x, 0)$, Fraction of Population Density of Susceptibles</inDefiningFormulation>
        <terms1:description xml:lang="en">integral of the population density fraction of susceptibles initial condition</terms1:description>
        <rdfs:label xml:lang="en">Integral of the Population Density Fraction of Susceptibles (Initial Condition)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674432"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#IntegralOfTheTotalPopulationDensityInitialCondition -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#IntegralOfTheTotalPopulationDensityInitialCondition">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsInitialConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PDESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalPopulationSize"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\int_{\Omega^{(l)}} n(x) d x=\hat{\mathcal{N}}_l$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{\mathcal{N}}_l$, Total Population Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n(x)$, Total Population Density</inDefiningFormulation>
        <terms1:description xml:lang="en">integral of the total population density initial condition</terms1:description>
        <rdfs:label xml:lang="en">Integral of the Total Population Density (Initial Condition)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674433"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#InteractionForce -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#InteractionForce">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#Force"/>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <terms1:description xml:lang="en">interaction force on individual by media and influencers</terms1:description>
        <rdfs:label xml:lang="en">Interaction Force</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673851"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#InteractionForceOnAnIndividual -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#InteractionForceOnAnIndividual">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#OpinionModelWithInfluencersAndMedia"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfluencerIndividualMatrix"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InteractionForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InteractionWeight"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MediumFollowerMatrix"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ParameterToScaleAttractiveForceFromInfluencers"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ParameterToScaleAttractiveForceFromMedia"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ParameterToScaleAttractiveForceFromOtherIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F_i(\mathbf{x}, \mathbf{y}, \mathbf{z}, t)=\frac{a}{\sum_{j^{\prime}} w_{i j^{\prime}}(t)} \sum_{j=1}^N w_{i j}(t)\left(x_j(t)-x_i(t)\right)+b \sum_{m=1}^M B_{i m}(t)\left(y_m(t)-x_i(t)\right)+c \sum_{l=1}^L C_{i l}(t)\left(z_l(t)-x_i(t)\right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B(t)$, Medium Follower Matrix</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C(t)$, Influencer Individual Matrix</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F_i(t)$, Interaction Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$a$, Parameter to Scale Attractive Force from Other Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$b$, Parameter to Scale Attractive Force from Media</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Parameter to Scale Attractive Force from Influencers</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$w_{ij}$, Interaction Weight</inDefiningFormulation>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isTimeContinuous>
        <terms1:description xml:lang="en">interaction force on an individual</terms1:description>
        <rdfs:comment xml:lang="en">The interaction force on individual i is given by a weighted sum of attractive forces from all other connected individuals j, the respective media and the respective influencer scaled by the parameters a,b,c &gt; 0 respectively.</rdfs:comment>
        <rdfs:label xml:lang="en">Interaction Force on an Individual</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674434"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#InteractionPotential -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#InteractionPotential">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">potential modeling pairwise interactions between
particles</terms1:description>
        <rdfs:label xml:lang="en">Interaction Potential</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#InteractionPotentialFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#InteractionPotentialFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#StochasticParticleBasedModelForClusteringDynamics"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InteractionPotential"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LengthScaleOfAttractiveForces"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LengthScaleOfRepulsiveForces"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StrengthOfAttractiveForces"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StrengthOfRepulsiveForces"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F(x)=-C_a \exp \left(-\frac{|x|}{l_a}\right)+C_r \exp \left(-\frac{|x|}{l_r}\right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C_a$, Strength Of Attractive Forces</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C_r$, Strength Of Repulsive Forces</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F(x)$, Interaction Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$l_a$, Length Scale Of Attractive Forces</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$l_r$, Length Scale Of Repulsive Forces</inDefiningFormulation>
        <terms1:description xml:lang="en">given by the generalized Morse potential</terms1:description>
        <rdfs:label xml:lang="en">Interaction Potential Formulation</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#InteractionWeight -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#InteractionWeight">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#RealDimensionless"/>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <terms1:description xml:lang="en">interaction weight between a pair of individuals to account for their influence on each other&apos;s opinions</terms1:description>
        <rdfs:label xml:lang="en">Interaction Weight</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674033"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#InteractionWeightBetweenIndividuals -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#InteractionWeightBetweenIndividuals">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#OpinionModelWithInfluencersAndMedia"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#IndividualRelationshipMatrix"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InteractionWeight"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#OpinionVectorOfIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PairFunction"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$ w_{ij}(t) = A_{ij}(t) \phi (|| x_j(t) - x_i(t)|| )$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A(t)$, Individual Relationship Matrix</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi$, Pair Function</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$w_{ij}(t)$, Interaction Weight</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x(t)$, Opinion Vector of Individuals</inDefiningFormulation>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <terms1:description xml:lang="en">interaction weights between pairs of individuals</terms1:description>
        <rdfs:label xml:lang="en">Interaction Weight Between Individuals</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674435"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#IntermediateConcentration -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#IntermediateConcentration">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <terms1:description xml:lang="en">amount of intermediate present in a reaction environment</terms1:description>
        <rdfs:label xml:lang="en">Intermediate Concentration</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673817"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#IntermediateConcentrationODEBiBiPingPong -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#IntermediateConcentrationODEBiBiPingPong">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{E*}}{dt} = k_{2} c_{ES_1} + k_{-3} c_{E*S_2} - k_{-2} c_{E*} c_{P_1} - k_{3} c_{E*} c_{S_2}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{E*}}{dt}$, Reaction Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{E*S_2}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{E*}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{ES_1}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{P_1}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S_2}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-2}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-3}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{2}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{3}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">ordinary differential equation describing the concentration over time in a Theorell-Chance bi bi reaction</terms1:description>
        <rdfs:label xml:lang="en">Intermediate Concentration ODE (Bi Bi Reaction Ping Pong)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674214"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#IntermediateSubstrate2ComplexConcentration -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#IntermediateSubstrate2ComplexConcentration">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <terms1:description xml:lang="en">amount of intermediate - substrate 2 complex present in a reaction environment</terms1:description>
        <rdfs:label xml:lang="en">Intermediate - Substrate 2 Complex Concentration</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673818"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#IntermediateSubstrate2ComplexConcentrationODEBiBiPingPong -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#IntermediateSubstrate2ComplexConcentrationODEBiBiPingPong">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{E*S_2}}{dt} = k_{3} c_{E*} c_{S_2} + k_{-4} c_{E} c_{P_2} - k_{-3} c_{E*S_2} - k_{4} c_{E*S_2}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{E*S_2}}{dt}$, Reaction Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{E*S_2}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{E*}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{E}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{P_2}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S_2}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-3}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-4}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{3}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{4}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">ordinary differential equation describing the concentration over time in a Theorell-Chance bi bi reaction</terms1:description>
        <rdfs:label xml:lang="en">Intermediate - Substrate 2 - Complex Concentration ODE (Bi Bi Reaction Ping Pong)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674215"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#IntermolecularPotential -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#IntermolecularPotential">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">energy function that describes the interactions between molecules</terms1:description>
        <rdfs:comment xml:lang="en">Intermolecular potential energy function that describes the interactions between molecules. Typically, intermolecular forces are weak relative to intramolecular forces.</rdfs:comment>
        <rdfs:label xml:lang="en">Intermolecular Potential</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Intermolecular_force"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674034"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q245031"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#IonCurrent -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#IonCurrent">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricCurrent"/>
        <terms1:description xml:lang="en">flow of electrical charge observed in electrolytes, wires, plasma, and other conducting materials or fluids</terms1:description>
        <rdfs:label xml:lang="en">Ion Current</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Ion_current"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674035"/>
        <qudtID rdf:resource="https://qudt.org/vocab/quantitykind/IonCurrent"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q6063423"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#IrreversibilityAssumption -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#IrreversibilityAssumption">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ComplexedEnzymeConcentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ProductConcentration"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{c_{EX}}{c_P} \gg 1$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_P$, Product Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{EX}$, Complexed Enzyme Concentration</inDefiningFormulation>
        <terms1:description xml:lang="en">complexed enzyme concentration much higher than the product concentration</terms1:description>
        <rdfs:label xml:lang="en">Irreversibility Assumption</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674436"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#IsotropicGaussianFunction -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#IsotropicGaussianFunction">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">Gaussian function representing density and density fractions of provinces</terms1:description>
        <rdfs:comment xml:lang="en">Isotropic Gaussian Function located at the center of the respective province used in the PDE SEIR Model for representing density and density fractions.</rdfs:comment>
        <rdfs:label xml:lang="en">Isotropic Gaussian Function</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673982"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#IsotropicGaussianFunctionFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#IsotropicGaussianFunctionFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PDESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CenterOfProvince"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#IsotropicGaussianFunction"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PiNumber"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Variance"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$G^{(l)}(x) \equiv  \frac{1}{2\pi\sigma^2}\text{exp}(-\frac{||x-x_0^{(l)}||^2}{2\sigma^2})$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$G^{(l)}(x)$, Isotropic Gaussian Function</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\pi$, Pi Number</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Variance</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x_0^{(l)}$, Center of Province</inDefiningFormulation>
        <terms1:description xml:lang="en">isotropic gaussian function located at the center of the respective province for representing density and density fractions</terms1:description>
        <rdfs:label xml:lang="en">Isotropic Gaussian Function Formulation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674437"/>
    </owl:NamedIndividual>
    


