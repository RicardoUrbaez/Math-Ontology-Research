    <!-- https://mardi4nfdi.de/mathmoddb#ObjectComparisonFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ObjectComparisonFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#ObjectComparisonModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BooleanRing"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfObjectProperties"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ObjectProperty"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PowerSet"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{B} = \mathcal{P}(x_1,x_2,...,x_m)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{B}$, Boolean Ring</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{P}$, Power Set</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$m$, Number of Object Properties</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Object Property</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
