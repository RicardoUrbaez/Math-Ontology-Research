    <!-- https://mardi4nfdi.de/mathmoddb#AverageOpinionOfFollowersOfMediaInThePartialFieldModelFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#AverageOpinionOfFollowersOfMediaInThePartialFieldModelFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PartialMeanFieldOpinionModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AverageOpinionOfFollowersOfMediaInThePartialFieldModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LimitingDistributionOfIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MediumInfluencerFractionLimit"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Opinion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{x}_m(t)=\frac{\sum_{l=1}^L \int_D x \rho_{m, l}(x, t) d x}{\sum_{l=1}^L n_{m, l}(t)}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho_{m,l}$, Limiting Distribution of Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{x}_m(t)$, Average Opinion of Followers of Media in the Partial Field Model</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n_{m,l}$, Medium Influencer Fraction Limit</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Opinion</inDefiningFormulation>
        <terms1:description xml:lang="en">equation describing the average opinon of the followers of a specific medium in the partial field opinion model</terms1:description>
        <rdfs:label xml:lang="en">Average Opinion of Followers of Media in the Partial Mean Field Model Formulation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674139"/>
    </owl:NamedIndividual>
    


