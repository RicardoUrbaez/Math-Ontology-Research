        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#NeumannBoundaryCondition"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n \cdot \nabla \phi_p|_{\Gamma_N}=0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Gamma_N$, Electrode Interfaces</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi_p$, Fermi Potential for Holes</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Normal Unit Vector</inDefiningFormulation>
        <terms1:description xml:lang="en">Neumann boundary condition for the Fermi potential governing the holes</terms1:description>
        <rdfs:label xml:lang="en">Neumann Boundary Condition for Hole Fermi Potential</rdfs:label>
