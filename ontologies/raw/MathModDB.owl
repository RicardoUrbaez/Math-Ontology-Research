    <!-- https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationforBiBiReactionPingPongMechanismwithProducts1and2SS -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationforBiBiReactionPingPongMechanismwithProducts1and2SS">
