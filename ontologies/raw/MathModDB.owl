    <!-- https://mardi4nfdi.de/mathmoddb#FreeFallDetermineGravitation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#FreeFallDetermineGravitation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ComputationalTask"/>
        <containsInput rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallImpactTime"/>
        <containsInput rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallInitialHeight"/>
        <containsInput rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallInitialVelocity"/>
        <containsOutput rdf:resource="https://mardi4nfdi.de/mathmoddb#GravitationalAccelerationEarthSurface"/>
        <uses rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallModelVacuum"/>
        <terms1:description xml:lang="en">given the time that it takes for an object to freely fall from a certain height to the ground, what is the magnitude of the gravitational acceleration</terms1:description>
        <rdfs:label xml:lang="en">Free Fall Determine Gravitation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6684566"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#FreeFallDetermineTime -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#FreeFallDetermineTime">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ComputationalTask"/>
        <assumes rdf:resource="https://mardi4nfdi.de/mathmoddb#UniformGravitationalAcceleration"/>
        <containsConstant rdf:resource="https://mardi4nfdi.de/mathmoddb#GravitationalAccelerationEarthSurface"/>
        <containsInput rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallInitialHeight"/>
        <containsInput rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallInitialVelocity"/>
        <containsOutput rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallImpactTime"/>
        <uses rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallModelAirDrag"/>
        <uses rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallModelVacuum"/>
        <terms1:description xml:lang="en">how long does it take for a freely falling object to fall to the ground</terms1:description>
        <rdfs:label xml:lang="en">Free Fall Determine Time</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6684567"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#FreeFallDetermineVelocity -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#FreeFallDetermineVelocity">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ComputationalTask"/>
        <containsConstant rdf:resource="https://mardi4nfdi.de/mathmoddb#GravitationalAccelerationEarthSurface"/>
        <containsInput rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallInitialHeight"/>
        <containsInput rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallInitialVelocity"/>
        <containsOutput rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallImpactVelocity"/>
        <uses rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallModelAirDrag"/>
        <uses rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallModelVacuum"/>
        <terms1:description xml:lang="en">with which velocity will a freely falling object hit the ground</terms1:description>
        <rdfs:label xml:lang="en">Free Fall Determine Velocity</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6684568"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#FreeFallEquationAirDrag -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#FreeFallEquationAirDrag">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <assumes rdf:resource="https://mardi4nfdi.de/mathmoddb#UniformGravitationalAcceleration"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallModelAirDrag"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CrossSection"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DensityOfAir"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DragCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallHeight"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallInitialHeight"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallInitialVelocity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallMass"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallTerminalVelocity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallVelocity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GravitationalAccelerationEarthSurface"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align} 
m\dot{v} &amp;=&amp; mg-\frac{1}{2}\rho C_DAv^2\\
v(t) &amp;=&amp; v_0 + v_{\infty}\tanh\left(\frac{gt}{v_{\infty}}\right) \\
y(t) &amp;=&amp; y_0+v_0t-\frac{v_\infty^2}{g}\ln\cosh\left(\frac{gt}{v_\infty}\right)
\end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Cross Section</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C_D$, Drag Coefficient</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho$, Density of Air</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$g$, Gravitational Acceleration (Earth Surface)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$m$, Free Fall Mass</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v$, Free Fall Velocity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0$, Free Fall Initial Velocity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_{\infty}$, Free Fall Terminal Velocity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$y$, Free Fall Height</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$y_0$, Free Fall Initial Height</inDefiningFormulation>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isLinear>
        <terms1:description xml:lang="en">modeling the fall of objects by the laws of classical mechanics, including aerodynamic drag and assuming a uniform gravitational field</terms1:description>
        <rdfs:comment xml:lang="en">Moreover, assuming the falling object to be a point mass.</rdfs:comment>
        <rdfs:label xml:lang="en">Free Fall Equation (Air Drag)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Free_fall"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q38083707"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674363"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#FreeFallEquationNonUniformGravitation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#FreeFallEquationNonUniformGravitation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallHeight"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallInitialHeight"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallTime"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantileFunctionOfTheBetaDistribution"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallEquationAirDrag"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$y(t)=y_0Q\left(1-\frac{t}{t_{\mathrm{ff}}};\frac{3}{2},\frac{1}{2}\right)$</definingFormulation>
        <inDefiningFormulation>$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$Q$, Quantile Function of The Beta Distribution</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t_\mathrm{ff}$, Free Fall Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$y$, Free Fall Height</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$y_0$, Free Fall Initial Height</inDefiningFormulation>
        <terms1:description xml:lang="en">modeling the fall of objects by the laws of classical mechanics, neglecting aerodynamic drag but allowing for a non-uniform gravitational field</terms1:description>
        <rdfs:comment xml:lang="en">Moreover, assuming the falling object to be a point mass.</rdfs:comment>
        <rdfs:label xml:lang="en">Free Fall Equation (Non-Uniform Gravitation)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Free_fall"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q38083707"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674364"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#FreeFallEquationVacuum -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#FreeFallEquationVacuum">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <assumes rdf:resource="https://mardi4nfdi.de/mathmoddb#VanishingAirDensity"/>
        <assumes rdf:resource="https://mardi4nfdi.de/mathmoddb#VanishingDragCoefficient"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallModelVacuum"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallHeight"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallInitialHeight"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallInitialVelocity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallVelocity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GravitationalAccelerationEarthSurface"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallEquationAirDrag"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}
\dot{v} &amp;=&amp; g \\
v(t) &amp;=&amp; v_0-gt \\
y(t) &amp;=&amp; y_0+v_0t-\frac{1}{2}gt^2
\end{align}$</definingFormulation>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$y(t)=y_0+v_0t-\frac{1}{2}gt^2$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$g$, Gravitational Acceleration (Earth Surface)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v$, Free Fall Velocity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0$, Free Fall Initial Velocity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$y$, Free Fall Height</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$y_0$, Free Fall Initial Height</inDefiningFormulation>
        <terms1:description xml:lang="en">modeling the fall of objects by the laws of classical mechanics, neglecting aerodynamic drag and assuming a uniform gravitational field</terms1:description>
        <rdfs:comment xml:lang="en">Moreover, assuming the falling object to be a point mass.</rdfs:comment>
        <rdfs:label xml:lang="en">Free Fall Equation (Vacuum)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Free_fall"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q38083707"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674365"/>
    </owl:NamedIndividual>
    


