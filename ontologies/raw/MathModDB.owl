        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#EnzymeKinetics"/>
        <terms1:description xml:lang="en">uni uni reaction with inhibition</terms1:description>
        <rdfs:comment xml:lang="en">Uni Uni Reaction with reversible inhibition. The enzyme-inhibitor-substrate complex (EIS) can form product, the inhibition is thus partial.</rdfs:comment>
        <rdfs:label xml:lang="en">Uni Uni Reaction with Reversible Partial Inhibition</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6684688"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#UniUniReactionWithUncompetitiveCompleteInhibition -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#UniUniReactionWithUncompetitiveCompleteInhibition">
