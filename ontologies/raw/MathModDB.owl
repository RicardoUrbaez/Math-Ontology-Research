    <!-- https://mardi4nfdi.de/mathmoddb#DynamicalElectronScatteringModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#DynamicalElectronScatteringModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HookeLawLinearElasticity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MomentumBalanceEquation"/>
        <containsBoundaryCondition rdf:resource="https://mardi4nfdi.de/mathmoddb#NeumannBoundaryConditionStressFreeRelaxation"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumModelClosedSystem"/>
        <terms1:description xml:lang="en">quantum-mechanical propagation of electrons through a sample governed by dynamical electron scattering</terms1:description>
        <rdfs:comment xml:lang="en">In crystalline solids, e.g. semiconductor nanostructures, it is influenced by spatial variations in the material composition and by local deformations of the lattice due to elastic strain. In order to model TEM images, we need to use elasticity theory to obtain the strain profile and couple this with the equations describing the electron propagation through the sample.</rdfs:comment>
        <rdfs:label xml:lang="en">Dynamical Electron Scattering Model</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.1007/s11082-020-02356-y"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675392"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ETMeasurementEquationNoScatterNoAttenuation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ETMeasurementEquationNoScatterNoAttenuation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#EmissionTomographyNoScatterNoAttenuation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#ParticleMovementLineNoAttenuation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalVector"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PoissonDistribution"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ETMeasurementEquationNoScatterWithAttenuation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$g(\theta,s) = \int_{x\cdot\theta = s} f(x) dx$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\theta$, Normal Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$g$, Poisson Distribution</inDefiningFormulation>
        <terms1:description xml:lang="en">emission tomography equation neglecting scattering and attenuation</terms1:description>
        <rdfs:label xml:lang="en">ET Measurement Equation (No Scatter, No Attenuation)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ETMeasurementEquationNoScatterWithAttenuation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ETMeasurementEquationNoScatterWithAttenuation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AttenuationCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PoissonDistribution"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$g(y) = \int_{L} f(x)e^{-\int^{x} \mu(s) \, ds}\,dx$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu$, Attenuation Coefficient</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$g$, Poisson Distribution</inDefiningFormulation>
        <terms1:description xml:lang="en">emission tomography equation neglecting scattering but including attenuation</terms1:description>
        <rdfs:label xml:lang="en">ET Measurement Equation (No Scatter, With Attenuation)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Radon_transform"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q979829"/>
        <skos:altLabel xml:lang="en">Attenuated Radon Transform</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#EadieHofsteeEquationUniUniReactionwithoutProductandCompetitiveCompleteInhibitionSteadyStateAssumption -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#EadieHofsteeEquationUniUniReactionwithoutProductandCompetitiveCompleteInhibitionSteadyStateAssumption">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CompetitiveInhibitionConstantUniUniReactionReversibleInhibition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitorConcentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InitialReactionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LimitingReactionRateUniUniReactionForward"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisConstantSubstrateUniUniReactionSteadyStateAssumption"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SubstrateConcentration"/>
        <linearizes rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationUniUniReactionwithoutProductandCompetitiveCompleteInhibitionSteadyStateAssumption"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0 = V_{max,f} - K_S (1 + \frac{c_I}{K_{ic}}) \frac{v_0}{c_S}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_S$, Michaelis Constant Substrate (Uni Uni Reaction - Steady State Assumption)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{ic}$, Competitive Inhibition Constant (Uni Uni Reaction Reversible Inhibition)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V_{max,f}$, Limiting Reaction Rate (Uni Uni Reaction - Forward)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_I$, Inhibitor Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_S$, Substrate Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0$, Initial Reaction Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isLinear>
        <terms1:description xml:lang="en">equation for uni uni reaction without product and competitive complete inhibition following steady state assumption</terms1:description>
        <rdfs:label xml:lang="en">Eadie Hofstee Equation (Uni Uni Reaction without Product and Competitive Complete Inhibition - Steady State Assumption)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674327"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#EadieHofsteeEquationUniUniReactionwithoutProductandMixedCompleteInhibitionSteadyStateAssumption -->

