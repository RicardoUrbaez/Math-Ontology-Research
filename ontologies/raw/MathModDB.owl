        <terms1:description xml:lang="en">standard compartment-based model for morphogen gradient modelling</terms1:description>
        <rdfs:comment xml:lang="en">Signaling molecules (A) are produced locally, and morphogen molecules (B) are produced from A. Diffusion corresponds to two chains of chemical reactions (picture).</rdfs:comment>
        <rdfs:label xml:lang="en">Standard Compartment-Based Morphogen Gradient Model</rdfs:label>
    </owl:NamedIndividual>
    


