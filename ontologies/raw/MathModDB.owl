    <!-- https://mardi4nfdi.de/mathmoddb#UncompetitiveInhibitionConstantUniUniReactionReversibleInhibition -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#UncompetitiveInhibitionConstantUniUniReactionReversibleInhibition">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UncompetitiveInhibitionConstantUniUniReactionReversibleInhibition"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstant"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iu} \equiv \frac{k_{-4}}{k_4} $</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iu}$, Uncompetitive Inhibition Constant (Uni Uni Reaction Reversible Inhibition)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_4$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-4}$, Reaction Rate Constant</inDefiningFormulation>
        <isChemicalConstant rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isChemicalConstant>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <terms1:description xml:lang="en">constant for the uncompetitive inhibition in an uni uni reaction</terms1:description>
        <rdfs:label xml:lang="en">Uncompetitive Inhibition Constant (Uni Uni Reaction Reversible Inhibition)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674020"/>
    </owl:NamedIndividual>
    


