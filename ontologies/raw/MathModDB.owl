    <!-- https://mardi4nfdi.de/mathmoddb#MolecularOrientation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MolecularOrientation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PolarAngle"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumStateVector"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$O = \langle \psi | \cos \theta | \psi \rangle$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi$, Quantum State Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\theta$, Polar Angle</inDefiningFormulation>
        <terms1:description xml:lang="en">expectation value indicating in how far molecular axes point in the same direction as space fxed axes</terms1:description>
        <rdfs:comment xml:lang="en">Typically achieved by the interaction of permanent dipole moments with external electrostatic fields.</rdfs:comment>
        <rdfs:label xml:lang="en">Molecular Orientation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674475"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MolecularPhysics -->

