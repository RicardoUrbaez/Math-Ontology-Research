        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isTimeContinuous>
        <terms1:description xml:lang="en">propagation of the action potential</terms1:description>
        <rdfs:comment xml:lang="en">Accounts for the propagation of the action potential. Necessary because Subcellular model only considers isolated processes in one sacomere.</rdfs:comment>
        <rdfs:label xml:lang="en">Action Potential Propagation Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674954"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ActiveContractileForce -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ActiveContractileForce">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ActiveContractileForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MaximumIsometricMuscleForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MuscleContractionVelocity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MuscleLength"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F_{\text{ACE}}(t) \equiv  F^{\text{M}}_{0} \cdot a(t) \cdot f_{\text{L}}(\mathcal{l}_{\text{M}}(t)) \cdot f_{\text{v}} (\nu_{\text{M}}(t))$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F^{\text{M}}_{0}$, Maximum Isometric Muscle Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F_{\text{ACE}}$, Active Contractile Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{l}_{\text{M}}$, Muscle Length</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\nu_{\text{M}}$, Muscle Contraction Velocity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">active force generated by the contractile element</terms1:description>
        <rdfs:label xml:lang="en">Active Contractile Force</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673730"/>
    </owl:NamedIndividual>
    


