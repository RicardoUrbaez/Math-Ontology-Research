        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha$, Contact Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\beta$, Birth Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">equation for the susceptibles in the SIR model with births and deaths</terms1:description>
        <rdfs:label xml:lang="en">Susceptibles at Time Step n+1 in the Discrete SIR Model with Births and Deaths</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674587"/>
