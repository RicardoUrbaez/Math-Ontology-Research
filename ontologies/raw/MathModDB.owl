    <!-- https://mardi4nfdi.de/mathmoddb#InitialValueForElectronScattering -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#InitialValueForElectronScattering">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsInitialConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#DynamicalElectronScatteringModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AmplitudeOfElectronWave"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReciprocalLattice"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReciprocalLatticeVectors"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\varphi_{\mathbf{g}}(0) =\delta_{\mathbf{0},\mathbf{g}} \quad \text{for } \mathbf{g}\in \Lambda_m^*$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Lambda^*_m$, Reciprocal Lattice</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\varphi_{\mathbf{g}}(0)$, Amplitude of Electron Wave</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$g$, Reciprocal Lattice Vectors</inDefiningFormulation>
        <terms1:description xml:lang="en">initial value for electron scattering, used for modeling of transmission electron microscopy</terms1:description>
        <rdfs:label xml:lang="en">Initial Value for Electron Scattering</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674130"/>
    </owl:NamedIndividual>
    


