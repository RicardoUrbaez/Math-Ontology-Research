        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$y_0$, Free Fall Initial Height</inDefiningFormulation>
        <terms1:description xml:lang="en">initial height and velocity of an object before it falls through a fluid or a gas</terms1:description>
        <rdfs:label xml:lang="en">Free Fall Initial Condition</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674368"/>
    </owl:NamedIndividual>
    


