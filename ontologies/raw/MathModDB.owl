        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">ordinary differential equation describing the concentration over time in a ping pong bi bi reaction</terms1:description>
        <rdfs:label xml:lang="en">Substrate 2 Concentration ODE (Bi Bi Reaction Ping Pong)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674219"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#Substrate2ConcentrationODEBiBiTheorellChance -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#Substrate2ConcentrationODEBiBiTheorellChance">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{S_2}}{dt} = k_{-2} c_{EP_2} c_{P_1} - k_{2} c_{ES_1} c_{S_2}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{S_2}}{dt}$, Reaction Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{EP_2}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{ES_1}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{P_1}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S_2}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-2}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{2}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">ordinary differential equation describing the concentration over time in a Theorell-Chance bi bi reaction</terms1:description>
        <rdfs:label xml:lang="en">Substrate 2 Concentration ODE (Bi Bi Reaction Theorell-Chance)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674240"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SubstrateConcentration -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SubstrateConcentration">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <terms1:description xml:lang="en">amount of substrate present in a reaction environment</terms1:description>
        <rdfs:label xml:lang="en">Substrate Concentration</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673927"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SubstrateConcentrationODEUniUni -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SubstrateConcentrationODEUniUni">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{S}}{dt}=-k_{1}*c_{E}*c_{S}+k_{-1}*c_{ES}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{S}}{dt}$, Reaction Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{ES}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{E}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-1}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{1}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">ordinary differential equation describing the concentration over time in a uni uni reaction</terms1:description>
        <rdfs:label xml:lang="en">Substrate Concentration ODE (Uni Uni Reaction)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674581"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SurfaceForceDensity -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SurfaceForceDensity">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">concept that describes the force per unit area acting on a surface</terms1:description>
        <rdfs:label xml:lang="en">Surface Force Density</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673845"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SusceptibleCitiesODE -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SusceptibleCitiesODE">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactNetwork"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfInfectedCities"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfRegions"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfSusceptibleCities"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateOfChangeOfSusceptibleCities"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SpreadingRateTimeDependent"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{ds_m(t)}{dt} = -s_m(t) \alpha(t) \sum_{n=1}^{N_R} G_{m,n} i_n(t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$G_{m,n}$, Contact Network</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N_R$, Number of Regions</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha(t)$, Spreading Rate (Time-dependent)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{ds_m(t)}{dt}$, Rate of Change of Susceptible Cities</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$i_n(t)$, Number of Infected Cities</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s_m(t)$, Number of Susceptible Cities</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDynamic>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isLinear>
        <terms1:description xml:lang="en">ordinary differential equation describing the rate of change of susceptible cities</terms1:description>
        <rdfs:label xml:lang="en">Susceptible Cities ODE</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674582"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SusceptibleIndividuals -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SusceptibleIndividuals">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#IntegerDimensionless"/>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <terms1:description xml:lang="en">number of susceptible individuals</terms1:description>
        <rdfs:comment xml:lang="en">The number of susceptible individuals. When a susceptible and an infectious individual come into &quot;infectious contact&quot;, the susceptible individual contracts the disease and transitions to the infectious compartment.</rdfs:comment>
        <rdfs:label xml:lang="en">Number of Susceptible Individuals</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673882"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SusceptibleInfectiousEpidemicSpreadingModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SusceptibleInfectiousEpidemicSpreadingModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleInfectiousEpidemicSpreadingODESystem"/>
        <containsInitialCondition rdf:resource="https://mardi4nfdi.de/mathmoddb#InitialNumberOfInfectedCities"/>
        <models rdf:resource="https://mardi4nfdi.de/mathmoddb#RomanizationSpreadingInNorthernTunesia"/>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDynamic>
        <terms1:description xml:lang="en">model for the susceptible infectious epidemic spreading on a network with time-dependent spreading rate.</terms1:description>
        <rdfs:label xml:lang="en">Susceptible Infectious Epidemic Spreading Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675419"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SusceptibleInfectiousEpidemicSpreadingODESystem -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SusceptibleInfectiousEpidemicSpreadingODESystem">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ConservationOfCityNumbers"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactNetwork"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfCities"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfInfectedCities"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfRegions"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfSusceptibleCities"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateOfChangeOfSusceptibleCities"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Region"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SpreadingRateTimeDependent"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleCitiesODE"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align} \frac{ds_m(t)}{dt} &amp;= -s_m(t) \alpha(t) \sum_{n=1}^{N_R} G_{m,n} i_n(t) \\ i_m(t) &amp;= P_m - s_m(t) \end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$G_{m,n}$, Contact Network</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N_R$, Number of Regions</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$P_m$, Number of Cities</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha(t)$, Spreading Rate (Time-dependent)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{ds_m(t)}{dt}$, Rate of Change of Susceptible Cities</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$i$, Number of Infected Cities</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$m$, Region</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Region</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s_m(t)$, Number of Susceptible Cities</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDynamic>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isLinear>
        <terms1:description xml:lang="en">equations describing the spreading in a susceptible infectious epidemic model on a network with time-dependent spreading rate</terms1:description>
        <rdfs:label xml:lang="en">Susceptible Infectious Epidemic Spreading ODE System</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674563"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SusceptibleInfectiousRemovedModelWithBirthsAndDeaths -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SusceptibleInfectiousRemovedModelWithBirthsAndDeaths">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
