        <models rdf:resource="https://mardi4nfdi.de/mathmoddb#MuscleMovement"/>
        <terms1:description xml:lang="en">mathematical model of the neuromuscular system combining continuum mechanics models with electrophysiological models</terms1:description>
        <rdfs:label xml:lang="en">Electrophysiological Muscle Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675402"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ElectrophysiologicalMuscleModelODESystem -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ElectrophysiologicalMuscleModelODESystem">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectrophysiologicalMuscleModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DisplacementMuscleTendon"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LumpedActivationParameter"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MaterialDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MaterialPointAcceleration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MaterialPointVelocity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Pressure"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StressTensorPiolaKirchhoff"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}  \rho_{\text{M}1} \mathbf{\ddot{x}}_{\text{M}1} &amp;= \mathbf{\nabla} \cdot \left(\mathbf{P}_{\text{passive}}(\mathbf{F}_{\text{M}1}) + \mathbf{P}_{\text{active}}(\mathbf{F}_{\text{M}1}, \gamma_{\text{M}1}) - p_{\text{M}1}\mathbf{F}^{-T}_{\text{M}1} \right), &amp;\mathbf{\nabla} \cdot \ \mathbf{\dot{x}}_{\text{M}1} = 0 \ &amp;\text{in} \ \Omega_{\text{M}1}\times [0,T_{\text{end}})\\             \rho_{\text{M}2} \mathbf{\ddot{x}}_{\text{M}2} &amp;= \mathbf{\nabla} \cdot \left(\mathbf{P}_{\text{passive}}(\mathbf{F}_{\text{M}2}) + \mathbf{P}_{\text{active}}(\mathbf{F}_{\text{M}2}, \gamma_{\text{M}2}) - p_{\text{M}2}\mathbf{F}^{-T}_{\text{M}2} \right),  &amp;\nabla \cdot \  \mathbf{\dot{x}}_{\text{M}2} = 0 \ &amp;\text{in} \  \Omega_{\text{M}2}\times [0,T_{\text{end}})\\  \rho_{\text{T}}\mathbf{\ddot{x}}_\text{T}&amp;= \mathbf{\nabla} \cdot \left(\mathbf{P}_\text{passive}(\mathbf{F}_{\text{T}}) - p_\text{T}\mathbf{F}^{-T}_{\text{T}}\right), &amp;\mathbf{\nabla} \cdot \  \mathbf{\dot{x}}_{\text{T}}=0 \ &amp; \text{in} \ \Omega_{\text{T}}\times [0,T_{\text{end}}) \end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\ddot{\mathbf{x}}$, Material Point Acceleration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\dot{\mathbf{x}}$, Material Point Velocity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, Lumped Activation Parameter</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathbf{P}$, Stress Tensor (Piola-Kirchhoff)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathbf{x}$, Displacement Muscle Tendon</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho$, Material Density</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p$, Pressure</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">three-dimensional electrophysiological model for a muscle</terms1:description>
        <rdfs:comment xml:lang="en">One continuum mechanics three-dimensional model for each participant. The equations originate from conservation of mass and momentum for each participant.</rdfs:comment>
        <rdfs:label xml:lang="en">Electrophysiological Muscle ODE System</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674244"/>
    </owl:NamedIndividual>
    


