        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumStateVectorStationary"/>
        <terms1:description xml:lang="en">adiabatic eigen state of the light particle(s) dynamics in quantum-classical models</terms1:description>
        <rdfs:comment xml:lang="en">Note the parametric dependence of the light particle(s) eigen states in quantum-classical dynamics</rdfs:comment>
        <rdfs:label xml:lang="en">Light Particle Eigen State</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticleExpansionCoefficient -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticleExpansionCoefficient">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticlePosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleEigenState"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleExpansionCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticlePosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleStateVector"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumNumber"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_n\equiv\langle\phi_n(R)|\psi\rangle_r$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R$, Heavy Particle Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi$, Light Particle Eigen State</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi$, Light Particle State Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Light Particle Expansion Coefficient</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Quantum Number</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r$, Light Particle Position</inDefiningFormulation>
        <terms1:description xml:lang="en">adiabatic expansion coefficient of the light particle(s) quantum state in quantum-classical models</terms1:description>
        <rdfs:label xml:lang="en">Light Particle Expansion Coefficient</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticleHamiltonian -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticleHamiltonian">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumClassicalHamiltonian"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleHamiltonian"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleKineticOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumClassicalPotential"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianOperator"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{h}\equiv\hat{t}+\hat{V}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V$, Quantum-Classical Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$h$, Light Particle Hamiltonian</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Light Particle Kinetic Operator</inDefiningFormulation>
        <terms1:description xml:lang="en">governing the light particle(s) dynamics in quantum-classical models</terms1:description>
        <rdfs:comment xml:lang="en">Note that this Hamiltonian is parametrically dependent on the heavy partivcle(s) positions through the quantum-classical potential</rdfs:comment>
        <rdfs:label xml:lang="en">Light Particle Hamiltonian</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Mixed_quantum-classical_dynamics"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q65091550"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticleKineticOperator -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticleKineticOperator">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleKineticOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleMass"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticlePosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PlanckConstant"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumKineticOperator"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{T} \equiv - \frac{\hbar^2}{2m} \nabla_r^2$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$M$, Light Particle Mass</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R$, Light Particle Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{T}$, Light Particle Kinetic Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hbar$, Planck Constant</inDefiningFormulation>
        <terms1:description xml:lang="en">kinetic energy operator of the light particle(s) in quantum-classical dynamics models</terms1:description>
        <rdfs:label xml:lang="en">Light Particle Kinetic Operator</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticleMass -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticleMass">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ParticleMass"/>
        <terms1:description xml:lang="en">mass(es) of the light particle(s) in quantum-classical dynamics models</terms1:description>
        <rdfs:label xml:lang="en">Light Particle Mass</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticCoupling1 -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticCoupling1">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticlePosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleEigenState"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticCoupling1"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticlePosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumNumber"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}d_{nm}^k &amp; \equiv &amp; \langle \phi_n(R) | \nabla_{R_k} | \phi_m(R) \rangle_r \\ d_{nn}^k &amp;=&amp; 0 \\ d_{nm}^k &amp;=&amp; -\left( d_{mn}^k \right)^\ast \end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R$, Heavy Particle Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi$, Light Particle Eigen State</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$d$, Light Particle Nonadiabatic Coupling 1</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$m$, Quantum Number</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Quantum Number</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r$, Light Particle Position</inDefiningFormulation>
        <terms1:description xml:lang="en">first order nonadiabatic coupling of the light particle(s) quantum states induced by heavy particle(s) dynamics in quantum-classical models</terms1:description>
        <rdfs:comment xml:lang="en">Note that the ﬁrst-order coupling tensor is anti-Hermitian with respect to interchange of the adiabatic state indices</rdfs:comment>
        <rdfs:label xml:lang="en">Light Particle Nonadiabatic Coupling 1</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticCoupling2 -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticCoupling2">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticlePosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleEigenState"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticCoupling2"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticlePosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumNumber"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t_{nm} \equiv \langle \phi_n(R) | \Delta_R | \phi_m(R) \rangle_r$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R$, Heavy Particle Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi$, Light Particle Eigen State</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$m$, Quantum Number</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Quantum Number</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r$, Light Particle Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Light Particle Nonadiabatic Coupling 2</inDefiningFormulation>
        <terms1:description xml:lang="en">second order nonadiabatic coupling of the light particle(s) quantum states induced by heavy particle(s) dynamics in quantum-classical models</terms1:description>
        <rdfs:label xml:lang="en">Light Particle Nonadiabatic Coupling 2</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticCriterion1 -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticCriterion1">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#FewestSwitchesSurfaceHopping1"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticProbability1"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RandomNumber"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$P&gt;r$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$P$, Light Particle Nonadiabatic Probability 1</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r$, Random Number</inDefiningFormulation>
        <terms1:description xml:lang="en">stochastic criterion for a nonadiabatic transition of the light particle(s) in quantum-classical dynamics</terms1:description>
        <rdfs:comment xml:lang="en">Note that the nonadiabatic transition probabilities are compared against random numbers uniformly distributed between 0 and 1.</rdfs:comment>
        <rdfs:label xml:lang="en">Light Particle Nonadiabatic Criterion 1</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticCriterion2 -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticCriterion2">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#FewestSwitchesSurfaceHopping2"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticProbability2"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RandomNumber"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$P&gt;r$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$P$, Light Particle Nonadiabatic Probability 2</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r$, Random Number</inDefiningFormulation>
        <terms1:description xml:lang="en">stochastic criterion for a nonadiabatic transition of the light particle(s) in quantum-classical dynamics</terms1:description>
        <rdfs:comment xml:lang="en">Note that the nonadiabatic transition probabilities are compared against random numbers uniformly distributed between 0 and 1.</rdfs:comment>
        <rdfs:label xml:lang="en">Light Particle Nonadiabatic Criterion 2</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticProbability1 -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticProbability1">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticleVelocity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleDensityMatrix"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticCoupling1"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticProbability1"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PlanckConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align} P_{mn}(t,t+\Delta t) &amp;\equiv&amp; \frac {\rho_{mm}(t)-\rho_{mm}(t+\Delta t)} {\rho_{mm}(t)} \\ &amp;=&amp; \max \left[ 0, - \frac{2 \Delta t}  {\hbar \rho_{mm}} \Re ( \rho_{mn} ) d_{mn}  \cdot v \right] \end{align}$</definingFormulation>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Zeit</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$P$, Light Particle Nonadiabatic Probability 1</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hbar$, Planck constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho$, Light Particle Density Matrix</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$d$, Light Particle Nonadiabatic Coupling 1</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v$, Heavy Particle Velocity</inDefiningFormulation>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">FSSH-1 probability for a nonadiabatic transition of the light particle(s) subsystem, induced by the heavy particle(s) dynamics</terms1:description>
        <rdfs:comment xml:lang="en">Numerical problems may occur due to the (near) divergence of the nonadiabatic coupling tensor elements, thus enforcing very small time steps</rdfs:comment>
        <rdfs:label xml:lang="en">Light Particle Nonadiabatic Probability 1</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.1063/1.459170"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticProbability2 -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticProbability2">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleDensityMatrix"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleEigenEnergy"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleExpansionCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticProbability2"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleTimeOverlap"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PlanckConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}P_{mn}(t,t+\Delta t) &amp;\equiv&amp; \frac {\rho_{mm}(t)-\rho_{mm}(t+\Delta t)} {\rho_{mm}(t)}\\ c(t+\Delta t)&amp;=&amp; \exp (-\mathrm{i} E \Delta t / \hbar) \Gamma (t,t+\Delta t) c(t) \end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$E$, Light Particle Eigen Energy</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$P$, Light Particle Nonadiabatic Probability 2</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Gamma$, Light Particle Time Overlap</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hbar$, Planck Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho$, Light Particle Density Matrix</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Light Particle Expansion Coefficient</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">FSSH-2 probability for a nonadiabatic transition of the light particle(s) subsystem, induced by the heavy particle(s) dynamics</terms1:description>
        <rdfs:comment xml:lang="en">Numerical problems due to the (near) divergence of the nonadiabatic coupling tensor elements are circumvented here, thus allowing much longer time steps than in Tully&apos;s traditional FSSH-1</rdfs:comment>
        <rdfs:label xml:lang="en">Light Particle Nonadiabatic Probability 2</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.1021/acs.jctc.4c00089"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticTransitions -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticleNonadiabaticTransitions">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ComputationalTask"/>
        <terms1:description xml:lang="en">nonadiabatic transitions of the light particle(s) in quantum-classical dynamics models</terms1:description>
        <rdfs:comment xml:lang="en">Note that in quantum-classical dynamics the effective Hamiltonian governing the non-adiabatic transitions of the light particles parametrically depends on the heavy particle(s) positions.</rdfs:comment>
        <rdfs:comment xml:lang="en">Typically, the many different approaches to quantum-classical dynamics, most notably surface hopping trajectories, differ in the way how the nonadiabatic transition probabilities are calculated.</rdfs:comment>
        <rdfs:label xml:lang="en">Light Particle Nonadiabatic Transitions</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Mixed_quantum-classical_dynamics"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticlePosition -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticlePosition">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ParticlePosition"/>
        <terms1:description xml:lang="en">position(s) of the light particle(s) in quantum-classical dynamics models</terms1:description>
        <rdfs:label xml:lang="en">Light Particle Position</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticlePropagation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticlePropagation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ComputationalTask"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleTISE"/>
        <similarTo rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumTimeEvolution"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumTimeEvolution"/>
        <terms1:description xml:lang="en">propagating the (quantum!) state of the light particle(s) in quantum-classical dynamics models</terms1:description>
        <rdfs:comment xml:lang="en">Note that in quantum-classical dynamics the effective Hamiltonian governing the quantum dynamics of the light particles parametrically depends on the heavy particle(s) positions.</rdfs:comment>
        <rdfs:comment xml:lang="en">The electrons are usually treated by a local approximation of the TDSE, i.e., they depend only on the electronic forces and couplings at the instantaneous position of the nuclei.</rdfs:comment>
        <rdfs:label xml:lang="en">Light Particle Propagation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Mixed_quantum-classical_dynamics"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticleStateVector -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticleStateVector">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumStateVectorDynamic"/>
        <terms1:description xml:lang="en">quantum state vector of the light particle(s) in quantum-classical models</terms1:description>
        <rdfs:label xml:lang="en">Light Particle State Vector</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticleTDSE -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticleTDSE">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticlePosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ImaginaryUnit"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleHamiltonian"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticlePosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleStateVector"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PlanckConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#SchroedingerEquationTimeDependent"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathrm{i} \hbar \frac{\partial}{\partial t} | \psi(t) \rangle_r = \hat H(r;R) | \psi(t) \rangle_r$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$H$, Light Particle Hamiltonian</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R$, Heavy Particle Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hbar$, Planck Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathrm{i}$, Imaginary Unit</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi$, Light Particle State Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r$, Light Particle Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">time-dependent Schrödinger equation for the light particle(s) dynamics in quantum-classical models</terms1:description>
        <rdfs:comment xml:lang="en">Note that the underlying Hamiltonian for the light particle(s) is parametrically dependent on the heavy particle(s) position(s).</rdfs:comment>
        <rdfs:label xml:lang="en">Light Particle TDSE</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Mixed_quantum-classical_dynamics"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q65091550"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticleTISE -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticleTISE">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticlePosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleEigenEnergy"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleEigenState"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleHamiltonian"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticlePosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumNumber"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#SchrödingerEquationTimeIndependent"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat H(r;R) | \phi_n(R) \rangle_r = E_n(R) | \phi_n(R) \rangle_r$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$E$, Light Particle Eigen Energy</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$H$, Light Particle Hamiltonian</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R$, Heavy Particle Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Quantum Number</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r$, Light Particle Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$| \phi \rangle$, Light Particle Eigen State</inDefiningFormulation>
        <terms1:description xml:lang="en">time-independent Schrödinger equation for the light particle(s) dynamics in quantum-classical models</terms1:description>
        <rdfs:comment xml:lang="en">Note that the resulting eigen states and eigen energies for the light particle(s) are parametrically dependent on the heavy particle(s) position(s).</rdfs:comment>
        <rdfs:label xml:lang="en">Light Particle TISE</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Mixed_quantum-classical_dynamics"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q65091550"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticleTimeOverlap -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticleTimeOverlap">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleEigenState"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleTimeOverlap"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumNumber"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Gamma_{nm} (t,t+\tau)\equiv\langle\phi_n(t+\tau)|\phi_m(t)\rangle_r$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Gamma$, Light Particle Time Overlap</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi$, Light Particle Eigen State</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tau$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$m$, Quantum Number</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Quantum Number</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">overlap of light particle(s) eigen states after one time step</terms1:description>
        <rdfs:label xml:lang="en">Light Particle Time Overlap</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LikelihoodValue -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LikelihoodValue">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">probability density of observed data viewed as a function of the parameters of a statistical model</terms1:description>
        <rdfs:comment xml:lang="en">Measure used in statistics to quantify how well a given set of model parameters explains observed data.</rdfs:comment>
        <rdfs:label xml:lang="en">Likelihood Value</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Likelihood_function"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674037"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q45284"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LimitingDistributionOfIndividuals -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LimitingDistributionOfIndividuals">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#RealDimensionless"/>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <terms1:description xml:lang="en">limiting distribution of individuals</terms1:description>
        <rdfs:label xml:lang="en">Limiting Distribution of Individuals</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673766"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LimitingDistributionOfIndividualsFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LimitingDistributionOfIndividualsFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <assumes rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfIndividualsTendsToInfinityAssumption"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PartialMeanFieldOpinionModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AttractionForceAtOpinion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LimitingDistributionOfIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NoiseStrength"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Opinion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateOfSwitchingInfluencers"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#EmpiricalDistributionOfIndividualsFormulation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\partial_t \rho_{m, l}(x, t)=\frac{1}{2} \sigma^2 \Delta \rho_{m, l}(x, t)-\nabla \cdot\left(\rho_{m, l}(x, t) \mathcal{F} \left(x, y_m, z_l, \rho\right)\right) \quad+\sum_{l^{\prime} \neq l}\left(-\Lambda_m^{\rightarrow l^{\prime}}(x, t) \rho_{m, l}(x, t)+\Lambda_m^{\rightarrow l}(x, t) \rho_{m, l^{\prime}}(x, t)\right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Lambda_m^{\rightarrow l}$, Rate of Switching Influencers</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{F}$, Attraction Force at Opinion</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\partial_t \rho_{m, l}(x, t)$, Limiting Distribution of Individuals</inDefiningFormulation>
