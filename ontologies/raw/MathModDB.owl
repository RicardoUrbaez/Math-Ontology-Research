        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{2}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{4}$, Reaction Rate Constant</inDefiningFormulation>
        <terms1:description xml:lang="en">constant representing the concentration at which the reaction rate is half of its maximum value</terms1:description>
        <rdfs:label xml:lang="en">Michaelis Constant Substrate 1 (Bi Bi Reaction Ping Pong - Michaelis Menten Model - Steady State Assumption)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674490"/>
    </owl:NamedIndividual>
    


