        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EnzymeProduct1ComplexConcentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EnzymeProduct1Product2ComplexConcentration"/>
