        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#Rate"/>
        <terms1:description xml:lang="en">rate at which an individual switches the influencer they are following at a given time</terms1:description>
        <rdfs:label xml:lang="en">Rate of Switching Influencers</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674038"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#RateOfSwitchingInfluencersFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#RateOfSwitchingInfluencersFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#OpinionModelWithInfluencersAndMedia"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LinkRecommendationFunction"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MediumInfluencerFraction"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Opinion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PairFunction"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateOfSwitchingInfluencers"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ScalingParameterForSwitchingInfluencers"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Lambda_m^{\rightarrow l}(x, t)=\eta \psi\left(\left\|z_l-x\right\|\right) r\left(\frac{n_{m, l}(t)}{\sum_{m^{\prime}=1}^M n_{m^{\prime}, l}(t)}\right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Lambda_m^{\rightarrow l}(x, t)$, Rate of Switching Influencers</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\eta$, Scaling Parameter for Switching Influencers</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi$, Pair Function</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n_{m, l}$, Medium Influencer Fraction</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r$, Link Recommendation Function</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Opinion</inDefiningFormulation>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <terms1:description xml:lang="en">rate of switching influencers</terms1:description>
        <rdfs:comment xml:lang="en">Each individual i can at any time t switch its current influencer l′ to another influencer l with a given rate. By setting the pair function to ψ(x) = exp(−x),
an individual has an exponentially higher rate to switch to an influencer that has a similar opinion than to an influencer with a very different opinion. This rate of switching influencers is defined by this formulation.</rdfs:comment>
        <rdfs:label xml:lang="en">Rate of Switching Influencers Formulation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674558"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ReactionDiffusionMasterEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ReactionDiffusionMasterEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#StandardCompartmentBasedMorphogenGradientModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#JointProbability"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionOperator"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac {\partial p}{\partial t} (\mathbf{n}, \mathbf{m}, t) = (\mathcal{D} + \mathcal{R}) p(\mathbf{n}, \mathbf{m}, t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{D}$, &apos;Diffusion Operator&apos;</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{R}$, Reaction Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p(\mathbf{n}, \mathbf{m}, t)$,  Joint Probability</inDefiningFormulation>
        <terms1:description xml:lang="en">corresponds to the system of reactions</terms1:description>
        <rdfs:label xml:lang="en">Reaction Diffusion Master Equation</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ReactionDiffusionSystem -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ReactionDiffusionSystem">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <assumedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#StandardCompartmentBasedMorphogenGradientModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Morphogen"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Signal"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">\begin{aligned}
\emptyset \rightarrow A \\
A \rightarrow B \rightarrow \emptyset
\end{aligned}</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Signal</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B$, Morphogen</inDefiningFormulation>
        <terms1:description xml:lang="en">molecules of Signal (A) are continuously produced and converted into molecules of morphogen (B)</terms1:description>
        <rdfs:comment xml:lang="en">∅ is interpreted as sources and sinks of molecules. The reaction producing A is locally restricted. A is converted to B at a rate of k₂.</rdfs:comment>
        <rdfs:label xml:lang="en">Reaction Diffusion System</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ReactionOperator -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ReactionOperator">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Operators_O_i_Minus"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Operators_O_i_Plus"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{aligned} \mathcal{R} f(\mathbf{n}, \mathbf{m}):\equiv &amp; k_1\left\{f\left(\mathcal{O}_1^{-} \mathbf{n}, \mathbf{m}\right)-f(\mathbf{n}, \mathbf{m})\right\} \\ &amp; +k_2 \sum_{i=1}^K\left\{\left(n_i+1\right) f\left(\mathcal{O}_i^{+} \mathbf{n}, \mathcal{O}_i^{-} \mathbf{m}\right)-n_i f(\mathbf{n}, \mathbf{m})\right\} \\ &amp; +k_3 \sum_{i=1}^K\left\{\left(m_i+1\right) f\left(\mathbf{n}, \mathcal{O}_i^{+} \mathbf{m}\right)-m_i f(\mathbf{n}, \mathbf{m})\right\} .\end{aligned}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{O}_i^{+}$, Operators Oi Plus</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{O}_i^{-}$, Operators Oi Minus</inDefiningFormulation>
        <terms1:description xml:lang="en">reaction operator used in the reaction diffusion master equation</terms1:description>
        <rdfs:label xml:lang="en">Reaction Operator</rdfs:label>
    </owl:NamedIndividual>
    


