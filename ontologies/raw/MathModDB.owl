    <!-- https://mardi4nfdi.de/mathmoddb#RateOfChangeOfPopulationDensityFractionOfExposedMeanODE -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#RateOfChangeOfPopulationDensityFractionOfExposedMeanODE">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#ODESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AlleeThreshold"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AsymptomaticInfectionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AsymptomaticRecoveryRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposedInTheODERegionMean"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposedInThePDERegion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfInfectiousInTheODERegionMean"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfSusceptiblesInTheODERegionMean"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PopulationDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateOfBecomingInfectious"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SymptomaticInfectionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnitNormalVector"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$ \dot{\bar{e}}_2 \approx\left(1-\frac{A}{\bar{n}_2+n_0}\right) \bar{s}_2\left(\beta_e \bar{e}_2+\beta_i \bar{i}_2\right)-\sigma \bar{e}_2-\phi_e \bar{e}_2-\frac{1}{\left|\Omega_2\right|} \int_{\Gamma} \nu_1^T D \nabla e_1 d o $</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Allee Threshold</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$D$, Diffusion Coefficient for SEIR Model</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\bar{e}_2$, Fraction Of Population Density Of Exposed In The ODE Region (Mean)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\bar{i}_2$, Fraction Of Population Density Of Infectious In The ODE Region (Mean)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\bar{s}_2$, Fraction Of Population Density Of Susceptibles In The ODE Region (Mean)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\beta_e$, Asymptomatic Infection Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\beta_i$, Symptomatic Infection Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\nu_1^T$, Unit Normal Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi_e$, Asymptomatic Recovery Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Rate Of Becoming Infectious</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$e_1$, Fraction Of Population Density Of Exposed In The PDE Region</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Population Density</inDefiningFormulation>
        <terms1:description xml:lang="en">rate of change of the mean population density of exposed individuals described by an ODE</terms1:description>
        <rdfs:comment xml:lang="en">Ordinary Differential Equation describing the rate of change of the population density of exposed with a right-hand side contribution from the flux of the PDE solution 𝑒₁ across the interface Γ.</rdfs:comment>
        <rdfs:label xml:lang="en">Rate Of Change Of Population Density Fraction Of Exposed Mean ODE</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#RateOfChangeOfPopulationDensityFractionOfExposedPDE -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#RateOfChangeOfPopulationDensityFractionOfExposedPDE">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PDESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AlleeThreshold"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AsymptomaticInfectionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AsymptomaticRecoveryRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposed"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfInfectious"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfSusceptibles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PopulationDensity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateOfBecomingInfectious"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SymptomaticInfectionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\partial_t e =\operatorname{div}(D \nabla e)+\left(1-\frac{A}{n+n_0}\right) s\left(\beta_e e+\beta_i i\right)-\sigma e-\phi_e e $</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Allee Threshold</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$D$, Diffusion Coefficient for SEIR Model</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\beta_e$, Asymptomatic Infection Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\beta_i$, Symptomatic Infection Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi_e$, Asymptomatic Recovery Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Rate of Becoming Infectious</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$e$, Fraction of Population Density of Exposed</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$i$, Fraction of Population Density of Infectious</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Population Density</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s$, Fraction of Population Density of Susceptibles</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <terms1:description xml:lang="en">partial derivative of population density fraction of exposed</terms1:description>
        <rdfs:label xml:lang="en">Rate of Change of Population Density Fraction of Exposed PDE</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674554"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#RateOfChangeOfPopulationDensityFractionOfInfectiousMeanODE -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#RateOfChangeOfPopulationDensityFractionOfInfectiousMeanODE">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#ODESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposedInTheODERegionMean"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfInfectiousInTheODERegionMean"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfInfectiousInThePDERegion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfectedRecoveryRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateOfBecomingInfectious"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnitNormalVector"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">\dot{\bar{i}}_2 \approx \sigma \bar{e}_2-\phi_i \bar{i}_2-\frac{1}{\left|\Omega_2\right|} \int_{\Gamma} \nu_1^T D \nabla i_1 d o</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$D$, Diffusion Coefficient for SEIR Model</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\bar{e}_2$, Fraction Of Population Density Of Exposed In The ODE Region (Mean)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\bar{i}_2$, Fraction Of Population Density Of Infectious In The ODE Region (Mean)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\nu_1^T$, Unit Normal Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi_i$, Infected Recovery Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Rate Of Becoming Infectious</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$i_1$, Fraction Of Population Density Of Infectious In The PDE Region</inDefiningFormulation>
        <terms1:description xml:lang="en">rate of change of the mean population density of infectious individuals described by an ODE</terms1:description>
        <rdfs:comment xml:lang="en">Ordinary Differential Equation describing the rate of change of the population density of Infectious with a right-hand side contribution from the flux of the PDE solution 𝑖₁ across the interface Γ.</rdfs:comment>
        <rdfs:label xml:lang="en">Rate Of Change Of Population Density Fraction Of Infectious Mean ODE</rdfs:label>
    </owl:NamedIndividual>
    


