    <!-- https://mardi4nfdi.de/mathmoddb#SteadyStateAssumption -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SteadyStateAssumption">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ComplexedEnzymeConcentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{EX}}{dt} = 0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{EX}$, Complexed Enzyme Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">rate of bound enzyme formation and breakdown is equal</terms1:description>
        <rdfs:label xml:lang="en">Steady State Assumption</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674154"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SteadyStateEquations -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SteadyStateEquations">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#StandardCompartmentBasedMorphogenGradientModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AverageNumberOfMoleculesOfMorphogen"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AverageNumberOfMoleculesOfSignal"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionCoefficientA"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionCoefficientB"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#JumpRateOfA"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#JumpRateOfB"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Length"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MatrixS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateConstant"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">\begin{align*}
\left(\frac{D_A}{h^2} S-k_2 I\right) \overline{\mathbf{A}}=-k_1 \mathbf{e}_1
\quad\left(\frac{D_B}{h^2} S-k_3 I\right) \overline{\mathbf{B}}=-k_2 \overline{\mathbf{A}}
\end{align*}</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$D_{A}$, Diffusion Coefficient A</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$D_{B}$, Diffusion Coefficient B</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S$, Matrix S</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{D_A}{h^2}$, Jump Rate of A</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{D_B}{h^2}$, Jump Rate of B</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\overline{A}_i$,  Average Number Of Molecules Of Signal</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\overline{B}_i$,  Average Number Of Molecules Of Morphogen</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$h$, Length</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_1$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_2$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_3$, Reaction Rate Constant</inDefiningFormulation>
        <terms1:description xml:lang="en">steady state equations satisfied by average number of molecules of A and B</terms1:description>
        <rdfs:label xml:lang="en">Steady State Equations</rdfs:label>
    </owl:NamedIndividual>
    


