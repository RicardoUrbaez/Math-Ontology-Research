        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S_0^i + I_0^i = N^i$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_0^i$, Number of Infectious Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N^i$, Total Population Size</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$S_0^i$, Number of Susceptible Individuals</inDefiningFormulation>
