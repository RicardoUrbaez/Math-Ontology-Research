    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ClassicalLangevinEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ClassicalLangevinEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BoltzmannConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalPosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FrictionCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Mass"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Temperature"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#WhiteNoise"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalNewtonEquation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$M\frac{\mathrm{d^2}}{\mathrm{d}t^2} \vec{q} = F(q) - \gamma \frac{\mathrm{d}}{\mathrm{d}t}{q} + \sqrt{2 \gamma k_B T} R(t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F$, Classical Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$M$, Mass</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R(t)$, White Noise</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$T$, Temperature</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, Friction Coefficient</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_B$, Boltzmann Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q$, Classical Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDeterministic>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDynamic>
        <terms1:description xml:lang="en">same as (classical) Newton&apos;s equation of motion, but with additional terms for friction|damping and for stochastic collisions added</terms1:description>
        <rdfs:comment xml:lang="en">Note that a Langevin equation can be reformulated as a Fokker–Planck equation governing a probability distribution.</rdfs:comment>
        <rdfs:label xml:lang="en">Classical Langevin Equation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Langevin_equation"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674259"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q584537"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ClassicalLangevinModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ClassicalLangevinModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalLangevinEquation"/>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDeterministic>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDynamic>
        <terms1:description xml:lang="en">mathematical model typically used to describe the dynamics of systems subject to a combination of deterministic and fluctuating forces</terms1:description>
        <rdfs:comment xml:lang="en">The approach is characterized by the use of simplified models while accounting for omitted degrees of freedom only implicitly, i.e., by the use of stochastic differential equations.</rdfs:comment>
        <rdfs:label xml:lang="en">Classical Langevin Model</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Langevin_dynamics"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675383"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q6485978"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ClassicalLiouvilleEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ClassicalLiouvilleEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <assumes rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalApproximation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalDynamicsModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalDensityPhaseSpace"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalHamiltonFunction"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalMomentum"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalPosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#LiouvilleVonNeumannEquation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{d\rho}{dt}=\frac{\partial\rho}{\partial t}+\sum_{i=1}^n\left(\frac{\partial\rho}{\partial q_i}\dot{q}_i+\frac{\partial\rho}{\partial p_i}\dot{p}_i\right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$H$, Classical Hamilton Function</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho$, Classical Density (Phase Space)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p$, Classical Momentum</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q$, Classical Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">partial differential equation for the that time rate of change of density of points in phase space</terms1:description>
        <rdfs:comment xml:lang="en">Consider a Hamiltonian dynamical system with canonical coordinates and conjugate momenta. Then the phase space distribution  determines the probability that the system will be found in the infinitesimal phase space volume.</rdfs:comment>
        <rdfs:comment xml:lang="en">Note the similarity with the quantum Liouville (von Neumann) equation where the  Poisson brackets {.,.} are replaced by commutator brackets [.,.]</rdfs:comment>
        <rdfs:label xml:lang="en">Classical Liouville Equation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674267"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q766722"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ClassicalMechanics -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ClassicalMechanics">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ResearchField"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ContinuumMechanics"/>
        <terms1:description xml:lang="en">sub-field of mechanics, which is concerned with the set of physical laws describing the motion of bodies under the action of a system of forces</terms1:description>
        <rdfs:label xml:lang="en">Classical Mechanics</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Classical_mechanics"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6684699"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q11397"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ClassicalMomentum -->

