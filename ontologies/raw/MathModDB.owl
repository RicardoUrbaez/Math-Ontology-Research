    <!-- https://mardi4nfdi.de/mathmoddb#ConditionForPositiveSolutionsInTheSISModelWithBirthsAndDeaths -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ConditionForPositiveSolutionsInTheSISModelWithBirthsAndDeaths">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsConstraintConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#SusceptibleInfectiousSusceptibleModelWithBirthsAndDeaths"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BirthRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RelativeRemovalRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$(\gamma + \beta) \Delta t \leq 1$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Delta t$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\beta$, Birth Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, Relative Removal Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">positive solution constraint</terms1:description>
