        <terms1:description xml:lang="en">molecules of Signal (species of molecules) in the Standard Compartment-Based Morphogen Gradient Model</terms1:description>
        <rdfs:comment xml:lang="en">Subscript denotes the compartment.</rdfs:comment>
        <rdfs:label xml:lang="en">Signal</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPrediction -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPrediction">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPredictionGlobal"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPredictionLocal"/>
        <models rdf:resource="https://mardi4nfdi.de/mathmoddb#PredictingSimulationErrorRuntime"/>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDeterministic>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isLinear>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <terms1:description xml:lang="en">constists of a global model, that uses a priori knowledge of the simulation to describe global trends, and a local model that describes local deviations from the trend</terms1:description>
        <rdfs:label xml:lang="en">Simulation Behavior Prediction by a Stochastic Model</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPredictionFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPredictionFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPrediction"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPredictionGlobalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPredictionLocalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StochasticProcess"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\ln f(x) = \mu(x) + s(x)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu$, Simulation Behavior Prediction Global Formulation</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$f$, Stochastic Process</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s$, Simulation Behavior Prediction Local Formulation</inDefiningFormulation>
        <terms1:description xml:lang="en">simulation behavior prediction formulation</terms1:description>
        <rdfs:comment xml:lang="en">Full model that combines the global and local model on the logarithmic scale as a stochastic process.</rdfs:comment>
        <rdfs:label xml:lang="en">Simulation Behavior Prediction Formulation</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPredictionGlobal -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPredictionGlobal">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <terms1:description xml:lang="en">describes known trends in the simulation behavior as a linear combination of basis functions on a logarithmic scale</terms1:description>
        <rdfs:label xml:lang="en">Simulation Behavior Prediction Global Stochastic Model</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPredictionGlobalFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPredictionGlobalFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPredictionGlobal"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BasisFunction"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CoefficientSimulationBehaviorPredictionGlobal"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StudentsT-Distribution"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">\begin{align}
\mu(x) &amp;\equiv \ln\Bigl( \sum_{i=1}^q c_i \phi_i(x) \Bigr)
\ln(c_i) &amp;\sim \text{Student-t}(4, 0, 7)
\end{align}</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu$, Simulation Behavior Prediction Global Formulation</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi$, Basis Function</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\text{Student-t}, Students t-distribution</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Coefficient Simulation Behavior Prediction Global</inDefiningFormulation>
        <terms1:description xml:lang="en">simulation behavior prediction global formulation</terms1:description>
        <rdfs:label xml:lang="en">Simulation Behavior Prediction Global Formulation</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPredictionLocal -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPredictionLocal">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <terms1:description xml:lang="en">describes local deviations from the global model as a zero-mean Gaussian Process with a radial basis function as covariance function</terms1:description>
        <rdfs:label xml:lang="en">Simulation Behavior Prediction Local Stochastic Model</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPredictionLocalFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPredictionLocalFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#SimulationBehaviorPredictionLocal"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CovarianceFunction"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GaussianProcess"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">s(x) \sim \mathcal{GP}(0, k)</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{GP}$, Gaussian Process</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k$, Covariance Function</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s$, Simulation Behavior Prediction Local Formulation</inDefiningFormulation>
        <terms1:description xml:lang="en">simulation behavior prediction local formulation</terms1:description>
        <rdfs:comment xml:lang="en">Gaussian Process (GP) with zero means and covariance k.</rdfs:comment>
        <rdfs:label xml:lang="en">Simulation Behavior Prediction Local Formulation</rdfs:label>
    </owl:NamedIndividual>
    


