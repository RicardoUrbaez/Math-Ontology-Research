    <!-- https://mardi4nfdi.de/mathmoddb#ParticleMovementLine -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ParticleMovementLine">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AttenuationCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PoissonDistribution"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#BoltzmannEquationMovingParticlesTimeContinuousNoScatterAssumption"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$g(y) = \int_{L} f(x)e^{-\int^{x} \mu(s) \, ds}\,dx$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu$, Attenuation Coefficient</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$g$, Poisson Distribution</inDefiningFormulation>
        <terms1:description xml:lang="en">particle movement equation on a line</terms1:description>
        <rdfs:label xml:lang="en">Particle Movement on a Line</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ParticleMovementLineNoAttenuation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ParticleMovementLineNoAttenuation">
