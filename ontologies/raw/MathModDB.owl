    <!-- https://mardi4nfdi.de/mathmoddb#FarFieldRadiation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#FarFieldRadiation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ComputationalTask"/>
        <uses rdf:resource="https://mardi4nfdi.de/mathmoddb#MaxwellEquationsModel"/>
        <terms1:description xml:lang="en">electromagnetic radiation behaviors that predominate at greater distances</terms1:description>
        <rdfs:comment xml:lang="en">Given ρ(r, t) and j(r, t) that are localized in some domain in space, calculate E(r, t) and B(r, t) far from this domain. For instance, calculate the electromagnetic field emitted by an oscillating dipole.</rdfs:comment>
        <rdfs:comment xml:lang="en">The far field is a region of the electromagnetic (EM) field around an object, such as a transmitting antenna, or the result of radiation scattering off an object. Electromagnetic radiation far-field behaviors predominate at greater distances.</rdfs:comment>
        <rdfs:label xml:lang="en">Far Field Radiation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Near_and_far_field"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6684565"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#FaradayLaw -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#FaradayLaw">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#MaxwellEquationsModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricField"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MagneticField"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$ \nabla \times \mathbf{E} = -\frac{\partial \mathbf{B}} {\partial t}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B$, Magnetic Field</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$E$, Electric Field</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">basic law of electromagnetism of magnetic fields inducing a potential difference</terms1:description>
        <rdfs:label xml:lang="en">Faraday Law</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Faraday%27s_law_of_induction"/>
        <skos:altLabel xml:lang="en">Faraday&apos;s law of induction</skos:altLabel>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674353"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q181465"/>
    </owl:NamedIndividual>
    


