        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContinuityOfTheNormalMassFlux"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContinuityOfTheNormalStresses"/>
        <terms1:description xml:lang="en">coupling free flow of an incompressible fluid (Stokes) to a flow in/through a permeable media (Darcy)</terms1:description>
        <rdfs:label xml:lang="en">Stokes Darcy Coupling Conditions</rdfs:label>
