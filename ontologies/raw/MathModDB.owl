        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Substrate2Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Substrate2ConcentrationODEBiBiOrdered"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}
\frac{dc_{S_1}}{dt} &amp;= k_{-1} c_{ES_1} - k_{1} c_{E} c_{S_1} \\
\frac{dc_{S_2}}{dt} &amp;= k_{-2} c_{ES_{1}S_{2}} - k_{2} c_{ES_1} c_{S_2} \\
\frac{dc_{ES_1}}{dt} &amp;= k_{1} c_{E} c_{S_1} + k_{-2} c_{ES_{1}S_{2}} - k_{-1} c_{ES_1} - k_2 c_{ES_1} c_{S_2} \\
\frac{dc_{ES_{1}S_{2}}}{dt} &amp;= k_{2} c_{ES_1} c_{S_2} + k_{-3} c_{EP_{1}P_{2}} - k_{-2} c_{ES_{1}S_{2}} - k_{3} c_{ES_{1}S_{2}} \\
\frac{dc_{EP_{1}P_{2}}}{dt} &amp;= k_{3} c_{ES_{1}S_{2}} + k_{-4} c_{EP_1} c_{P_2} - k_{-3} c_{EP_{1}P_{2}} - k_{4} c_{EP_{1}P_{2}} \\
\frac{dc_{EP_1}}{dt} &amp;= k_{4} c_{EP_{1}P_{2}} + k_{-5} c_{E} c_{P_1} - k_{-4} c_{EP_1} c_{P_2} - k_{5} c_{EP_1} \\
\frac{dc_{P_1}}{dt} &amp;= k_{5} c_{EP_1} - k_{-5} c_{E} c_{P_1} \\
\frac{dc_{P_2}}{dt} &amp;= k_{4} c_{EP_{1}P_{2}} - k_{-4} c_{EP_1} c_{P_2} \\
\frac{dc_{E}}{dt} &amp;= k_{-1} c_{ES_1} + k_5 c_{EP_1} - k_{1} c_{E} c_{S_1} - k_{-5} c_{E} c_{P_1} \\
\end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{EP_1P_2}}{dt}$, Reaction Rate of Enzyme - Product 1 - Product 2 Complex</inDefiningFormulation>
