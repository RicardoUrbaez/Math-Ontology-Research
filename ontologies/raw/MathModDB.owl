    <!-- https://mardi4nfdi.de/mathmoddb#DarcyEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#DarcyEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#DarcyModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidDynamicViscosityPorousMedium"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidIntrinsicPermeabilityPorousMedium"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidPressurePorousMedium"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidVelocityPorousMedium"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}
v^{pm} = -K \mu^{-1} \nabla p^{vm} \\
\nabla \cdot v^{pm} = 0
\end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K$, Fluid Intrinsic Permeability (Porous Medium)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu$, Fluid Dynamic Viscosity (Porous Medium)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p^{pm}$, Fluid Pressure (Porous Medium)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v^{pm}$, Fluid Velocity (Porous Medium)</inDefiningFormulation>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isTimeContinuous>
        <terms1:description xml:lang="en">describing the flow of a fluid through a porous medium</terms1:description>
        <rdfs:comment xml:lang="en">mathematical model describing the flow of a fluid through a porous medium.</rdfs:comment>
        <rdfs:label xml:lang="en">Darcy Equation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Darcy%27s_law"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674304"/>
    </owl:NamedIndividual>
    


