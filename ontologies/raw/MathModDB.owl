        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PlanckConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumMomentumOperator"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumMechanicalOperator"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p\equiv-{\rm i}\hbar \nabla$</definingFormulation>
        <inDefiningFormulation>$\mathrm{i}$, Imaginary Unit</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hbar$, Planck Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p$, Quantum Momentum Operator</inDefiningFormulation>
        <terms1:description xml:lang="en">in the coordinate representation of quantum mechanics, the momentum of a particle is represented by this operator</terms1:description>
        <rdfs:label xml:lang="en">Quantum Momentum Operator</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Momentum#Quantum_mechanical"/>
