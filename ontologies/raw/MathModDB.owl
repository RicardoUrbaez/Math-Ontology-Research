    <!-- https://mardi4nfdi.de/mathmoddb#ClassicalBrownianEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ClassicalBrownianEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BoltzmannConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalPosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Temperature"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#WhiteNoise"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalLangevinEquation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{\text{d}}{\text{d}t}q = - \frac{D}{k_\text{B} T} F(q) + \sqrt{2 D} R(t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$D$, Diffusion Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F$, Classical Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R(t)$, White Noise</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$T$, Temperature</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_\text{B}$, Boltzmann Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q$, Classical Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDeterministic>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDynamic>
        <terms1:description xml:lang="en">special case of an equation of motion where no average acceleration takes place</terms1:description>
        <rdfs:label xml:lang="en">Classical Brownian Equation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Brownian_dynamics"/>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Brownian_motion"/>
        <skos:altLabel xml:lang="en">Langevin Equation Without Inertia.</skos:altLabel>
        <skos:altLabel xml:lang="en">Overdamped Langevin Equation</skos:altLabel>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674258"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q178036"/>
    </owl:NamedIndividual>
    


