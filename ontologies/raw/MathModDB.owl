    <!-- https://mardi4nfdi.de/mathmoddb#CoulombFrictionOfTwoParticles -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#CoulombFrictionOfTwoParticles">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsConstraintConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#TangentialInteractionForceOfTwoParticles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ContactPointOfParticles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FrictionCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalInteractionForceOfTwoParticles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TangentialInteractionForceOfTwoParticles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TangentialStiffness"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnitNormalVector"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}
\lVert \boldsymbol F^{T, cons}_{ij}\rVert&amp;\leq \mu \lVert \boldsymbol F_{ij}^N\rVert\qquad \text{with}\\
\boldsymbol F^{T, cons}_{ij} &amp;= -k_{ij}^T\boldsymbol\xi_{ij}=-k_{ij}^T\left(\boldsymbol x_{C_{ji}}- \boldsymbol x_{C_{ij}} - \langle \boldsymbol x_{C_{ji}}- \boldsymbol x_{C_{ij}}, \boldsymbol n_{ij}\rangle \boldsymbol n_{ij}\right)
\end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\boldsymbol F^{T, cons}_{ij}\in\mathbb R^3$, &apos;Tangential Interaction Force Of Two Particles&apos;</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\boldsymbol F_{ij}^N$, Normal Interaction Force Of Two Particles</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\boldsymbol n_{ij}\in\mathbb R^3$, Unit Normal Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu$, Friction Coefficient</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{ij}^T$, Tangential Stiffness</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x_{C_{ij}}$, Contact Point Of Particles</inDefiningFormulation>
        <terms1:description xml:lang="en">describes the transition between static and dynamic friction in a simple (linear) friction model</terms1:description>
        <rdfs:label xml:lang="en">Coulomb Friction Condition Between Two Particles</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674302"/>
    </owl:NamedIndividual>
    


