    <!-- https://mardi4nfdi.de/mathmoddb#ClosedSystemApproximation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ClosedSystemApproximation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <assumedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#SchroedingerEquationTimeDependent"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumDampingRate"/>
