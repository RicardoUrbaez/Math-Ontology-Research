        <terms1:description xml:lang="en">discrete-time SIR model with births and deaths</terms1:description>
        <rdfs:label xml:lang="en">Susceptible Infectious Removed Model with Births and Deaths</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675318"/>
    </owl:NamedIndividual>
    


