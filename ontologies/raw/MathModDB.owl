        <terms1:description xml:lang="en">uni uni reaction model</terms1:description>
        <rdfs:comment xml:lang="en">Ordinary differential equations for the rates of change of all chemical species (substrate, enzyme, enzyme-substrate complex, product) in an Uni Uni reaction.kᵢ  with positive or negative i represents the rate constant of the forward- or backward-reaction i-th reaction step.</rdfs:comment>
        <rdfs:label xml:lang="en">Uni Uni Reaction (ODE Model)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675446"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#UniUniReactionODESystem -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#UniUniReactionODESystem">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EnzymeConcentrationODEUniUni"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EnzymeSubstrateComplexConcentrationODEUniUni"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ProductConcentrationODEUniUni"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SubstrateConcentrationODEUniUni"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}
\frac{dc_{S}}{dt}&amp;=-k_{1}*c_{E}*c_{S}+k_{-1}*c_{ES} \\
\frac{dc_{P}}{dt}&amp;=k_{2}*c_{ES}-k_{-2}*c_{E}*c_{P} \\
\frac{dc_{E}}{dt}&amp;=-k_{1}*c_{E}*c_{S}+k_{-1}*c_{ES}+k_{2}*c_{ES}-k_{-2}*c_{E}*c_{P} \\
\frac{dc_{ES}}{dt}&amp;=k_{1}*c_{E}*c_{S}-k_{-1}*c_{ES}-k_{2}*c_{ES}+k_{-2}*c_{E}*c_{P}
\end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{ES}}{dt}$, Reaction Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{E}}{dt}$, Reaction Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{P}}{dt}$, Reaction Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{S}}{dt}$, Reaction Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{ES}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{E}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{P}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-1}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-2}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{1}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{2}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">system of ordinary differential equations describing an uni uni reaction over time</terms1:description>
        <rdfs:label xml:lang="en">Uni Uni Reaction ODE System</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674594"/>
    </owl:NamedIndividual>
    


