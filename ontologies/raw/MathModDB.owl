        <terms1:description xml:lang="en">relations among individuals such as friendship or connections on social media are defined through a binary adjacency matrix</terms1:description>
        <rdfs:label xml:lang="en">Individual Relationship Matrix</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674015"/>
    </owl:NamedIndividual>
    


