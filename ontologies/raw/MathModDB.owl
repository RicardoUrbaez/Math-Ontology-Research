    <!-- https://mardi4nfdi.de/mathmoddb#DarwinHowieWhelanEquationNoStrain -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#DarwinHowieWhelanEquationNoStrain">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#DynamicalElectronScatteringModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnitNormalVector"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#DarwinHowieWhelanEquationStrained"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align*} 
\frac{\mathrm d}{\mathrm d z} \psi_\mathbf{g}(z) &amp;= 2\mathrm{i} \pi s_\mathbf{g} \psi_\mathbf{g}(z)+ \frac{\mathrm{i} \pi}{\rho_\mathbf{g}}\sum_{\mathbf{h}\in \Lambda^*_m} U_{\mathbf{g-h}}\psi_\mathbf{h}(z)\\
 \quad s_g &amp;= -\frac{g\cdot(2k_0+g)}{2n\cdot(k_0+g)}
\end{align*}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$U_g$, Electric Potential Fourier Coefficients</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Lambda^*_m$, Reciprocal Lattice</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi_g$, Amplitude of Electron Wave</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$g$, Reciprocal Lattice Vectors</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_0$, Wave Vector of an Electron</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Unit Normal Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s_g$, Excitation error</inDefiningFormulation>
        <terms1:description xml:lang="en">simuating TEM images of an unstrained crystal by numerically solving the Darwin–Howie–Whelan equation describing the electron propagation</terms1:description>
        <rdfs:label xml:lang="en">Darwin-Howie-Whelan Equation for an Unstrained Crystal</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674128"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#DarwinHowieWhelanEquationStrained -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#DarwinHowieWhelanEquationStrained">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#DynamicalElectronScatteringModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnitNormalVector"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}
\frac{\mathrm d}{\mathrm d z} \varphi_{\mathbf{g}}(z) &amp;= 2\mathrm{i} \pi \Big(s_{\mathbf{g}} + \frac{\mathrm d}{\mathrm d z}(\mathbf{g}\cdot \mathbf{u}(\mathbf{r}))\Big)\varphi_{\mathbf{g}}(z)+ \mathrm{i} \pi\sum_{\mathbf{h}\in \Lambda^*_m} U_{\mathbf{g-h}}\varphi_{\mathbf{h}}(z)\\
\quad s_g &amp;= -\frac{g\cdot(2k_0+g)}{2n\cdot(k_0+g)}
\end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$U_g$, Electric Potential Fourier Coefficients</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Lambda^*_m$, Reciprocal Lattice</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi_g$, Amplitude of Electron Wave</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$g$, Reciprocal Lattice Vectors</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_0$, Wave Vector of an Electron</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Unit Normal Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s_g$, Excitation Error</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$u$, Displacement of Atoms</inDefiningFormulation>
        <terms1:description xml:lang="en">simuating TEM images by numerically solving the Darwin–Howie–Whelan equation describing the electron propagation</terms1:description>
        <rdfs:label xml:lang="en">Darwin-Howie-Whelan Equation for a Strained Crystal</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674129"/>
    </owl:NamedIndividual>
    


