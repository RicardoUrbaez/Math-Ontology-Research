    <!-- https://mardi4nfdi.de/mathmoddb#ObjectClusterFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ObjectClusterFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ObjectClusterMatrix"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ObjectCommittorFunctions"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ObjectRatingMatrix"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathrm{R_c} = (\chi^T\chi)^{-1}\chi^T\mathrm{R}\chi$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\chi$, Object Committor Functions</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathrm{R_c}$, Object Cluster Matrix</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathrm{R}$, Object Rating Matrix</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isLinear>
        <terms1:description xml:lang="en">formulation determining the coherence of object clusters</terms1:description>
        <rdfs:label xml:lang="en">Object Cluster Formulation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674530"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ObjectClusterMatrix -->

