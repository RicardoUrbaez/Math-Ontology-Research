    <!-- https://mardi4nfdi.de/mathmoddb#QuantumMomentumOperator -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumMomentumOperator">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
