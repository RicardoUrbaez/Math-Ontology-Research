    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#StabilityAutonomousSystem -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#StabilityAutonomousSystem">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <assumedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#LyapunovEquation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixA"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Re(eig(A))$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Control System Matrix A</inDefiningFormulation>
        <terms1:description xml:lang="en">asymptotic stability of fixed points of a system of constant coefficient linear differential equations of first order</terms1:description>
        <rdfs:comment xml:lang="en">The asymptotic stability of fixed points of a system of constant coefficient linear differential equations of first order (aka linear autonomous system, time-invariant system, ẋ = A x) can be analyzed using the eigenvalues of the corresponding matrix.</rdfs:comment>
        <rdfs:label xml:lang="en">Stability Autonomous System</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Stability_theory"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674576"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q1756677"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#StandardCompartmentBasedMorphogenGradientModel -->

