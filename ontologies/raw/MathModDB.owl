    <!-- https://mardi4nfdi.de/mathmoddb#MotorNeuronPoolModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MotorNeuronPoolModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <describedAsStudiedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#Homs-Pons_2024_Coupled_simulations_and_parameter_inversion_for_neural_system_and_electrophysiological_muscle_models"/>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDynamic>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isTimeContinuous>
        <terms1:description xml:lang="en">mathematical model of neuromuscular system based on the agonist-antagonist myoneural interface</terms1:description>
        <rdfs:label xml:lang="en">Motor Neuron Pool Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675437"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MotorNeuronPoolODESystem -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MotorNeuronPoolODESystem">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#MotorNeuronPoolModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CouplingCurrent"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FibreContractionVelocity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FibreStretch"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#IonCurrent"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MembraneCapacitance"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NeuralInput"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SensoryOrganCurrent"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TransmembranePotential"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align} 
\frac{\text{d}V^{\text{d}}_{\text{m}}}{\text{d}t} &amp;= \frac{1}{C^{\text{d}}_{\text{m}}}\left(-I^{\text{d}}_{\text{ion}}(V^{\text{d}}_{\text{m}}) - I^{\text{d}}_{\text{C}}(V^{\text{d}}_{\text{m}},V^{\text{s}}_{\text{m}}) \right) \\ 
\frac{\text{d}V^{\text{s}}_{\text{m}}}{\text{d}t} &amp;= \frac{1}{C^{\text{s}}_{\text{m}}}\left(-I^{\text{s}}_{\text{ion}}(V^{\text{s}}_{\text{m}}) - I^{\text{s}}_{\text{C}}(V^{\text{d}}_{\text{m}},V^{\text{s}}_{\text{m}}) + I_{\text{spindle}}(\lambda_{\text{f}}, \dot{\lambda}_\text{f}) + I_\text{ext} \right) \\ 
\end{align}$</definingFormulation>
        <inDefiningFormulation>$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C_{\text{m}}$, Membrane Capacitance</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_{\text{C}}$, Coupling Current</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_{\text{ext}}$, Neural Input</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_{\text{ion}}$, Ion Current</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_{\text{spindle}}$, Sensory Organ Current</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V_{\text{m}}$, Transmembrane Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\lambda_{\text{f}}$, Fibre Contraction Velocity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\lambda_{\text{f}}$, Fibre Stretch</inDefiningFormulation>
        <terms1:description xml:lang="en">two coupled ODEs which describe the transmembrane potentials</terms1:description>
        <rdfs:comment xml:lang="en">Transmembrane potentials in the soma and the dendrite compartments.</rdfs:comment>
        <rdfs:label xml:lang="en">Motor Neuron Pool ODE System</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674513"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MultiGridReactionDiffusionMasterEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MultiGridReactionDiffusionMasterEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#GeneralizedCompartmentBasedMorphogenGradientModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GeneralizedDiffusionOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GeneralizedReactionOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#JointProbability"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{\partial p}{\partial t}(\mathbf{n}, \mathbf{m}, t)=(\tilde{\mathcal{D}}+\tilde{\mathcal{R}}) p(\mathbf{n}, \mathbf{m}, t)$.</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{\mathcal{D}}$, Generalized Diffusion Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{\mathcal{R}}$, Generalized Reaction Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p(\mathbb(n), \mathbb(m), t)$, Joint Probability</inDefiningFormulation>
        <terms1:description xml:lang="en">multi grid reaction diffusion master equation</terms1:description>
        <rdfs:comment xml:lang="en">Dividing by γ in the second term of the generalized reaction operator definition can be interpreted as a sum of γ reactions Aⱼ → Bᵢ that share the rate k₂.</rdfs:comment>
        <rdfs:label xml:lang="en">Multi Grid Reaction Diffusion Master Equation</rdfs:label>
    </owl:NamedIndividual>
    


