    <!-- https://mardi4nfdi.de/mathmoddb#NavierStokesEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NavierStokesEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidKinematicViscosityFreeFlow"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FluidVelocityFreeFlow"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#StokesEquation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{aligned}\frac{\partial \vec u}{\partial t}+\vec u\cdot\nabla\vec u-\nu\nabla^2\vec u&amp;=-\nabla h\\\nabla\cdot\vec u&amp;=0\end{aligned}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\nu$, Fluid Kinematic Viscosity (Free Flow)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$u$, Fluid Velocity (Free Flow)</inDefiningFormulation>
        <terms1:description xml:lang="en">system of nonlinear partial differential equations describing the motion of viscous fluids</terms1:description>
        <rdfs:label xml:lang="en">Navier Stokes Equation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Navier%E2%80%93Stokes_equations"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674515"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q201321"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#NavierStokesModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NavierStokesModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <assumes rdf:resource="https://mardi4nfdi.de/mathmoddb#CreepingFlowAssumption"/>
        <terms1:description xml:lang="en">describes a fluid flow with small advective inertial forces compared to viscous forces</terms1:description>
        <rdfs:comment xml:lang="en">The Stokes model describes a fluid flow with small advective inertial forces compared to viscous forces, with a low Reynolds number. It occurs in situations with very slow fluid velocities, high viscosities, or small flow length scales.</rdfs:comment>
        <rdfs:label xml:lang="en">Stokes Model</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Stokes_flow"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675409"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#NearFieldRadiation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NearFieldRadiation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ComputationalTask"/>
        <uses rdf:resource="https://mardi4nfdi.de/mathmoddb#MaxwellEquationsModel"/>
        <terms1:description xml:lang="en">electromagnetic radiation behaviors that predominate at shorter distances</terms1:description>
        <rdfs:comment xml:lang="en">The near field is a region of the electromagnetic (EM) field around an object, such as a transmitting antenna, or the result of radiation scattering off an object. Non-radiative near-field behaviors dominate close to the antenna or scatterer.</rdfs:comment>
        <rdfs:label xml:lang="en">Near Field Radiation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Near-field_optics"/>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Near_and_far_field"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6684609"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q6984336"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#NeumannBoundaryCondition -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NeumannBoundaryCondition">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <terms1:description xml:lang="en">boundary condition specifying the values of derivatives of a solution of a differential equation along the boundaries of a domain</terms1:description>
        <rdfs:label xml:lang="en">Neumann Boundary Condition</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Neumann_boundary_condition"/>
        <skos:altLabel xml:lang="en">second-type boundary condition</skos:altLabel>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674517"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q1149279"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#NeumannBoundaryConditionElectricPotential -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NeumannBoundaryConditionElectricPotential">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricPotential"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectrodeInterfaces"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnitNormalVector"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#NeumannBoundaryCondition"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n \cdot \nabla \phi(r,t)|_{\Gamma_N}=0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Gamma_N$, Electrode Interfaces</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi$, Electric Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Normal Unit Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">typically used to indicate that the electric field should be perpendicalar to an electrode interface</terms1:description>
        <rdfs:label xml:lang="en">Neumann Boundary Condition for Electric Potential</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6534333"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#NeumannBoundaryConditionForElectronFermiPotential -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NeumannBoundaryConditionForElectronFermiPotential">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsBoundaryConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#DriftDiffusionModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectrodeInterfaces"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FermiPotentialForElectrons"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnitNormalVector"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#NeumannBoundaryCondition"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n \cdot \nabla \psi|_{\Gamma_N}=0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Gamma_N$, Electrode Interfaces</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi_n$, Fermi Potential for Electrons</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Normal Unit Vector</inDefiningFormulation>
        <terms1:description xml:lang="en">Neumann boundary condition for the Fermi potential governing the electrons</terms1:description>
        <rdfs:label xml:lang="en">Neumann Boundary Condition for Electron Fermi Potential</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674322"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#NeumannBoundaryConditionForHoleFermiPotential -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NeumannBoundaryConditionForHoleFermiPotential">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsBoundaryConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#DriftDiffusionModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectrodeInterfaces"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FermiPotentialForHoles"/>
