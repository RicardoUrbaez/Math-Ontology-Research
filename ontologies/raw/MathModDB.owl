    <!-- https://mardi4nfdi.de/mathmoddb#PoissonDistributedDeaths -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PoissonDistributedDeaths">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#GammaGompertzMakehamModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AgeOfAnIndividual"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DeathCount"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ExposureOfAnIndividual"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PoissonDistribution"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RiskOfDeath"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$D(x)\sim P\left(E(x)\mu(x)\right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$D$, Death Count</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$E$, Exposure of an Individual</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$P$, Poisson Distribution</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu$, Risk of Death</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Age of an Individual</inDefiningFormulation>
        <terms1:description xml:lang="en">assuming that death counts at age x are Poisson-distributed</terms1:description>
        <rdfs:label xml:lang="en">Poisson-Distributed Deaths</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674545"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PoissonDistribution -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PoissonDistribution">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EulerNumber"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ExpectationValue"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfOccurrences"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PoissonDistribution"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ProbabilityDistribution"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$P(k;\lambda)\equiv\frac{\lambda^ke^{-\lambda}}{k!}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$P$, Poisson Distribution</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\lambda$, Expectation Value</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$e$, Euler Number</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k$, Number of Occurrences</inDefiningFormulation>
        <terms1:description xml:lang="en">discrete probability distribution that models the number of events occurring in a fixed interval of time or space, given a constant mean rate of occurrence</terms1:description>
        <rdfs:comment xml:lang="en">Assuming that these events occur with a known constant mean rate and independently of the time since the last event.</rdfs:comment>
        <rdfs:label xml:lang="en">Poisson Distribution</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Poisson_distribution"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674104"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q205692"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PoissonEquationForTheElectricPotential -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PoissonEquationForTheElectricPotential">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DensityOfElectrons"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DensityOfHoles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DopingProfile"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricPotential"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElementaryCharge"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FermiPotentialForElectrons"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FermiPotentialForHoles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PermittivityDielectric"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$-\nabla\cdot\left(\epsilon_s\nabla\psi\right) = q\left(C+p(\psi,\phi_p)-n(\psi,\phi_n)\right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C$, Doping Profile</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\epsilon_s$, Permittivity (Dielectric)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi_n$, Fermi Potential for Electrons</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi_p$, Fermi Potential for Holes</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi$, Electric Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Density of Electrons</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p$, Density of Holes</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q$, Elementary Charge</inDefiningFormulation>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <terms1:description xml:lang="en">For use in semiconductor physics, with electron and hole densities</terms1:description>
        <rdfs:label xml:lang="en">Poisson Equation for the Electric Potential</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674308"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PoissonEquationForTheElectricPotentialFiniteVolume -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PoissonEquationForTheElectricPotentialFiniteVolume">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#ScharfetterGummelScheme"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlVolume"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricPotential"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PermittivityDielectric"/>
        <discretizes rdf:resource="https://mardi4nfdi.de/mathmoddb#PoissonEquationForTheElectricPotential"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$-\epsilon_s\left(\frac{\psi_{k+1}-\psi_{k}}{h_{k,k+1}}-\frac{\psi_{k}-\psi_{k-1}}{h_{k-1,k}}\right)=q\left(C_k+p(\psi_k,\phi_{p;k})-n(\psi_k,\phi_{n;k})\right)|\omega_k|$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\epsilon_s$, Permittivity (Dielectric)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\omega_k$, Control Volume</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi$, Electric Potential</inDefiningFormulation>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isSpaceContinuous>
        <terms1:description xml:lang="en">used within the Scharfetter-Gummel finite volume disretization scheme</terms1:description>
        <rdfs:comment xml:lang="en">Used within the Scharfetter-Gummel finite volume disretization scheme which is the standard numerical method for solving the van Roosbroeck system.</rdfs:comment>
        <rdfs:label xml:lang="en">Poisson Equation for the Electric Potential (Finite Volume)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674356"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PoissonLogLikelihood -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PoissonLogLikelihood">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#GammaGompertzMakehamModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AgeOfAnIndividual"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DeathCount"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ExposureOfAnIndividual"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LikelihoodValue"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RiskOfDeath"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\log L = \sum_{x}[D(x)\log\mu(x)-E(x)\mu(x)]$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$D$, Death Count</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$E$, Exposure of an Individual</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$L$, Likelihood Value</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu$, Risk of Death</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Age of an Individual</inDefiningFormulation>
        <terms1:description xml:lang="en">log-likelihood function of a Poisson distribution</terms1:description>
        <rdfs:label xml:lang="en">Poisson log-Likelihood</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674483"/>
    </owl:NamedIndividual>
    


