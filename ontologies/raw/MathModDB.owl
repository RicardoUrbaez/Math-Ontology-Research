    <!-- https://mardi4nfdi.de/mathmoddb#UniformGravitationalAcceleration -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#UniformGravitationalAcceleration">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EarthRadius"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallHeight"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$h \approx r$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$h$, Free Fall Height</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r$, Earth Radius</inDefiningFormulation>
        <terms1:description xml:lang="en">assuming that the gravitational constant remains unchanged from the beginning to the end of a trajectory, e.g. a free fall</terms1:description>
        <rdfs:comment xml:lang="en">This is a very good approximation for an apple falling from a tree, but not for celestial mechanics where the inverse-square law of the gravitational field must be taken into account.</rdfs:comment>
        <rdfs:label xml:lang="en">Uniform Gravitational Acceleration</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674362"/>
    </owl:NamedIndividual>
    


