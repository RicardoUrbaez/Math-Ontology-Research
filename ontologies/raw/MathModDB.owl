        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">initial number of susceptible and infectious individuals is equal to the total population of each subdomain</terms1:description>
        <rdfs:label xml:lang="en">Initial Condition for the Multi-Population SIS Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674416"/>
