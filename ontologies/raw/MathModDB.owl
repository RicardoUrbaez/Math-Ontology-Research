        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi(\mathbf{n}, \mathbf{m}) \equiv \lim _{t \rightarrow \infty} p(\mathbf{n}, \mathbf{m}, t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p(\mathbf{n}, \mathbf{m}, t)$,  Joint Probability</inDefiningFormulation>
        <terms1:description xml:lang="en">satisfies the stationary reaction-diffusion master equation</terms1:description>
        <rdfs:label xml:lang="en">Stationary Distribution</rdfs:label>
        <wikidataID>https://www.wikidata.org/wiki/Q4441378</wikidataID>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#StationaryMultiGridReactionDiffusionMasterEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#StationaryMultiGridReactionDiffusionMasterEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#GeneralizedCompartmentBasedMorphogenGradientModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StationaryDistribution"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$0 = (\tilde{\mathcal{D}} +  \tilde{\mathcal{R}}) p(\mathbb{n}, \mathbb{m}, t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{\mathcal{D}}$, Generalized Diffusion Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{\mathcal{R}}$, Generalized Reaction Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p(\mathbb{n}, \mathbb{m}, t)$, Joint Probability</inDefiningFormulation>
        <terms1:description xml:lang="en">stationary multi grid reaction diffusion master equation</terms1:description>
        <rdfs:label xml:lang="en">Stationary Multi Grid Reaction Diffusion Master Equation</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#StationaryReactionDiffusionMasterEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#StationaryReactionDiffusionMasterEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#StandardCompartmentBasedMorphogenGradientModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StationaryDistribution"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$0 = (\mathcal{D} + \mathcal{R})\phi(\mathbf{n}, \mathbf{m})$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{D}$, Diffusion Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{R)$, Reaction Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi$, Stationary Distribution</inDefiningFormulation>
        <terms1:description xml:lang="en">stationary reaction-diffusion master equation</terms1:description>
        <rdfs:label xml:lang="en">Stationary Reaction-Diffusion Master Equation</rdfs:label>
    </owl:NamedIndividual>
    


