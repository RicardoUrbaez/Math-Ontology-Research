    <!-- https://mardi4nfdi.de/mathmoddb#ClassicalHamiltonEquations -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ClassicalHamiltonEquations">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalDynamicsModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalHamiltonFunction"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalMomentum"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalPosition"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalNewtonEquation"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#SchroedingerEquationTimeDependent"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}
\frac{\mathrm{d}\boldsymbol{q}}{\mathrm{d}t} &amp;=&amp; +\frac{\partial \mathcal{H}}{\partial \boldsymbol{p}} \\
\frac{\mathrm{d}\boldsymbol{p}}{\mathrm{d}t} &amp;=&amp; -\frac{\partial \mathcal{H}}{\partial \boldsymbol{q}}
\end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$H$, Classical Hamilton Function</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p$, Classical Momentum</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q$, Classical Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isTimeContinuous>
        <terms1:description xml:lang="en">classical equations of motion for systems described by a classical Hamilton function specifying the total energy</terms1:description>
        <rdfs:comment xml:lang="en">Hamiltonian mechanics emerged in 1833 as a reformulation of Lagrangian mechanics. Introduced by Sir William Rowan Hamilton, Hamiltonian mechanics replaces (generalized) velocities used in Lagrangian mechanics with (generalized) momenta. Both theories provide interpretations of classical mechanics and describe the same physical phenomena.</rdfs:comment>
        <rdfs:label xml:lang="en">Classical Hamilton Equations</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Hamiltonian_mechanics"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674257"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q1115699"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ClassicalHamiltonEquationsLeapFrog -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ClassicalHamiltonEquationsLeapFrog">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalMomentum"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalPosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EulerForwardMethod"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Mass"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeStep"/>
        <discretizes rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalHamiltonEquations"/>
        <similarTo rdf:resource="https://mardi4nfdi.de/mathmoddb#SchrödingerEquationStrangMarchuk"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{align}
p(t+\tau/2) &amp;=&amp; p(t)+\tau F(q(t))/2 \\
q(t+\tau) &amp;=&amp; q(t)+\tau p(t+\tau/2)/m \\
p(t+\tau) &amp;=&amp; p(t+\tau/2)+\tau F(q(t+\tau))/2
\end{align}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F$, Classical Forces</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tau$, Time Step</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$m$, Mass</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p$, Classical Momentum</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q$, Classical Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isTimeContinuous>
        <terms1:description xml:lang="en">leap frog scheme for time-discretization of Hamilton&apos;s equations of motion</terms1:description>
        <rdfs:label xml:lang="en">Classical Hamilton Equations (Leap Frog)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674264"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ClassicalHamiltonFunction -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ClassicalHamiltonFunction">
