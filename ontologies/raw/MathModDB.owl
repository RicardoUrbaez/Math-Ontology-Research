    <!-- https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationBiBiReactionPingPongMechanismwithProduct1SS -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationBiBiReactionPingPongMechanismwithProduct1SS">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstantProduct1BiBiReactionPingPongSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstantSubstrate1BiBiReactionPingPongSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LimitingReactionRateForwardBiBiReactionPingPong"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisMentenConstantSubstrate1BiBiReactionPingPongSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisMentenConstantSubstrate2BiBiReactionPingPongSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRate"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationforBiBiReactionPingPongMechanismwithProducts1and2SS"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0 = \frac{V_{1} c_{S_1} c_{S_2}}{K_{S_2} c_{S_1} + K_{S_1} c_{S_2} + c_{S_1} c_{S_2} + \frac{K_{iS_1} K_{S_2}}{K_{iP_1}} c_{P_1} + \frac{K_{S_2}}{K_{iP_1}} c_{S_1} c_{P_1}}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{S_1}$, Michaelis Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{S_2}$, Michaelis Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iP_1}$, Inhibition Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iS_1}$, Inhibition Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V_{1}$, Reaction Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{P_1}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S_1}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S_2}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0$, Reaction Rate</inDefiningFormulation>
        <terms1:description xml:lang="en">equation for bi bi reaction with ping pong mechanism with product 1 following steady state assumption</terms1:description>
        <rdfs:label xml:lang="en">Michaelis Menten Equation (Bi Bi Reaction Ping Pong with Product 1 - Michaelis Menten Model - Steady State Assumption)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674193"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationUniUniReactionwithoutProductandCompetitiveCompleteInhibitionSteadyStateAssumption -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationUniUniReactionwithoutProductandCompetitiveCompleteInhibitionSteadyStateAssumption">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CompetitiveInhibitionConstantUniUniReactionReversibleInhibition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitorConcentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InitialReactionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LimitingReactionRateUniUniReactionForward"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisConstantSubstrateUniUniReactionSteadyStateAssumption"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SubstrateConcentration"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0 = \frac{V_{max,f} c_S}{c_S + K_S (1 + \frac{c_I}{K_{ic}})}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_S$,Michaelis Constant Substrate (Uni Uni Reaction - Steady State Assumption)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{ic}$,Competitive Inhibition Constant (Uni Uni Reaction Reversible Inhibition)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V_{max,f}$,Limiting Reaction Rate (Uni Uni Reaction - Forward)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_I$,Inhibitor Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_S$, Substrate Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0$, Initial Reaction Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isLinear>
        <terms1:description xml:lang="en">equation for uni uni reaction without product and competitive complete inhibition following steady state assumption</terms1:description>
        <rdfs:label xml:lang="en">Michaelis Menten Equation (Uni Uni Reaction without Product and Competitive Complete Inhibition - Steady State Assumption)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674315"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationUniUniReactionwithoutProductandCompetitivePartialInhibitionSteadyStateAssumption -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationUniUniReactionwithoutProductandCompetitivePartialInhibitionSteadyStateAssumption">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CompetitiveInhibitionConstantUniUniReactionReversibleInhibition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitorConcentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InitialReactionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LimitingReactionRateUniUniReactionForward"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisConstantSubstrateUniUniReactionSteadyStateAssumption"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SubstrateConcentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UncompetitiveInhibitionConstantUniUniReactionReversibleInhibition"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0 = \frac{V_{max,f} c_S}{K_S \frac{(1+\frac{c_I}{K_{ic}})}{(1+\frac{c_I}{K_{iu}})} + C_S}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_S$,Michaelis Constant Substrate (Uni Uni Reaction - Steady State Assumption)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{ic}$,Competitive Inhibition Constant (Uni Uni Reaction Reversible Inhibition)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iu}$,Uncompetitive Inhibition Constant (Uni Uni Reaction Reversible Inhibition)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V_{max,f}$,Limiting Reaction Rate (Uni Uni Reaction - Forward)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_I$,Inhibitor Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_S$, Substrate Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0$, Initial Reaction Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isLinear>
        <terms1:description xml:lang="en">equation for uni uni reaction without product and competitive partial inhibition following steady state assumption</terms1:description>
        <rdfs:label xml:lang="en">Michaelis Menten Equation (Uni Uni Reaction without Product and Competitive Partial Inhibition - Steady State Assumption)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674494"/>
    </owl:NamedIndividual>
    


