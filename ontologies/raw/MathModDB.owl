    <!-- https://mardi4nfdi.de/mathmoddb#PositronEmissionTomographyEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PositronEmissionTomographyEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AttenuationCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PoissonDistribution"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ETMeasurementEquationNoScatterWithAttenuation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$g(y) = e^{-\int_L \mu(s) \, ds} \int_{L} f(x)\,dx$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu$, Attenuation Coefficient</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$g$, Poisson Distribution</inDefiningFormulation>
        <terms1:description xml:lang="en">medicine imaging technique</terms1:description>
        <rdfs:label xml:lang="en">Positron Emission Tomography Equation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Positron_emission_tomography"/>
        <rdfs:seeAlso rdf:resource="https://www.ncbi.nlm.nih.gov/books/NBK232475/"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q208376"/>
    </owl:NamedIndividual>
    


