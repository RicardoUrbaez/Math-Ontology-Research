    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianNormalMode -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianNormalMode">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <terms1:description xml:lang="en">quantum-mechanical represention of molecular vibrations in terms of normal modes</terms1:description>
        <rdfs:comment xml:lang="en">Pattern of motion in which all parts of the system move sinusoidally with the same frequency and with a fixed phase relation.</rdfs:comment>
        <rdfs:label xml:lang="en">Quantum Hamiltonian (Normal Mode)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Normal_mode"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674520"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q900488"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianNormalModeAnharmonic -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianNormalModeAnharmonic">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ForceConstantAnharmonic"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalModeCoordinateDimensionless"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalModeMomentumDimensionless"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfParticles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#VibrationFrequencyHarmonic"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianNormalMode"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{H}=\frac{1}{2}\sum_{i=1}^{3N-6}\omega_i\left(\hat{p}_i^2+\hat{q}_i^2\right) + \frac{1}{6} \sum_{ijk} \phi_{ijk} q_iq_jq_k + \frac{1}{24} \sum_{ijkl} \phi_{ijk} q_iq_jq_kq_l$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Number of Particles</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{H}$, Quantum Hamiltonian Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\omega$, Vibration Frequency (Harmonic)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi_{ijkl}$, Force Constant (Anharmonic)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi_{ijk}$, Force Constant (Anharmonic)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p$, Normal Mode Momentum (Dimensionless)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q$, Normal Mode Coordinate (Dimensionless)</inDefiningFormulation>
        <terms1:description xml:lang="en">quantum-mechanical represention of molecular normal modes of vibration beyond the harmonic approximation</terms1:description>
        <rdfs:label xml:lang="en">Quantum Hamiltonian (Normal Mode, Anharmonic)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674522"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianNormalModeHarmonic -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianNormalModeHarmonic">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalModeCoordinateDimensionless"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalModeMomentumDimensionless"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfParticles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#VibrationFrequencyHarmonic"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianNormalModeAnharmonic"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{H}=\frac{1/2}\sum_{i=1}^{3N-6}\omega_i\left(\hat{p}_i^2+\hat{q}_i^2\right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Number of Particles</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{H}$, Quantum Hamiltonian Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\omega$, Vibration Frequency (Harmonic)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p$, Normal Mode Momentum (Dimensionless)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q$, Normal Mode Coordinate (Dimensionless)</inDefiningFormulation>
        <terms1:description xml:lang="en">quantum-mechanical represention of molecular normal modes of vibration within the harmonic approximation</terms1:description>
        <rdfs:label xml:lang="en">Quantum Hamiltonian (Normal Mode, Harmonic)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674524"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianNormalModeIntermolecular -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianNormalModeIntermolecular">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ForceConstantAnharmonic"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#IntermolecularPotential"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalModeCoordinate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalModeMomentum"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfParticles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#VibrationFrequencyHarmonic"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianNormalModeAnharmonic"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{H}=\frac{1}{2}\sum_{i=1}^{3N-6}\omega_i\left(\hat{p}_i^2+\hat{q}_i^2\right) + \frac{1}{6} \sum_{ijk} \phi_{ijk} q_iq_jq_k + \frac{1}{24} \sum_{ijkl} \phi_{ijk} q_iq_jq_kq_l + U(q)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Number of Particles</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$U$, Intermolecular Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{H}$, Quantum Hamiltonian Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\omega$, Vibration Frequency (Harmonic)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi$, Force Constant (Anharmonic)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p$, Normal Mode Momentum</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q$, Normal Mode Coordinate</inDefiningFormulation>
        <terms1:description xml:lang="en">quantum-mechanical represention of molecular normal modes of vibration, including intermolecular interaction</terms1:description>
        <rdfs:label xml:lang="en">Quantum Hamiltonian (Normal Mode, Intermolecular)</rdfs:label>
