    <!-- https://mardi4nfdi.de/mathmoddb#FickEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#FickEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalFokkerPlanckEquation"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#TransportEquation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F = - \alpha \nabla u$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F$, Diffusion Flux</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\alpha$, Diffusion Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$u$, Concentration</inDefiningFormulation>
        <terms1:description xml:lang="en">mathematical description for transport of mass|particles by diffusion</terms1:description>
        <rdfs:label xml:lang="en">Fick Equation</rdfs:label>
        <skos:altLabel xml:lang="en">Fick&apos;s law of diffusion</skos:altLabel>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674310"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q856634"/>
    </owl:NamedIndividual>
    


