    <!-- https://mardi4nfdi.de/mathmoddb#BoundaryConditionsforElectrophysiologicalMuscleODESystem -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#BoundaryConditionsforElectrophysiologicalMuscleODESystem">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsBoundaryConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectrophysiologicalMuscleModelODESystem"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DisplacementMuscleTendon"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MaterialPointDisplacement"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MaterialPointVelocity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StressTensorPiolaKirchhoff"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{array}{cccc} 
\mathbf{x}_{\text{M}1} = \mathbf{x}_{\text{T}}, &amp;\dot{\mathbf{x}}_{\text{M}1} = \dot{\mathbf{x}}_{\text{T}}, &amp; \mathbf{P}(\mathbf{F}_{\text{M}1})=\mathbf{P}(\mathbf{F}_{\text{T}}), &amp; \text{on } \partial \Omega_{\text{M}1-\text{T}} \\ 
 \mathbf{x}_{\text{M}2} = \mathbf{x}_{\text{T}}, &amp;\dot{\mathbf{x}}_{\text{M}2} = \dot{\mathbf{x}}_{\text{T}}, &amp; \mathbf{P}(\mathbf{F}_{\text{M}2})=\mathbf{P}(\mathbf{F}_{\text{T}}), &amp; \text{on} \partial \Omega_{\text{M}2-\text{T}}
\end{array}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\dot{\mathbf{x}}$, Material Point Velocity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathbf{P}$, Stress Tensor (Piola-Kirchhoff)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathbf{x}$, Material Point Displacement</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Displacement Muscle Tendon</inDefiningFormulation>
        <terms1:description xml:lang="en">kinematic and dynamic conditions at the interfaces beween each muscle and the tendon</terms1:description>
        <rdfs:label xml:lang="en">Boundary Conditions of Electrophysiological Muscle ODE System</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674243"/>
    </owl:NamedIndividual>
    


