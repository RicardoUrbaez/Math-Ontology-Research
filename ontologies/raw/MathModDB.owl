    <!-- https://mardi4nfdi.de/mathmoddb#SylvesterEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SylvesterEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#H2OptimalApproximation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnknownMatrix"/>
        <describedAsInventedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#Sylvester_1884_Sur_léquations_en_matrices_px_xq"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#LyapunovEquation"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#SylvesterEquationControllability"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#SylvesterEquationObservability"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$AX+XB=C$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A,B,C$ given matrices</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$X$, Unknown Matrix</inDefiningFormulation>
        <terms1:description xml:lang="en">matrix equation, typically used in the field of control theory</terms1:description>
        <rdfs:comment xml:lang="en">Due to the different sizes of A, B, C, the matrix X will be rectangular in general.</rdfs:comment>
        <rdfs:label xml:lang="en">Sylvester Equation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Sylvester_equation"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674590"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q3730848"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SylvesterEquationControllability -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SylvesterEquationControllability">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixA"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixAReduced"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixB"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixBReduced"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnknownMatrix"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#LyapunovEquationControllability"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$AX + X\tilde{A}^{*} + B\tilde{B}^{*} = 0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Control System Matrix A</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B$, Control System Matrix B</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$X$, Unknown Matrix</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{A}$, Control System Matrix A (Reduced)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{B}$, Control System Matrix B (Reduced)</inDefiningFormulation>
        <terms1:description xml:lang="en">Sylvester equation for the controllability of a linear control system</terms1:description>
        <rdfs:comment xml:lang="en">Except for the use of the reduced matrices (tilde-notation), there is a formal similarity with the Lyapunov equations for the calculations of Gramians.</rdfs:comment>
        <rdfs:label xml:lang="en">Sylvester Equation Controllability</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674378"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SylvesterEquationObservability -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SylvesterEquationObservability">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixA"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixAReduced"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixC"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixCReduced"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnknownMatrix"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#LyapunovEquationObservability"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{A}Y + YA^{*} - C\tilde{C}^{*} = 0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Control System Matrix A</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C$, Control System Matrix C</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{A}$, Control System Matrix A (Reduced)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{C}$, Control System Matrix C (Reduced)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$Υ$, Unknown Matrix</inDefiningFormulation>
        <terms1:description xml:lang="en">Sylvester equation for the observability of a linear control system</terms1:description>
        <rdfs:comment xml:lang="en">Except for the use of the reduced matrices (tilde-notation), there is a formal similarity with the Lyapunov equations for the calculations of Gramians. However, note the sign change in the CC term.</rdfs:comment>
        <rdfs:label xml:lang="en">Sylvester Equation Observability</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674464"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SylvesterGeneralizedControllability -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SylvesterGeneralizedControllability">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixAReduced"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixBReduced"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixNReduced"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#LyapunovGeneralizedControllability"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#SylvesterEquationControllability"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$AX + X\tilde{A}^{*} + \sum_kN_kX\tilde{N}_k^{*} + B\tilde{B}^{*} = 0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Control System Matrix A (Reduced)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B$, Control System Matrix B (Reduced)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Control System Matrix N (Reduced)</inDefiningFormulation>
        <terms1:description xml:lang="en">generalized Sylvester equation for the controllability of a bi-linear control system</terms1:description>
        <rdfs:comment xml:lang="en">Except for the use of the reduced matrices (tilde-notation), there is a formal similarity with the generalized Lyapunov equations for the calculations of generalized Gramians.</rdfs:comment>
        <rdfs:label xml:lang="en">Sylvester Generalized Controllability</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674376"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SylvesterGeneralizedObservability -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SylvesterGeneralizedObservability">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixAReduced"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixCReduced"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemMatrixNReduced"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#SylvesterEquationObservability"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{A}Y + YA^{*} + \sum_k\tilde{N}_kYN_k^{*} - C\tilde{C}^{*} = 0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$A$, Control System Matrix A (Reduced)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C$, Control System Matrix C (Reduced)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Control System Matrix N (Reduced)</inDefiningFormulation>
        <terms1:description xml:lang="en">generalized Sylvester equation for the observability of a bi-linear control system</terms1:description>
        <rdfs:comment xml:lang="en">Except for the use of the reduced matrices (tilde-notation), there is a formal similarity with the generalized Lyapunov equations for the calculations of generalized Gramians. However, note the sign change in the CC term.</rdfs:comment>
        <rdfs:label xml:lang="en">Sylvester Generalized Observability</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674377"/>
    </owl:NamedIndividual>
    


