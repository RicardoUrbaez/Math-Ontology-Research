        <containsInput rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalPosition"/>
        <containsInput rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalVelocity"/>
        <containsOutput rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalMomentum"/>
        <containsOutput rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalPosition"/>
        <containsOutput rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalVelocity"/>
