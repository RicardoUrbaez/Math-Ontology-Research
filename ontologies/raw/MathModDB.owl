    <!-- https://mardi4nfdi.de/mathmoddb#VanishingAirDensity -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#VanishingAirDensity">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
