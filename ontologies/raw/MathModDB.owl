        <models rdf:resource="https://mardi4nfdi.de/mathmoddb#SolarSystemMechanics"/>
        <terms1:description xml:lang="en">classical mechanics model of the sun (fixed) and the 8 planets (moving) as point masses</terms1:description>
        <rdfs:comment xml:lang="en">Neglecting dwarf planets, satellites (e.g. Moon), asteroids, as well as the interaction with other stars or exoplanets. The numerical model of the Solar System consists of a set of mathematical equations, which, when solved, give the approximate positions of the planets as a function of time.</rdfs:comment>
        <rdfs:label xml:lang="en">Solar System Model</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Numerical_model_of_the_Solar_System"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675440"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q7069658"/>
    </owl:NamedIndividual>
    


