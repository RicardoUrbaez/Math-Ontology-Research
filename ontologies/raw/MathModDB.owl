    <!-- https://mardi4nfdi.de/mathmoddb#RecurrentNeuralNetworkSurrogateForDiscreteElementMethod -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#RecurrentNeuralNetworkSurrogateForDiscreteElementMethod">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <describedAsStudiedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#Jahnke_2022_Efficient_Numerical_Simulation_of_Soil-Tool_Interaction"/>
