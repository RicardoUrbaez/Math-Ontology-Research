    <!-- https://mardi4nfdi.de/mathmoddb#ClassicalFokkerPlanckEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ClassicalFokkerPlanckEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalPosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ControlSystemInput"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Drift"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ProbabilityDistribution"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <similarTo rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalBrownianEquation"/>
        <similarTo rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalLangevinEquation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{\partial}{\partial t} p(x, t) = -\frac{\partial}{\partial x}\left[(\mu(x, t)-u) p(x, t)\right] + \frac{\partial^2}{\partial x^2}\left[D(x, t) p(x, t)\right]$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$D$, Diffusion constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu$, Drift</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p$, Probability Distribution</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$u_t$, Control System Input</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Classical Position</inDefiningFormulation>
        <terms1:description xml:lang="en">partial differential equation describing the dynamics of a probability density of the velocity of a particle under the influence of drag forces and random forces</terms1:description>
        <rdfs:comment xml:lang="en">For vanishing drift and constant diffusion, the Fokker Planck equation yield&apos;s Fick&apos;s first law of diffusion.</rdfs:comment>
        <rdfs:comment xml:lang="en">Note the external forcing which connects the FPE to the model order reduction and/or optimal control tasks.</rdfs:comment>
        <rdfs:label xml:lang="en">Classical Fokker Planck Equation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Fokker%E2%80%93Planck_equation"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674263"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q891766"/>
    </owl:NamedIndividual>
    


