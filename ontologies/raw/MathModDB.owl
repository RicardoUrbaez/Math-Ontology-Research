    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposedFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposedFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PDESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DensityFractionCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposed"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#IsotropicGaussianFunction"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$e(x, 0)=\sum_{\tilde{l}=1}^{\tilde{L}} w_e^{(\tilde{l})} G^{(\tilde{l})}(x)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$G^{(\tilde{l})}(x)$, Isotropic Gaussian Function</inDefiningFormulation>
