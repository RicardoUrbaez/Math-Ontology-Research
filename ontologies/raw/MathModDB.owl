    <!-- https://mardi4nfdi.de/mathmoddb#NormalModesIntermolecular -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#NormalModesIntermolecular">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumEigenEnergyIntermolecular"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianNormalModeIntermolecular"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalModesAnharmonic"/>
        <terms1:description xml:lang="en">describing molecular vibrations in terms of normal modes, beyond the harmonic approximation, and including intermolecular interactions</terms1:description>
        <rdfs:comment xml:lang="en">Thus describing cluster effects, solvent effects etc.</rdfs:comment>
        <rdfs:label xml:lang="en">Normal Modes (Intermolecular)</rdfs:label>
