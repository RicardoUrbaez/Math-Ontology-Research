    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#EmpiricalDistributionOfIndividualsFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#EmpiricalDistributionOfIndividualsFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PartialMeanFieldOpinionModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiracDeltaDistribution"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EmpiricalDistributionOfIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfluencerIndividualMatrix"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MediumFollowerMatrix"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Opinion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TotalNumberOfIndividuals"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho_{m, l}^{(N)}(x, t)=\frac{1}{N} \sum_{\substack{i: B_{i m}=1 \\ C_{i l}(t)=1}} \delta\left(x-x_i(t)\right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$B_im$, Medium Follower Matrix</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C_im$, Influencer Individual Matrix</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Total Number of Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\delta$, Dirac Delta Distribution</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho_{m, l}^{(N)}$, Empirical Distribution of Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$, Opinion</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x_i$, Opinion</inDefiningFormulation>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <terms1:description xml:lang="en">empirical distribution of individuals that follow a medium and influencer</terms1:description>
        <rdfs:comment xml:lang="en">Empirical distribution of individuals that follow a medium 𝑚 and influencer 𝑙 at time 𝑡 by the sum of Dirac delta distributions δ placed at the individuals’ opinions. This distribution describes the stochastic opinion instances at a given time and integrates to

∫ᴰ ρₘ,ₗ⁽ᴺ⁾(𝑥, 𝑡) 𝑑𝑥 ≔ 𝑛ₘ,ₗ⁽ᴺ⁾(𝑡),

the proportion of individuals that follow medium 𝑚 and influencer 𝑙.</rdfs:comment>
        <rdfs:label xml:lang="en">Empirical Distribution of Individuals Formulation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674458"/>
    </owl:NamedIndividual>
    


