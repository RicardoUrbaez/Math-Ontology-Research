    <!-- https://mardi4nfdi.de/mathmoddb#LightParticleDensityMatrix -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticleDensityMatrix">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleDensityMatrix"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleExpansionCoefficient"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho_{mn} \equiv c_m c_n^\ast$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\rho$, Light Particle Density Matrix</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Light Particle Expansion Coefficient</inDefiningFormulation>
        <terms1:description xml:lang="en">quantum density matrix of the light particle(s) in quantum-classical models</terms1:description>
        <rdfs:label xml:lang="en">Light Particle Density Matrix</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticleEigenEnergy -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticleEigenEnergy">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumEigenEnergy"/>
        <terms1:description xml:lang="en">adiabatic eigen energy of the light particle(s) dynamics in quantum-classical models</terms1:description>
        <rdfs:comment xml:lang="en">Note that in quantum-classical dynamics the parametric dependence of the light particle(s) eigen energies can be interpreted as adiabatic potential energy curves|surfaces governing the heavy particle(s) positions. In one dimension, they may feature avoided or true crossings, in two (or more) dimensions they may display conical intersections.</rdfs:comment>
        <rdfs:label xml:lang="en">Light Particle Eigen Energy</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LightParticleEigenState -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LightParticleEigenState">
