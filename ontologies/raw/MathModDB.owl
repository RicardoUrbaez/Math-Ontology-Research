    <!-- https://mardi4nfdi.de/mathmoddb#Enzyme-Product1-Product2ComplexConcentrationODEBiBiOrdered -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#Enzyme-Product1-Product2ComplexConcentrationODEBiBiOrdered">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{EP_{1}P_{2}}}{dt} = k_{3} c_{ES_{1}S_{2}} + k_{-4} c_{EP_1} c_{P_2} - k_{-3} c_{EP_{1}P_{2}} - k_{4} c_{EP_{1}P_{2}}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{dc_{EP_{1}P_{2}}}{dt}$, Reaction Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{EP_1}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{EP_{1}P_{2}}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{ES_{1}S_{2}}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{P_2}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-3}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{-4}$, Reaction Rate Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_{3}$, Reaction Rate Constant</inDefiningFormulation>
