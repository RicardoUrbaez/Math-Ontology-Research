    <!-- https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianElectricDipole -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#QuantumHamiltonianElectricDipole">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#LiouvilleVonNeumannEquation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumLindbladEquation"/>
