    <!-- https://mardi4nfdi.de/mathmoddb#HeavyParticleKineticOperator -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#HeavyParticleKineticOperator">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticleKineticOperator"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticleMass"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticlePosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PlanckConstant"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumKineticOperator"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{T} \equiv - \frac{\hbar^2}{2M} \nabla_R^2$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$M$, Heavy Particle Mass</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R$, Heavy Particle Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{T}$, Heavy Particle Kinetic Operator</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hbar$, Planck Constant</inDefiningFormulation>
        <terms1:description xml:lang="en">kinetic energy operator of the heavy particle(s) in quantum-classical dynamics models</terms1:description>
        <rdfs:label xml:lang="en">Heavy Particle Kinetic Operator</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#HeavyParticleMass -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#HeavyParticleMass">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ParticleMass"/>
        <terms1:description xml:lang="en">mass(es) of the heavy particle(s) in quantum-classical dynamics models</terms1:description>
        <rdfs:label xml:lang="en">Heavy Particle Mass</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#HeavyParticleMeanForce -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#HeavyParticleMeanForce">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticleMeanForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticlePosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticlePosition"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LightParticleStateVector"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#QuantumClassicalHamiltonian"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F(R,t)\equiv-\nabla_R\langle \psi(R,t) | \hat{H}(r;R)| \psi(R,t) \rangle_r$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F$, Heavy Particle Mean Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$H$, Quantum-Classical Hamiltonian</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$R$, Heavy Particle Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi$, Light Particle State Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r$, Light Particle Position</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">mean force acting on the heavy particle(s) in quantum-classical dynamics model</terms1:description>
        <rdfs:label xml:lang="en">Heavy Particle Mean Force</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#HeavyParticleNewtonEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#HeavyParticleNewtonEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#MeanFieldEhrenfestModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticleMass"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#HeavyParticleMeanForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalNewtonEquation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{\mathrm{d^2}}{\mathrm{d}t^2} \vec{q} = \vec{F} / M$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F$, Heavy Particle Mean Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$M$, Heavy Particle Mass</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">Newton equation governing the heavy particle(s) dynamics in quantum-classical dynamics</terms1:description>
        <rdfs:label xml:lang="en">Heavy Particle Newton Equation</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#HeavyParticlePosition -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#HeavyParticlePosition">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ParticlePosition"/>
        <terms1:description xml:lang="en">position(s) of the heavy particle(s) in quantum-classical dynamics models</terms1:description>
        <rdfs:label xml:lang="en">Heavy Particle Position</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#HeavyParticlePropagation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#HeavyParticlePropagation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ComputationalTask"/>
        <similarTo rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalTimeEvolution"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalTimeEvolution"/>
        <terms1:description xml:lang="en">propagating the (classical!) state of the heavy particle(s) in quantum-classical dynamics models</terms1:description>
        <rdfs:comment xml:lang="en">Note that in quantum-classical dynamics the forces acting on the heavy particles depend on the quantum state of the light particles.</rdfs:comment>
        <rdfs:comment xml:lang="en">The classical trajectories can be integrated with conventional methods, as the Verlet algorithm. Such integration requires the forces acting on the nuclei. They are proportional to the gradient of the potential energy of the electronic states</rdfs:comment>
        <rdfs:label xml:lang="en">Heavy Particle Propagation</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Mixed_quantum-classical_dynamics"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#HeavyParticleVelocity -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#HeavyParticleVelocity">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalVelocity"/>
        <terms1:description xml:lang="en">velocity(s) of the heavy particle(s) in quantum-classical dynamics models</terms1:description>
        <rdfs:label xml:lang="en">Heavy Particle Velocity</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#HeavyParticleVelocityAdjustment -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#HeavyParticleVelocityAdjustment">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#ComputationalTask"/>
        <terms1:description xml:lang="en">adjusting heavy particle(s) velocity upon nonadiabatic transitions in quantum-classical dynamics</terms1:description>
        <rdfs:comment xml:lang="en">If the classical kinetic energy can aﬀord the energy cost of the quantum transition, the nuclei switch simultaneously to the new PES. The nuclear positions are kept
unchanged and the nuclear velocities are adjusted along the direction of the nonadiabatic (NA) coupling vector to conserve total energy. Otherwise, the surface hop is rejected. This procedure is essential to achieve Boltzmann quantum state populations and detailed balance between hops up and down in energy</rdfs:comment>
        <rdfs:label xml:lang="en">Heavy Particle Velocity Adjustment</rdfs:label>
    </owl:NamedIndividual>
    


