    <!-- https://mardi4nfdi.de/mathmoddb#ObjectRatingFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ObjectRatingFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MaimalObjectDescriptivenessRating"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ObjectCommonalityMatrix"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ObjectRatingMatrix"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$f: \mathbf{M}\rightarrow\mathbf{R}: f(s)=y, \ s\in\mathbf{M},\  y\in\{\mathbf{R}| 0 \leq y \leq score_{max}\}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathbf{M}$, Object Commonality Matrix</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathbf{R}$, Object Rating Matrix</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$score_{max}$, Maximal Object Descriptiveness Rating</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <terms1:description xml:lang="en">formulation rating the object commonalities</terms1:description>
        <rdfs:label xml:lang="en">Object Rating Formulation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674534"/>
    </owl:NamedIndividual>
    


