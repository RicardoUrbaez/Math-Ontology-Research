        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isTimeContinuous>
        <terms1:description xml:lang="en">quantum dynamics of a closed system, i.e., a system that is not interacting with its environment</terms1:description>
        <rdfs:comment xml:lang="en">A famous example is Schrödinger&apos;s cat, but only as long as the box is not opened!</rdfs:comment>
