    <!-- https://mardi4nfdi.de/mathmoddb#MomentumBalanceEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MomentumBalanceEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EigenStressOfCrystal"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StressOfCrystal"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\nabla\cdot(\sigma-\sigma^\ast)=0$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Stress of Crystal</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma^\ast$, Eigenstress of Crystal</inDefiningFormulation>
        <terms1:description xml:lang="en">in the theory of elasticity, the conservation of momentum can also be written in vector form</terms1:description>
        <rdfs:comment xml:lang="en">These equations are known as the momentum balance equations because the momentum fluxes are balanced by body and surface forces.</rdfs:comment>
        <rdfs:label xml:lang="en">Momentum Balance Equation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674325"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MonodomainEquationforActionPropagationPotential -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MonodomainEquationforActionPropagationPotential">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#ActionPotentialPropagationModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EffectiveConductivity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#IonCurrent"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MembraneCapacitance"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TransmembranePotential"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{\partial V^\text{f}_\text{m}}{\partial t} = \frac{1}{C^\text{f}_\text{m}} \left( \frac{1}{A_\text{m}} \sigma_{\text{eff}} \frac{\partial^2 V^{\text{f}}_{\text{m}}}{\partial s^2} - I_\text{ion} (V^{\text{f}}_{\text{m}}, \mathbf{y}) + S(V^{\text{s}}_{\text{m}})\right)~ \text{in} ~ \Omega_{f}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$C^{\text{f}}_{\text{m}}$, Membrane Capacitance</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_{\text{ion}}$, Ion Current</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V^{\text{f}}_{\text{m}}$, Transmembrane Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma_{\text{eff}}$, Effective Conductivity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">the evelution of the transmembrane potential at each sacomeres location</terms1:description>
        <rdfs:comment xml:lang="en">Describes the evelution of the transmembrane potential at each sacomeres location i.e. the propagation of the action potential.</rdfs:comment>
        <rdfs:label xml:lang="en">Monodomain Equation for Action Potential Propagation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674596"/>
    </owl:NamedIndividual>
    


