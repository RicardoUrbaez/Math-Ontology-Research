    <!-- https://mardi4nfdi.de/mathmoddb#BoltzmannEquationMovingParticles -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#BoltzmannEquationMovingParticles">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AttenuationCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Density"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalVector"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ParticleVelocity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ScatterCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ScatteringCrossSection"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#TransportEquation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c\,u_t (x, \theta, t) +  \theta \cdot \nabla u (x, \theta, t) = - \mu (x) \, u (x,\theta,t) + s(x) \, \int_{S^{n-1}} u (x, \theta&apos;, t) \, \sigma(\theta,\theta&apos;) \, d\theta&apos;$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu$, Attenuation Coefficient</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Scattering Cross Section</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\theta$, Normal Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Particle Velocity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s$, Scattering Coefficient</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$u$, Density</inDefiningFormulation>
        <terms1:description xml:lang="en">special version of the Boltzmann equation for moving particles</terms1:description>
        <rdfs:label xml:lang="en">Boltzmann Equation for Moving Particles</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Boltzmann_equation"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q891653"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#BoltzmannEquationMovingParticlesTimeContinuousNoScatterAssumption -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#BoltzmannEquationMovingParticlesTimeContinuousNoScatterAssumption">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AttenuationCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Density"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NormalVector"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#BoltzmannEquationMovingParticlesTimeContinuous)"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$ \theta \cdot \nabla u (x, \theta) = - \mu (x) \, u (x,\theta)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mu$, Attenuation Coefficient</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\theta$, Normal Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$u$, Density</inDefiningFormulation>
        <terms1:description xml:lang="en">special version of the Boltzmann equation for moving particles, time continuous, no scattering</terms1:description>
        <rdfs:label xml:lang="en">Boltzmann Equation for Moving Particles (time continuous, No Scatter Assumption)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Boltzmann_equation"/>
        <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q891653"/>
    </owl:NamedIndividual>
    


