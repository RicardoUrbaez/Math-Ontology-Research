    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SchrödingerEquationDifferencingScheme -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SchrödingerEquationDifferencingScheme">
