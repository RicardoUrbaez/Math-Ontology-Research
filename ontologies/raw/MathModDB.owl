    <!-- https://mardi4nfdi.de/mathmoddb#FreeFallInitialCondition -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#FreeFallInitialCondition">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedAsInitialConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallModelAirDrag"/>
        <containedAsInitialConditionIn rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallModelVacuum"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallHeight"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallInitialHeight"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FreeFallInitialVelocity"/>
