        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$j$, Quantum Number</inDefiningFormulation>
        <terms1:description xml:lang="en">quantum-mechanical eigen energies of a non-rigid rotor</terms1:description>
        <rdfs:label xml:lang="en">Quantum Eigen Energy (Linear Non-Rigid Rotor)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674551"/>
    </owl:NamedIndividual>
    


