        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#Momentum"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p \equiv mv$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$m$, Mass</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p$, Classical Momentum</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v$, Classical Velocity</inDefiningFormulation>
        <terms1:description xml:lang="en">momentum of a point particle in classical mechanics</terms1:description>
        <rdfs:label xml:lang="en">Classical Momentum</rdfs:label>
