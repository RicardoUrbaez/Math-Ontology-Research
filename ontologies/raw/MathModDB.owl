    <!-- https://mardi4nfdi.de/mathmoddb#ApproximateSpreadingCurveFormulation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ApproximateSpreadingCurveFormulation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ApproximateSpreadingCurve"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfCities"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfRegions"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RateOfChangeOfSusceptibleCities"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TimeDependentContactNetwork"/>
        <containsInitialCondition rdf:resource="https://mardi4nfdi.de/mathmoddb#InitialNumberOfInfectedCities"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi (t\, |\,\sigma , i(0)) \equiv \left( P_m - \int _{0}^t \left. \frac{ds_m(\tau )}{d\tau } \right| _{\sigma , P_m - i(0)} d\tau \right) _{m = 1,\ldots ,N_R}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N_R$, Number of Regions</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$P_m$, Number of Cities</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\frac{ds_m(\tau)}{d\tau}$, Rate of Change of susceptible Cities</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi$, Spreading Curve (Approximate)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Contact Network (Time-dependent)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDynamic>
        <terms1:description xml:lang="en">definition of approximate spreading curve through time</terms1:description>
        <rdfs:label xml:lang="en">Spreading Curve (Approximate, Formulation)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674133"/>
    </owl:NamedIndividual>
    


