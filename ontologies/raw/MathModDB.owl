    <!-- https://mardi4nfdi.de/mathmoddb#RungeKuttaMethod -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#RungeKuttaMethod">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#EulerBackwardMethod"/>
        <specializedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#EulerForwardMethod"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\begin{array}{c|cccc} c_1    &amp; a_{11} &amp; a_{12}&amp; \dots &amp; a_{1s}\\c_2    &amp; a_{21} &amp; a_{22}&amp; \dots &amp; a_{2s}\\ \vdots &amp; \vdots &amp; \vdots&amp; \ddots&amp; \vdots\\c_s    &amp; a_{s1} &amp; a_{s2}&amp; \dots &amp; a_{ss} \\\hline       &amp; b_1    &amp; b_2   &amp; \dots &amp; b_s\\ \end{array}$</definingFormulation>
        <terms1:description xml:lang="en">family of implicit and explicit methods used in temporal discretization for the approximate solutions of differential equations</terms1:description>
        <rdfs:comment xml:lang="en">These methods, which include the Euler method,  were developed around 1900 by the German mathematicians Carl Runge and Wilhelm Kutta.</rdfs:comment>
        <rdfs:label xml:lang="en">Runge–Kutta Method</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://en.wikipedia.org/wiki/Runge%E2%80%93Kutta_methods</rdfs:seeAlso>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674564"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q725944"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SEIRDerivativerelation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SEIRDerivativerelation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#HybridPDEODESEIRModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DiffusionCoefficient"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfExposed"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfInfectious"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfRemoved"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FractionOfPopulationDensityOfSusceptibles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#UnitOuterNormalVector"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\nu^T D \nabla s =\nu^T D \nabla e=\nu^T D \nabla i=\nu^T D \nabla r=0 $</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$D$, &apos;Diffusion Coefficient for SEIR Model&apos;</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\nu$, Unit Outer Normal Vector</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$e$, Fraction of Population Density of Exposed</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$i$, Fraction of Population Density of Infectious</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$r$, Fraction of Population Density of Removed</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$s$, Fraction of Population Density of Susceptibles</inDefiningFormulation>
        <terms1:description xml:lang="en">derivative relation</terms1:description>
        <rdfs:label xml:lang="en">SEIR Derivative Relation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674565"/>
    </owl:NamedIndividual>
    


