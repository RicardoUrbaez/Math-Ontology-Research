        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PTNLine"/>
        <describedAsDocumentedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#Gattermann_2017_Line_pool_generation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$(\mathcal{L},f)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{L}$, PTNLine</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$f_l$, Frequency</inDefiningFormulation>
        <terms1:description xml:lang="en">line concepts assign frequencies to lines of a line pool</terms1:description>
        <rdfs:comment xml:lang="en">A line concept is a set of lines  together with their frequencies. The frequency of a line says how often service is offered along that line within a given time period (e.g., an hour, a day).</rdfs:comment>
        <rdfs:label xml:lang="en">Line Concept</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674445"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LineConceptCosts -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LineConceptCosts">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Costs"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CostsOfLineConcept"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Frequency"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LineConcept"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LineCostsComputation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$cost(\mathcal{L},f)=\sum_{l \in \mathcal{L}} f_l \cdot cost_l$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$(\mathcal{L},f)$, Line Concept</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$cost(\mathcal{L},f)$,Costs of Line Concept</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$cost_l$, Costs</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$f_l$, Frequency</inDefiningFormulation>
        <terms1:description xml:lang="en">costs of a line concept</terms1:description>
        <rdfs:comment xml:lang="en">The costs for a line concept summarizing the costs of single lines multiplied by their frequencies.</rdfs:comment>
        <rdfs:label xml:lang="en">Line Concept Costs</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674465"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#LineCostsComputation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#LineCostsComputation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Costs"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#CostsPerUnit"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Duration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FixedCosts"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#GraphTypeIdentifier"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Length"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PeriodLength"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TurnOverTime"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$cost_l=costs\_fixed+\sum_{e \in l}\left(costs\_length \cdot length_e + costs\_edges\right) + costs\_vehicles \cdot \lvert x \cdot \frac{duration_l + turn\_over\_time}{period\_length}\rvert$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$cost_l$, Costs</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$costs\_edges$, Costs</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$costs\_fixed$, Fixed Costs</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$costs\_length$, Costs per Unit</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$costs\_vehicles$, Costs</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$duration_l$, Duration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$length_e$, Length</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$period\_length$, Period Length</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$turn\_over\_time$, Turn Over Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$x$,Graph Type Identifier</inDefiningFormulation>
        <terms1:description xml:lang="en">sum of all costs of a single line</terms1:description>
        <rdfs:comment xml:lang="en">The costs of a single line in public transport are made up of various individual costs.</rdfs:comment>
        <rdfs:label xml:lang="en">Line Costs Computation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674459"/>
    </owl:NamedIndividual>
    


