    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SensoryOrganEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SensoryOrganEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#SensoryOrganModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FibreContractionVelocity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FibreStretch"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MuscleSpindleFiringRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NumberOfSpindles"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$I_\text{spindle} = \sum^{N_\text{spindle}}_{j=1} w_jIa_j\left(\lambda^{j}_{\text{f}}, \dot{\lambda}^{j}_{\text{f}}\right)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$Ia_j$, Muscle Spindle Firing Rate</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N$, Number of Spindles</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\dot{\lambda}_{\text{f}}$, Fibre Contraction Velocity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\lambda_{\text{f}}$, Fibre Stretch</inDefiningFormulation>
        <terms1:description xml:lang="en">representing a sensory organ</terms1:description>
        <rdfs:label xml:lang="en">Sensory Organ Equation</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674574"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#SensoryOrganModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#SensoryOrganModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <describedAsStudiedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#Homs-Pons_2024_Coupled_simulations_and_parameter_inversion_for_neural_system_and_electrophysiological_muscle_models"/>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isLinear>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isTimeContinuous>
        <terms1:description xml:lang="en">mathematical model to detect macroscopic length change in the muscels and provide the motor neurons with this information.</terms1:description>
        <rdfs:label xml:lang="en">Sensory Organ Model</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.1002/gamm.202370009"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675439"/>
    </owl:NamedIndividual>
    


