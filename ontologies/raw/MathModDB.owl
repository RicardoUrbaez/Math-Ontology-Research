    <!-- https://mardi4nfdi.de/mathmoddb#BoltzmannApproximationForElectrons -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#BoltzmannApproximationForElectrons">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BandEdgeEnergyForConductionBand"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BoltzmannConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DensityOfElectrons"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DensityOfStatesForConductionBand"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricPotential"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElementaryCharge"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FermiPotentialForElectrons"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Temperature"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n(\psi,\phi_n)=N_c\exp\left(\frac{q(\psi-\phi_n)-E_c}{k_BT}\right)$</definingFormulation>
        <inDefiningFormulation>$q$, Elementary Charge</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$E_c$, Band Edge Energy for Conduction Band</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N_c$, Density of States for Conduction Band</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$T$, Temperature</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi_n$, Fermi Potential for Electrons</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi$, Electric Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_B$, Boltzmann Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$n$, Density of Electrons</inDefiningFormulation>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <terms1:description xml:lang="en">Boltzmann approximation for electrons; for use in semiconductor physics</terms1:description>
        <rdfs:label xml:lang="en">Boltzmann Approximation for Electrons</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674241"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#BoltzmannApproximationForHoles -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#BoltzmannApproximationForHoles">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BandEdgeEnergyForValenceBand"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#BoltzmannConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DensityOfHoles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#DensityOfStatesForValenceBand"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricPotential"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElementaryCharge"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#FermiPotentialForHoles"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Temperature"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p(\psi,\phi_p)=N_v\exp\left(\frac{q(\phi_p-\psi)+E_v}{k_BT}\right)$</definingFormulation>
        <inDefiningFormulation>$q$, Elementary Charge</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$E_v$, Band Edge Energy for Valence Band</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$N_v$, Density of States for Valence Band</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$T$, Temperature</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi_p$, Fermi Potential for Holes</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\psi$, Electric Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$k_B$, Boltzmann Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p$, Density of Holes</inDefiningFormulation>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <terms1:description xml:lang="en">Boltzmann approximation for holes; for use in semiconductor physics</terms1:description>
        <rdfs:label xml:lang="en">Boltzmann Approximation for Holes</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674242"/>
    </owl:NamedIndividual>
    


