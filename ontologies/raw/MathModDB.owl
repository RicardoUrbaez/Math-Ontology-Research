    <!-- https://mardi4nfdi.de/mathmoddb#MultipolarExpansionModel3D -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MultipolarExpansionModel3D">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SphericalHarmonicsExpansion3D"/>
        <models rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectromagneticFieldsAndWaves"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#MaxwellEquationsModel"/>
        <usedBy rdf:resource="https://mardi4nfdi.de/mathmoddb#FarFieldRadiation"/>
        <terms1:description xml:lang="en">mathematical series approximating an angle-dependent function</terms1:description>
        <rdfs:comment xml:lang="en">Multipole expansions are often used to represent electromagnetic fields, where the fields at distant points are given in terms of sources (charges and/or currents) in a small region (far field limit). The first term is called the monopole moment, the second term is called the dipole moment, the third term the quadrupole moment, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">Multipolar Expansion Model (3D)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Multipole_expansion"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6675438"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q1027847"/>
    </owl:NamedIndividual>
    


