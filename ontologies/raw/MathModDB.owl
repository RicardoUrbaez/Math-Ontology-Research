    <!-- https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationforBiBiReactionOrderedMechanismwithProducts1and2SS -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationforBiBiReactionOrderedMechanismwithProducts1and2SS">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#BiBiReactionOrderedMechanismMichaelisMentenModelwithProducts1and2SS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EquilibriumConstantBiBiReactionOrderedSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstantProduct1BiBiReactionOrderedSteadyStateAssumption"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstantProduct2BiBiReactionOrderedSteadyStateAssumption"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstantSubstrate1BiBiReactionOrderedSteadyStateAssumption"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstantSubstrate2BiBiReactionOrderedSteadyStateAssumption"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InitialReactionRate"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LimitingReactionRateBackwardBiBiReactionOrdered"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LimitingReactionRateForwardBiBiReactionOrdered"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisConstantProduct1BiBiReactionOrderedSteadyStateAssumption"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisConstantProduct2BiBiReactionOrderedSteadyStateAssumption"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisConstantSubstrate1BiBiReactionOrderedSteadyStateAssumption"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisConstantSubstrate2BiBiReactionOrderedSteadyStateAssumption"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ProductConcentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SubstrateConcentration"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0 = \frac{V_{max,f} V_{max,b} (c_{S_1} c_{S_2} - \frac{c_{P_1} c_{P_2}}{K_{eq}})}{V_{max,b} K_{iS_1} K_{S_2} + V_{max,b} K_{S_2} c_{S_1} + V_{max,b} K_{S_1} c_{S_2} + \frac{V_{max,f} K_{P_1}}{K_{eq}} c_{P_2} + \frac{V_{max,f} K_{P_2}}{K_{eq}} c_{P_1} + V_{max,b} c_{S_1} c_{S_2} + \frac{V_{max,f} K_{P_1}}{K_{iS_1} K_{eq}} c_{S_1} c_{P_2} + \frac{V_{max,f}}{K_{eq}} c_{P_1} c_{P_2} + \frac{V_{max,b} K_{S_1}}{K_{iP_1}} c_{S_1} c_{P_1} + \frac{V_{max,b}}{K_{iP_2}} c_{S_1} c_{S_2} c_{P_2} + \frac{V_{max,f}}{K_{iS_2} K_{eq}} c_{S_2} c_{P_1} c_{P_2}}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{P_1}$, Michaelis Constant Product 1 (Bi Bi Reaction Ordered - Steady State Assumption)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{P_2}$, Michaelis Constant Product 2 (Bi Bi Reaction Ordered - Steady State Assumption)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{S_1}$, Michaelis Constant Substrate 1 (Bi Bi Reaction Ordered - Steady State Assumption)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{S_2}$, Michaelis Constant Substrate 2 (Bi Bi Reaction Ordered - Steady State Assumption)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{eq}$, Equilibrium Constant (Bi Bi Reaction Ordered - Steady State Assumption)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iP_1}$, Inhibition Constant Product 1 (Bi Bi Reaction Ordered - Steady State Assumption)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iP_2}$, Inhibition Constant Product 2 (Bi Bi Reaction Ordered - Steady State Assumption)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iS_1}$, Inhibition Constant Substrate 1 (Bi Bi Reaction Ordered - Steady State Assumption)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iS_2}$, Inhibition Constant Substrate 2 (Bi Bi Reaction Ordered - Steady State Assumption)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V_{max,b}$, Limiting Reaction Rate (Bi Bi Reaction Ordered Mechanism - Backward)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V_{max,f}$, Limiting Reaction Rate (Bi Bi Reaction Ordered Mechanism - Forward)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{P_1}$, Product Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{P_2}$, Product Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S_1}$, Substrate Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S_2}$, Substrate Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0$, Initial Reaction Rate</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <isDynamic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDynamic>
        <isLinear rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isLinear>
        <terms1:description xml:lang="en">equation for bi bi reaction with ordered mechanism and products 1 and 2 following steady state assumption</terms1:description>
        <rdfs:label xml:lang="en">Michaelis Menten Equation (Bi Bi Reaction Ordered with Products 1 and 2 - Steady State Assumption)</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674502"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationforBiBiReactionOrderedMechanismwithProducts1and2SingleCCSS -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#MichaelisMentenEquationforBiBiReactionOrderedMechanismwithProducts1and2SingleCCSS">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#BiBiReactionOrderedMechanismMichaelisMentenModelwithProducts1and2ansSingleCCSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Concentration"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EquilibriumConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#EquilibriumConstantBiBiReactionOrderedSingleCCSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstantProduct1BiBiReactionOrderedSingleCCSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstantProduct2BiBiReactionOrderedSingleCCSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstantSubstrate1BiBiReactionOrderedSingleCCSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InhibitionConstantSubstrate2BiBiReactionOrderedSingleCCSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LimitingReactionRateBackwardBiBiReactionOrderedsingleCC"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LimitingReactionRateForwardBiBiReactionOrderedsingleCC"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisConstant"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisMentenConstantProduct1BiBiReactionOrderedsingleCCSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisMentenConstantProduct2BiBiReactionOrderedsingleCCSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisMentenConstantSubstrate1BiBiReactionOrderedsingleCCSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MichaelisMentenConstantSubstrate2BiBiReactionOrderedsingleCCSS"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ReactionRate"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0 = \frac{V_1 V_2 (c_{S_1} c_{S_2} - \frac{c_{P_1} c_{P_2}}{K_{eq}})}{V_2 K_{iS_1} K_{S_2} + V_2 K_{S_2} c_{S_1} + V_2 K_{S_1} c_{S_2} + \frac{V_1 K_{P_1}}{K_{eq}} c_{P_2} + \frac{V_1 K_{P_2}}{K_{eq}} c_{P_1} + V_2 c_{S_1} c_{S_2} + \frac{V_1 K_{P_1}}{K_{iS_1} K_{eq}} c_{S_1} c_{P_2} + \frac{V_1}{K_{eq}} c_{P_1} c_{P_2} + \frac{V_2 K_{S_1}}{K_{iP_1}} c_{S_1} c_{P_1} + \frac{V_2}{K_{iP_2}} c_{S_1} c_{S_2} c_{P_2} + \frac{V_1}{K_{iS_2} K_{eq}} c_{S_2} c_{P_1} c_{P_2}}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{P_1}$, Michaelis Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{P_2}$, Michaelis Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{S_1}$, Michaelis Constant Substrate 1 (Bi Bi Reaction Ordered with Single Central Complex - Steady State Assumption)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{S_2}$, Michaelis Constant Substrate 2 (Bi Bi Reaction Ordered with Single Central Complex - Steady State Assumption)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{eq}$, Equilibrium Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iP_1}$, Inhibition Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iP_2}$, Inhibition Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iS_1}$, Inhibition Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$K_{iS_2}$, Inhibition Constant</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V_1$, Limiting Reaction Rate (Bi Bi Reaction Ordered Mechanism with Single Central Complex - Forward)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$V_2$, Limiting Reaction Rate Backward (Bi Bi Reaction Ordered - Single Central Complex)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{P_1}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{P_2}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S_1}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c_{S_2}$, Concentration</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v_0$, Reaction Rate</inDefiningFormulation>
        <terms1:description xml:lang="en">equation for bi bi reaction with ordered mechanism and products 1 and 2 and Single Central Complex following steady state assumption</terms1:description>
