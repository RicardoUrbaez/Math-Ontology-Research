    <!-- https://mardi4nfdi.de/mathmoddb#ChangeInOpinionsOfIndividuals -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ChangeInOpinionsOfIndividuals">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#OpinionModelWithInfluencersAndMedia"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InteractionForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NoiseStrength"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#OpinionVectorOfIndividuals"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#OpinionVectorOfInfluencers"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#OpinionVectorOfMedia"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#WienerProcess"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$dx_i(t) = F_i(\mathbf{x}, \mathbf{y}, \mathbf{z}, t)dt + \sigma dW_i(t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F_i(t)$, Interaction Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$W_i(t)$, Wiener Process</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathbf{x}(t)$, Opinion Vector of Individuals</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathbf{y}(t)$, Opinion Vector of Media</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathbf{z}(t)$, Opinion Vector of Influencers</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\sigma$, Noise Strength</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <isTimeContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isTimeContinuous>
        <terms1:description xml:lang="en">opinion adaption of individuals over time</terms1:description>
        <rdfs:comment xml:lang="en">Individuals i = 1,...,N adapt their opinions in time according to this stochastic differential equation (SDE)</rdfs:comment>
        <rdfs:label xml:lang="en">Change in Opinions of Individuals</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674250"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ChangeInOpinionsOfInfluencers -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ChangeInOpinionsOfInfluencers">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#OpinionModelWithInfluencersAndMedia"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AverageOpinionOfInfluencerFollowers"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfluencerInertiaParameter"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NoiseStrength"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Opinion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#WienerProcess"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma d z_l(t)=\left(\hat{x}_l(t)-z_l(t)\right) d t+\hat{\sigma} d \hat{W}_l(t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, Inertia Parameter for Opinion Changes of Influencers</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{W}_l$, Wiener Process</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{\sigma}$, Noise Strength</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{x}_l(t)$, Average Opinion of Followers of Influencers</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$z_l(t)$, Opinion</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <terms1:description xml:lang="en">opinion adaption of influencers over time</terms1:description>
        <rdfs:comment xml:lang="en">Influencers l= 1,. . . , L slowly change their opinions in the direction of their average followership according to this Stochastic differential equation</rdfs:comment>
        <rdfs:label xml:lang="en">Change in Opinions of Influencers</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674251"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ChangeInOpinionsOfInfluencrsInThePartialFieldModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ChangeInOpinionsOfInfluencrsInThePartialFieldModel">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#PartialMeanFieldOpinionModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AverageOpinionOfFollowersOfInfluencersInThePartialFieldModel"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#InfluencerInertiaParameter"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NoiseStrength"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Opinion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#WienerProcess"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma d z_l(t)=\left(\hat{x}_l(t)-z_l(t)\right) d t+\hat{\sigma} d \hat{W}_l(t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, Inertia Parameter for Opinion Changes of Influencers</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{W}_l$, Wiener Process</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{\sigma}$, Noise Strength</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\hat{x}_l$, Average Opinion of Followers of Influencers in the Partial Field Model</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$z_l$, Opinion</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDeterministic>
        <terms1:description xml:lang="en">opinion adaption of influencers over time in the partial mean field model</terms1:description>
        <rdfs:comment xml:lang="en">Stochastic Differential equation describing the change in opinions of a given Influencer in the partial field opinion model</rdfs:comment>
        <rdfs:label xml:lang="en">Change in Opinions of Influencers in the Partial Mean Field Model</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674252"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ChangeInOpinionsOfMedia -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ChangeInOpinionsOfMedia">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <containedIn rdf:resource="https://mardi4nfdi.de/mathmoddb#OpinionModelWithInfluencersAndMedia"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#AverageOpinionOfMediaFollowers"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MediaInertiaParameter"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#NoiseStrength"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Opinion"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#WienerProcess"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Gamma d y_m(t)=\left(\tilde{x}_m(t)-y_m(t)\right) d t+\tilde{\sigma} d \tilde{W}_m(t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\Gamma$, Inertia Parameter for Opinion Changes of Media</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{W}_m$, Wiener Process</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{\sigma}$, Noise strength</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\tilde{x}_m(t)$, Average Opinion of Followers of Media</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$y_m(t)$, Opinion</inDefiningFormulation>
        <isDeterministic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDeterministic>
        <isDimensionless rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isDimensionless>
        <isSpaceContinuous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isSpaceContinuous>
        <terms1:description xml:lang="en">opinion adaption of media agents over time</terms1:description>
        <rdfs:comment xml:lang="en">Media agents m = 1,...,M slowly adapt their opinions according to this stochastic differential equation such that media agents are drawn in the direction of the average opinion of their followers.</rdfs:comment>
        <rdfs:label xml:lang="en">Change in Opinions of Media</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674253"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#ChangeInOpinionsOfMediaInThePartialFieldModel -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#ChangeInOpinionsOfMediaInThePartialFieldModel">
