    <!-- https://mardi4nfdi.de/mathmoddb#PassiveMuscleForce -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PassiveMuscleForce">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MaximumIsometricMuscleForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MuscleLength"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PassiveMuscleForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PassiveMuscleStrain"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#StressFreeMuscleLength"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F_{\text{PME}}(\mathcal{l}_{\text{M}}) \equiv F^\text{M}_0 \frac{\exp\left(\frac{k_{\text{PE}}}{\epsilon^{\text{M}}_0}\left(\frac{\mathcal{l_{\text{M}}(t)}}{\mathcal{l}_{\text{M}}^{\text{slack}}}-1\right)\right)-1}{\exp(k_{\text{PE}})-1}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F^{\text{M}}_0$, Maximum Isometric Muscle Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F_{\text{PME}}$, Passive Muscle Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\epsilon^{M}_0$, Passive Muscle Strain</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{l}^{\text{slack}}_{\text{M}}$, Stress Free Muscle Length</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{l}_{\text{M}}$, Muscle Length</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">force developed in noncontracting or inactive muscles by the elastic elements within the muscle</terms1:description>
        <rdfs:label xml:lang="en">Passive Muscle Force</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674010"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PassiveMuscleStrain -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PassiveMuscleStrain">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#MechanicalStrain"/>
        <terms1:description xml:lang="en">passive muscle strain</terms1:description>
        <rdfs:label xml:lang="en">Passive Muscle Strain</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674099"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PassiveTendonForce -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PassiveTendonForce">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#MaximumIsometricMuscleForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PassiveTendonForce"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TendonLength"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#TendonStrain"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F_{\mathrm{PTE}}(\mathcal{l}_{\mathrm{T}}(t)) \equiv \begin{cases} F_0^{\mathrm{M}} 0.10377(\exp(91-\epsilon_{\mathrm{T}}(t))-1) \  &amp; \mathrm{if} \  0 \leq \epsilon_{\mathrm{T}}(t)  \leq 0.01516  \\ F_0^{\mathrm{M}} (37.526 \epsilon_{\mathrm{T}}(t) - 0.26029 ) \  &amp; \mathrm{if} \  0.01516 &lt;\epsilon_{\mathrm{T}}(t) &lt; 0.1  \end{cases}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F_0^{\text{M}}$, Maximum Isometric Muscle Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$F_{\text{PTE}}$, Passive Tendon Force</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\epsilon_{\text{T}}$, Tendon Strain</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\mathcal{l}_{\text{T}}$, Tendon Length</inDefiningFormulation>
        <terms1:description xml:lang="en">force that a tendon can generate without the muscle actively contracting</terms1:description>
        <rdfs:comment xml:lang="en">Concrete values are fitted on experimental studies, see reference.</rdfs:comment>
        <rdfs:label xml:lang="en">Passive Tendon Force</rdfs:label>
        <doiID rdf:resource="https://doi.org/10.5194/ms-7-19-2016"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674125"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PeriodLength -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PeriodLength">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <terms1:description xml:lang="en">length of a period in time units</terms1:description>
        <rdfs:label xml:lang="en">Period Length</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674045"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PeriodicBoundaryConditionElectricField -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PeriodicBoundaryConditionElectricField">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ElectricPotential"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#LengthOfUnitCell"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Time"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#PeriodicBoundaryConditions"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi(r,t)=\phi(r+L,t)$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$L$, Length of Unit Cell</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\phi$, Electric Potential</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$t$, Time</inDefiningFormulation>
        <terms1:description xml:lang="en">periodic boundary condition for electric potential, e.g., for modeling devices with repeated units</terms1:description>
        <rdfs:comment xml:lang="en">Example: The SiQbus electron shuttling device contains periodically repeated unit cells with four clavier gates each.</rdfs:comment>
        <rdfs:label xml:lang="en">Periodic Boundary Condition for Electric Potential</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6534337"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PeriodicBoundaryConditions -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PeriodicBoundaryConditions">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <terms1:description xml:lang="en">set of boundary conditions which are often chosen for approximating a large (infinite) system by using a small part called a unit cell</terms1:description>
        <rdfs:comment xml:lang="en">When an object passes through one side of the unit cell, it re-appears on the opposite side with the same velocity. In topological terms, the space made by one-dimensional PBCs can be thought of as being mapped onto a circle. The space made by two-dimensional PBCs can be thought of as being mapped onto a torus.</rdfs:comment>
        <rdfs:label xml:lang="en">Periodic Boundary Conditions</rdfs:label>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674544"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q2992284"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PermeabilityVacuum -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PermeabilityVacuum">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <isPhysicalConstant rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isPhysicalConstant>
        <terms1:description xml:lang="en">strength of the magnetic field induced by an electric current</terms1:description>
        <rdfs:comment xml:lang="en">The magnetic permeability in a classical vacuum. It is a physical constant that quantifies the strength of the magnetic field induced by an electric current.</rdfs:comment>
        <rdfs:label xml:lang="en">Permeability (Vacuum)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Vacuum_permeability"/>
        <skos:altLabel xml:lang="en">Magnetic Constant</skos:altLabel>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673739"/>
        <qudtID rdf:resource="http://qudt.org/vocab/constant/MagneticConstant"/>
        <wikidataID rdf:resource="https://www.wikidata.org/wiki/Q1515261"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PermittivityDielectric -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PermittivityDielectric">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <terms1:description xml:lang="en">measure of the electric polarizability of a dielectric material</terms1:description>
        <rdfs:comment xml:lang="en">In electromagnetism, the absolute permittivity, often simply called permittivity is a measure of the electric polarizability of a dielectric material. It is given as the product of the vacuum dielectric permittivity and the relative permittivity of the material. Permittivities may be complex and frequency-dependent.</rdfs:comment>
        <rdfs:label xml:lang="en">Permittivity (Dielectric)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Permittivity"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6534318"/>
        <qudtID rdf:resource="https://qudt.org/vocab/quantitykind/Permittivity"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q211569"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PermittivityRelative -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PermittivityRelative">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PermittivityDielectric"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PermittivityRelative"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#PermittivityVacuum"/>
        <nondimensionalizes rdf:resource="https://mardi4nfdi.de/mathmoddb#PermittivityDielectric"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\varepsilon_{\mathrm{r}} \equiv \frac{\varepsilon}{\varepsilon_0}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\varepsilon$, Permittivity (Dielectric)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\varepsilon_0$, Permittivity (Vacuum)</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\varepsilon_{\mathrm{r}}$, Permittivity (Relative)</inDefiningFormulation>
        <terms1:description xml:lang="en">permittivity of a material expressed as a ratio with the electric permittivity of a vacuum</terms1:description>
        <rdfs:comment xml:lang="en">The relative permittivity (in older texts, dielectric constant) is the permittivity of a material expressed as a ratio with the electric permittivity of a vacuum. A dielectric is an insulating material, and the dielectric constant of an insulator measures the ability of the insulator to store electric energy in an electrical field. Permittivities may be complex and frequency-dependent.</rdfs:comment>
        <rdfs:label xml:lang="en">Permittivity (Relative)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Relative_permittivity"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674103"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q4027242"/>
    </owl:NamedIndividual>
    


    <!-- https://mardi4nfdi.de/mathmoddb#PermittivityVacuum -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#PermittivityVacuum">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#PermittivityDielectric"/>
        <isPhysicalConstant rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isPhysicalConstant>
        <terms1:description xml:lang="en">physical constant that represents the capability of the vacuum to permit electric field lines</terms1:description>
        <rdfs:comment xml:lang="en">Vacuum permittivity is the value of the absolute dielectric permittivity of classical vacuum. It is an ideal (baseline) physical constant.</rdfs:comment>
        <rdfs:label xml:lang="en">Permittivity (Vacuum)</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Vacuum_permittivity"/>
        <skos:altLabel xml:lang="en">distributed capacitance of the vacuum</skos:altLabel>
        <skos:altLabel xml:lang="en">electric constant</skos:altLabel>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6673740"/>
