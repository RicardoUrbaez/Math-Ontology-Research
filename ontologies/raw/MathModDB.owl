    <!-- https://mardi4nfdi.de/mathmoddb#RelativisticMomentum -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#RelativisticMomentum">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#Quantity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#ClassicalVelocity"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Mass"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#RelativisticMomentum"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#SpeedOfLight"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#Momentum"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p\equiv\frac{mv}{\sqrt{1-\frac{v^2}{c^2}}}$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$c$, Speed of Light</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$m$, Mass</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$p$, Relativistic Momentum</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$v$, Classical Velocity</inDefiningFormulation>
        <terms1:description xml:lang="en">momentum of a particle in special relativity</terms1:description>
        <rdfs:label xml:lang="en">Relativistic Momentum</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://en.wikipedia.org/wiki/Momentum#Relativistic"/>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674075"/>
    </owl:NamedIndividual>
    


