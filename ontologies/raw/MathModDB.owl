    <!-- https://mardi4nfdi.de/mathmoddb#FourierEquation -->

    <owl:NamedIndividual rdf:about="https://mardi4nfdi.de/mathmoddb#FourierEquation">
        <rdf:type rdf:resource="https://mardi4nfdi.de/mathmoddb#MathematicalFormulation"/>
        <contains rdf:resource="https://mardi4nfdi.de/mathmoddb#Temperature"/>
        <specializes rdf:resource="https://mardi4nfdi.de/mathmoddb#TransportEquation"/>
        <definingFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q = - \gamma \nabla T$</definingFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$T$, Temperature</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$\gamma$, Thermal Conductivity</inDefiningFormulation>
        <inDefiningFormulation rdf:datatype="https://mardi4nfdi.de/mathmoddb#LaTeX">$q$, Heat Flux</inDefiningFormulation>
        <terms1:description xml:lang="en">differential form of Fourier&apos;s law of thermal conduction</terms1:description>
        <rdfs:comment xml:lang="en">Assuming that the local heat flux  is equal to the product of thermal conductivity  and the negative local temperature gradient.</rdfs:comment>
        <rdfs:label xml:lang="en">Fourier Equation</rdfs:label>
        <skos:altLabel xml:lang="en">Fourier&apos;s law of heat conduction</skos:altLabel>
        <mardiID rdf:resource="https://portal.mardi4nfdi.de/wiki/Item:Q6674358"/>
        <wikidataID rdf:resource="https://wikidata.org/wiki/Q12016821"/>
    </owl:NamedIndividual>
    


