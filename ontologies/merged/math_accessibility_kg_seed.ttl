mathkg:MathematicalConcept rdf:type owl:Class ;
                           rdfs:subClassOf owl:Thing ;
                           obo:IAO_0000115 "A general concept used to represent mathematical objects, operations, or relations in the math accessibility knowledge graph." ;
                           rdfs:comment "Top-level parent class added to organize the Week 2 seed ontology hierarchy." ;
                           rdfs:label "Mathematical Concept" ;
                           skos:definition "A broad category for mathematical entities represented in the math accessibility knowledge graph." .


###  http://example.org/mathkg/Matrix
mathkg:Matrix rdf:type owl:Class ;
              rdfs:subClassOf mathkg:MathObject ;
              obo:IAO_0000115 "A matrix is a rectangular array of numbers, symbols, or expressions arranged in rows and columns." ;
              dc:source "OntoMathPRO" ;
              rdfs:comment "Mapped from OntoMathPRO mathematics:E1703 based on a direct Matrix@en label match." ;
              rdfs:label "Matrix"@en ;
              skos:definition "A matrix is a rectangular array of numbers, symbols, or expressions arranged in rows and columns." ;
              skos:exactMatch omp:E1703 ;
    skos:definition "Matrix is a mathematical concept used as an object, quantity, structure, or named idea in mathematical discourse."@en ;
    skos:example "Use matrix as the spoken semantic name for this concept in accessible math output."@en ;
    mathkg:conceptType "MathObject" ;
    mathkg:kindRoleClassification "kind" ;
    mathkg:mappingQuality "canonical_match" ;
    mathkg:provenanceNote "OntoMathPRO class mathematics:E1703 has direct rdfs:label Matrix@en; selected as canonical IRI according to Week 2 rules" ;
    mathkg:accessibilityNote "Speech rendering should use the canonical label and a concise definition when the notation may be ambiguous."@en ;
    mathkg:reviewStatus "ready_for_metadata_review" ;
    skos:note "merge_status: canonical_match" ;
    skos:altLabel "matrix"@en ;
    skos:definition "Matrix is a mathematical concept used as an object, quantity, structure, or named idea in mathematical discourse."@en ;
    skos:example "Use matrix as the spoken semantic name for this concept in accessible math output."@en ;
    mathkg:provenanceNote "OntoMathPRO class mathematics:E1703 has direct rdfs:label Matrix@en; selected as canonical IRI according to Week 2 rules" ;
    mathkg:accessibilityNote "Speech rendering should use the canonical label and a concise definition when the notation may be ambiguous."@en .

###  http://example.org/mathkg/Mean
mathkg:Mean rdf:type owl:Class ;
            rdfs:subClassOf mathkg:MathObject ;
            obo:IAO_0000115 "The mean is a measure of central tendency, often computed by dividing the sum of values by the number of values." ;
            dc:source "OntoMathPRO" ;
            rdfs:comment "Included for Week 2 validation coverage; exact canonical IRI and cross-source equivalence require further review." ;
            rdfs:label "Mean"@en ;
            skos:exactMatch omp:E1666 ;
            skos:note "merge_status: mapped" ;
    skos:definition "Mean is a mathematical operation used to transform one or more inputs into a result."@en ;
    skos:example "Use mean when reading a step that applies a mathematical rule to inputs."@en ;
    mathkg:conceptType "MathOperation" ;
    mathkg:kindRoleClassification "kind" ;
    mathkg:mappingQuality "canonical_match" ;
    mathkg:provenanceNote "OntoMathPRO class mathematics:E1666 has English label Average value and Russian label Среднее значение; selected as canonical source for the Mean concept" ;
    mathkg:accessibilityNote "Speech rendering should name the operation and, where possible, identify its operands and result."@en ;
    mathkg:reviewStatus "needs_definition_review" ;
    skos:note "merge_status: canonical_match" ;
    skos:altLabel "mean"@en ;
    skos:definition "Mean is a mathematical operation used to transform one or more inputs into a result."@en ;
    skos:example "Use mean when reading a step that applies a mathematical rule to inputs."@en ;
    mathkg:provenanceNote "OntoMathPRO class mathematics:E1666 has English label Average value and Russian label Среднее значение; selected as canonical source for the Mean concept" ;
    mathkg:accessibilityNote "Speech rendering should name the operation and, where possible, identify its operands and result."@en .

