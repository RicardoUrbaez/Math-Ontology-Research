@prefix : <http://example.org/mathkg/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix IAO: <http://purl.obolibrary.org/obo/IAO_> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix omp: <http://cll.niimm.ksu.ru/ontologies/mathematics#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix mathkg: <http://example.org/mathkg/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <http://example.org/mathkg/> .

<http://example.org/mathkg/> rdf:type owl:Ontology ;
                              dc:description "Initial Week 2 seed merge ontology for a math accessibility knowledge graph. This file defines project-local classes for verified mathematical concepts and links them to canonical OntoMathPRO IRIs using the Week 2 cross-ontology mapping table." ;
                              dc:license "Research prototype for academic use; source ontologies retain their original licenses." ;
                              dc:source "OntoMathPRO, MathModDB, OntoMathEdu, OpenMath Content Dictionaries" ;
                              dc:title "Math Accessibility Knowledge Graph Seed Ontology" ;
                              dcterms:license "Research prototype for academic use; source ontologies retain their original licenses." ;
                              rdfs:comment "Initial Week 2 seed merge ontology based on the verified cross-ontology mapping table and canonical IRI review process." ;
                              rdfs:label "Math Accessibility Knowledge Graph Seed Ontology" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.obolibrary.org/obo/IAO_0000115
obo:IAO_0000115 rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/license
dc:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/source
dc:source rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#exactMatch
skos:exactMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#note
skos:note rdf:type owl:AnnotationProperty .


mathkg:conceptType a owl:AnnotationProperty ;
    rdfs:label "Concept type"@en ;
    obo:IAO_0000115 "An annotation property recording the project-level type assigned to a mathematical concept."@en .

mathkg:kindRoleClassification a owl:AnnotationProperty ;
    rdfs:label "Kind/role classification"@en ;
    obo:IAO_0000115 "An annotation property recording whether a concept is treated as a rigid kind or a context-dependent role."@en .

mathkg:mappingQuality a owl:AnnotationProperty ;
    rdfs:label "Mapping quality"@en ;
    obo:IAO_0000115 "An annotation property recording the confidence or decision status for a concept mapping."@en .

mathkg:accessibilityNote a owl:AnnotationProperty ;
    rdfs:label "Accessibility note"@en ;
    obo:IAO_0000115 "An annotation property recording speech, readability, or accessibility guidance for a concept."@en .

mathkg:reviewStatus a owl:AnnotationProperty ;
    rdfs:label "Review status"@en ;
    obo:IAO_0000115 "An annotation property recording whether a concept metadata record is ready or needs further review."@en .

mathkg:provenanceNote a owl:AnnotationProperty ;
    rdfs:label "Provenance note"@en ;
    obo:IAO_0000115 "An annotation property recording source and merge-decision notes for a concept."@en .

#################################################################
#    Object Properties
#################################################################

###  http://example.org/mathkg/MathRelation
mathkg:MathRelation rdf:type owl:ObjectProperty ;
                    rdfs:domain mathkg:MathObject ;
                    rdfs:range mathkg:MathObject ;
                    obo:IAO_0000115 "A mathematical relation property connects mathematical objects in the math accessibility knowledge graph." ;
                    rdfs:comment "ObjectProperty root added to satisfy the Week 2 OWL 2 DL requirement for a MathRelation object-property subhierarchy." ;
                    rdfs:label "Math Relation"@en ;
                    skos:definition "An upper-level object property used to organize mathematical relations between mathematical objects."@en ;
                    skos:note "Upper-level object property branch for mathematical relations."@en .


###  http://example.org/mathkg/dependsOn
mathkg:dependsOn rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf mathkg:MathRelation ;
                 rdfs:domain mathkg:MathObject ;
                 rdfs:range mathkg:MathObject ;
                 rdfs:label "depends on"@en ;
                 skos:definition "Relates a mathematical object or concept to another concept it depends on."@en ;
    obo:IAO_0000115 "Relates a mathematical object or concept to another concept it depends on."@en .

###  http://example.org/mathkg/hasElement
mathkg:hasElement rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf mathkg:MathRelation ;
                  owl:inverseOf mathkg:isElementOf ;
                  rdfs:domain mathkg:MathObject ;
                  rdfs:range mathkg:MathObject ;
                  rdfs:label "has element"@en ;
                  skos:definition "Relates a mathematical object, such as a set, to an element that belongs to it."@en ;
    obo:IAO_0000115 "Relates a mathematical object, such as a set, to an element that belongs to it."@en .

###  http://example.org/mathkg/hasOperand
mathkg:hasOperand rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf mathkg:MathRelation ;
                  obo:IAO_0000115 "Connects a mathematical operation to one of its input mathematical objects." ;
                  rdfs:label "has operand" .


###  http://example.org/mathkg/hasRelation
mathkg:hasRelation rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf mathkg:MathRelation ;
                   obo:IAO_0000115 "Connects a mathematical object to a relation concept or related mathematical object." ;
                   rdfs:label "has relation" .


###  http://example.org/mathkg/hasResult
mathkg:hasResult rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf mathkg:MathRelation ;
                 obo:IAO_0000115 "Connects a mathematical operation to its output or result." ;
                 rdfs:label "has result" .


###  http://example.org/mathkg/isElementOf
mathkg:isElementOf rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf mathkg:MathRelation ;
                   rdfs:domain mathkg:MathObject ;
                   rdfs:range mathkg:MathObject ;
                   rdfs:label "is element of"@en ;
                   skos:definition "Relates an element to the mathematical object it belongs to."@en ;
    obo:IAO_0000115 "Relates an element to the mathematical object it belongs to."@en .

###  http://example.org/mathkg/isEqualTo
mathkg:isEqualTo rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf mathkg:MathRelation ;
                 rdfs:domain mathkg:MathObject ;
                 rdfs:range mathkg:MathObject ;
                 rdfs:label "is equal to"@en ;
                 skos:definition "Relates two mathematical objects that are considered equal."@en ;
    obo:IAO_0000115 "Relates two mathematical objects that are considered equal."@en .

###  http://example.org/mathkg/isLessThan
mathkg:isLessThan rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf mathkg:MathRelation ;
                  rdfs:domain mathkg:MathObject ;
                  rdfs:range mathkg:MathObject ;
                  rdfs:label "is less than"@en ;
                  skos:definition "Relates one mathematical object or value to another that is greater than it."@en ;
    obo:IAO_0000115 "Relates one mathematical object or value to another that is greater than it."@en .

###  http://example.org/mathkg/isSubsetOf
mathkg:isSubsetOf rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf mathkg:MathRelation ;
                  rdfs:domain mathkg:MathObject ;
                  rdfs:range mathkg:MathObject ;
                  rdfs:label "is subset of"@en ;
                  skos:definition "Relates one set to another set that contains it."@en ;
    obo:IAO_0000115 "Relates one set to another set that contains it."@en .

#################################################################
#    Classes
#################################################################

###  http://example.org/mathkg/Addition
mathkg:Addition rdf:type owl:Class ;
                rdfs:subClassOf mathkg:MathOperation ;
                obo:IAO_0000115 "Addition is the operation of combining quantities to produce their sum." ;
                dc:source "OntoMathPRO" ;
                rdfs:comment "Mapped from OntoMathPRO mathematics:E1315 based on a direct Addition@en label match." ;
                rdfs:label "Addition"@en ;
                skos:definition "Addition is the operation of combining quantities to produce their sum." ;
                skos:exactMatch omp:E1315 ;
    skos:definition "Addition is a mathematical operation used to transform one or more inputs into a result."@en ;
    skos:example "Use addition when reading a step that applies a mathematical rule to inputs."@en ;
    mathkg:conceptType "MathOperation" ;
    mathkg:kindRoleClassification "kind" ;
    mathkg:mappingQuality "canonical_match" ;
    mathkg:provenanceNote "OntoMathPRO class mathematics:E1315 has direct rdfs:label Addition@en; selected as canonical IRI according to Week 2 rules" ;
    mathkg:accessibilityNote "Speech rendering should name the operation and, where possible, identify its operands and result."@en ;
    mathkg:reviewStatus "ready_for_metadata_review" ;
    skos:note "merge_status: canonical_match" ;
    skos:altLabel "addition"@en ;
    skos:definition "Addition is a mathematical operation used to transform one or more inputs into a result."@en ;
    skos:example "Use addition when reading a step that applies a mathematical rule to inputs."@en ;
    mathkg:provenanceNote "OntoMathPRO class mathematics:E1315 has direct rdfs:label Addition@en; selected as canonical IRI according to Week 2 rules" ;
    mathkg:accessibilityNote "Speech rendering should name the operation and, where possible, identify its operands and result."@en .

###  http://example.org/mathkg/Angle
mathkg:Angle rdf:type owl:Class ;
             rdfs:subClassOf mathkg:MathObject ;
             obo:IAO_0000115 "An angle is a measure of rotation or the figure formed by two rays sharing a common endpoint." ;
             dc:source "OntoMathPRO" ;
             rdfs:comment "Included for Week 2 validation coverage; exact canonical IRI and cross-source equivalence require further review." ;
             rdfs:label "Angle"@en ;
             skos:exactMatch omp:E1187 ;
             skos:note "merge_status: mapped" ;
    skos:definition "Angle is a mathematical concept used as an object, quantity, structure, or named idea in mathematical discourse."@en ;
    skos:example "Use angle as the spoken semantic name for this concept in accessible math output."@en ;
    mathkg:conceptType "MathObject" ;
    mathkg:kindRoleClassification "kind" ;
    mathkg:mappingQuality "canonical_match" ;
    mathkg:provenanceNote "OntoMathPRO class mathematics:E1187 has direct English label Angle and Russian label угол; selected as canonical source for Angle" ;
    mathkg:accessibilityNote "Speech rendering should use the canonical label and a concise definition when the notation may be ambiguous."@en ;
    mathkg:reviewStatus "needs_definition_review" ;
    skos:note "merge_status: canonical_match" ;
    skos:altLabel "angle"@en ;
    skos:definition "Angle is a mathematical concept used as an object, quantity, structure, or named idea in mathematical discourse."@en ;
    skos:example "Use angle as the spoken semantic name for this concept in accessible math output."@en ;
    mathkg:provenanceNote "OntoMathPRO class mathematics:E1187 has direct English label Angle and Russian label угол; selected as canonical source for Angle" ;
    mathkg:accessibilityNote "Speech rendering should use the canonical label and a concise definition when the notation may be ambiguous."@en .

###  http://example.org/mathkg/Area
mathkg:Area rdf:type owl:Class ;
            rdfs:subClassOf mathkg:MathObject ;
            obo:IAO_0000115 "Area is the measure of the size of a two-dimensional region." ;
            dc:source "MathModDB" ;
            rdfs:comment "Included for Week 2 validation coverage; exact canonical IRI and cross-source equivalence require further review." ;
            rdfs:label "Area"@en ;
            skos:exactMatch <https://mardi4nfdi.de/mathmoddb#Area> ;
            skos:note "merge_status: mapped" ;
    skos:definition "Area is a mathematical concept used as an object, quantity, structure, or named idea in mathematical discourse."@en ;
    skos:example "Use area as the spoken semantic name for this concept in accessible math output."@en ;
    mathkg:conceptType "MathObject" ;
    mathkg:kindRoleClassification "kind" ;
    mathkg:mappingQuality "canonical_match" ;
    mathkg:provenanceNote "MathModDB individual mathmoddb:Area has direct English label Area and description as a quantity expressing the extent of a two-dimensional surface or shape; selected as canonical source for Area" ;
    mathkg:accessibilityNote "Speech rendering should use the canonical label and a concise definition when the notation may be ambiguous."@en ;
    mathkg:reviewStatus "needs_definition_review" ;
    skos:note "merge_status: canonical_match" ;
    skos:altLabel "area"@en ;
    skos:definition "Area is a mathematical concept used as an object, quantity, structure, or named idea in mathematical discourse."@en ;
    skos:example "Use area as the spoken semantic name for this concept in accessible math output."@en ;
    mathkg:provenanceNote "MathModDB individual mathmoddb:Area has direct English label Area and description as a quantity expressing the extent of a two-dimensional surface or shape; selected as canonical source for Area" ;
    mathkg:accessibilityNote "Speech rendering should use the canonical label and a concise definition when the notation may be ambiguous."@en .

###  http://example.org/mathkg/Circle
mathkg:Circle rdf:type owl:Class ;
              rdfs:subClassOf mathkg:MathObject ;
              obo:IAO_0000115 "A circle is the set of points in a plane that are all the same distance from a given center point." ;
              dc:source "OntoMathPRO" ;
              rdfs:comment "Included for Week 2 validation coverage; exact canonical IRI and cross-source equivalence require further review." ;
              rdfs:label "Circle"@en ;
              skos:exactMatch omp:E109 ;
              skos:note "merge_status: mapped" ;
    skos:definition "Circle is a mathematical concept used as an object, quantity, structure, or named idea in mathematical discourse."@en ;
    skos:example "Use circle as the spoken semantic name for this concept in accessible math output."@en ;
    mathkg:conceptType "MathObject" ;
    mathkg:kindRoleClassification "kind" ;
    mathkg:mappingQuality "canonical_match" ;
    mathkg:provenanceNote "OntoMathPRO class mathematics:E109 has direct English label Circle and Russian label окружность; selected as canonical source for Circle" ;
    mathkg:accessibilityNote "Speech rendering should use the canonical label and a concise definition when the notation may be ambiguous."@en ;
    mathkg:reviewStatus "needs_definition_review" ;
    skos:note "merge_status: canonical_match" ;
    skos:altLabel "circle"@en ;
    skos:definition "Circle is a mathematical concept used as an object, quantity, structure, or named idea in mathematical discourse."@en ;
    skos:example "Use circle as the spoken semantic name for this concept in accessible math output."@en ;
    mathkg:provenanceNote "OntoMathPRO class mathematics:E109 has direct English label Circle and Russian label окружность; selected as canonical source for Circle" ;
    mathkg:accessibilityNote "Speech rendering should use the canonical label and a concise definition when the notation may be ambiguous."@en .

###  http://example.org/mathkg/Coefficient
mathkg:Coefficient rdf:type owl:Class ;
                   rdfs:subClassOf mathkg:MathObject ;
                   obo:IAO_0000115 "A coefficient is a numerical or symbolic factor that multiplies another term in an expression." ;
                   dc:source "OntoMathPRO" ;
                   rdfs:comment "Included for Week 2 validation coverage; exact canonical IRI and cross-source equivalence require further review. Classified under MathematicalConcept pending review of a dedicated role hierarchy." ;
                   rdfs:label "Coefficient"@en ;
                   skos:exactMatch omp:E2129 ;
                   skos:note "merge_status: mapped" ;
    skos:definition "Coefficient is a context-dependent mathematical role used inside expressions, formulas, or models."@en ;
    skos:example "Use coefficient when a symbol's meaning depends on its role in an expression or model."@en ;
    mathkg:conceptType "Role" ;
    mathkg:kindRoleClassification "role" ;
    mathkg:mappingQuality "canonical_match" ;
    mathkg:provenanceNote "OntoMathPRO class mathematics:E2129 has direct English label Coefficient and Russian label коэффициент; selected as canonical source for Coefficient" ;
    mathkg:accessibilityNote "Speech rendering should preserve the expression context because this concept changes meaning by role."@en ;
    mathkg:reviewStatus "needs_definition_review" ;
    skos:note "merge_status: canonical_match" ;
    skos:altLabel "coefficient"@en ;
    skos:definition "Coefficient is a context-dependent mathematical role used inside expressions, formulas, or models."@en ;
    skos:example "Use coefficient when a symbol's meaning depends on its role in an expression or model."@en ;
    mathkg:provenanceNote "OntoMathPRO class mathematics:E2129 has direct English label Coefficient and Russian label коэффициент; selected as canonical source for Coefficient" ;
    mathkg:accessibilityNote "Speech rendering should preserve the expression context because this concept changes meaning by role."@en .

###  http://example.org/mathkg/ComplexNumber
mathkg:ComplexNumber rdf:type owl:Class ;
                     rdfs:subClassOf mathkg:MathObject ;
                     obo:IAO_0000115 "A complex number is a number with a real part and an imaginary part." ;
                     dc:source "OntoMathPRO" ;
                     rdfs:comment "Mapped from OntoMathPRO mathematics:E2127 based on a direct Complex number@en label match." ;
                     rdfs:label "Complex Number"@en ;
                     skos:definition "A complex number is a number with a real part and an imaginary part." ;
                     skos:exactMatch omp:E2127 ;
    skos:definition "Complex Number is a mathematical concept used as an object, quantity, structure, or named idea in mathematical discourse."@en ;
    skos:example "Use complex number as the spoken semantic name for this concept in accessible math output."@en ;
    mathkg:conceptType "MathObject" ;
    mathkg:kindRoleClassification "kind" ;
    mathkg:mappingQuality "canonical_match" ;
    mathkg:provenanceNote "OntoMathPRO class mathematics:E2127 has direct rdfs:label Complex number@en; selected as canonical IRI according to Week 2 rules" ;
    mathkg:accessibilityNote "Speech rendering should use the canonical label and a concise definition when the notation may be ambiguous."@en ;
    mathkg:reviewStatus "ready_for_metadata_review" ;
    skos:note "merge_status: canonical_match" ;
    skos:altLabel "complex number"@en ;
    skos:altLabel "complexnumber"@en ;
    skos:definition "Complex Number is a mathematical concept used as an object, quantity, structure, or named idea in mathematical discourse."@en ;
    skos:example "Use complex number as the spoken semantic name for this concept in accessible math output."@en ;
    mathkg:provenanceNote "OntoMathPRO class mathematics:E2127 has direct rdfs:label Complex number@en; selected as canonical IRI according to Week 2 rules" ;
    mathkg:accessibilityNote "Speech rendering should use the canonical label and a concise definition when the notation may be ambiguous."@en .

###  http://example.org/mathkg/Constant
mathkg:Constant rdf:type owl:Class ;
                rdfs:subClassOf mathkg:MathObject ;
                obo:IAO_0000115 "A constant is a value that is fixed within a given mathematical context." ;
                dc:source "OntoMathPRO" ;
                rdfs:comment "Included for Week 2 validation coverage; exact canonical IRI and cross-source equivalence require further review. Classified under MathematicalConcept pending review of a dedicated role hierarchy." ;
                rdfs:label "Constant"@en ;
                skos:exactMatch omp:E2134 ;
                skos:note "merge_status: mapped" ;
    skos:definition "Constant is a context-dependent mathematical role used inside expressions, formulas, or models."@en ;
    skos:example "Use constant when a symbol's meaning depends on its role in an expression or model."@en ;
    mathkg:conceptType "Role" ;
    mathkg:kindRoleClassification "role" ;
    mathkg:mappingQuality "canonical_match" ;
    mathkg:provenanceNote "OntoMathPRO class mathematics:E2134 has direct English label Constant and Russian labels Постоянная and Константа; selected as canonical source for Constant" ;
    mathkg:accessibilityNote "Speech rendering should preserve the expression context because this concept changes meaning by role."@en ;
    mathkg:reviewStatus "needs_definition_review" ;
    skos:note "merge_status: canonical_match" ;
    skos:altLabel "constant"@en ;
    skos:definition "Constant is a context-dependent mathematical role used inside expressions, formulas, or models."@en ;
    skos:example "Use constant when a symbol's meaning depends on its role in an expression or model."@en ;
    mathkg:provenanceNote "OntoMathPRO class mathematics:E2134 has direct English label Constant and Russian labels Постоянная and Константа; selected as canonical source for Constant" ;
    mathkg:accessibilityNote "Speech rendering should preserve the expression context because this concept changes meaning by role."@en .

###  http://example.org/mathkg/Cosine
mathkg:Cosine rdf:type owl:Class ;
              rdfs:subClassOf mathkg:MathObject ;
              obo:IAO_0000115 "Cosine is a trigonometric function that relates an angle to a ratio in a right triangle and to coordinates on the unit circle." ;
              dc:source "OpenMath Content Dictionaries" ;
              rdfs:comment "Included for Week 2 validation coverage; exact canonical IRI and cross-source equivalence require further review." ;
              rdfs:label "Cosine"@en ;
              skos:exactMatch <http://www.openmath.org/cd/transc1#cos> ;
              skos:note "merge_status: mapped" ;
    skos:definition "Cosine is a mathematical operation used to transform one or more inputs into a result."@en ;
    skos:example "Use cosine when reading a step that applies a mathematical rule to inputs."@en ;
    mathkg:conceptType "MathOperation" ;
    mathkg:kindRoleClassification "kind" ;
    mathkg:mappingQuality "canonical_match" ;
    mathkg:provenanceNote "OpenMath Official transc1 Content Dictionary includes cos as the cosine function; selected as canonical source for the Cosine operation" ;
    mathkg:accessibilityNote "Speech rendering should name the operation and, where possible, identify its operands and result."@en ;
    mathkg:reviewStatus "needs_definition_review" ;
    skos:note "merge_status: canonical_match" ;
    skos:altLabel "cosine"@en ;
    skos:definition "Cosine is a mathematical operation used to transform one or more inputs into a result."@en ;
    skos:example "Use cosine when reading a step that applies a mathematical rule to inputs."@en ;
    mathkg:provenanceNote "OpenMath Official transc1 Content Dictionary includes cos as the cosine function; selected as canonical source for the Cosine operation" ;
    mathkg:accessibilityNote "Speech rendering should name the operation and, where possible, identify its operands and result."@en .

###  http://example.org/mathkg/Derivative
