                  rdfs:label "Derivative"@en ;
                  skos:exactMatch <http://www.openmath.org/cd/calculus1#diff> ;
                  skos:note "merge_status: mapped" ;
    skos:definition "Derivative is a mathematical operation used to transform one or more inputs into a result."@en ;
    skos:example "Use derivative when reading a step that applies a mathematical rule to inputs."@en ;
    mathkg:conceptType "MathOperation" ;
    mathkg:kindRoleClassification "kind" ;
    mathkg:mappingQuality "canonical_match" ;
    mathkg:provenanceNote "OpenMath Official calculus1 Content Dictionary includes diff for ordinary differentiation of a unary function; selected as canonical source because no safer general OntoMathPRO derivative class was confirmed" ;
    mathkg:accessibilityNote "Speech rendering should name the operation and, where possible, identify its operands and result."@en ;
    mathkg:reviewStatus "needs_definition_review" ;
    skos:note "merge_status: canonical_match" ;
    skos:altLabel "derivative"@en ;
    skos:definition "Derivative is a mathematical operation used to transform one or more inputs into a result."@en ;
    skos:example "Use derivative when reading a step that applies a mathematical rule to inputs."@en ;
    mathkg:provenanceNote "OpenMath Official calculus1 Content Dictionary includes diff for ordinary differentiation of a unary function; selected as canonical source because no safer general OntoMathPRO derivative class was confirmed" ;
    mathkg:accessibilityNote "Speech rendering should name the operation and, where possible, identify its operands and result."@en .

###  http://example.org/mathkg/Determinant
mathkg:Determinant rdf:type owl:Class ;
                   rdfs:subClassOf mathkg:MathOperation ;
                   obo:IAO_0000115 "A determinant is a value computed from a square matrix that captures key algebraic properties of the matrix." ;
                   dc:source "OpenMath Content Dictionaries" ;
                   rdfs:comment "Included for Week 2 validation coverage; exact canonical IRI and cross-source equivalence require further review." ;
                   rdfs:label "Determinant"@en ;
                   skos:exactMatch <http://www.openmath.org/cd/linalg1#determinant> ;
                   skos:note "merge_status: mapped" ;
    skos:definition "Determinant is a mathematical operation used to transform one or more inputs into a result."@en ;
    skos:example "Use determinant when reading a step that applies a mathematical rule to inputs."@en ;
    mathkg:conceptType "MathOperation" ;
    mathkg:kindRoleClassification "kind" ;
    mathkg:mappingQuality "canonical_match" ;
    mathkg:provenanceNote "OpenMath Official linalg1 Content Dictionary includes determinant as the unary function returning the determinant of a square matrix; selected as canonical source for Determinant" ;
    mathkg:accessibilityNote "Speech rendering should name the operation and, where possible, identify its operands and result."@en ;
    mathkg:reviewStatus "needs_definition_review" ;
    skos:note "merge_status: canonical_match" ;
    skos:altLabel "determinant"@en ;
    skos:definition "Determinant is a mathematical operation used to transform one or more inputs into a result."@en ;
    skos:example "Use determinant when reading a step that applies a mathematical rule to inputs."@en ;
    mathkg:provenanceNote "OpenMath Official linalg1 Content Dictionary includes determinant as the unary function returning the determinant of a square matrix; selected as canonical source for Determinant" ;
    mathkg:accessibilityNote "Speech rendering should name the operation and, where possible, identify its operands and result."@en .

###  http://example.org/mathkg/Division
mathkg:Division rdf:type owl:Class ;
                rdfs:subClassOf mathkg:MathOperation ;
                obo:IAO_0000115 "Division is the operation of partitioning a quantity into equal parts or determining how many times one quantity contains another." ;
                dc:source "OpenMath Content Dictionaries" ;
                rdfs:comment "Included for Week 2 validation coverage; exact canonical IRI and cross-source equivalence require further review." ;
                rdfs:label "Division"@en ;
                skos:exactMatch <http://www.openmath.org/cd/arith1#divide> ;
                skos:note "merge_status: mapped" ;
    skos:definition "Division is a mathematical operation used to transform one or more inputs into a result."@en ;
    skos:example "Use division when reading a step that applies a mathematical rule to inputs."@en ;
    mathkg:conceptType "MathOperation" ;
