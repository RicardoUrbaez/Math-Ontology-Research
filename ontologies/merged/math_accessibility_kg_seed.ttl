###  http://example.org/mathkg/RelationConcept
mathkg:RelationConcept rdf:type owl:Class ;
                       rdfs:subClassOf mathkg:MathObject ;
                       obo:IAO_0000115 "A relation is a mathematical connection or association between objects, values, or sets." ;
                       dc:source "OntoMathPRO" ;
                       rdfs:comment "Included for Week 2 validation coverage; exact canonical IRI and cross-source equivalence require further review." ;
                       rdfs:label "Relation"@en ;
                       skos:definition "The conceptual category of mathematical relations, represented structurally by the MathRelation object-property hierarchy."@en ;
                       skos:exactMatch omp:E2452 ;
                       skos:note "This class preserves the validation concept Relation, while mathkg:MathRelation is used for the OWL object-property hierarchy."@en ,
                                 "merge_status: mapped" ;
    skos:definition "Relation is a mathematical relation used to compare or connect mathematical objects."@en ;
    skos:example "Use relation when explaining how two mathematical objects or expressions are connected."@en ;
    mathkg:conceptType "MathRelation" ;
    mathkg:kindRoleClassification "kind" ;
    mathkg:mappingQuality "canonical_match" ;
    mathkg:provenanceNote "OntoMathPRO class mathematics:E2452 has direct English label Relation and Russian label отношение; selected as canonical source for Relation" ;
    mathkg:accessibilityNote "Speech rendering should make the relation explicit rather than relying only on symbol names."@en ;
    mathkg:reviewStatus "needs_definition_review" ;
    skos:note "merge_status: canonical_match" ;
    skos:altLabel "relation"@en ;
    skos:definition "Relation is a mathematical relation used to compare or connect mathematical objects."@en ;
    skos:example "Use relation when explaining how two mathematical objects or expressions are connected."@en ;
    mathkg:provenanceNote "OntoMathPRO class mathematics:E2452 has direct English label Relation and Russian label отношение; selected as canonical source for Relation" ;
    mathkg:accessibilityNote "Speech rendering should make the relation explicit rather than relying only on symbol names."@en .

