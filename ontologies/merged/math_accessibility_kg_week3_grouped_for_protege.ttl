mathkg: a owl:Ontology ;
    dc:description "Week 3 enrichment layer with 500 kind/role classified concepts, annotation coverage, provenance, and gloss metadata hooks." ;
    dc:license "Research prototype for academic use; source ontologies retain their original licenses." ;
    dc:source "OntoMathPRO; Week 2 validation set; OpenMath/MathModDB/OntoMathEdu validation notes" ;
    dc:title "Math Accessibility Knowledge Graph Week 3 Enrichment" ;
    dcterms:license "Research prototype for academic use; source ontologies retain their original licenses." .

mathkg:canonicalGloss a owl:AnnotationProperty ;
    rdfs:label "canonical gloss" .

mathkg:conciseForm a owl:AnnotationProperty ;
    rdfs:label "concise form" .

mathkg:documentRoleForm a owl:AnnotationProperty ;
    rdfs:label "document role form" .

mathkg:domainTag a owl:AnnotationProperty .

mathkg:expertForm a owl:AnnotationProperty ;
    rdfs:label "expert form" .

mathkg:glossForConcept a owl:ObjectProperty ;
    rdfs:label "gloss for concept" .

mathkg:groupingBasis a owl:AnnotationProperty ;
    rdfs:label "grouping basis" .

mathkg:hasGlossRecord a owl:ObjectProperty ;
    rdfs:label "has gloss record" .

mathkg:kindRoleType a owl:AnnotationProperty .

mathkg:pedagogicalForm a owl:AnnotationProperty ;
    rdfs:label "pedagogical form" .

mathkg:protegeDisplayGroup a owl:AnnotationProperty ;
    rdfs:label "Protege display group" .

mathkg:provenanceNote a owl:AnnotationProperty .

mathkg:semanticType a owl:AnnotationProperty .

mathkg:sourceProvenance a owl:AnnotationProperty ;
    rdfs:label "source provenance" .

mathkg:sourceProvenanceNote a owl:AnnotationProperty ;
    rdfs:label "source provenance note" .

mathkg:Abeliangroup a owl:Class ;
    rdfs:label "Abelian group" ;
