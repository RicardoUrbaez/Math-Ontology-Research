mathkg:Isometricembedding a owl:Class ;
    rdfs:label "Isometric embedding" ;
    mathkg:domainTag "general-mathematics" ;
    mathkg:groupingBasis "scalar" ;
    mathkg:hasGlossRecord gloss:IsometricEmbedding ;
    mathkg:kindRoleType "kind" ;
    mathkg:provenanceNote "Selected from OntoMathPRO English-labeled class inventory to complete the 500 target concept layer." ;
    mathkg:semanticType "scalar" ;
    IAO:0000115 "Let $(M,g)$ and $(N,h)$ be Riemannian manifolds. An isometric embedding is a smooth embedding $f : M \\to N$ which preserves the metric in the sense that $g$ is equal to the pullback of $h$ by $f$, i.e. $g = f*h$." ;
    dc:source "OntoMathPRO" ;
    rdfs:subClassOf mathkg:ScalarConcept ;
    skos:altLabel "isometric embedding",
        "isometricembedding" ;
    skos:definition "Let $(M,g)$ and $(N,h)$ be Riemannian manifolds. An isometric embedding is a smooth embedding $f : M \\to N$ which preserves the metric in the sense that $g$ is equal to the pullback of $h$ by $f$, i.e. $g = f*h$." ;
    skos:exactMatch <http://cll.niimm.ksu.ru/ontologies/mathematics#E1350> ;
    skos:example "Use isometric embedding as the spoken semantic name for the corresponding mathematical concept." .

