mathkg:Function a owl:Class ;
    rdfs:subClassOf mathkg:KindConcept ;
    rdfs:label "Function" ;
    IAO:0000115 "A Function is a mathematical function concept that associates inputs with outputs according to a rule." ;
    skos:definition "A Function is a mathematical function concept that associates inputs with outputs according to a rule." ;
    skos:example "Use function when an input is associated with an output by a named rule." ;
    mathkg:kindRoleType "kind" ;
    mathkg:semanticType "function" ;
    dc:source "OntoMathPRO" ;
    mathkg:provenanceNote "Anchored in Week 2 validation set as MathObject; status verified." ;
    skos:altLabel "function" ;
    mathkg:domainTag "general-mathematics" ;
