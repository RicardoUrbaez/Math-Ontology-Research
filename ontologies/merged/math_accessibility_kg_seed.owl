<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/mathkg/"
     xml:base="http://example.org/mathkg/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:IAO="http://purl.obolibrary.org/obo/IAO_"
     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:omp="http://cll.niimm.ksu.ru/ontologies/mathematics#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:mathkg="http://example.org/mathkg/"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://example.org/mathkg/">
        <dc:description>Initial Week 2 seed merge ontology for a math accessibility knowledge graph. This file defines project-local classes for verified mathematical concepts and links them to canonical OntoMathPRO IRIs using the Week 2 cross-ontology mapping table.</dc:description>
        <dc:license>Research prototype for academic use; source ontologies retain their original licenses.</dc:license>
        <dc:source>OntoMathPRO, MathModDB, OntoMathEdu, OpenMath Content Dictionaries</dc:source>
        <dc:title>Math Accessibility Knowledge Graph Seed Ontology</dc:title>
        <dcterms:license>Research prototype for academic use; source ontologies retain their original licenses.</dcterms:license>
        <rdfs:comment>Initial Week 2 seed merge ontology based on the verified cross-ontology mapping table and canonical IRI review process.</rdfs:comment>
        <rdfs:label>Math Accessibility Knowledge Graph Seed Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/mathkg/accessibilityNote -->

    <owl:AnnotationProperty rdf:about="http://example.org/mathkg/accessibilityNote">
        <obo:IAO_0000115 xml:lang="en">An annotation property recording speech, readability, or accessibility guidance for a concept.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">Accessibility note</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- http://example.org/mathkg/conceptType -->

    <owl:AnnotationProperty rdf:about="http://example.org/mathkg/conceptType">
        <obo:IAO_0000115 xml:lang="en">An annotation property recording the project-level type assigned to a mathematical concept.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">Concept type</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- http://example.org/mathkg/kindRoleClassification -->

    <owl:AnnotationProperty rdf:about="http://example.org/mathkg/kindRoleClassification">
        <obo:IAO_0000115 xml:lang="en">An annotation property recording whether a concept is treated as a rigid kind or a context-dependent role.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">Kind/role classification</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- http://example.org/mathkg/mappingQuality -->

    <owl:AnnotationProperty rdf:about="http://example.org/mathkg/mappingQuality">
        <obo:IAO_0000115 xml:lang="en">An annotation property recording the confidence or decision status for a concept mapping.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">Mapping quality</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- http://example.org/mathkg/provenanceNote -->

    <owl:AnnotationProperty rdf:about="http://example.org/mathkg/provenanceNote">
        <obo:IAO_0000115 xml:lang="en">An annotation property recording source and merge-decision notes for a concept.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">Provenance note</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- http://example.org/mathkg/reviewStatus -->

    <owl:AnnotationProperty rdf:about="http://example.org/mathkg/reviewStatus">
        <obo:IAO_0000115 xml:lang="en">An annotation property recording whether a concept metadata record is ready or needs further review.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">Review status</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000115 -->

    <owl:AnnotationProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000115"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/license"/>
    


    <!-- http://purl.org/dc/elements/1.1/source -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/source"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#altLabel -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#altLabel"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#definition -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#exactMatch -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#exactMatch"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#example -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#example"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#note -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#note"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/mathkg/MathRelation -->

    <owl:ObjectProperty rdf:about="http://example.org/mathkg/MathRelation">
        <rdfs:domain rdf:resource="http://example.org/mathkg/MathObject"/>
        <rdfs:range rdf:resource="http://example.org/mathkg/MathObject"/>
        <obo:IAO_0000115>A mathematical relation property connects mathematical objects in the math accessibility knowledge graph.</obo:IAO_0000115>
        <rdfs:comment>ObjectProperty root added to satisfy the Week 2 OWL 2 DL requirement for a MathRelation object-property subhierarchy.</rdfs:comment>
        <rdfs:label xml:lang="en">Math Relation</rdfs:label>
        <skos:definition xml:lang="en">An upper-level object property used to organize mathematical relations between mathematical objects.</skos:definition>
        <skos:note xml:lang="en">Upper-level object property branch for mathematical relations.</skos:note>
    </owl:ObjectProperty>
    


    <!-- http://example.org/mathkg/dependsOn -->

    <owl:ObjectProperty rdf:about="http://example.org/mathkg/dependsOn">
        <rdfs:subPropertyOf rdf:resource="http://example.org/mathkg/MathRelation"/>
        <rdfs:domain rdf:resource="http://example.org/mathkg/MathObject"/>
        <rdfs:range rdf:resource="http://example.org/mathkg/MathObject"/>
        <obo:IAO_0000115 xml:lang="en">Relates a mathematical object or concept to another concept it depends on.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">depends on</rdfs:label>
        <skos:definition xml:lang="en">Relates a mathematical object or concept to another concept it depends on.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://example.org/mathkg/hasElement -->

    <owl:ObjectProperty rdf:about="http://example.org/mathkg/hasElement">
        <rdfs:subPropertyOf rdf:resource="http://example.org/mathkg/MathRelation"/>
        <owl:inverseOf rdf:resource="http://example.org/mathkg/isElementOf"/>
        <rdfs:domain rdf:resource="http://example.org/mathkg/MathObject"/>
        <rdfs:range rdf:resource="http://example.org/mathkg/MathObject"/>
        <obo:IAO_0000115 xml:lang="en">Relates a mathematical object, such as a set, to an element that belongs to it.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">has element</rdfs:label>
        <skos:definition xml:lang="en">Relates a mathematical object, such as a set, to an element that belongs to it.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://example.org/mathkg/hasOperand -->

    <owl:ObjectProperty rdf:about="http://example.org/mathkg/hasOperand">
        <rdfs:subPropertyOf rdf:resource="http://example.org/mathkg/MathRelation"/>
        <obo:IAO_0000115>Connects a mathematical operation to one of its input mathematical objects.</obo:IAO_0000115>
        <rdfs:label>has operand</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/mathkg/hasRelation -->

    <owl:ObjectProperty rdf:about="http://example.org/mathkg/hasRelation">
        <rdfs:subPropertyOf rdf:resource="http://example.org/mathkg/MathRelation"/>
        <obo:IAO_0000115>Connects a mathematical object to a relation concept or related mathematical object.</obo:IAO_0000115>
        <rdfs:label>has relation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/mathkg/hasResult -->

    <owl:ObjectProperty rdf:about="http://example.org/mathkg/hasResult">
        <rdfs:subPropertyOf rdf:resource="http://example.org/mathkg/MathRelation"/>
        <obo:IAO_0000115>Connects a mathematical operation to its output or result.</obo:IAO_0000115>
        <rdfs:label>has result</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/mathkg/isElementOf -->

    <owl:ObjectProperty rdf:about="http://example.org/mathkg/isElementOf">
        <rdfs:subPropertyOf rdf:resource="http://example.org/mathkg/MathRelation"/>
        <rdfs:domain rdf:resource="http://example.org/mathkg/MathObject"/>
        <rdfs:range rdf:resource="http://example.org/mathkg/MathObject"/>
        <obo:IAO_0000115 xml:lang="en">Relates an element to the mathematical object it belongs to.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">is element of</rdfs:label>
        <skos:definition xml:lang="en">Relates an element to the mathematical object it belongs to.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://example.org/mathkg/isEqualTo -->

    <owl:ObjectProperty rdf:about="http://example.org/mathkg/isEqualTo">
        <rdfs:subPropertyOf rdf:resource="http://example.org/mathkg/MathRelation"/>
        <rdfs:domain rdf:resource="http://example.org/mathkg/MathObject"/>
        <rdfs:range rdf:resource="http://example.org/mathkg/MathObject"/>
        <obo:IAO_0000115 xml:lang="en">Relates two mathematical objects that are considered equal.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">is equal to</rdfs:label>
        <skos:definition xml:lang="en">Relates two mathematical objects that are considered equal.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://example.org/mathkg/isLessThan -->

    <owl:ObjectProperty rdf:about="http://example.org/mathkg/isLessThan">
        <rdfs:subPropertyOf rdf:resource="http://example.org/mathkg/MathRelation"/>
        <rdfs:domain rdf:resource="http://example.org/mathkg/MathObject"/>
        <rdfs:range rdf:resource="http://example.org/mathkg/MathObject"/>
        <obo:IAO_0000115 xml:lang="en">Relates one mathematical object or value to another that is greater than it.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">is less than</rdfs:label>
        <skos:definition xml:lang="en">Relates one mathematical object or value to another that is greater than it.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://example.org/mathkg/isSubsetOf -->

    <owl:ObjectProperty rdf:about="http://example.org/mathkg/isSubsetOf">
        <rdfs:subPropertyOf rdf:resource="http://example.org/mathkg/MathRelation"/>
        <rdfs:domain rdf:resource="http://example.org/mathkg/MathObject"/>
        <rdfs:range rdf:resource="http://example.org/mathkg/MathObject"/>
        <obo:IAO_0000115 xml:lang="en">Relates one set to another set that contains it.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">is subset of</rdfs:label>
        <skos:definition xml:lang="en">Relates one set to another set that contains it.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/mathkg/Addition -->

    <owl:Class rdf:about="http://example.org/mathkg/Addition">
        <rdfs:subClassOf rdf:resource="http://example.org/mathkg/MathOperation"/>
        <accessibilityNote xml:lang="en">Speech rendering should name the operation and, where possible, identify its operands and result.</accessibilityNote>
        <conceptType>MathOperation</conceptType>
        <kindRoleClassification>kind</kindRoleClassification>
        <mappingQuality>canonical_match</mappingQuality>
        <provenanceNote>OntoMathPRO class mathematics:E1315 has direct rdfs:label Addition@en; selected as canonical IRI according to Week 2 rules</provenanceNote>
        <reviewStatus>ready_for_metadata_review</reviewStatus>
        <obo:IAO_0000115>Addition is the operation of combining quantities to produce their sum.</obo:IAO_0000115>
        <dc:source>OntoMathPRO</dc:source>
        <rdfs:comment>Mapped from OntoMathPRO mathematics:E1315 based on a direct Addition@en label match.</rdfs:comment>
        <rdfs:label xml:lang="en">Addition</rdfs:label>
        <skos:altLabel xml:lang="en">addition</skos:altLabel>
        <skos:definition xml:lang="en">Addition is a mathematical operation used to transform one or more inputs into a result.</skos:definition>
        <skos:definition>Addition is the operation of combining quantities to produce their sum.</skos:definition>
        <skos:exactMatch rdf:resource="http://cll.niimm.ksu.ru/ontologies/mathematics#E1315"/>
        <skos:example xml:lang="en">Use addition when reading a step that applies a mathematical rule to inputs.</skos:example>
        <skos:note>merge_status: canonical_match</skos:note>
    </owl:Class>
    


    <!-- http://example.org/mathkg/Angle -->

    <owl:Class rdf:about="http://example.org/mathkg/Angle">
        <rdfs:subClassOf rdf:resource="http://example.org/mathkg/MathObject"/>
        <accessibilityNote xml:lang="en">Speech rendering should use the canonical label and a concise definition when the notation may be ambiguous.</accessibilityNote>
        <conceptType>MathObject</conceptType>
        <kindRoleClassification>kind</kindRoleClassification>
        <mappingQuality>canonical_match</mappingQuality>
        <provenanceNote>OntoMathPRO class mathematics:E1187 has direct English label Angle and Russian label угол; selected as canonical source for Angle</provenanceNote>
        <reviewStatus>needs_definition_review</reviewStatus>
        <obo:IAO_0000115>An angle is a measure of rotation or the figure formed by two rays sharing a common endpoint.</obo:IAO_0000115>
        <dc:source>OntoMathPRO</dc:source>
        <rdfs:comment>Included for Week 2 validation coverage; exact canonical IRI and cross-source equivalence require further review.</rdfs:comment>
        <rdfs:label xml:lang="en">Angle</rdfs:label>
        <skos:altLabel xml:lang="en">angle</skos:altLabel>
        <skos:definition xml:lang="en">Angle is a mathematical concept used as an object, quantity, structure, or named idea in mathematical discourse.</skos:definition>
        <skos:exactMatch rdf:resource="http://cll.niimm.ksu.ru/ontologies/mathematics#E1187"/>
        <skos:example xml:lang="en">Use angle as the spoken semantic name for this concept in accessible math output.</skos:example>
        <skos:note>merge_status: canonical_match</skos:note>
        <skos:note>merge_status: mapped</skos:note>
    </owl:Class>
    


    <!-- http://example.org/mathkg/Area -->

    <owl:Class rdf:about="http://example.org/mathkg/Area">
        <rdfs:subClassOf rdf:resource="http://example.org/mathkg/MathObject"/>
        <accessibilityNote xml:lang="en">Speech rendering should use the canonical label and a concise definition when the notation may be ambiguous.</accessibilityNote>
        <conceptType>MathObject</conceptType>
        <kindRoleClassification>kind</kindRoleClassification>
        <mappingQuality>canonical_match</mappingQuality>
        <provenanceNote>MathModDB individual mathmoddb:Area has direct English label Area and description as a quantity expressing the extent of a two-dimensional surface or shape; selected as canonical source for Area</provenanceNote>
        <reviewStatus>needs_definition_review</reviewStatus>
        <obo:IAO_0000115>Area is the measure of the size of a two-dimensional region.</obo:IAO_0000115>
        <dc:source>MathModDB</dc:source>
        <rdfs:comment>Included for Week 2 validation coverage; exact canonical IRI and cross-source equivalence require further review.</rdfs:comment>
        <rdfs:label xml:lang="en">Area</rdfs:label>
        <skos:altLabel xml:lang="en">area</skos:altLabel>
        <skos:definition xml:lang="en">Area is a mathematical concept used as an object, quantity, structure, or named idea in mathematical discourse.</skos:definition>
        <skos:exactMatch rdf:resource="https://mardi4nfdi.de/mathmoddb#Area"/>
        <skos:example xml:lang="en">Use area as the spoken semantic name for this concept in accessible math output.</skos:example>
        <skos:note>merge_status: canonical_match</skos:note>
        <skos:note>merge_status: mapped</skos:note>
    </owl:Class>
    


    <!-- http://example.org/mathkg/Circle -->

    <owl:Class rdf:about="http://example.org/mathkg/Circle">
        <rdfs:subClassOf rdf:resource="http://example.org/mathkg/MathObject"/>
        <accessibilityNote xml:lang="en">Speech rendering should use the canonical label and a concise definition when the notation may be ambiguous.</accessibilityNote>
        <conceptType>MathObject</conceptType>
        <kindRoleClassification>kind</kindRoleClassification>
        <mappingQuality>canonical_match</mappingQuality>
        <provenanceNote>OntoMathPRO class mathematics:E109 has direct English label Circle and Russian label окружность; selected as canonical source for Circle</provenanceNote>
        <reviewStatus>needs_definition_review</reviewStatus>
        <obo:IAO_0000115>A circle is the set of points in a plane that are all the same distance from a given center point.</obo:IAO_0000115>
        <dc:source>OntoMathPRO</dc:source>
        <rdfs:comment>Included for Week 2 validation coverage; exact canonical IRI and cross-source equivalence require further review.</rdfs:comment>
        <rdfs:label xml:lang="en">Circle</rdfs:label>
        <skos:altLabel xml:lang="en">circle</skos:altLabel>
        <skos:definition xml:lang="en">Circle is a mathematical concept used as an object, quantity, structure, or named idea in mathematical discourse.</skos:definition>
        <skos:exactMatch rdf:resource="http://cll.niimm.ksu.ru/ontologies/mathematics#E109"/>
        <skos:example xml:lang="en">Use circle as the spoken semantic name for this concept in accessible math output.</skos:example>
        <skos:note>merge_status: canonical_match</skos:note>
        <skos:note>merge_status: mapped</skos:note>
    </owl:Class>
    


    <!-- http://example.org/mathkg/Coefficient -->

    <owl:Class rdf:about="http://example.org/mathkg/Coefficient">
        <rdfs:subClassOf rdf:resource="http://example.org/mathkg/MathObject"/>
        <accessibilityNote xml:lang="en">Speech rendering should preserve the expression context because this concept changes meaning by role.</accessibilityNote>
        <conceptType>Role</conceptType>
        <kindRoleClassification>role</kindRoleClassification>
        <mappingQuality>canonical_match</mappingQuality>
        <provenanceNote>OntoMathPRO class mathematics:E2129 has direct English label Coefficient and Russian label коэффициент; selected as canonical source for Coefficient</provenanceNote>
        <reviewStatus>needs_definition_review</reviewStatus>
        <obo:IAO_0000115>A coefficient is a numerical or symbolic factor that multiplies another term in an expression.</obo:IAO_0000115>
        <dc:source>OntoMathPRO</dc:source>
        <rdfs:comment>Included for Week 2 validation coverage; exact canonical IRI and cross-source equivalence require further review. Classified under MathematicalConcept pending review of a dedicated role hierarchy.</rdfs:comment>
        <rdfs:label xml:lang="en">Coefficient</rdfs:label>
        <skos:altLabel xml:lang="en">coefficient</skos:altLabel>
        <skos:definition xml:lang="en">Coefficient is a context-dependent mathematical role used inside expressions, formulas, or models.</skos:definition>
        <skos:exactMatch rdf:resource="http://cll.niimm.ksu.ru/ontologies/mathematics#E2129"/>
        <skos:example xml:lang="en">Use coefficient when a symbol&apos;s meaning depends on its role in an expression or model.</skos:example>
        <skos:note>merge_status: canonical_match</skos:note>
        <skos:note>merge_status: mapped</skos:note>
    </owl:Class>
    


    <!-- http://example.org/mathkg/ComplexNumber -->

    <owl:Class rdf:about="http://example.org/mathkg/ComplexNumber">
        <rdfs:subClassOf rdf:resource="http://example.org/mathkg/MathObject"/>
        <accessibilityNote xml:lang="en">Speech rendering should use the canonical label and a concise definition when the notation may be ambiguous.</accessibilityNote>
        <conceptType>MathObject</conceptType>
        <kindRoleClassification>kind</kindRoleClassification>
        <mappingQuality>canonical_match</mappingQuality>
        <provenanceNote>OntoMathPRO class mathematics:E2127 has direct rdfs:label Complex number@en; selected as canonical IRI according to Week 2 rules</provenanceNote>
        <reviewStatus>ready_for_metadata_review</reviewStatus>
        <obo:IAO_0000115>A complex number is a number with a real part and an imaginary part.</obo:IAO_0000115>
        <dc:source>OntoMathPRO</dc:source>
        <rdfs:comment>Mapped from OntoMathPRO mathematics:E2127 based on a direct Complex number@en label match.</rdfs:comment>
        <rdfs:label xml:lang="en">Complex Number</rdfs:label>
        <skos:altLabel xml:lang="en">complex number</skos:altLabel>
        <skos:altLabel xml:lang="en">complexnumber</skos:altLabel>
        <skos:definition>A complex number is a number with a real part and an imaginary part.</skos:definition>
        <skos:definition xml:lang="en">Complex Number is a mathematical concept used as an object, quantity, structure, or named idea in mathematical discourse.</skos:definition>
        <skos:exactMatch rdf:resource="http://cll.niimm.ksu.ru/ontologies/mathematics#E2127"/>
        <skos:example xml:lang="en">Use complex number as the spoken semantic name for this concept in accessible math output.</skos:example>
        <skos:note>merge_status: canonical_match</skos:note>
    </owl:Class>
    


    <!-- http://example.org/mathkg/Constant -->

    <owl:Class rdf:about="http://example.org/mathkg/Constant">
        <rdfs:subClassOf rdf:resource="http://example.org/mathkg/MathObject"/>
        <accessibilityNote xml:lang="en">Speech rendering should preserve the expression context because this concept changes meaning by role.</accessibilityNote>
        <conceptType>Role</conceptType>
        <kindRoleClassification>role</kindRoleClassification>
        <mappingQuality>canonical_match</mappingQuality>
        <provenanceNote>OntoMathPRO class mathematics:E2134 has direct English label Constant and Russian labels Постоянная and Константа; selected as canonical source for Constant</provenanceNote>
        <reviewStatus>needs_definition_review</reviewStatus>
        <obo:IAO_0000115>A constant is a value that is fixed within a given mathematical context.</obo:IAO_0000115>
        <dc:source>OntoMathPRO</dc:source>
        <rdfs:comment>Included for Week 2 validation coverage; exact canonical IRI and cross-source equivalence require further review. Classified under MathematicalConcept pending review of a dedicated role hierarchy.</rdfs:comment>
        <rdfs:label xml:lang="en">Constant</rdfs:label>
        <skos:altLabel xml:lang="en">constant</skos:altLabel>
        <skos:definition xml:lang="en">Constant is a context-dependent mathematical role used inside expressions, formulas, or models.</skos:definition>
        <skos:exactMatch rdf:resource="http://cll.niimm.ksu.ru/ontologies/mathematics#E2134"/>
        <skos:example xml:lang="en">Use constant when a symbol&apos;s meaning depends on its role in an expression or model.</skos:example>
        <skos:note>merge_status: canonical_match</skos:note>
        <skos:note>merge_status: mapped</skos:note>
    </owl:Class>
    


    <!-- http://example.org/mathkg/Cosine -->

    <owl:Class rdf:about="http://example.org/mathkg/Cosine">
        <rdfs:subClassOf rdf:resource="http://example.org/mathkg/MathObject"/>
        <accessibilityNote xml:lang="en">Speech rendering should name the operation and, where possible, identify its operands and result.</accessibilityNote>
        <conceptType>MathOperation</conceptType>
        <kindRoleClassification>kind</kindRoleClassification>
        <mappingQuality>canonical_match</mappingQuality>
        <provenanceNote>OpenMath Official transc1 Content Dictionary includes cos as the cosine function; selected as canonical source for the Cosine operation</provenanceNote>
        <reviewStatus>needs_definition_review</reviewStatus>
        <obo:IAO_0000115>Cosine is a trigonometric function that relates an angle to a ratio in a right triangle and to coordinates on the unit circle.</obo:IAO_0000115>
        <dc:source>OpenMath Content Dictionaries</dc:source>
        <rdfs:comment>Included for Week 2 validation coverage; exact canonical IRI and cross-source equivalence require further review.</rdfs:comment>
        <rdfs:label xml:lang="en">Cosine</rdfs:label>
        <skos:altLabel xml:lang="en">cosine</skos:altLabel>
        <skos:definition xml:lang="en">Cosine is a mathematical operation used to transform one or more inputs into a result.</skos:definition>
        <skos:exactMatch rdf:resource="http://www.openmath.org/cd/transc1#cos"/>
        <skos:example xml:lang="en">Use cosine when reading a step that applies a mathematical rule to inputs.</skos:example>
        <skos:note>merge_status: canonical_match</skos:note>
