PREFIX mathkg: <http://example.org/mathkg/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dc: <http://purl.org/dc/elements/1.1/>
PREFIX dcterms: <http://purl.org/dc/terms/>

# Purpose: list the four TTS/accessibility surface forms for local concepts.
SELECT ?concept ?label ?concise ?pedagogical ?expert ?documentRole
WHERE {
  ?concept rdfs:label ?label .
  OPTIONAL { ?concept mathkg:conciseForm ?concise . }
  OPTIONAL { ?concept mathkg:pedagogicalForm ?pedagogical . }
  OPTIONAL { ?concept mathkg:expertForm ?expert . }
  OPTIONAL { ?concept mathkg:documentRoleForm ?documentRole . }
  FILTER(STRSTARTS(STR(?concept), STR(mathkg:)))
}
ORDER BY ?label
LIMIT 100
