PREFIX mathkg: <http://example.org/mathkg/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dc: <http://purl.org/dc/elements/1.1/>
PREFIX dcterms: <http://purl.org/dc/terms/>

# Purpose: traverse the current Week 3 kind/role hierarchy for the 500-concept layer.
SELECT ?root ?rootLabel ?concept ?label ?kindRole ?semanticType
WHERE {
  VALUES ?root { mathkg:KindConcept mathkg:RoleConcept }
  ?root rdfs:label ?rootLabel .
  ?concept rdfs:subClassOf+ ?root ;
           rdfs:label ?label .
  OPTIONAL { ?concept mathkg:kindRoleType ?kindRole . }
  OPTIONAL { ?concept mathkg:semanticType ?semanticType . }
}
ORDER BY ?rootLabel ?kindRole ?semanticType ?label
