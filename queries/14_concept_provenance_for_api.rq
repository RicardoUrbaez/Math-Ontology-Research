PREFIX mathkg: <http://example.org/mathkg/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dc: <http://purl.org/dc/elements/1.1/>
PREFIX dcterms: <http://purl.org/dc/terms/>

# Purpose: expose provenance and mapping quality for API response payloads.
SELECT ?concept ?label ?source ?sourceIri ?mappingQuality ?conceptType ?kindRole
WHERE {
  ?concept rdfs:label ?label .
  OPTIONAL { ?concept dc:source ?source . }
  OPTIONAL { ?concept dcterms:source ?sourceIri . }
  OPTIONAL { ?concept mathkg:mappingQuality ?mappingQuality . }
  OPTIONAL { ?concept mathkg:conceptType ?conceptType . }
  OPTIONAL { ?concept mathkg:kindRoleClassification ?kindRole . }
  FILTER(STRSTARTS(STR(?concept), STR(mathkg:)))
}
ORDER BY ?label
LIMIT 100
