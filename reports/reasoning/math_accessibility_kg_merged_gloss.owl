<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/mathkg/"
     xml:base="http://example.org/mathkg/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:IAO="http://purl.obolibrary.org/obo/IAO_"
     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:gloss="http://example.org/mathkg/gloss/"
     xmlns:mathkg="http://example.org/mathkg/"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://example.org/mathkg/">
        <dc:description>Week 3 enrichment layer with 500 kind/role classified concepts, annotation coverage, provenance, and gloss metadata hooks.</dc:description>
        <dc:license>Research prototype for academic use; source ontologies retain their original licenses.</dc:license>
        <dc:source>OntoMathPRO; Week 2 validation set; OpenMath/MathModDB/OntoMathEdu validation notes</dc:source>
        <dc:title>Math Accessibility Knowledge Graph Week 3 Enrichment</dc:title>
        <dcterms:license>Research prototype for academic use; source ontologies retain their original licenses.</dcterms:license>
    </owl:Ontology>
    


