    <!-- http://example.org/mathkg/Abeliangroup -->

    <owl:Class rdf:about="http://example.org/mathkg/Abeliangroup">
        <rdfs:subClassOf rdf:resource="http://example.org/mathkg/KindConcept"/>
        <domainTag>algebra</domainTag>
        <kindRoleType>kind</kindRoleType>
        <provenanceNote>Selected from OntoMathPRO English-labeled class inventory to complete the 500 target concept layer.</provenanceNote>
        <semanticType>scalar</semanticType>
        <obo:IAO_0000115>An Abelian group is a mathematical concept used as a named object, value, or quantity in formal mathematical discourse.</obo:IAO_0000115>
        <dc:source>OntoMathPRO</dc:source>
        <rdfs:label>Abelian group</rdfs:label>
        <skos:altLabel>abelian group</skos:altLabel>
        <skos:altLabel>abeliangroup</skos:altLabel>
        <skos:definition>An Abelian group is a mathematical concept used as a named object, value, or quantity in formal mathematical discourse.</skos:definition>
        <skos:exactMatch rdf:resource="http://cll.niimm.ksu.ru/ontologies/mathematics#E2146"/>
        <skos:example>Use abelian group as the spoken semantic name for the corresponding mathematical concept.</skos:example>
    </owl:Class>
    


